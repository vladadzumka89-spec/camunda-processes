    <bpmn:sequenceFlow id="Flow_132hruz" sourceRef="BRT_detail_type" targetRef="ST_write_type" />
    <bpmn:sequenceFlow id="Flow_timer_to_buh" sourceRef="Timer_month_end" targetRef="UT_buh_real" />
    <bpmn:sequenceFlow id="Flow_1escksh" sourceRef="UT_reissue" targetRef="Timer_month_end" />
    <bpmn:sequenceFlow id="Flow_0dl2i3l" sourceRef="Timer_period_start" targetRef="UT_reissue" />
    <bpmn:sequenceFlow id="Flow_01kli45" sourceRef="Gateway_0ytub5u" targetRef="End_main" />
    <bpmn:sequenceFlow id="Flow_buh_to_merge" sourceRef="UT_buh_real" targetRef="Gateway_0ytub5u" />
    <bpmn:sequenceFlow id="Flow_0k3j07w" sourceRef="Activity_0pb3hxn" targetRef="Gateway_0ytub5u" />
    <bpmn:sequenceFlow id="Flow_136grnh" name="ні" sourceRef="Gateway_0szlp8w" targetRef="Gateway_0ytub5u" />
    <bpmn:sequenceFlow id="Flow_1wwa9rs" name="так" sourceRef="Gateway_0szlp8w" targetRef="Activity_1isenfd">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=is defined(x_studio_camunda_fop_name) 
and x_studio_camunda_fop_name != null  and (contains(lower case(x_studio_camunda_fop_name), "технопростір") or contains(lower case(x_studio_camunda_fop_name), "технопростiр") or contains(lower case(x_studio_camunda_fop_name), "техно простір") or contains(lower case(x_studio_camunda_fop_name), "техно простiр") or contains(lower case(x_studio_camunda_fop_name), "козак василь"))</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
