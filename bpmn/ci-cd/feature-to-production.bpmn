<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_feature"
                  targetNamespace="http://tut.ua/bpmn/feature-pipeline"
                  exporter="Claude Code"
                  exporterVersion="1.3">

  <!-- ═══════════════════════════════════════════════════════════
       FEATURE TO PRODUCTION — Головний пайплайн v3

       Старт: /start command
       Фініш: Фіча на production (єдиний позитивний кінець)

       Принцип: жодна невдача не завершує процес.
       Draft PR створюється одразу в main.
       Feature branch мерджиться в staging напряму через SSH.
       Після staging verify — 2-ге ревʼю PR-Agent → undraft PR → тімлід мерджить.

       Цикли зворотного зв'язку:
         1. PR-Agent score < 7 → коментар → чекаємо PR update → re-review
         2. Merge conflict → коментар → чекаємо PR update → re-review
         3. Staging/prod failure → коментар → чекаємо PR update → re-review

       Всі rework paths → comment на draft PR → wait msg_pr_updated → назад до 1-го PR-Agent.

       Викликає deploy-process як call activity (staging та production).
       Rollback — автоматичний (deploy-process error subprocess + rollback job type).
       Sync main→staging — окремий щонічний процес (main-to-staging-sync.bpmn).

       Job worker types:
         pr-agent-review, merge-feature-to-staging, github-pr-ready,
         github-comment, send-notification, http-request-smart, rollback
       ═══════════════════════════════════════════════════════════ -->

  <bpmn:error id="Error_deploy_failed" name="Deploy Failed" errorCode="DEPLOY_FAILED" />
  <bpmn:error id="Error_merge_conflict" name="Merge Conflict" errorCode="MERGE_CONFLICT" />

  <!-- Messages for process correlation -->
  <bpmn:message id="Message_pr_event" name="msg_pr_event">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=head_branch" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_pr_updated" name="msg_pr_updated">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>

  <bpmn:process id="feature-to-production" name="Feature to Production" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="3.0" />
    </bpmn:extensionElements>

    <!-- ═══════════════════ PHASE 0: /start ═══════════════════ -->

    <!-- ── START: Manual (/start command) ──────────────────── -->
    <bpmn:startEvent id="start_manual" name="Фіча розпочата (/start)">
      <bpmn:documentation>Розробник запускає /start в Claude Code CLI.
Camunda REST API створює інстанс процесу з task_name, task_description, head_branch.</bpmn:documentation>
      <bpmn:outgoing>f_manual_to_odoo</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ── XOR: Задача в Odoo існує? ────────────────────────── -->
    <bpmn:exclusiveGateway id="GW_odoo_check" name="Задача в Odoo існує?" default="f_odoo_default">
      <bpmn:incoming>f_manual_to_odoo</bpmn:incoming>
      <bpmn:outgoing>f_odoo_default</bpmn:outgoing>
      <bpmn:outgoing>f_odoo_skip</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ── Service Task: Створити задачу в Odoo ────────────── -->
    <bpmn:serviceTask id="task_create_odoo" name="Створити задачу в Odoo">
      <bpmn:documentation>Створює батьківську задачу в Odoo через Python worker (send-notification).
Використовує task_name та task_description з процесних змінних.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;feature_start&quot;" target="notification_type" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_odoo_default</bpmn:incoming>
      <bpmn:outgoing>f_odoo_to_wait</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── Merge: після odoo_check ──────────────────────────── -->
    <bpmn:exclusiveGateway id="Merge_odoo">
      <bpmn:incoming>f_odoo_to_wait</bpmn:incoming>
      <bpmn:incoming>f_odoo_skip</bpmn:incoming>
      <bpmn:outgoing>f_merge_to_wait</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ── Intermediate Catch: чекаємо Draft PR (targeting main) ── -->
    <bpmn:intermediateCatchEvent id="catch_pr_created" name="Чекаємо Draft PR">
      <bpmn:documentation>Чекає msg_pr_event з correlation key = head_branch.
Коли draft PR створено на цю гілку (targeting main) — продовжує flow.</bpmn:documentation>
      <bpmn:incoming>f_merge_to_wait</bpmn:incoming>
      <bpmn:outgoing>f_catch_to_review</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_catch_pr" messageRef="Message_pr_event" />
    </bpmn:intermediateCatchEvent>

    <!-- ═══════════════════ PHASE 1: CI ═══════════════════ -->

    <!-- ── PR-AGENT REVIEW (1st) ───────────────────────────── -->
    <bpmn:serviceTask id="task_pr_agent" name="Рев'ю PR-Agent">
      <bpmn:documentation>Запускає PR-Agent (Docker/CLI) для автоматичного code review draft PR.
Використовує Grok через OpenRouter API.
Перевіряє: безпека, архітектура, type hinting, іменування tut_*.
Output: review_score, review_comment, has_critical_issues</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="pr-agent-review" retries="2" />
      </bpmn:extensionElements>
      <bpmn:incoming>f_catch_to_review</bpmn:incoming>
      <bpmn:incoming>f_wait_update_back</bpmn:incoming>
      <bpmn:incoming>f_rework_catch_to_review</bpmn:incoming>
      <bpmn:outgoing>f02</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── SCORE CHECK ───────────────────────────────────── -->
    <bpmn:exclusiveGateway id="gw_score" name="Оцінка ≥ 7?" default="f_score_no">
      <bpmn:incoming>f02</bpmn:incoming>
      <bpmn:outgoing>f_score_yes</bpmn:outgoing>
      <bpmn:outgoing>f_score_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Score < 7 path: коментар → receive task (чекаємо PR update) з нагадуваннями -->
    <bpmn:serviceTask id="task_cannot_merge" name="Коментар: потребує доопрацювання">
      <bpmn:documentation>Публікує коментар на draft PR: score &lt; 7 або є критичні проблеми.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;⚠️ **Потребує доопрацювання** — Score &quot; + string(review_score) + &quot;/10. Перевірте зауваження від PR-Agent вище та пушніть виправлення.&quot;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_score_no</bpmn:incoming>
      <bpmn:outgoing>f_to_wait_pr</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Receive Task: чекаємо PR update -->
    <bpmn:receiveTask id="recv_wait_pr_update" name="Чекаємо PR update" messageRef="Message_pr_updated">
      <bpmn:documentation>Очікує push нових комітів в draft PR (GitHub webhook: pull_request synchronize).
Кореляція по pr_number. Non-interrupting timer нагадує кожні 3 дні.</bpmn:documentation>
      <bpmn:incoming>f_to_wait_pr</bpmn:incoming>
      <bpmn:outgoing>f_wait_update_back</bpmn:outgoing>
    </bpmn:receiveTask>

    <!-- Non-interrupting boundary timer: нагадування кожні 3 дні -->
    <bpmn:boundaryEvent id="timer_pr_reminder" name="Нагадування (3 дні)" cancelActivity="false" attachedToRef="recv_wait_pr_update">
      <bpmn:outgoing>f_pr_reminder</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_pr_reminder">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P3D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="task_send_pr_reminder" name="Нагадати: PR потребує виправлень">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;reminder&quot;" target="notification_type" />
          <zeebe:input source="=&quot;⏰ Нагадування: PR #&quot; + string(pr_number) + &quot; потребує доопрацювання (score &lt; 7). Виправте зауваження PR-Agent.&quot;" target="message_body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_pr_reminder</bpmn:incoming>
      <bpmn:outgoing>f_to_End_rem_pr</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_rem_pr">
      <bpmn:incoming>f_to_End_rem_pr</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ── MERGE FEATURE → STAGING (SSH) ──────────────────── -->
    <bpmn:serviceTask id="task_merge_feature_staging" name="Merge feature → staging">
      <bpmn:documentation>Мерджить feature branch в staging напряму через SSH (git clone staging → git merge feature).
Конфлікти НЕ вирішуються автоматично (без -X theirs).
При конфлікті — boundary error event → коментар розробнику.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="merge-feature-to-staging" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="=head_branch" target="feature_branch" />
          <zeebe:input source="=staging_host" target="server_host" />
          <zeebe:input source="=repository" target="repository" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_score_yes</bpmn:incoming>
      <bpmn:outgoing>f03</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Boundary error on merge conflict -->
    <bpmn:boundaryEvent id="evt_merge_conflict" name="Merge конфлікт" attachedToRef="task_merge_feature_staging">
      <bpmn:outgoing>f_merge_conflict</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDef_merge_conflict" />
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="task_comment_conflict" name="Коментар: merge конфлікт">
      <bpmn:documentation>Публікує коментар на draft PR: merge конфлікт з staging, потрібен rebase на main.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;⚠️ **Merge конфлікт**: не вдалось змержити `&quot; + head_branch + &quot;` в staging. Виконайте rebase на main та вирішіть конфлікти, потім пушніть зміни.&quot;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_merge_conflict</bpmn:incoming>
      <bpmn:outgoing>f_conflict_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ═══════════════════ PHASE 2: CD STAGING ═══════════════════ -->

    <!-- ── DEPLOY STAGING (Call Activity) ────────────────── -->
    <bpmn:callActivity id="call_deploy_staging" name="Деплой на staging">
      <bpmn:documentation>Викликає deploy-process з параметрами staging.
При помилці — boundary error event → rework loop.
Автоматичний rollback всередині deploy-process (error subprocess).</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:calledElement processId="deploy-process" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=staging_host" target="server_host" />
          <zeebe:input source="=staging_ssh_user" target="ssh_user" />
          <zeebe:input source="=&quot;staging&quot;" target="branch" />
          <zeebe:input source="=staging_db" target="db_name" />
          <zeebe:input source="=staging_container" target="container" />
          <zeebe:input source="=staging_repo_dir" target="repo_dir" />
          <zeebe:input source="=true" target="run_smoke_test" />
          <zeebe:input source="=&quot;full&quot;" target="test_mode" />
          <zeebe:input source="=process_instance_key" target="process_instance_key" />
          <zeebe:output source="=modules_updated" target="staging_modules" />
          <zeebe:output source="=smoke_passed" target="staging_smoke" />
          <zeebe:output source="=clickbot_passed" target="clickbot_passed" />
          <zeebe:output source="=clickbot_report" target="clickbot_report" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f03</bpmn:incoming>
      <bpmn:outgoing>f04</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Boundary error on deploy staging → rework -->
    <bpmn:boundaryEvent id="evt_deploy_stg_error" name="Деплой staging невдалий" attachedToRef="call_deploy_staging">
      <bpmn:outgoing>f_deploy_fail</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDef_deploy_stg" errorRef="Error_deploy_failed" />
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="task_notify_deploy_fail" name="Повідомити: deploy staging failed">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;deploy_failed&quot;" target="notification_type" />
          <zeebe:input source="=&quot;❌ Deploy PR #&quot; + string(pr_number) + &quot; на staging провалився.&quot;" target="message_body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_deploy_fail</bpmn:incoming>
      <bpmn:outgoing>f_deploy_fail_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── SUBTASK: Перевірити staging ──────────────────────── -->
    <bpmn:serviceTask id="task_subtask_verify_staging" name="Підзадача: перевірити staging">
      <bpmn:documentation>Створює підзадачу в Odoo для техспеціаліста: перевірити staging після deploy.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=&quot;https://o.tut.ua/web/hook/67f62d7c-2612-444c-baf3-ad409c769bbe&quot;" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: &quot;Перевірити staging: PR #&quot; + string(pr_number), description: &quot;PR задеплоєно на staging. Clickbot: &quot; + (if clickbot_passed then &quot;passed&quot; else &quot;failed&quot;) + &quot;. Перевірте функціонал.&quot;, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f04</bpmn:incoming>
      <bpmn:outgoing>f_subtask_to_verify_staging</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ═══════════════════ PHASE 3: VERIFICATION ═══════════════════ -->

    <!-- ── USER: VERIFY STAGING ──────────────────────────── -->
    <bpmn:userTask id="user_verify_staging" name="Перевірити staging">
      <bpmn:documentation>Техспеціаліст перевіряє функціонал на staging:
— Фіча працює коректно
— Немає регресій
— Clickbot результати (якщо failed — перевірити вручну)

Форма: staging URL, PR опис, clickbot звіт.
Рішення: Approve / Reject (з коментарем)</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition candidateGroups="tech-specialist" />
        <zeebe:formDefinition formId="verify-staging-form" />
        <zeebe:taskSchedule dueDate="=now() + duration(&quot;P3D&quot;)" />
      </bpmn:extensionElements>
      <bpmn:incoming>f_subtask_to_verify_staging</bpmn:incoming>
      <bpmn:outgoing>f07</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Boundary: нагадування кожні 4 години -->
    <bpmn:boundaryEvent id="BE_rem_verify_staging" name="Нагадування (4 год)" cancelActivity="false" attachedToRef="user_verify_staging">
      <bpmn:outgoing>f_rem_verify_staging</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_rem_verify_staging">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT4H</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="ST_rem_verify_staging" name="⚠️ Нагадування: перевірте staging">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;reminder&quot;" target="notification_type" />
          <zeebe:input source="=&quot;⚠️ НАГАДУВАННЯ: Перевірте staging для PR #&quot; + string(pr_number) + &quot;. Задача очікує на перевірку.&quot;" target="message_body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_rem_verify_staging</bpmn:incoming>
      <bpmn:outgoing>f_to_End_rem_verify_staging</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_rem_verify_staging">
      <bpmn:incoming>f_to_End_rem_verify_staging</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Boundary: дедлайн 3 дні → ескалація керівнику -->
    <bpmn:boundaryEvent id="BE_ded_verify_staging" name="Дедлайн (3 дні)" cancelActivity="false" attachedToRef="user_verify_staging">
      <bpmn:outgoing>f_esc_verify_staging</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_ded_verify_staging">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="ST_esc_verify_staging" name="🔴 ЕСКАЛАЦІЯ: staging не перевірено">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=&quot;https://o.tut.ua/web/hook/67f62d7c-2612-444c-baf3-ad409c769bbe&quot;" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: &quot;🔴 ЕСКАЛАЦІЯ: staging не перевірено для PR #&quot; + string(pr_number), description: &quot;Задача перевірки staging не виконана протягом 3 днів. Потрібне втручання керівника.&quot;, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_esc_verify_staging</bpmn:incoming>
      <bpmn:outgoing>f_to_End_esc_verify_staging</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_esc_verify_staging">
      <bpmn:incoming>f_to_End_esc_verify_staging</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ── STAGING OK? ───────────────────────────────────── -->
    <bpmn:exclusiveGateway id="gw_staging_ok" name="Staging пройдено?" default="f_staging_yes">
      <bpmn:incoming>f07</bpmn:incoming>
      <bpmn:outgoing>f_staging_yes</bpmn:outgoing>
      <bpmn:outgoing>f_staging_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Staging rejected path → rework -->
    <bpmn:serviceTask id="task_request_rework" name="Коментар: staging відхилено">
      <bpmn:documentation>Публікує коментар на draft PR з описом проблем від техспеціаліста.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;⚠️ **Staging відхилено**: &quot; + (if rejection_reason != null then rejection_reason else &quot;&quot;) + &quot;\nБудь ласка, виправте та пушніть зміни.&quot;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_staging_no</bpmn:incoming>
      <bpmn:outgoing>f_staging_reject_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ═══════════════════ PHASE 4: SECOND REVIEW + UNDRAFT ═══════════════════ -->

    <!-- ── PR-AGENT REVIEW (2nd) ──────────────────────────── -->
    <bpmn:serviceTask id="task_pr_agent_second" name="Рев'ю PR-Agent (2-ге)">
      <bpmn:documentation>Другий запуск PR-Agent для review того самого draft PR після staging.
Output: second_review_score, second_has_critical</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="pr-agent-review" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=pr_number" target="pr_number" />
          <zeebe:input source="=pr_url" target="pr_url" />
          <zeebe:input source="=repository" target="repository" />
          <zeebe:output source="=review_score" target="second_review_score" />
          <zeebe:output source="=has_critical_issues" target="second_has_critical" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_staging_yes</bpmn:incoming>
      <bpmn:incoming>f_second_review_update_back</bpmn:incoming>
      <bpmn:outgoing>f_pr_second_to_gw</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── SECOND SCORE CHECK ────────────────────────────── -->
    <bpmn:exclusiveGateway id="gw_second_score" name="Друга оцінка ≥ 7?" default="f_second_score_yes">
      <bpmn:incoming>f_pr_second_to_gw</bpmn:incoming>
      <bpmn:outgoing>f_second_score_yes</bpmn:outgoing>
      <bpmn:outgoing>f_second_score_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Second score < 7 path: коментар → receive task (чекаємо PR update) -->
    <bpmn:serviceTask id="task_comment_second_rework" name="Коментар: 2-ге ревʼю потребує доопрацювання">
      <bpmn:documentation>Публікує коментар на draft PR: 2-ге ревʼю score &lt; 7.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;⚠️ **Друге ревʼю потребує доопрацювання** — Score &quot; + string(second_review_score) + &quot;/10. Виправте зауваження та пушніть зміни.&quot;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_second_score_no</bpmn:incoming>
      <bpmn:outgoing>f_second_to_wait</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Receive Task: чекаємо PR update for 2nd review loop -->
    <bpmn:receiveTask id="recv_wait_second_update" name="Чекаємо PR update (2-ге)" messageRef="Message_pr_updated">
      <bpmn:documentation>Очікує push нових комітів в draft PR для повторного 2-го ревʼю.
Кореляція по pr_number.</bpmn:documentation>
      <bpmn:incoming>f_second_to_wait</bpmn:incoming>
      <bpmn:outgoing>f_second_review_update_back</bpmn:outgoing>
    </bpmn:receiveTask>

    <!-- Non-interrupting boundary timer: нагадування кожні 3 дні -->
    <bpmn:boundaryEvent id="timer_second_reminder" name="Нагадування (3 дні)" cancelActivity="false" attachedToRef="recv_wait_second_update">
      <bpmn:outgoing>f_second_reminder</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_second_reminder">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P3D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="task_send_second_reminder" name="Нагадати: 2-ге ревʼю потребує виправлень">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;reminder&quot;" target="notification_type" />
          <zeebe:input source="=&quot;⏰ Нагадування: PR #&quot; + string(pr_number) + &quot; потребує доопрацювання після 2-го ревʼю (score &lt; 7).&quot;" target="message_body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_second_reminder</bpmn:incoming>
      <bpmn:outgoing>f_to_End_rem_second</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_rem_second">
      <bpmn:incoming>f_to_End_rem_second</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ── UNDRAFT PR ─────────────────────────────────────── -->
    <bpmn:serviceTask id="task_undraft_pr" name="Undraft PR">
      <bpmn:documentation>Позначає draft PR як ready for review.
Staging пройдено + PR-Agent 2x OK.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-pr-ready" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=pr_number" target="pr_number" />
          <zeebe:input source="=repository" target="repository" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_second_score_yes</bpmn:incoming>
      <bpmn:outgoing>f_undraft_to_subtask</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── SUBTASK: Merge PR в main ────────────────────────── -->
    <bpmn:serviceTask id="task_subtask_merge_main" name="Підзадача: merge PR в main">
      <bpmn:documentation>Створює підзадачу в Odoo для тімліда: review та merge PR в main.
Staging пройдено + PR-Agent 2x OK. PR вже не draft.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=&quot;https://o.tut.ua/web/hook/67f62d7c-2612-444c-baf3-ad409c769bbe&quot;" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: &quot;Review та merge PR в main: &quot; + pr_title, description: &quot;Staging пройдено + PR-Agent 2x OK. PR вже не draft. Потрібен review та merge PR в main.&quot;, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_undraft_to_subtask</bpmn:incoming>
      <bpmn:outgoing>f_subtask_to_merge_main</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── USER: MERGE TO MAIN ───────────────────────────── -->
    <bpmn:userTask id="user_merge_main" name="Review та merge PR в main">
      <bpmn:documentation>Тімлід переглядає PR і мерджить в main через GitHub.
PR URL надається у формі.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition candidateGroups="tech-specialist" />
        <zeebe:formDefinition formId="merge-main-form" />
        <zeebe:taskSchedule dueDate="=now() + duration(&quot;P3D&quot;)" />
      </bpmn:extensionElements>
      <bpmn:incoming>f_subtask_to_merge_main</bpmn:incoming>
      <bpmn:outgoing>f09</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Boundary: нагадування кожні 4 години -->
    <bpmn:boundaryEvent id="BE_rem_merge_main" name="Нагадування (4 год)" cancelActivity="false" attachedToRef="user_merge_main">
      <bpmn:outgoing>f_rem_merge_main</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_rem_merge_main">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT4H</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="ST_rem_merge_main" name="⚠️ Нагадування: merge PR в main">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;reminder&quot;" target="notification_type" />
          <zeebe:input source="=&quot;⚠️ НАГАДУВАННЯ: PR в main очікує review та merge. PR #&quot; + string(pr_number)" target="message_body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_rem_merge_main</bpmn:incoming>
      <bpmn:outgoing>f_to_End_rem_merge_main</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_rem_merge_main">
      <bpmn:incoming>f_to_End_rem_merge_main</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Boundary: дедлайн 3 дні → ескалація керівнику -->
    <bpmn:boundaryEvent id="BE_ded_merge_main" name="Дедлайн (3 дні)" cancelActivity="false" attachedToRef="user_merge_main">
      <bpmn:outgoing>f_esc_merge_main</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_ded_merge_main">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="ST_esc_merge_main" name="🔴 ЕСКАЛАЦІЯ: PR в main не змержено">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=&quot;https://o.tut.ua/web/hook/67f62d7c-2612-444c-baf3-ad409c769bbe&quot;" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: &quot;🔴 ЕСКАЛАЦІЯ: PR в main не змержено для PR #&quot; + string(pr_number), description: &quot;Merge PR в main не виконано протягом 3 днів. Потрібне втручання керівника.&quot;, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_esc_merge_main</bpmn:incoming>
      <bpmn:outgoing>f_to_End_esc_merge_main</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_esc_merge_main">
      <bpmn:incoming>f_to_End_esc_merge_main</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ═══════════════════ PHASE 5: PRODUCTION ═══════════════════ -->

    <!-- ── DEPLOY PRODUCTION (Call Activity) ────────────────── -->
    <bpmn:callActivity id="call_deploy_prod" name="Деплой на production">
      <bpmn:documentation>Викликає deploy-process з параметрами production.
При помилці — boundary error event → rework loop.
Автоматичний rollback відбувається всередині deploy-process (error subprocess).</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:calledElement processId="deploy-process" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=production_host" target="server_host" />
          <zeebe:input source="=production_ssh_user" target="ssh_user" />
          <zeebe:input source="=&quot;main&quot;" target="branch" />
          <zeebe:input source="=production_db" target="db_name" />
          <zeebe:input source="=production_container" target="container" />
          <zeebe:input source="=production_repo_dir" target="repo_dir" />
          <zeebe:input source="=true" target="run_smoke_test" />
          <zeebe:input source="=process_instance_key" target="process_instance_key" />
          <zeebe:output source="=modules_updated" target="prod_modules" />
          <zeebe:output source="=smoke_passed" target="prod_smoke" />
          <zeebe:output source="=old_commit" target="prod_old_commit" />
          <zeebe:output source="=new_commit" target="prod_new_commit" />
          <zeebe:output source="=clickbot_passed" target="prod_clickbot_passed" />
          <zeebe:output source="=clickbot_report" target="prod_clickbot_report" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f09</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Boundary error on deploy production → rework -->
    <bpmn:boundaryEvent id="evt_deploy_prod_error" name="Деплой production невдалий" attachedToRef="call_deploy_prod">
      <bpmn:outgoing>f_deploy_prod_fail</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDef_deploy_prod" errorRef="Error_deploy_failed" />
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="task_notify_prod_fail" name="Повідомити: deploy production failed">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;deploy_failed&quot;" target="notification_type" />
          <zeebe:input source="=&quot;❌ Deploy на production провалився. Auto-rollback виконано.\nPR #&quot; + string(pr_number)" target="message_body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_deploy_prod_fail</bpmn:incoming>
      <bpmn:outgoing>f_prod_fail_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── SUBTASK: Перевірити production ───────────────────── -->
    <bpmn:serviceTask id="task_subtask_verify_prod" name="Підзадача: перевірити production">
      <bpmn:documentation>Створює підзадачу в Odoo для техспеціаліста: перевірити production після deploy.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=&quot;https://o.tut.ua/web/hook/67f62d7c-2612-444c-baf3-ad409c769bbe&quot;" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: &quot;Перевірити production: PR #&quot; + string(pr_number), description: &quot;PR задеплоєно на production. Перевірте функціонал.&quot;, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f_subtask_to_verify_prod</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── USER: VERIFY PRODUCTION ───────────────────────── -->
    <bpmn:userTask id="user_verify_prod" name="Перевірити production">
      <bpmn:documentation>Техспеціаліст заходить на o.tut.ua і перевіряє:
— Сайт працює
— Фіча задеплоєна коректно
— Немає регресій
— tut_core автоочистка кешу спрацювала (браузери перезавантажились)

Рішення: OK / Rollback (з причиною)</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition candidateGroups="tech-specialist" />
        <zeebe:formDefinition formId="verify-prod-form" />
        <zeebe:taskSchedule dueDate="=now() + duration(&quot;P1D&quot;)" />
      </bpmn:extensionElements>
      <bpmn:incoming>f_subtask_to_verify_prod</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Boundary: нагадування кожні 4 години -->
    <bpmn:boundaryEvent id="BE_rem_verify_prod" name="Нагадування (4 год)" cancelActivity="false" attachedToRef="user_verify_prod">
      <bpmn:outgoing>f_rem_verify_prod</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_rem_verify_prod">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT4H</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="ST_rem_verify_prod" name="⚠️ Нагадування: перевірте production">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;reminder&quot;" target="notification_type" />
          <zeebe:input source="=&quot;⚠️ НАГАДУВАННЯ: Перевірте production для PR #&quot; + string(pr_number) + &quot;. Задача терміново очікує перевірки.&quot;" target="message_body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_rem_verify_prod</bpmn:incoming>
      <bpmn:outgoing>f_to_End_rem_verify_prod</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_rem_verify_prod">
      <bpmn:incoming>f_to_End_rem_verify_prod</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Boundary: дедлайн 1 день → ескалація керівнику -->
    <bpmn:boundaryEvent id="BE_ded_verify_prod" name="Дедлайн (1 день)" cancelActivity="false" attachedToRef="user_verify_prod">
      <bpmn:outgoing>f_esc_verify_prod</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_ded_verify_prod">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="ST_esc_verify_prod" name="🔴 ЕСКАЛАЦІЯ: production не перевірено">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=&quot;https://o.tut.ua/web/hook/67f62d7c-2612-444c-baf3-ad409c769bbe&quot;" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: &quot;🔴 ЕСКАЛАЦІЯ: production не перевірено для PR #&quot; + string(pr_number), description: &quot;Перевірка production не виконана протягом 1 дня. ТЕРМІНОВО потрібне втручання керівника.&quot;, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_esc_verify_prod</bpmn:incoming>
      <bpmn:outgoing>f_to_End_esc_verify_prod</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_esc_verify_prod">
      <bpmn:incoming>f_to_End_esc_verify_prod</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ── PRODUCTION OK? ────────────────────────────────── -->
    <bpmn:exclusiveGateway id="gw_prod_ok" name="Production пройдено?" default="f_prod_yes">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f_prod_yes</bpmn:outgoing>
      <bpmn:outgoing>f_prod_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Production rejected path — rollback then rework -->
    <bpmn:serviceTask id="task_rollback_prod" name="Відкат production">
      <bpmn:documentation>Автоматичний rollback: git checkout попереднього коміту + docker compose up --force-recreate.
Використовує rollback job type з deploy handler.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="rollback" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="=production_host" target="server_host" />
          <zeebe:input source="=prod_old_commit" target="old_commit" />
          <zeebe:input source="=&quot;main&quot;" target="branch" />
          <zeebe:input source="=production_repo_dir" target="repo_dir" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_prod_no</bpmn:incoming>
      <bpmn:outgoing>f_rollback_notify</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="task_notify_rollback" name="Повідомити: rollback виконано">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;rollback&quot;" target="notification_type" />
          <zeebe:input source="=&quot;⚠️ Production rollback виконано для PR #&quot; + string(pr_number) + &quot;.\nПричина: &quot; + (if rollback_reason != null then rollback_reason else &quot;відхилено техспецом&quot;)" target="message_body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_rollback_notify</bpmn:incoming>
      <bpmn:outgoing>f_rollback_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── END SUCCESS ───────────────────────────────────── -->
    <bpmn:endEvent id="evt_end_success" name="Фіча на production">
      <bpmn:incoming>f_prod_yes</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ═══════════════════ SHARED REWORK PATH ═══════════════════
         Всі failure paths після merge сходяться сюди:
           1. Deploy staging failed → notify → comment rework
           2. Staging rejected → comment → comment rework
           3. Merge conflict → comment conflict → comment rework
           4. Deploy production failed → notify → comment rework
           5. Production rejected → rollback → notify → comment rework

         Rework path: comment → catch PR update → back to PR-Agent
    ═══════════════════════════════════════════════════════════════ -->

    <!-- ── COMMENT: Rework needed ─────────────────────────── -->
    <bpmn:serviceTask id="task_comment_rework" name="Коментар: потрібне виправлення">
      <bpmn:documentation>Публікує коментар на draft PR з інструкцією пушнути виправлення.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;🔄 Потрібне виправлення. Пушніть зміни в гілку `&quot; + head_branch + &quot;` для продовження CI/CD.&quot;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_deploy_fail_to_rework</bpmn:incoming>
      <bpmn:incoming>f_staging_reject_to_rework</bpmn:incoming>
      <bpmn:incoming>f_conflict_to_rework</bpmn:incoming>
      <bpmn:incoming>f_prod_fail_to_rework</bpmn:incoming>
      <bpmn:incoming>f_rollback_to_rework</bpmn:incoming>
      <bpmn:outgoing>f_rework_comment_to_catch</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── CATCH: Чекаємо PR update ───────────────────────── -->
    <bpmn:receiveTask id="catch_pr_rework" name="Чекаємо PR update" messageRef="Message_pr_updated">
      <bpmn:documentation>Чекаємо push нових комітів в draft PR через msg_pr_updated (correlation by pr_number).
Non-interrupting timer нагадує кожні 3 дні.</bpmn:documentation>
      <bpmn:incoming>f_rework_comment_to_catch</bpmn:incoming>
      <bpmn:outgoing>f_rework_catch_to_review</bpmn:outgoing>
    </bpmn:receiveTask>

    <!-- Non-interrupting boundary timer: rework нагадування кожні 3 дні -->
    <bpmn:boundaryEvent id="timer_rework_reminder" name="Нагадування (3 дні)" cancelActivity="false" attachedToRef="catch_pr_rework">
      <bpmn:outgoing>f_rework_reminder</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_rework_reminder">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P3D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="task_send_rework_reminder" name="Нагадати: потрібне виправлення">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;reminder&quot;" target="notification_type" />
          <zeebe:input source="=&quot;⏰ Нагадування: PR #&quot; + string(pr_number) + &quot; потребує виправлення. Пушніть зміни в гілку &quot; + head_branch + &quot;.&quot;" target="message_body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_rework_reminder</bpmn:incoming>
      <bpmn:outgoing>f_to_End_rem_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_rem_rework">
      <bpmn:incoming>f_to_End_rem_rework</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ═══════════════════ SEQUENCE FLOWS ═══════════════════ -->

    <!-- Phase 0: /start -->
    <bpmn:sequenceFlow id="f_manual_to_odoo" sourceRef="start_manual" targetRef="GW_odoo_check" />
    <bpmn:sequenceFlow id="f_odoo_default" sourceRef="GW_odoo_check" targetRef="task_create_odoo" />
    <bpmn:sequenceFlow id="f_odoo_skip" name="Задача існує" sourceRef="GW_odoo_check" targetRef="Merge_odoo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=is defined(odoo_task_id) and odoo_task_id != null</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_odoo_to_wait" sourceRef="task_create_odoo" targetRef="Merge_odoo" />
    <bpmn:sequenceFlow id="f_merge_to_wait" sourceRef="Merge_odoo" targetRef="catch_pr_created" />
    <bpmn:sequenceFlow id="f_catch_to_review" sourceRef="catch_pr_created" targetRef="task_pr_agent" />

    <!-- Phase 1: CI -->
    <bpmn:sequenceFlow id="f02" sourceRef="task_pr_agent" targetRef="gw_score" />

    <!-- Score < 7 loop (with reminders) -->
    <bpmn:sequenceFlow id="f_score_no" name="&lt; 7" sourceRef="gw_score" targetRef="task_cannot_merge" />
    <bpmn:sequenceFlow id="f_to_wait_pr" sourceRef="task_cannot_merge" targetRef="recv_wait_pr_update" />
    <bpmn:sequenceFlow id="f_wait_update_back" sourceRef="recv_wait_pr_update" targetRef="task_pr_agent" />
    <bpmn:sequenceFlow id="f_pr_reminder" sourceRef="timer_pr_reminder" targetRef="task_send_pr_reminder" />
    <bpmn:sequenceFlow id="f_to_End_rem_pr" sourceRef="task_send_pr_reminder" targetRef="End_rem_pr" />

    <!-- Score >= 7 → merge feature to staging -->
    <bpmn:sequenceFlow id="f_score_yes" name="≥ 7" sourceRef="gw_score" targetRef="task_merge_feature_staging">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=review_score &gt;= 7 and has_critical_issues = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- Merge conflict → comment → rework -->
    <bpmn:sequenceFlow id="f_merge_conflict" sourceRef="evt_merge_conflict" targetRef="task_comment_conflict" />
    <bpmn:sequenceFlow id="f_conflict_to_rework" sourceRef="task_comment_conflict" targetRef="task_comment_rework" />

    <!-- Phase 2: CD Staging -->
    <bpmn:sequenceFlow id="f03" sourceRef="task_merge_feature_staging" targetRef="call_deploy_staging" />
    <bpmn:sequenceFlow id="f04" sourceRef="call_deploy_staging" targetRef="task_subtask_verify_staging" />
    <bpmn:sequenceFlow id="f_subtask_to_verify_staging" sourceRef="task_subtask_verify_staging" targetRef="user_verify_staging" />

    <!-- Deploy staging error → rework -->
    <bpmn:sequenceFlow id="f_deploy_fail" sourceRef="evt_deploy_stg_error" targetRef="task_notify_deploy_fail" />
    <bpmn:sequenceFlow id="f_deploy_fail_to_rework" sourceRef="task_notify_deploy_fail" targetRef="task_comment_rework" />

    <!-- Phase 3: Verification -->
    <bpmn:sequenceFlow id="f07" sourceRef="user_verify_staging" targetRef="gw_staging_ok" />

    <!-- Staging rejected → rework -->
    <bpmn:sequenceFlow id="f_staging_no" name="Проблеми" sourceRef="gw_staging_ok" targetRef="task_request_rework">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=staging_approved = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_staging_reject_to_rework" sourceRef="task_request_rework" targetRef="task_comment_rework" />

    <!-- Staging approved → 2nd review -->
    <bpmn:sequenceFlow id="f_staging_yes" name="OK" sourceRef="gw_staging_ok" targetRef="task_pr_agent_second" />

    <!-- Phase 4: Second review + undraft -->
    <bpmn:sequenceFlow id="f_pr_second_to_gw" sourceRef="task_pr_agent_second" targetRef="gw_second_score" />
    <bpmn:sequenceFlow id="f_second_score_yes" name="≥ 7" sourceRef="gw_second_score" targetRef="task_undraft_pr" />
    <bpmn:sequenceFlow id="f_second_score_no" name="&lt; 7" sourceRef="gw_second_score" targetRef="task_comment_second_rework">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=second_review_score &lt; 7 or second_has_critical = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_second_to_wait" sourceRef="task_comment_second_rework" targetRef="recv_wait_second_update" />
    <bpmn:sequenceFlow id="f_second_review_update_back" sourceRef="recv_wait_second_update" targetRef="task_pr_agent_second" />
    <bpmn:sequenceFlow id="f_second_reminder" sourceRef="timer_second_reminder" targetRef="task_send_second_reminder" />
    <bpmn:sequenceFlow id="f_to_End_rem_second" sourceRef="task_send_second_reminder" targetRef="End_rem_second" />

    <bpmn:sequenceFlow id="f_undraft_to_subtask" sourceRef="task_undraft_pr" targetRef="task_subtask_merge_main" />
    <bpmn:sequenceFlow id="f_subtask_to_merge_main" sourceRef="task_subtask_merge_main" targetRef="user_merge_main" />
    <bpmn:sequenceFlow id="f09" sourceRef="user_merge_main" targetRef="call_deploy_prod" />

    <!-- Phase 5: Production -->
    <bpmn:sequenceFlow id="f10" sourceRef="call_deploy_prod" targetRef="task_subtask_verify_prod" />
    <bpmn:sequenceFlow id="f_subtask_to_verify_prod" sourceRef="task_subtask_verify_prod" targetRef="user_verify_prod" />
    <bpmn:sequenceFlow id="f11" sourceRef="user_verify_prod" targetRef="gw_prod_ok" />

    <!-- Deploy production error → rework -->
    <bpmn:sequenceFlow id="f_deploy_prod_fail" sourceRef="evt_deploy_prod_error" targetRef="task_notify_prod_fail" />
    <bpmn:sequenceFlow id="f_prod_fail_to_rework" sourceRef="task_notify_prod_fail" targetRef="task_comment_rework" />

    <!-- Production OK → End -->
    <bpmn:sequenceFlow id="f_prod_yes" name="OK" sourceRef="gw_prod_ok" targetRef="evt_end_success" />

    <!-- Production rejected → rollback → rework -->
    <bpmn:sequenceFlow id="f_prod_no" name="Проблема" sourceRef="gw_prod_ok" targetRef="task_rollback_prod">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=prod_approved = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_rollback_notify" sourceRef="task_rollback_prod" targetRef="task_notify_rollback" />
    <bpmn:sequenceFlow id="f_rollback_to_rework" sourceRef="task_notify_rollback" targetRef="task_comment_rework" />

    <!-- Boundary event flows: user_verify_staging -->
    <bpmn:sequenceFlow id="f_rem_verify_staging" sourceRef="BE_rem_verify_staging" targetRef="ST_rem_verify_staging" />
    <bpmn:sequenceFlow id="f_esc_verify_staging" sourceRef="BE_ded_verify_staging" targetRef="ST_esc_verify_staging" />
    <bpmn:sequenceFlow id="f_to_End_rem_verify_staging" sourceRef="ST_rem_verify_staging" targetRef="End_rem_verify_staging" />
    <bpmn:sequenceFlow id="f_to_End_esc_verify_staging" sourceRef="ST_esc_verify_staging" targetRef="End_esc_verify_staging" />

    <!-- Boundary event flows: user_merge_main -->
    <bpmn:sequenceFlow id="f_rem_merge_main" sourceRef="BE_rem_merge_main" targetRef="ST_rem_merge_main" />
    <bpmn:sequenceFlow id="f_esc_merge_main" sourceRef="BE_ded_merge_main" targetRef="ST_esc_merge_main" />
    <bpmn:sequenceFlow id="f_to_End_rem_merge_main" sourceRef="ST_rem_merge_main" targetRef="End_rem_merge_main" />
    <bpmn:sequenceFlow id="f_to_End_esc_merge_main" sourceRef="ST_esc_merge_main" targetRef="End_esc_merge_main" />

    <!-- Boundary event flows: user_verify_prod -->
    <bpmn:sequenceFlow id="f_rem_verify_prod" sourceRef="BE_rem_verify_prod" targetRef="ST_rem_verify_prod" />
    <bpmn:sequenceFlow id="f_esc_verify_prod" sourceRef="BE_ded_verify_prod" targetRef="ST_esc_verify_prod" />
    <bpmn:sequenceFlow id="f_to_End_rem_verify_prod" sourceRef="ST_rem_verify_prod" targetRef="End_rem_verify_prod" />
    <bpmn:sequenceFlow id="f_to_End_esc_verify_prod" sourceRef="ST_esc_verify_prod" targetRef="End_esc_verify_prod" />

    <!-- Shared rework path -->
    <bpmn:sequenceFlow id="f_rework_comment_to_catch" sourceRef="task_comment_rework" targetRef="catch_pr_rework" />
    <bpmn:sequenceFlow id="f_rework_catch_to_review" sourceRef="catch_pr_rework" targetRef="task_pr_agent" />
    <bpmn:sequenceFlow id="f_rework_reminder" sourceRef="timer_rework_reminder" targetRef="task_send_rework_reminder" />
    <bpmn:sequenceFlow id="f_to_End_rem_rework" sourceRef="task_send_rework_reminder" targetRef="End_rem_rework" />

    <!-- ── ERROR EVENT SUBPROCESS (Catch-all) ───────────────── -->
    <bpmn:subProcess id="subprocess_error_pipeline" name="Обробка помилок" triggeredByEvent="true">
      <bpmn:startEvent id="evt_error_catch_pipeline" name="Помилка">
        <bpmn:outgoing>f_error_to_notify_pipeline</bpmn:outgoing>
        <bpmn:errorEventDefinition id="ErrorDef_catch_pipeline">
          <bpmn:extensionElements>
            <zeebe:errorEventDefinition errorCodeVariable="caught_error_code" errorMessageVariable="caught_error_message" />
          </bpmn:extensionElements>
        </bpmn:errorEventDefinition>
      </bpmn:startEvent>

      <bpmn:serviceTask id="ST_error_notify_pipeline" name="❌ Створити задачу про помилку в Odoo">
        <bpmn:documentation>Створює підзадачу в Odoo про непередбачену помилку в CI/CD пайплайні з деталями.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="send-notification" retries="2" />
          <zeebe:ioMapping>
            <zeebe:input source="=&quot;pipeline_error&quot;" target="notification_type" />
            <zeebe:input source="=&quot;Задача: &quot; + (if is defined(task_name) and task_name != null then task_name else &quot;—&quot;) + &quot;\nГілка: &quot; + (if is defined(head_branch) and head_branch != null then head_branch else &quot;—&quot;) + (if is defined(pr_number) and pr_number != null then &quot;\nPR: #&quot; + string(pr_number) else &quot;&quot;) + &quot;\nКод помилки: &quot; + (if is defined(caught_error_code) and caught_error_code != null then caught_error_code else &quot;—&quot;) + &quot;\nДеталі: &quot; + (if is defined(caught_error_message) and caught_error_message != null then caught_error_message else &quot;Невідома помилка&quot;)" target="message_body" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>f_error_to_notify_pipeline</bpmn:incoming>
        <bpmn:outgoing>f_notify_to_end_pipeline</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:endEvent id="evt_error_end_pipeline">
        <bpmn:incoming>f_notify_to_end_pipeline</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="f_error_to_notify_pipeline" sourceRef="evt_error_catch_pipeline" targetRef="ST_error_notify_pipeline" />
      <bpmn:sequenceFlow id="f_notify_to_end_pipeline" sourceRef="ST_error_notify_pipeline" targetRef="evt_error_end_pipeline" />
    </bpmn:subProcess>

  </bpmn:process>

  <!-- ═══════════════════ DIAGRAM ═══════════════════
       Layout v4 — refactored flow:
         Score<7 loop: y=100 (above main)
         Main flow:    y=380 (single horizontal line, left-to-right)
         Second review loop: y=100 (above main, x=1980+)
         Failure paths: y=530 (below main)
         Rework path:   y=740 (shared bottom)
         Reminders:     y=840 (below rework)
       Width: ~3800px
  ═══════════════════════════════════════════════════ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_feature">
    <bpmndi:BPMNPlane id="BPMNPlane_feature" bpmnElement="feature-to-production">

      <!-- ═══ MAIN FLOW (y=380) ═══ -->

      <bpmndi:BPMNShape id="start_manual_di" bpmnElement="start_manual">
        <dc:Bounds x="30" y="362" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GW_odoo_check_di" bpmnElement="GW_odoo_check" isMarkerVisible="true">
        <dc:Bounds x="100" y="355" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_create_odoo_di" bpmnElement="task_create_odoo">
        <dc:Bounds x="190" y="340" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Merge_odoo_di" bpmnElement="Merge_odoo" isMarkerVisible="true">
        <dc:Bounds x="380" y="355" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="catch_pr_created_di" bpmnElement="catch_pr_created">
        <dc:Bounds x="465" y="362" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_pr_agent_di" bpmnElement="task_pr_agent">
        <dc:Bounds x="520" y="340" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="gw_score_di" bpmnElement="gw_score" isMarkerVisible="true">
        <dc:Bounds x="760" y="355" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_merge_feature_staging_di" bpmnElement="task_merge_feature_staging">
        <dc:Bounds x="890" y="340" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="evt_merge_conflict_di" bpmnElement="evt_merge_conflict">
        <dc:Bounds x="952" y="402" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_comment_conflict_di" bpmnElement="task_comment_conflict">
        <dc:Bounds x="890" y="490" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="call_deploy_staging_di" bpmnElement="call_deploy_staging">
        <dc:Bounds x="1130" y="340" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="evt_deploy_stg_error_di" bpmnElement="evt_deploy_stg_error">
        <dc:Bounds x="1192" y="402" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_subtask_verify_staging_di" bpmnElement="task_subtask_verify_staging">
        <dc:Bounds x="1370" y="340" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="user_verify_staging_di" bpmnElement="user_verify_staging">
        <dc:Bounds x="1610" y="340" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="gw_staging_ok_di" bpmnElement="gw_staging_ok" isMarkerVisible="true">
        <dc:Bounds x="1850" y="355" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- Phase 4: Second review + undraft -->
      <bpmndi:BPMNShape id="task_pr_agent_second_di" bpmnElement="task_pr_agent_second">
        <dc:Bounds x="1980" y="340" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="gw_second_score_di" bpmnElement="gw_second_score" isMarkerVisible="true">
        <dc:Bounds x="2200" y="355" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_undraft_pr_di" bpmnElement="task_undraft_pr">
        <dc:Bounds x="2320" y="340" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_subtask_merge_main_di" bpmnElement="task_subtask_merge_main">
        <dc:Bounds x="2560" y="340" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="user_merge_main_di" bpmnElement="user_merge_main">
        <dc:Bounds x="2800" y="340" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="call_deploy_prod_di" bpmnElement="call_deploy_prod">
        <dc:Bounds x="3040" y="340" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="evt_deploy_prod_error_di" bpmnElement="evt_deploy_prod_error">
        <dc:Bounds x="3102" y="402" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_subtask_verify_prod_di" bpmnElement="task_subtask_verify_prod">
        <dc:Bounds x="3280" y="340" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="user_verify_prod_di" bpmnElement="user_verify_prod">
        <dc:Bounds x="3520" y="340" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="gw_prod_ok_di" bpmnElement="gw_prod_ok" isMarkerVisible="true">
        <dc:Bounds x="3760" y="355" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="evt_end_success_di" bpmnElement="evt_end_success">
        <dc:Bounds x="3900" y="362" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- ═══ SCORE < 7 LOOP (y=100) ═══ -->

      <bpmndi:BPMNShape id="task_cannot_merge_di" bpmnElement="task_cannot_merge">
        <dc:Bounds x="760" y="60" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="recv_wait_pr_update_di" bpmnElement="recv_wait_pr_update">
        <dc:Bounds x="520" y="60" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="timer_pr_reminder_di" bpmnElement="timer_pr_reminder">
        <dc:Bounds x="652" y="122" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_send_pr_reminder_di" bpmnElement="task_send_pr_reminder">
        <dc:Bounds x="700" y="200" width="160" height="80" />
      </bpmndi:BPMNShape>

      <!-- ═══ SECOND REVIEW < 7 LOOP (y=100, x=2200) ═══ -->

      <bpmndi:BPMNShape id="task_comment_second_rework_di" bpmnElement="task_comment_second_rework">
        <dc:Bounds x="2200" y="60" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="recv_wait_second_update_di" bpmnElement="recv_wait_second_update">
        <dc:Bounds x="1980" y="60" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="timer_second_reminder_di" bpmnElement="timer_second_reminder">
        <dc:Bounds x="2112" y="122" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_send_second_reminder_di" bpmnElement="task_send_second_reminder">
        <dc:Bounds x="2150" y="200" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="End_rem_second_di" bpmnElement="End_rem_second">
        <dc:Bounds x="2330" y="222" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- ═══ BOUNDARY EVENTS: REMINDERS & ESCALATIONS ═══ -->

      <!-- user_verify_staging boundaries -->
      <bpmndi:BPMNShape id="BE_rem_verify_staging_di" bpmnElement="BE_rem_verify_staging">
        <dc:Bounds x="1630" y="402" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST_rem_verify_staging_di" bpmnElement="ST_rem_verify_staging">
        <dc:Bounds x="1550" y="500" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BE_ded_verify_staging_di" bpmnElement="BE_ded_verify_staging">
        <dc:Bounds x="1730" y="402" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST_esc_verify_staging_di" bpmnElement="ST_esc_verify_staging">
        <dc:Bounds x="1700" y="500" width="120" height="60" />
      </bpmndi:BPMNShape>

      <!-- user_merge_main boundaries -->
      <bpmndi:BPMNShape id="BE_rem_merge_main_di" bpmnElement="BE_rem_merge_main">
        <dc:Bounds x="2820" y="402" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST_rem_merge_main_di" bpmnElement="ST_rem_merge_main">
        <dc:Bounds x="2740" y="500" width="120" height="60" />
