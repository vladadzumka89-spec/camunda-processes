      </bpmndi:BPMNShape>
      <!-- ── Module update → Smoke test ── -->
      <bpmndi:BPMNShape id="task_module_update_di" bpmnElement="task_module_update">
        <dc:Bounds x="1985" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_smoke_test_di" bpmnElement="task_smoke_test">
        <dc:Bounds x="2165" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <!-- ── Clickbot diamond ── -->
      <bpmndi:BPMNShape id="gw_clickbot_di" bpmnElement="gw_clickbot" isMarkerVisible="true">
        <dc:Bounds x="2370" y="275" width="50" height="50" />
