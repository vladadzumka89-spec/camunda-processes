    <bpmn:userTask id="Activity_1v9eoaf" name="Визначити дату переключення">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Визначити дату переключення ФОП &#34; + fop_name + &#34; на &#34; + selected_store, description: &#34;&#60;b&#62;ФОП:&#60;/b&#62; &#34; + fop_name + &#34; (&#34; + string(income_percent) + &#34;% ліміту, &#34; + string(days_to_limit) + &#34; днів до ліміту)&#34; + &#34;&#60;br/&#62;&#60;b&#62;Магазин:&#60;/b&#62; &#34; + selected_store + &#34;&#60;br/&#62;&#60;b&#62;Новий ФОП:&#60;/b&#62; &#34; + (if is defined(new_fop_name) then new_fop_name else &#34;(не вказано)&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Чи платна зміна:&#60;/b&#62; &#34; + (if is_paid_change = &#34;Так&#34; then &#34;Так&#34; else &#34;Ні&#34;) + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#34; + &#34;&#60;br/&#62;1. Визначте дату переключення ФОП на терміналі.&#34; + &#34;&#60;br/&#62;2. Враховуйте, що відповідь від ТРЦ може займати 12–14 днів — плануйте дату переключення з цим запасом.&#34; + &#34;&#60;br/&#62;3. Вкажіть дату у полі «Дата переключення».&#34; + &#34;&#60;br/&#62;4. Змініть стадію задачі на &#60;b&#62;«Виконано»&#60;/b&#62;, щоб процес пішов далі.&#34;, x_studio_camunda_fop_name: fop_name, x_studio_camunda_total_income: total_income, x_studio_camunda_days_to_limit: days_to_limit, x_studio_camunda_selected_store: selected_store, x_studio_camunda_new_fop_name: (if is defined(new_fop_name) then new_fop_name else &#34;&#34;), x_studio_camunda_is_paid_change: (if is defined(is_paid_change) then is_paid_change else &#34;Ні&#34;), parent_id: odoo_task_id, _model: &#34;project.project&#34;, _id: 524, process_instance_key: process_instance_key, x_studio_camunda_role_code: &#34;accountant&#34;, x_studio_camunda_task_code: &#34;set_date&#34;}" target="body" />
          <zeebe:output source="= x_studio_camunda_switch_date" target="switch_date" />
        </zeebe:ioMapping>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1spb1a2</bpmn:incoming>
      <bpmn:outgoing>Flow_1ls5iho</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_0rhyd10" name="Знайти ФОП з 0 оборотом та перевірити к-сть працівників">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Знайти ФОП з 0 оборотом для заміни &#34; + fop_name + &#34; на &#34; + selected_store + (if is_paid_change = &#34;Так&#34; then &#34; ⚠️ ПЛАТНА ЗМІНА&#34; else &#34;&#34;), description: &#34;&#60;b&#62;Магазин:&#60;/b&#62; &#34; + selected_store + &#34;&#60;br/&#62;&#60;b&#62;Старий ФОП:&#60;/b&#62; &#34; + fop_name + &#34; (група &#34; + string(ep_group) + &#34;)&#34; + &#34;&#60;br/&#62;&#60;b&#62;Дохід:&#60;/b&#62; &#34; + string(total_income) + &#34; грн (&#34; + string(income_percent) + &#34;% ліміту)&#34; + &#34;&#60;br/&#62;&#60;b&#62;К-сть працівників на поточному ФОП:&#60;/b&#62; &#34; + string(employee_count) + (if is_paid_change = &#34;Так&#34; then &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;⚠️ УВАГА: Зміна ФОП на цьому магазині ПЛАТНА!&#60;/b&#62;&#60;br/&#62;Оберіть ФОП з мінімальним або нульовим оборотом, щоб зменшити кількість переключень у майбутньому.&#34; else &#34;&#34;) + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#34; + &#34;&#60;br/&#62;1. Підберіть ФОП з нульовим або мінімальним оборотом у поточному році.&#34; + &#34;&#60;br/&#62;2. Перевірте к-сть зареєстрованих працівників на обраному ФОП.&#34; + &#34;&#60;br/&#62;3. Переконайтесь, що після переведення &#34; + string(employee_count) + &#34; працівників з поточного ФОП, загальна к-сть не перевищить 8 осіб — це максимум на один ФОП.&#34; + &#34;&#60;br/&#62;4. Впишіть назву обраного ФОП у поле «Новий ФОП (з 0 оборотом)».&#34; + &#34;&#60;br/&#62;5. Змініть стадію задачі на &#60;b&#62;«Виконано»&#60;/b&#62;, щоб процес пішов далі.&#34;, x_studio_camunda_fop_name: fop_name, x_studio_camunda_total_income: total_income, x_studio_camunda_days_to_limit: days_to_limit, x_studio_camunda_selected_store: selected_store, x_studio_camunda_is_paid_change: (if is defined(is_paid_change) then is_paid_change else &#34;Ні&#34;), parent_id: odoo_task_id, _model: &#34;project.project&#34;, _id: 524, process_instance_key: process_instance_key, x_studio_camunda_role_code: &#34;accountant&#34;, x_studio_camunda_task_code: &#34;select_fop&#34;}" target="body" />
          <zeebe:output source="= x_studio_camunda_new_fop_name" target="new_fop_name" />
        </zeebe:ioMapping>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_14egqul</bpmn:incoming>
      <bpmn:outgoing>Flow_1spb1a2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_1m5lz1c" name="Вибрати магазин, який преключаємо">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Вибрати магазин для переключення ФОП &#34; + fop_name, description: &#34;&#60;b&#62;ФОП:&#60;/b&#62; &#34; + fop_name + &#34; (&#34; + string(income_percent) + &#34;% ліміту, &#34; + string(days_to_limit) + &#34; днів до ліміту)&#34; + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;Магазини:&#60;/b&#62;&#60;br/&#62;&#34; + stores + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#34; + &#34;&#60;br/&#62;1. Проаналізуйте список магазинів та оберіть один, який будемо переключати на інший ФОП.&#34; + &#34;&#60;br/&#62;2. Оберіть магазин з найбільшим доходом, щоб максимально знизити навантаження на ФОП.&#34; + &#34;&#60;br/&#62;3. Впишіть назву обраного магазину у поле «Обраний магазин».&#34; + &#34;&#60;br/&#62;4. Змініть стадію задачі на &#60;b&#62;«Виконано»&#60;/b&#62;, щоб процес пішов далі.&#34;, x_studio_camunda_fop_name: fop_name, x_studio_camunda_total_income: total_income, x_studio_camunda_days_to_limit: days_to_limit, parent_id: odoo_task_id, _model: &#34;project.project&#34;, _id: 524, process_instance_key: process_instance_key, x_studio_camunda_role_code: &#34;accountant&#34;, x_studio_camunda_task_code: &#34;select_store&#34;}" target="body" />
          <zeebe:output source="= if is defined(x_studio_camunda_selected_store) and x_studio_camunda_selected_store != null then x_studio_camunda_selected_store else &#34;(не обрано)&#34;" target="selected_store" />
        </zeebe:ioMapping>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0c40yaa</bpmn:incoming>
      <bpmn:outgoing>Flow_15htyy8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_0bkeomf" name="Перевірити кількість магазинів на ФОП">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Перевірити магазини ФОП &#34; + fop_name, description: &#34;&#60;b&#62;ФОП:&#60;/b&#62; &#34; + fop_name + &#34; (ЄДРПОУ: &#34; + fop_edrpou + &#34;)&#34; + &#34;&#60;br/&#62;&#60;b&#62;Група ЄП:&#60;/b&#62; &#34; + string(ep_group) + &#34;&#60;br/&#62;&#60;b&#62;Дохід за рік:&#60;/b&#62; &#34; + string(total_income) + &#34; грн (&#34; + string(income_percent) + &#34;% від ліміту &#34; + string(limit_amount) + &#34; грн)&#34; + &#34;&#60;br/&#62;&#60;b&#62;Днів до ліміту:&#60;/b&#62; &#34; + string(days_to_limit) + &#34;&#60;br/&#62;&#60;b&#62;Прогнозна дата:&#60;/b&#62; &#34; + projected_date + &#34;&#60;br/&#62;&#60;b&#62;К-сть працівників на ФОП:&#60;/b&#62; &#34; + string(employee_count) + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;Магазини:&#60;/b&#62;&#60;br/&#62;&#34; + stores + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#34; + &#34;&#60;br/&#62;1. Перевірте список магазинів, на яких працює цей ФОП.&#34; + &#34;&#60;br/&#62;2. Звірте к-сть магазинів та працівників з даними у звіті.&#34; + &#34;&#60;br/&#62;3. Якщо дані коректні — підтвердіть інформацію.&#34; + &#34;&#60;br/&#62;4. Змініть стадію задачі на &#60;b&#62;«Виконано»&#60;/b&#62;, щоб процес пішов далі.&#34;, x_studio_camunda_fop_name: fop_name, x_studio_camunda_total_income: total_income, x_studio_camunda_days_to_limit: days_to_limit, parent_id: odoo_task_id, _model: &#34;project.project&#34;, _id: 524, process_instance_key: process_instance_key, x_studio_camunda_role_code: &#34;accountant&#34;, x_studio_camunda_task_code: &#34;check_stores&#34;}" target="body" />
        </zeebe:ioMapping>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1hjjtgs</bpmn:incoming>
      <bpmn:incoming>Flow_08sqmwa</bpmn:incoming>
      <bpmn:outgoing>Flow_0c40yaa</bpmn:outgoing>
