      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_merge_clickbot_di" bpmnElement="gw_merge_clickbot" isMarkerVisible="true">
        <dc:Bounds x="2680" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <!-- ── Clickbot report + boundary event ── -->
      <bpmndi:BPMNShape id="ST_clickbot_report_di" bpmnElement="ST_clickbot_report">
