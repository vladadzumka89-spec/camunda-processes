    <bpmn:sequenceFlow id="Flow_rem_pih_end" sourceRef="ST_rem_pih" targetRef="End_rem_pih" />
    <bpmn:sequenceFlow id="Flow_ded_pih" sourceRef="BE_ded_pih" targetRef="UT_esc_pih" />
    <bpmn:sequenceFlow id="Flow_esc_pih_end" sourceRef="UT_esc_pih" targetRef="End_esc_pih" />
    <bpmn:sequenceFlow id="Flow_contract_to_gw" sourceRef="Task_approver_contract" targetRef="GW_contract_result" />
    <bpmn:sequenceFlow id="Flow_nego_manual_end" sourceRef="Task_nego_manual" targetRef="End_nego_manual" />
    <bpmn:sequenceFlow id="Flow_nego_self_to_gw" sourceRef="CA_nego_self" targetRef="Task_dmn_record" />
    <bpmn:sequenceFlow id="Flow_dmn_to_gw" sourceRef="Task_dmn_record" targetRef="GW_dmn_decision" />
    <bpmn:sequenceFlow id="Flow_timer_to_yulia" sourceRef="GW_timer_decision" targetRef="Task_yulia">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_has_question = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_yulia_to_gw" sourceRef="Task_yulia" targetRef="GW_yulia_decision" />
    <bpmn:sequenceFlow id="Flow_yulia_yes" name="так" sourceRef="GW_yulia_decision" targetRef="Task_pay">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_pay = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_yulia_no" name="ні" sourceRef="GW_yulia_decision" targetRef="End_no_pay" />
    <bpmn:sequenceFlow id="Flow_yulia_timer_to_dasha" sourceRef="Timer_yulia_deadline" targetRef="Task_dasha" />
    <bpmn:sequenceFlow id="Flow_dasha_to_pay" sourceRef="Task_dasha" targetRef="CA_nego_self" />
    <bpmn:sequenceFlow id="Flow_dmn_pay" name="Платимо" sourceRef="GW_dmn_decision" targetRef="Task_pay" />
    <bpmn:sequenceFlow id="Flow_timer_to_pay" sourceRef="GW_timer_decision" targetRef="Task_pay" />
    <bpmn:sequenceFlow id="Flow_contract_yes" name="так" sourceRef="GW_contract_result" targetRef="Task_pay">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_contract_approved = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0ues5t2" sourceRef="CA_nego_self" targetRef="Task_pay" />
    <bpmn:sequenceFlow id="Flow_pay_to_service" sourceRef="Task_pay" targetRef="Task_service_receipt" />
    <bpmn:sequenceFlow id="Flow_0073gjv" sourceRef="Activity_1mf4l1i" targetRef="End_main" />
    <bpmn:sequenceFlow id="Flow_contract_no" name="ні" sourceRef="GW_contract_result" targetRef="Task_dmn_nego_who" />
    <bpmn:sequenceFlow id="Flow_nego_self" name="Веде переговори Юля" sourceRef="GW_who_nego" targetRef="CA_nego_self">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_nego_who = "yulia"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_dmn_nego_who_to_gw" sourceRef="Task_dmn_nego_who" targetRef="GW_who_nego" />
    <bpmn:sequenceFlow id="Flow_nego_dasha" name="Веде переговори Даша" sourceRef="GW_who_nego" targetRef="Task_nego_manual">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_nego_who = "dasha"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_dmn_wait" name="Перевипуск рахунку" sourceRef="GW_dmn_decision" targetRef="End_wait_new">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= nego_action = "reissue"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_dmn_break" name="Розриваємо договір" sourceRef="GW_dmn_decision" targetRef="CA_break_contract">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= nego_action = "break_contract"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_break_to_end" sourceRef="CA_break_contract" targetRef="End_break_contract" />
    <bpmn:sequenceFlow id="Flow_service_to_end" sourceRef="Task_service_receipt" targetRef="Activity_1mf4l1i" />
  </bpmn:process>
