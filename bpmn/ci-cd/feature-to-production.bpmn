<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_feature"
                  targetNamespace="http://tut.ua/bpmn/feature-pipeline"
                  exporter="Claude Code"
                  exporterVersion="2.0">

  <!-- ═══════════════════════════════════════════════════════════
       FEATURE TO PRODUCTION v5.0 — Thin Orchestrator

       Декомпозований пайплайн: використовує Call Activities для
       pr-review, verification-process та deploy-process.

       Старт: /start command
       Фініш: Фіча на production

       Фази:
         0. /start → Odoo task → wait Draft PR
         1. PR Review (Call Activity: pr-review)
         2. Merge → staging deploy → staging verification
         3. 2nd PR Review → undraft → merge verification → github merge
         4. Production verification (manual deploy)

       Rework: будь-яка невдача → коментар → wait PR update → назад до review
       ═══════════════════════════════════════════════════════════ -->

  <bpmn:error id="Error_deploy_failed" name="Deploy Failed" errorCode="DEPLOY_FAILED" />
  <bpmn:error id="Error_merge_conflict" name="Merge Conflict" errorCode="MERGE_CONFLICT" />

  <!-- Messages for process correlation -->
  <bpmn:message id="Message_pr_event" name="msg_pr_event">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=head_branch" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_pr_updated" name="msg_pr_updated">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>

  <bpmn:process id="feature-to-production" name="Feature to Production" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="5.0" />
    </bpmn:extensionElements>

    <!-- ═══════════════════ PHASE 0: /start ═══════════════════ -->

    <bpmn:startEvent id="start_manual" name="Фіча розпочата (/start)">
      <bpmn:documentation>Розробник запускає /start в Claude Code CLI.</bpmn:documentation>
      <bpmn:outgoing>f_manual_to_odoo</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="GW_odoo_check" name="Задача в Odoo існує?" default="f_odoo_default">
      <bpmn:incoming>f_manual_to_odoo</bpmn:incoming>
      <bpmn:outgoing>f_odoo_default</bpmn:outgoing>
      <bpmn:outgoing>f_odoo_skip</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="task_create_odoo" name="Створити задачу в Odoo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=&quot;https://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: if is defined(task_name) and task_name != null and task_name != &quot;&quot; then task_name else &quot;[feature] Нова задача&quot;, description: if is defined(task_description) and task_description != null then task_description else &quot;&quot;, _id: odoo_project_id, create_process: true}" target="body" />
          <zeebe:input source="=&quot;odoo_response&quot;" target="result_variable_name" />
          <zeebe:output source="=string(odoo_response.id)" target="odoo_task_id" />
          <zeebe:output source="=process_instance_key" target="process_instance_key" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_odoo_default</bpmn:incoming>
      <bpmn:outgoing>f_odoo_to_merge</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Merge_odoo">
      <bpmn:incoming>f_odoo_to_merge</bpmn:incoming>
      <bpmn:incoming>f_odoo_skip</bpmn:incoming>
      <bpmn:outgoing>f_merge_to_wait</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:intermediateCatchEvent id="catch_pr_created" name="Чекаємо Draft PR">
      <bpmn:documentation>Чекає msg_pr_event з correlation key = head_branch.</bpmn:documentation>
      <bpmn:incoming>f_merge_to_wait</bpmn:incoming>
      <bpmn:outgoing>f_catch_to_review</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_catch_pr" messageRef="Message_pr_event" />
    </bpmn:intermediateCatchEvent>

    <!-- ═══════════════════ PHASE 1: PR REVIEW ═══════════════════ -->

    <bpmn:callActivity id="call_pr_review" name="Рев'ю PR-Agent">
      <bpmn:documentation>Call Activity: pr-review. Запускає PR-Agent review з loop до score >= 7.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:calledElement processId="pr-review" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=pr_number" target="pr_number" />
          <zeebe:input source="=pr_url" target="pr_url" />
          <zeebe:input source="=repository" target="repository" />
          <zeebe:output source="=review_score" target="review_score" />
          <zeebe:output source="=has_critical_issues" target="has_critical_issues" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_catch_to_review</bpmn:incoming>
      <bpmn:incoming>f_rework_catch_to_review</bpmn:incoming>
      <bpmn:outgoing>f_review_to_merge_staging</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- ═══════════════════ PHASE 2: STAGING ═══════════════════ -->

    <bpmn:serviceTask id="task_merge_staging" name="Merge feature → staging">
      <bpmn:documentation>Мерджить feature branch в staging через SSH.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="merge-feature-to-staging" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="=head_branch" target="feature_branch" />
          <zeebe:input source="=staging_host" target="server_host" />
          <zeebe:input source="=repository" target="repository" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_review_to_merge_staging</bpmn:incoming>
      <bpmn:outgoing>f_merge_to_deploy_staging</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:boundaryEvent id="evt_merge_conflict" name="Merge конфлікт" attachedToRef="task_merge_staging">
      <bpmn:outgoing>f_merge_conflict</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDef_merge_conflict" />
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="task_notify_conflict" name="Повідомити: merge конфлікт">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=&quot;https://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: &quot;Merge конфлікт: PR #&quot; + string(pr_number) + &quot; — &quot; + head_branch, description: &quot;Не вдалось змержити гілку в staging. Потрібен rebase на main.\n\nКонфліктні файли:\n&quot; + (if is defined(conflict_files) and conflict_files != null and conflict_files != &quot;&quot; then conflict_files else &quot;(не вдалось визначити)&quot;)}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_merge_conflict</bpmn:incoming>
      <bpmn:outgoing>f_conflict_to_comment</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:callActivity id="call_deploy_staging" name="Деплой на staging">
      <bpmn:documentation>Call Activity: deploy-process з параметрами staging.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:calledElement processId="deploy-process" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=staging_host" target="server_host" />
          <zeebe:input source="=staging_ssh_user" target="ssh_user" />
          <zeebe:input source="=&quot;staging&quot;" target="branch" />
          <zeebe:input source="=staging_db" target="db_name" />
          <zeebe:input source="=staging_container" target="container" />
          <zeebe:input source="=staging_repo_dir" target="repo_dir" />
          <zeebe:input source="=true" target="run_smoke_test" />
          <zeebe:input source="=&quot;full&quot;" target="test_mode" />
          <zeebe:input source="=process_instance_key" target="parent_process_instance_key" />
          <zeebe:input source="=odoo_project_id" target="odoo_project_id" />
          <zeebe:output source="=modules_updated" target="staging_modules" />
          <zeebe:output source="=smoke_passed" target="staging_smoke" />
          <zeebe:output source="=clickbot_passed" target="clickbot_passed" />
          <zeebe:output source="=clickbot_report" target="clickbot_report" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_merge_to_deploy_staging</bpmn:incoming>
      <bpmn:outgoing>f_deploy_to_verify_staging</bpmn:outgoing>
    </bpmn:callActivity>

    <bpmn:boundaryEvent id="evt_deploy_stg_error" name="Деплой staging невдалий" attachedToRef="call_deploy_staging">
      <bpmn:outgoing>f_deploy_stg_fail</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDef_deploy_stg" errorRef="Error_deploy_failed" />
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="task_notify_deploy_fail" name="Повідомити: deploy staging failed">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=&quot;https://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: &quot;[deploy] ❌ Деплой staging провалився&quot;, description: &quot;&lt;p&gt;❌ Deploy PR #&quot; + string(pr_number) + &quot; на staging провалився.&lt;/p&gt;&quot;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_deploy_stg_fail</bpmn:incoming>
      <bpmn:outgoing>f_deploy_fail_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:callActivity id="call_verify_staging" name="Перевірити staging">
      <bpmn:documentation>Call Activity: verification-process. Створює Odoo задачу, чекає результату.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:calledElement processId="verification-process" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;Перевірити staging: &quot; + head_branch" target="task_name" />
          <zeebe:input source="=&quot;Перевірте зміни на staging.\nPR: &quot; + pr_url + &quot;\nМодулі: &quot; + string(staging_modules)" target="task_description" />
          <zeebe:input source="=string(process_instance_key)" target="correlation_key" />
          <zeebe:input source="=&quot;R/PT4H&quot;" target="reminder_cycle" />
          <zeebe:input source="=&quot;P3D&quot;" target="deadline_duration" />
          <zeebe:output source="=staging_approved" target="staging_approved" />
          <zeebe:output source="=comment" target="staging_comment" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_deploy_to_verify_staging</bpmn:incoming>
      <bpmn:outgoing>f_verify_staging_to_gw</bpmn:outgoing>
    </bpmn:callActivity>

    <bpmn:exclusiveGateway id="gw_staging_ok" name="Staging пройдено?" default="f_staging_ok">
      <bpmn:incoming>f_verify_staging_to_gw</bpmn:incoming>
      <bpmn:outgoing>f_staging_ok</bpmn:outgoing>
      <bpmn:outgoing>f_staging_rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="task_comment_staging_reject" name="Коментар: staging відхилено">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;⚠️ **Staging відхилено**: &quot; + (if is defined(staging_comment) and staging_comment != null then staging_comment else &quot;&quot;) + &quot;\nБудь ласка, виправте та пушніть зміни.&quot;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_staging_rejected</bpmn:incoming>
      <bpmn:outgoing>f_staging_reject_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ═══════════════════ PHASE 3: 2ND REVIEW + MERGE ═══════════════════ -->

    <bpmn:callActivity id="call_pr_review_2nd" name="Рев'ю PR-Agent (2-ге)">
      <bpmn:documentation>Call Activity: pr-review. Другий запуск PR-Agent після staging.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:calledElement processId="pr-review" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=pr_number" target="pr_number" />
          <zeebe:input source="=pr_url" target="pr_url" />
          <zeebe:input source="=repository" target="repository" />
          <zeebe:output source="=review_score" target="second_review_score" />
          <zeebe:output source="=has_critical_issues" target="second_has_critical" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_staging_ok</bpmn:incoming>
      <bpmn:outgoing>f_2nd_review_to_undraft</bpmn:outgoing>
    </bpmn:callActivity>

    <bpmn:serviceTask id="task_undraft_pr" name="Undraft PR">
      <bpmn:documentation>Позначає draft PR як ready for review.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-pr-ready" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=pr_number" target="pr_number" />
          <zeebe:input source="=repository" target="repository" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_2nd_review_to_undraft</bpmn:incoming>
      <bpmn:outgoing>f_undraft_to_verify_merge</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:callActivity id="call_verify_merge" name="Review та merge PR">
      <bpmn:documentation>Call Activity: verification-process. Тімлід робить review та merge PR в main.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:calledElement processId="verification-process" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;Review та merge PR #&quot; + string(pr_number) + &quot; в main&quot;" target="task_name" />
          <zeebe:input source="=&quot;PR: &quot; + pr_url" target="task_description" />
          <zeebe:input source="=string(process_instance_key)" target="correlation_key" />
          <zeebe:input source="=&quot;R/PT4H&quot;" target="reminder_cycle" />
          <zeebe:input source="=&quot;P3D&quot;" target="deadline_duration" />
          <zeebe:output source="=merge_approved" target="merge_approved" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_undraft_to_verify_merge</bpmn:incoming>
      <bpmn:outgoing>f_verify_merge_to_gw</bpmn:outgoing>
    </bpmn:callActivity>

    <bpmn:exclusiveGateway id="gw_merge_ok" name="Merge пройдено?" default="f_merge_ok">
      <bpmn:incoming>f_verify_merge_to_gw</bpmn:incoming>
      <bpmn:outgoing>f_merge_ok</bpmn:outgoing>
      <bpmn:outgoing>f_merge_rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="task_comment_merge_reject" name="Коментар: merge відхилено">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;⚠️ **Merge відхилено**. Будь ласка, виправте та пушніть зміни.&quot;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_merge_rejected</bpmn:incoming>
      <bpmn:outgoing>f_merge_reject_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="task_github_merge" name="Merge PR в main">
      <bpmn:documentation>Автоматичний merge PR в main через GitHub API.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-merge" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=pr_number" target="pr_number" />
          <zeebe:input source="=repository" target="repository" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_merge_ok</bpmn:incoming>
      <bpmn:outgoing>f_github_merge_to_verify_prod</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ═══════════════════ PHASE 4: PRODUCTION (manual) ═══════════════════ -->

    <bpmn:callActivity id="call_verify_prod" name="Задеплоїте на production">
      <bpmn:documentation>Call Activity: verification-process. Ручний деплой на production.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:calledElement processId="verification-process" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;Задеплоїте на production: PR #&quot; + string(pr_number)" target="task_name" />
          <zeebe:input source="=&quot;PR: &quot; + pr_url + &quot;\nЗмержено в main.&quot;" target="task_description" />
          <zeebe:input source="=string(process_instance_key)" target="correlation_key" />
          <zeebe:input source="=&quot;R/PT4H&quot;" target="reminder_cycle" />
          <zeebe:input source="=&quot;P1D&quot;" target="deadline_duration" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_github_merge_to_verify_prod</bpmn:incoming>
      <bpmn:outgoing>f_verify_prod_to_end</bpmn:outgoing>
    </bpmn:callActivity>

    <bpmn:endEvent id="evt_end_success" name="Фіча на production ✅">
      <bpmn:incoming>f_verify_prod_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ═══════════════════ SHARED REWORK PATH ═══════════════════ -->

    <bpmn:serviceTask id="task_comment_rework" name="Коментар: потрібне виправлення">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;🔄 Потрібне виправлення. Пушніть зміни в гілку `&quot; + head_branch + &quot;` для продовження CI/CD.&quot;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_conflict_to_comment</bpmn:incoming>
      <bpmn:incoming>f_deploy_fail_to_rework</bpmn:incoming>
      <bpmn:incoming>f_staging_reject_to_rework</bpmn:incoming>
      <bpmn:incoming>f_merge_reject_to_rework</bpmn:incoming>
      <bpmn:outgoing>f_rework_to_catch</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:receiveTask id="catch_pr_rework" name="Чекаємо PR update" messageRef="Message_pr_updated">
      <bpmn:documentation>Чекає push нових комітів в PR (correlation by pr_number).</bpmn:documentation>
      <bpmn:incoming>f_rework_to_catch</bpmn:incoming>
      <bpmn:outgoing>f_rework_catch_to_review</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:boundaryEvent id="timer_rework_reminder" name="Нагадування (3 дні)" cancelActivity="false" attachedToRef="catch_pr_rework">
      <bpmn:outgoing>f_rework_reminder</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_rework_reminder">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P3D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="task_send_rework_reminder" name="Нагадати: потрібне виправлення">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=&quot;https://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: &quot;⏰ Нагадування: PR #&quot; + string(pr_number) + &quot; потребує виправлення&quot;, description: &quot;&lt;p&gt;⏰ Нагадування: PR #&quot; + string(pr_number) + &quot; потребує виправлення. Пушніть зміни в гілку &quot; + head_branch + &quot;.&lt;/p&gt;&quot;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_rework_reminder</bpmn:incoming>
      <bpmn:outgoing>f_to_End_rem_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_rem_rework">
      <bpmn:incoming>f_to_End_rem_rework</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ═══════════════════ ERROR EVENT SUBPROCESS ═══════════════════ -->

    <bpmn:subProcess id="subprocess_error_pipeline" name="Обробка помилок пайплайну" triggeredByEvent="true">
      <bpmn:startEvent id="evt_error_catch" name="Помилка пайплайну" isInterrupting="true">
        <bpmn:outgoing>f_err_to_notify</bpmn:outgoing>
        <bpmn:errorEventDefinition id="ErrorDef_catch_pipeline" />
      </bpmn:startEvent>

      <bpmn:serviceTask id="ST_error_notify" name="Повідомити про помилку">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="http-request-smart" retries="2" />
          <zeebe:ioMapping>
            <zeebe:input source="=&quot;POST&quot;" target="method" />
            <zeebe:input source="=&quot;https://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
            <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
            <zeebe:input source="={name: &quot;[pipeline] ❌ Помилка CI/CD пайплайну&quot;, description: &quot;&lt;p&gt;Критична помилка в пайплайні для PR #&quot; + string(pr_number) + &quot;.&lt;/p&gt;&quot;}" target="body" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>f_err_to_notify</bpmn:incoming>
        <bpmn:outgoing>f_err_to_end</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:endEvent id="evt_error_end" name="Пайплайн завершено з помилкою">
        <bpmn:incoming>f_err_to_end</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="f_err_to_notify" sourceRef="evt_error_catch" targetRef="ST_error_notify" />
      <bpmn:sequenceFlow id="f_err_to_end" sourceRef="ST_error_notify" targetRef="evt_error_end" />
    </bpmn:subProcess>

    <!-- ═══════════════════ SEQUENCE FLOWS ═══════════════════ -->

    <bpmn:sequenceFlow id="f_manual_to_odoo" sourceRef="start_manual" targetRef="GW_odoo_check" />
    <bpmn:sequenceFlow id="f_odoo_default" sourceRef="GW_odoo_check" targetRef="task_create_odoo" />
    <bpmn:sequenceFlow id="f_odoo_skip" name="Задача існує" sourceRef="GW_odoo_check" targetRef="Merge_odoo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=is defined(odoo_task_id) and odoo_task_id != null</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_odoo_to_merge" sourceRef="task_create_odoo" targetRef="Merge_odoo" />
    <bpmn:sequenceFlow id="f_merge_to_wait" sourceRef="Merge_odoo" targetRef="catch_pr_created" />
    <bpmn:sequenceFlow id="f_catch_to_review" sourceRef="catch_pr_created" targetRef="call_pr_review" />
    <bpmn:sequenceFlow id="f_review_to_merge_staging" sourceRef="call_pr_review" targetRef="task_merge_staging" />
    <bpmn:sequenceFlow id="f_merge_conflict" sourceRef="evt_merge_conflict" targetRef="task_notify_conflict" />
    <bpmn:sequenceFlow id="f_conflict_to_comment" sourceRef="task_notify_conflict" targetRef="task_comment_rework" />
    <bpmn:sequenceFlow id="f_merge_to_deploy_staging" sourceRef="task_merge_staging" targetRef="call_deploy_staging" />
    <bpmn:sequenceFlow id="f_deploy_stg_fail" sourceRef="evt_deploy_stg_error" targetRef="task_notify_deploy_fail" />
    <bpmn:sequenceFlow id="f_deploy_fail_to_rework" sourceRef="task_notify_deploy_fail" targetRef="task_comment_rework" />
    <bpmn:sequenceFlow id="f_deploy_to_verify_staging" sourceRef="call_deploy_staging" targetRef="call_verify_staging" />
    <bpmn:sequenceFlow id="f_verify_staging_to_gw" sourceRef="call_verify_staging" targetRef="gw_staging_ok" />
    <bpmn:sequenceFlow id="f_staging_ok" name="OK" sourceRef="gw_staging_ok" targetRef="call_pr_review_2nd" />
    <bpmn:sequenceFlow id="f_staging_rejected" name="Проблеми" sourceRef="gw_staging_ok" targetRef="task_comment_staging_reject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=staging_approved = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_staging_reject_to_rework" sourceRef="task_comment_staging_reject" targetRef="task_comment_rework" />
    <bpmn:sequenceFlow id="f_2nd_review_to_undraft" sourceRef="call_pr_review_2nd" targetRef="task_undraft_pr" />
    <bpmn:sequenceFlow id="f_undraft_to_verify_merge" sourceRef="task_undraft_pr" targetRef="call_verify_merge" />
    <bpmn:sequenceFlow id="f_verify_merge_to_gw" sourceRef="call_verify_merge" targetRef="gw_merge_ok" />
    <bpmn:sequenceFlow id="f_merge_ok" name="OK" sourceRef="gw_merge_ok" targetRef="task_github_merge" />
    <bpmn:sequenceFlow id="f_merge_rejected" name="Відхилено" sourceRef="gw_merge_ok" targetRef="task_comment_merge_reject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=merge_approved = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_merge_reject_to_rework" sourceRef="task_comment_merge_reject" targetRef="task_comment_rework" />
    <bpmn:sequenceFlow id="f_github_merge_to_verify_prod" sourceRef="task_github_merge" targetRef="call_verify_prod" />
    <bpmn:sequenceFlow id="f_verify_prod_to_end" sourceRef="call_verify_prod" targetRef="evt_end_success" />
    <bpmn:sequenceFlow id="f_rework_to_catch" sourceRef="task_comment_rework" targetRef="catch_pr_rework" />
    <bpmn:sequenceFlow id="f_rework_catch_to_review" sourceRef="catch_pr_rework" targetRef="call_pr_review" />
    <bpmn:sequenceFlow id="f_rework_reminder" sourceRef="timer_rework_reminder" targetRef="task_send_rework_reminder" />
    <bpmn:sequenceFlow id="f_to_End_rem_rework" sourceRef="task_send_rework_reminder" targetRef="End_rem_rework" />

  </bpmn:process>

  <!-- ═══════════════════ DIAGRAM ═══════════════════ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_feature">
