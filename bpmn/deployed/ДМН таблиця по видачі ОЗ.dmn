<?xml version="1.0" encoding="UTF-8"?>
<definitions
  xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
  xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
  xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
  id="Definitions_OzByDepartment"
  name="ОЗ по підрозділу"
  namespace="http://camunda.org/schema/1.0/dmn"
  exporter="Camunda Modeler"
  exporterVersion="5.16.0"
  modeler:executionPlatform="Camunda Cloud"
  modeler:executionPlatformVersion="8.8.0">

  <decision id="oz-by-department" name="Які ОЗ видати по підрозділу">

    <decisionTable id="DecisionTable_OZ" hitPolicy="FIRST">

      <!-- INPUT: ID підрозділу -->
      <input id="Input_dept" label="ID підрозділу">
        <inputExpression id="InputExpr_dept" typeRef="number">
          <text>x_studio_camunda_pidrozdil</text>
        </inputExpression>
      </input>

      <!-- OUTPUT: перелік ОЗ для видачі -->
      <output id="Output_oz_list" label="Перелік ОЗ" name="oz_list" typeRef="string" />

      <!-- Правило 1: 101 Call-center (ID 1424) — з навушниками -->
      <rule id="Rule_callcenter">
        <description>101 Call-center</description>
        <inputEntry id="IE_callcenter">
          <text>1424</text>
        </inputEntry>
        <outputEntry id="OE_callcenter">
          <text>"Навушники, ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

      <!-- Правило 2: 103 Офіс (ID 1399) -->
      <rule id="Rule_office">
        <description>103 Офіс</description>
        <inputEntry id="IE_office">
          <text>1399</text>
        </inputEntry>
        <outputEntry id="OE_office">
          <text>"Ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

      <!-- Правило 3: 102 Фіни, бухи, кадри (ID 1425) -->
      <rule id="Rule_finance">
        <description>102 Фіни, бухи, кадри</description>
        <inputEntry id="IE_finance">
          <text>1425</text>
        </inputEntry>
        <outputEntry id="OE_finance">
          <text>"Ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

      <!-- Правило 4: 108 Бухгалтерія (ID 1472) -->
      <rule id="Rule_accounting">
        <description>108 Бухгалтерія</description>
        <inputEntry id="IE_accounting">
          <text>1472</text>
        </inputEntry>
        <outputEntry id="OE_accounting">
          <text>"Ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

      <!-- Правило 5: 110 Департамент якості (ID 1573) -->
      <rule id="Rule_quality">
        <description>110 Департамент якості</description>
        <inputEntry id="IE_quality">
          <text>1573</text>
        </inputEntry>
        <outputEntry id="OE_quality">
          <text>"Ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

      <!-- Правило 6: 131 Маркетинг (ID 1415) -->
      <rule id="Rule_marketing">
        <description>131 Маркетинг</description>
        <inputEntry id="IE_marketing">
          <text>1415</text>
        </inputEntry>
        <outputEntry id="OE_marketing">
          <text>"Ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

      <!-- Правило 7: 133 Фотографи (ID 1417) -->
      <rule id="Rule_photo">
        <description>133 Фотографи</description>
        <inputEntry id="IE_photo">
          <text>1417</text>
        </inputEntry>
        <outputEntry id="OE_photo">
          <text>"Ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

      <!-- Правило 8: 151 Рекрутинг (ID 1428) -->
      <rule id="Rule_recruiting">
        <description>151 Рекрутинг</description>
        <inputEntry id="IE_recruiting">
          <text>1428</text>
        </inputEntry>
        <outputEntry id="OE_recruiting">
          <text>"Ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

      <!-- Правило 9: 200 Логістичний центр (ID 1400) -->
      <rule id="Rule_logistics">
        <description>200 Логістичний центр</description>
        <inputEntry id="IE_logistics">
          <text>1400</text>
        </inputEntry>
        <outputEntry id="OE_logistics">
          <text>"Ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

      <!-- Правило 10: 208 Контент відділ (ID 1436) -->
      <rule id="Rule_content">
        <description>208 Контент відділ</description>
        <inputEntry id="IE_content">
          <text>1436</text>
        </inputEntry>
        <outputEntry id="OE_content">
          <text>"Ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

      <!-- Правило 11: 209 RnD (ID 1422) -->
      <rule id="Rule_rnd">
        <description>209 RnD</description>
        <inputEntry id="IE_rnd">
          <text>1422</text>
        </inputEntry>
        <outputEntry id="OE_rnd">
          <text>"Ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

      <!-- Правило 12: 400 Швейне виробництво (ID 1394) -->
      <rule id="Rule_sewing">
        <description>400 Швейне виробництво</description>
        <inputEntry id="IE_sewing">
          <text>1394</text>
        </inputEntry>
        <outputEntry id="OE_sewing">
          <text>"Ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

      <!-- Правило 13: 600 Роздріб Фамо (ID 1414) -->
      <rule id="Rule_famo">
        <description>600 Роздріб Фамо</description>
        <inputEntry id="IE_famo">
          <text>1414</text>
        </inputEntry>
        <outputEntry id="OE_famo">
          <text>"Ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

      <!-- Правило default: інший підрозділ -->
      <rule id="Rule_default">
        <description>Інший підрозділ</description>
        <inputEntry id="IE_default">
          <text></text>
        </inputEntry>
        <outputEntry id="OE_default">
          <text>"Ноутбук, монітор, стіл, стілець"</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <!-- DIAGRAM -->
  <dmndi:DMNDI>
    <dmndi:DMNDiagram>
      <dmndi:DMNShape dmnElementRef="oz-by-department">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
