        <inputEntry id="IE_com_dept"><text>1401</text></inputEntry>
        <inputEntry id="IE_com_pos"><text></text></inputEntry>
        <outputEntry id="OE_com"><text>"2 монітори, ноутбук, мишка, килимок, стіл, крісло, гарнітура"</text></outputEntry>
      </rule>

      <!-- === 200 Логістичний центр (ID 1400) — Комірник: нічого === -->
      <rule id="Rule_log_sk">
