    <bpmn:userTask id="UT_check_sum_tp" name="Перевірити суму та погодити (ТП)">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="3" type="http-request-smart" />
        </zeebe:taskListeners>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Перевірити суму та погодити (ТП, &#34; + (if x_studio_camunda_invoice_type != null then x_studio_camunda_invoice_type else &#34;—&#34;) + &#34;): &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34; №&#34; + x_studio_camunda_invoice_number + &#34; — &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#34;, description: &#34;&#60;b&#62;Постачальник:&#60;/b&#62; &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Сума:&#60;/b&#62; &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#60;br/&#62;&#60;b&#62;Тип рахунку:&#60;/b&#62; &#34; + (if x_studio_camunda_invoice_type != null then x_studio_camunda_invoice_type else &#34;—&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Період послуги:&#60;/b&#62; &#34; + (if x_studio_camunda_service_period != null then x_studio_camunda_service_period else &#34;—&#34;) + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#60;br/&#62;1. Перевірте суму та коректність даних рахунку.&#60;br/&#62;2. У полі «Погоджено» вкажіть «Так» (якщо рахунок коректний) або «Ні» (якщо є зауваження).&#60;br/&#62;3. Змініть стадію задачі на &#60;b&#62;«Виконано»&#60;/b&#62;, щоб процес пішов далі.&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, parent_process_instance_key: parent_process_instance_key, x_studio_camunda_pidrozdil: if x_studio_camunda_pidrozdil != null then x_studio_camunda_pidrozdil else null, user_ids: if x_studio_camunda_responsible_user_id != null then [x_studio_camunda_responsible_user_id] else []}" target="body" />
          <zeebe:output source="= x_studio_camunda_approved" target="x_studio_camunda_approved" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_famo_no</bpmn:incoming>
      <bpmn:outgoing>Flow_check_tp_to_appr</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_approved_tp" name="Погоджено?" default="Flow_appr_tp_no">
