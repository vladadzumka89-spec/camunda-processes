    <bpmn:intermediateCatchEvent id="Timer_month_end" name="Останній день місяця">
      <bpmn:incoming>Flow_rent_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_timer_to_buh</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT10S</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="UT_buh_real" name="Провести бух реалізацію&#10;(на основі рахунку)">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
