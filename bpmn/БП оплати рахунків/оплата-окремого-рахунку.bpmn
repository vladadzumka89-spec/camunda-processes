    <bpmn:sequenceFlow id="Flow_ded_bui" sourceRef="BE_ded_bui" targetRef="UT_esc_bui" />
    <bpmn:sequenceFlow id="Flow_esc_bui_end" sourceRef="UT_esc_bui" targetRef="End_esc_bui" />
    <bpmn:sequenceFlow id="Flow_pih_to_approve" sourceRef="UT_task_pih" targetRef="Task_approve" />
