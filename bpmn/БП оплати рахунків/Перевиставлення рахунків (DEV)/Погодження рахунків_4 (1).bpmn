    <bpmn:userTask id="UT_pay_invoice" name="Сплатити рахунок">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="3" type="http-request-smart" />
