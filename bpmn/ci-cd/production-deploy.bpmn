<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  id="Definitions_nightly_prod"
  targetNamespace="http://tut.ua/bpmn/nightly-prod-deploy"
  exporter="Claude Code" exporterVersion="3.0">

  <bpmn:error id="Error_deploy_failed" name="Deploy Failed" errorCode="DEPLOY_FAILED" />

  <!-- ── Process ───────────────────────────────────────── -->
  <bpmn:process id="production-nightly-deploy" name="Production Deploy" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="1.2" />
    </bpmn:extensionElements>

    <!-- ── 1. Timer Start ────────────────────────────── -->
    <bpmn:startEvent id="start_timer" name="23:30 EEST (з 22.04.2026)">
      <bpmn:documentation>Тимчасово вимкнено на ніч 21.04.2026.
ISO 8601: R/2026-04-22T20:30:00Z/P1D = 23:30 EEST щодня починаючи з 22.04.2026.
Щоб повернути CRON: замінити на "0 30 20 * * *" і задеплоїти нову версію.</bpmn:documentation>
      <bpmn:outgoing>f_start_to_zabbix</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_nightly_prod">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/2026-04-22T20:30:00Z/P1D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>

    <!-- ── 2. Zabbix: Create Maintenance ─────────────── -->
    <bpmn:serviceTask id="ST_zabbix_create" name="Zabbix: увімкнути maintenance">
      <bpmn:documentation>REST Connector: maintenance.create. Вимикає сповіщення Zabbix на час деплою (30 хв). Зберігає maintenanceId для cleanup.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=&quot;https://zabbix.dobrom.com/api_jsonrpc.php&quot;" target="url" />
          <zeebe:input source="={&quot;Authorization&quot;: &quot;Bearer &quot; + secrets.ZABBIX_API_TOKEN, &quot;Content-Type&quot;: &quot;application/json-rpc&quot;}" target="headers" />
          <zeebe:input source="={jsonrpc: &quot;2.0&quot;, method: &quot;maintenance.create&quot;, params: {name: &quot;deploy-&quot; + string(processInstanceKey), active_since: (now() - date and time(&quot;1970-01-01T00:00:00Z&quot;)) / duration(&quot;PT1S&quot;), active_till: (now() - date and time(&quot;1970-01-01T00:00:00Z&quot;)) / duration(&quot;PT1S&quot;) + 1500, maintenance_type: 0, tags_evaltype: 0, hosts: [{hostid: &quot;10966&quot;}, {hostid: &quot;10967&quot;}, {hostid: &quot;10968&quot;}], timeperiods: [{timeperiod_type: 0, start_date: (now() - date and time(&quot;1970-01-01T00:00:00Z&quot;)) / duration(&quot;PT1S&quot;), period: 1500}]}, id: 1}" target="body" />
          <zeebe:input source="=&quot;zabbixCreateResponse&quot;" target="resultVariable" />
          <zeebe:input source="={maintenanceId: response.body.result.maintenanceids[1]}" target="resultExpression" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_start_to_zabbix</bpmn:incoming>
      <bpmn:outgoing>f_zabbix_to_deploy</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── 3. Call deploy-process ─────────────────────── -->
    <bpmn:callActivity id="call_deploy_prod" name="Деплой на production">
      <bpmn:documentation>Call Activity: deploy-process для production server. Повертає has_changes, old_commit, new_commit.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:calledElement processId="deploy-process" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;production&quot;" target="server_host" />
          <zeebe:input source="=&quot;main&quot;" target="branch" />
          <zeebe:input source="=true" target="run_smoke_test" />
          <zeebe:input source="=&quot;light&quot;" target="test_mode" />
          <zeebe:input source="=&quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="odoo_webhook_url" />
          <zeebe:input source="=560" target="odoo_project_id" />
          <zeebe:output source="=if is defined(has_changes) and has_changes != null then has_changes else false" target="has_changes" />
          <zeebe:output source="=if is defined(old_commit) and old_commit != null then old_commit else &quot;none&quot;" target="old_commit" />
          <zeebe:output source="=if is defined(new_commit) and new_commit != null then new_commit else &quot;none&quot;" target="new_commit" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_zabbix_to_deploy</bpmn:incoming>
      <bpmn:outgoing>f_deploy_to_delete</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- ── 3a. Deploy error → delete maintenance → end ── -->
    <bpmn:boundaryEvent id="BE_deploy_error" name="Deploy failed" attachedToRef="call_deploy_prod">
      <bpmn:outgoing>f_error_to_delete_err</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDef_deploy_failed" errorRef="Error_deploy_failed" />
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="ST_zabbix_delete_error" name="Zabbix: вимкнути maintenance">
      <bpmn:documentation>Cleanup: видалити maintenance window при помилці деплою.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=&quot;https://zabbix.dobrom.com/api_jsonrpc.php&quot;" target="url" />
          <zeebe:input source="={&quot;Authorization&quot;: &quot;Bearer &quot; + secrets.ZABBIX_API_TOKEN, &quot;Content-Type&quot;: &quot;application/json-rpc&quot;}" target="headers" />
          <zeebe:input source="={jsonrpc: &quot;2.0&quot;, method: &quot;maintenance.delete&quot;, params: [maintenanceId], id: 1}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_error_to_delete_err</bpmn:incoming>
      <bpmn:outgoing>f_delete_err_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="evt_end_deploy_failed" name="Deploy failed — чекаємо наступну ніч">
      <bpmn:incoming>f_delete_err_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ── 4. Zabbix: Delete Maintenance (success path) ─ -->
    <bpmn:serviceTask id="ST_zabbix_delete" name="Zabbix: вимкнути maintenance">
      <bpmn:documentation>Cleanup: видалити maintenance window після завершення деплою.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=&quot;https://zabbix.dobrom.com/api_jsonrpc.php&quot;" target="url" />
          <zeebe:input source="={&quot;Authorization&quot;: &quot;Bearer &quot; + secrets.ZABBIX_API_TOKEN, &quot;Content-Type&quot;: &quot;application/json-rpc&quot;}" target="headers" />
          <zeebe:input source="={jsonrpc: &quot;2.0&quot;, method: &quot;maintenance.delete&quot;, params: [maintenanceId], id: 1}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_deploy_to_delete</bpmn:incoming>
      <bpmn:outgoing>f_delete_to_gw</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── 5. Check changes ──────────────────────────── -->
    <bpmn:exclusiveGateway id="GW_has_changes" name="Є зміни?" default="f_has_changes">
      <bpmn:incoming>f_delete_to_gw</bpmn:incoming>
      <bpmn:outgoing>f_has_changes</bpmn:outgoing>
      <bpmn:outgoing>f_no_changes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ── 5a. No changes → END ──────────────────────── -->
    <bpmn:endEvent id="evt_end_no_changes" name="Без змін">
      <bpmn:incoming>f_no_changes</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ── 6. Extract PR numbers ─────────────────────── -->
    <bpmn:serviceTask id="ST_extract_prs" name="Витягти номери PR">
      <bpmn:documentation>SSH на production, git log old..new, парсить PR номери.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="extract-deployed-prs" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=old_commit" target="old_commit" />
          <zeebe:input source="=new_commit" target="new_commit" />
          <zeebe:input source="=&quot;production&quot;" target="server_host" />
          <zeebe:output source="=deployed_prs" target="deployed_prs" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_has_changes</bpmn:incoming>
      <bpmn:outgoing>f_extract_to_publish</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── 7. Publish msg_prod_deployed per PR ────────── -->
    <bpmn:serviceTask id="ST_publish_per_pr" name="Повідомити FTP про деплой">
      <bpmn:documentation>Multi-instance: для кожного PR публікує msg_prod_deployed.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="publish-message" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;msg_prod_deployed&quot;" target="message_name" />
          <zeebe:input source="=string(pr_num)" target="correlation_key" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_extract_to_publish</bpmn:incoming>
      <bpmn:outgoing>f_publish_to_end</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics>
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="=deployed_prs" inputElement="pr_num" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:serviceTask>

    <!-- ── 8. END ────────────────────────────────────── -->
    <bpmn:endEvent id="evt_end_success" name="Production задеплоєно">
      <bpmn:incoming>f_publish_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ── Sequence Flows ────────────────────────────── -->
    <bpmn:sequenceFlow id="f_start_to_zabbix" sourceRef="start_timer" targetRef="ST_zabbix_create" />
    <bpmn:sequenceFlow id="f_zabbix_to_deploy" sourceRef="ST_zabbix_create" targetRef="call_deploy_prod" />
    <bpmn:sequenceFlow id="f_error_to_delete_err" sourceRef="BE_deploy_error" targetRef="ST_zabbix_delete_error" />
    <bpmn:sequenceFlow id="f_delete_err_to_end" sourceRef="ST_zabbix_delete_error" targetRef="evt_end_deploy_failed" />
    <bpmn:sequenceFlow id="f_deploy_to_delete" sourceRef="call_deploy_prod" targetRef="ST_zabbix_delete" />
    <bpmn:sequenceFlow id="f_delete_to_gw" sourceRef="ST_zabbix_delete" targetRef="GW_has_changes" />
    <bpmn:sequenceFlow id="f_has_changes" sourceRef="GW_has_changes" targetRef="ST_extract_prs" />
    <bpmn:sequenceFlow id="f_no_changes" sourceRef="GW_has_changes" targetRef="evt_end_no_changes">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=has_changes = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_extract_to_publish" sourceRef="ST_extract_prs" targetRef="ST_publish_per_pr" />
    <bpmn:sequenceFlow id="f_publish_to_end" sourceRef="ST_publish_per_pr" targetRef="evt_end_success" />
  </bpmn:process>

  <!-- ── Diagram ───────────────────────────────────────── -->
  <!--
    Main flow (y-center=190):
      start(165) → zabbix_create(271) → call_deploy(441) → zabbix_delete(611) → GW(781) → extract(901) → publish(1071) → end(1241)
    Error path (below call_deploy):
      BE_error(473,212) → zabbix_delete_error(441,320) → end_failed(611,342)
    No-changes path:
      GW(781) → end_no_changes(788,282)
  -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_nightly_prod">
    <bpmndi:BPMNPlane id="BPMNPlane_nightly_prod" bpmnElement="production-nightly-deploy">

      <!-- Main flow -->
      <bpmndi:BPMNShape id="di_start_timer" bpmnElement="start_timer">
        <dc:Bounds x="165" y="172" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_ST_zabbix_create" bpmnElement="ST_zabbix_create">
        <dc:Bounds x="271" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_call_deploy_prod" bpmnElement="call_deploy_prod">
        <dc:Bounds x="441" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_ST_zabbix_delete" bpmnElement="ST_zabbix_delete">
        <dc:Bounds x="611" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_GW_has_changes" bpmnElement="GW_has_changes" isMarkerVisible="true">
        <dc:Bounds x="781" y="165" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_ST_extract_prs" bpmnElement="ST_extract_prs">
        <dc:Bounds x="901" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_ST_publish_per_pr" bpmnElement="ST_publish_per_pr">
        <dc:Bounds x="1071" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_evt_end_success" bpmnElement="evt_end_success">
        <dc:Bounds x="1241" y="172" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- No-changes branch -->
      <bpmndi:BPMNShape id="di_evt_end_no_changes" bpmnElement="evt_end_no_changes">
        <dc:Bounds x="788" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Error path -->
      <bpmndi:BPMNShape id="di_BE_deploy_error" bpmnElement="BE_deploy_error">
        <dc:Bounds x="473" y="212" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_ST_zabbix_delete_error" bpmnElement="ST_zabbix_delete_error">
        <dc:Bounds x="441" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_evt_end_deploy_failed" bpmnElement="evt_end_deploy_failed">
        <dc:Bounds x="611" y="342" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Main flow edges -->
      <bpmndi:BPMNEdge id="di_f_start_to_zabbix" bpmnElement="f_start_to_zabbix">
        <di:waypoint x="201" y="190" />
        <di:waypoint x="271" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f_zabbix_to_deploy" bpmnElement="f_zabbix_to_deploy">
        <di:waypoint x="371" y="190" />
        <di:waypoint x="441" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f_deploy_to_delete" bpmnElement="f_deploy_to_delete">
        <di:waypoint x="541" y="190" />
        <di:waypoint x="611" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f_delete_to_gw" bpmnElement="f_delete_to_gw">
        <di:waypoint x="711" y="190" />
        <di:waypoint x="781" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f_has_changes" bpmnElement="f_has_changes">
        <di:waypoint x="831" y="190" />
        <di:waypoint x="901" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f_no_changes" bpmnElement="f_no_changes">
        <di:waypoint x="806" y="215" />
        <di:waypoint x="806" y="282" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f_extract_to_publish" bpmnElement="f_extract_to_publish">
        <di:waypoint x="1001" y="190" />
        <di:waypoint x="1071" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f_publish_to_end" bpmnElement="f_publish_to_end">
        <di:waypoint x="1171" y="190" />
        <di:waypoint x="1241" y="190" />
      </bpmndi:BPMNEdge>

      <!-- Error path edges -->
      <bpmndi:BPMNEdge id="di_f_error_to_delete_err" bpmnElement="f_error_to_delete_err">
        <di:waypoint x="491" y="248" />
        <di:waypoint x="491" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f_delete_err_to_end" bpmnElement="f_delete_err_to_end">
        <di:waypoint x="541" y="360" />
        <di:waypoint x="611" y="360" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
