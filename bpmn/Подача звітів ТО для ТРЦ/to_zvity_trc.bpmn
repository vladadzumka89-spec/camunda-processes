      <bpmn:incoming>Flow_Receive_to_WriteTT</bpmn:incoming>
      <bpmn:outgoing>Flow_WriteTT_to_SubmitJoin</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Gateway_SubmitJoin">
      <bpmn:incoming>Flow_Upload_to_SubmitJoin</bpmn:incoming>
      <bpmn:incoming>Flow_WriteTT_to_SubmitJoin</bpmn:incoming>
