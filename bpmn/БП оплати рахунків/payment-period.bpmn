<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="e787c33" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:collaboration id="Collab_1">
    <bpmn:participant id="Pool_1" name="Оплата за період" processRef="Process_payment_period" />
  </bpmn:collaboration>
  <bpmn:process id="Process_payment_period" name="Оплата за період" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="1.0" />
    </bpmn:extensionElements>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_system" name="Система (автоматично)">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_rem</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_rem</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_pay</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_buhgalter" name="Бухгалтер">
        <bpmn:flowNodeRef>UT_confirm</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_manager" name="Керівник (ескалація)">
        <bpmn:flowNodeRef>UT_esc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_esc</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_1" name="Старт">
      <bpmn:outgoing>Flow_start_to_confirm</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UT_confirm" name="Підтвердити оплати за період">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Підтвердити оплати ФОП за період &#34; + payment_period, description: &#34;Перегляньте та підтвердіть планові оплати ФОП за період &#34; + payment_period, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_start_to_confirm</bpmn:incoming>
      <bpmn:outgoing>Flow_confirm_to_pay</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="BE_rem" name="Нагадування" cancelActivity="false" attachedToRef="UT_confirm">
      <bpmn:outgoing>Flow_rem</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_rem">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT4H</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BE_ded" name="Дедлайн" cancelActivity="false" attachedToRef="UT_confirm">
      <bpmn:outgoing>Flow_ded</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_ded">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="ST_rem" name="Нагадування: підтвердити оплати">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;⚠️ НАГАДУВАННЯ: Підтвердити оплати ФОП за період &#34; + payment_period, description: &#34;Бухгалтер ще не підтвердив оплати ФОП за період &#34; + payment_period + &#34;. Будь ласка, підтвердіть планові оплати.&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_rem</bpmn:incoming>
      <bpmn:outgoing>Flow_rem_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_rem">
      <bpmn:incoming>Flow_rem_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_1" name="Оплати виконано">
      <bpmn:incoming>Flow_pay_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="UT_esc" name="🔴 ЕСКАЛАЦІЯ: Оплати не підтверджено">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;🔴 ЕСКАЛАЦІЯ: Оплати ФОП не підтверджено за період &#34; + payment_period, description: &#34;Бухгалтер не підтвердив оплати ФОП за період &#34; + payment_period + &#34; протягом 3 днів. Потрібне втручання керівника.&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ded</bpmn:incoming>
      <bpmn:outgoing>Flow_esc_end</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_esc">
      <bpmn:incoming>Flow_esc_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_start_to_confirm" sourceRef="Start_1" targetRef="UT_confirm" />
    <bpmn:sequenceFlow id="Flow_confirm_to_pay" sourceRef="UT_confirm" targetRef="ST_pay" />
    <bpmn:sequenceFlow id="Flow_pay_to_end" sourceRef="ST_pay" targetRef="End_1" />
    <bpmn:sequenceFlow id="Flow_rem" sourceRef="BE_rem" targetRef="ST_rem" />
    <bpmn:sequenceFlow id="Flow_rem_end" sourceRef="ST_rem" targetRef="End_rem" />
    <bpmn:sequenceFlow id="Flow_ded" sourceRef="BE_ded" targetRef="UT_esc" />
    <bpmn:sequenceFlow id="Flow_esc_end" sourceRef="UT_esc" targetRef="End_esc" />
    <bpmn:serviceTask id="ST_pay" name="Створити платіжні доручення">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Створити платіжні доручення за період &#34; + payment_period, description: &#34;Оплати ФОП за період &#34; + payment_period + &#34; підтверджено. Створюємо платіжні доручення.&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_confirm_to_pay</bpmn:incoming>
      <bpmn:outgoing>Flow_pay_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collab_1">
      <bpmndi:BPMNShape id="Pool_1_di" bpmnElement="Pool_1" isHorizontal="true">
