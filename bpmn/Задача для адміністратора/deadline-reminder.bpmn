<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="e787c33" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="deadline-reminder" name="Нагадування про дедлайн" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Задача створена">
      <bpmn:outgoing>Flow_start_to_timer</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:intermediateCatchEvent id="Timer_2h_before_deadline" name="Чекати до 2 год перед дедлайном">
      <bpmn:incoming>Flow_start_to_timer</bpmn:incoming>
      <bpmn:incoming>Flow_postpone_back_to_timer</bpmn:incoming>
      <bpmn:outgoing>Flow_timer_to_send_notification</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1">
        <bpmn:timeDate xsi:type="bpmn:tFormalExpression">
          = if current_deadline != null then date and time(current_deadline) - duration("PT2H") else date and time(deadline) - duration("PT2H")
        </bpmn:timeDate>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Service_send_notification" name="Надіслати нагадування працівнику">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/ВСТАВТЕ_ВАШ_WEBHOOK_ID_ДЛЯ_НАГАДУВАННЯ&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {&#10;  task_id: task_id,&#10;  assignee_id: assignee_id,&#10;  message: &#34;⏰ Нагадуємо! Через 2 години у вас закінчується дедлайн до задачі &#39;&#34; + task_name + &#34;&#39;. Будь ласка, завершіть її вчасно.&#34;,&#10;  model: &#34;project.task&#34;,&#10;  _id: task_id,&#10;  process_instance_key: process_instance_key&#10;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_timer_to_send_notification</bpmn:incoming>
      <bpmn:outgoing>Flow_notification_to_user_task</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="UserTask_decision" name="Задача &#34;Виконати або відкласти&#34;">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/ВСТАВТЕ_ВАШ_WEBHOOK_ID_ДЛЯ_USER_TASK&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {&#10;  name: &#34;Дедлайн наближається: &#34; + task_name,&#10;  description: &#34;&#60;p&#62;⏰ Через 2 години закінчується дедлайн до задачі &#60;b&#62;&#34; + task_name + &#34;&#60;/b&#62;.&#60;/p&#62;&#60;p&#62;Оберіть дію: виконати задачу або відкласти.&#60;/p&#62;&#34;,&#10;  model: &#34;project.task&#34;,&#10;  _id: task_id,&#10;  x_studio_camunda_user_ids: assignee_id,&#10;  process_instance_key: process_instance_key&#10;}" target="body" />
        </zeebe:ioMapping>
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="3" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_notification_to_user_task</bpmn:incoming>
      <bpmn:outgoing>Flow_user_task_to_gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_decision" name="Що обрав працівник?">
      <bpmn:incoming>Flow_user_task_to_gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_gateway_to_complete</bpmn:outgoing>
      <bpmn:outgoing>Flow_gateway_to_postpone</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_completed" name="Задачу виконано">
      <bpmn:incoming>Flow_gateway_to_complete</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Service_update_postponed" name="Оновити Odoo: відкладено до">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/ВСТАВТЕ_ВАШ_WEBHOOK_ID_ДЛЯ_ОНОВЛЕННЯ&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {&#10;  model: &#34;project.task&#34;,&#10;  _id: task_id,&#10;  x_studio_camunda_postponed_until: new_deadline,&#10;  process_instance_key: process_instance_key&#10;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_gateway_to_postpone</bpmn:incoming>
      <bpmn:outgoing>Flow_postpone_back_to_timer</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_start_to_timer" sourceRef="StartEvent_1" targetRef="Timer_2h_before_deadline" />
    <bpmn:sequenceFlow id="Flow_timer_to_send_notification" sourceRef="Timer_2h_before_deadline" targetRef="Service_send_notification" />
    <bpmn:sequenceFlow id="Flow_notification_to_user_task" sourceRef="Service_send_notification" targetRef="UserTask_decision" />
    <bpmn:sequenceFlow id="Flow_user_task_to_gateway" sourceRef="UserTask_decision" targetRef="Gateway_decision" />
    <bpmn:sequenceFlow id="Flow_gateway_to_complete" name="Виконати" sourceRef="Gateway_decision" targetRef="EndEvent_completed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
        = action = "complete"
      </bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_gateway_to_postpone" name="Відкласти" sourceRef="Gateway_decision" targetRef="Service_update_postponed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
        = action = "postpone"
      </bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_postpone_back_to_timer" sourceRef="Service_update_postponed" targetRef="Timer_2h_before_deadline" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="deadline-reminder">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="128" y="275" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Timer_2h_before_deadline_di" bpmnElement="Timer_2h_before_deadline">
        <dc:Bounds x="272" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="229" y="180" width="81" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Service_send_notification_di" bpmnElement="Service_send_notification">
        <dc:Bounds x="390" y="210" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_decision_di" bpmnElement="UserTask_decision">
        <dc:Bounds x="570" y="210" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_decision_di" bpmnElement="Gateway_decision" isMarkerVisible="true">
        <dc:Bounds x="755" y="225" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="735" y="195" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_completed_di" bpmnElement="EndEvent_completed">
        <dc:Bounds x="892" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="868" y="275" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Service_update_postponed_di" bpmnElement="Service_update_postponed">
        <dc:Bounds x="730" y="370" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_to_timer_di" bpmnElement="Flow_start_to_timer">
        <di:waypoint x="188" y="250" />
        <di:waypoint x="272" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_timer_to_send_notification_di" bpmnElement="Flow_timer_to_send_notification">
        <di:waypoint x="308" y="250" />
        <di:waypoint x="390" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_notification_to_user_task_di" bpmnElement="Flow_notification_to_user_task">
        <di:waypoint x="490" y="250" />
        <di:waypoint x="570" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_user_task_to_gateway_di" bpmnElement="Flow_user_task_to_gateway">
        <di:waypoint x="670" y="250" />
        <di:waypoint x="755" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_gateway_to_complete_di" bpmnElement="Flow_gateway_to_complete">
        <di:waypoint x="805" y="250" />
        <di:waypoint x="892" y="250" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="825" y="232" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_gateway_to_postpone_di" bpmnElement="Flow_gateway_to_postpone">
        <di:waypoint x="780" y="275" />
        <di:waypoint x="780" y="370" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="790" y="315" width="55" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_postpone_back_to_timer_di" bpmnElement="Flow_postpone_back_to_timer">
        <di:waypoint x="730" y="410" />
        <di:waypoint x="290" y="410" />
        <di:waypoint x="290" y="268" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
