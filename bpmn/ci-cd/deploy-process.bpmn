      <bpmndi:BPMNShape id="ST_publish_deploy_done_di" bpmnElement="ST_publish_deploy_done">
        <dc:Bounds x="3685" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="evt_end_success_di" bpmnElement="evt_end_success">
        <dc:Bounds x="3865" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <!-- ═══ EDGES ═══ -->
      <!-- Error subprocess -->
      <bpmndi:BPMNEdge id="f_err_to_odoo_di" bpmnElement="f_err_to_odoo">
        <di:waypoint x="196" y="80" />
        <di:waypoint x="260" y="80" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_err_odoo_to_rollback_di" bpmnElement="f_err_odoo_to_rollback">
        <di:waypoint x="360" y="80" />
        <di:waypoint x="440" y="80" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_err2_di" bpmnElement="f_err2">
        <di:waypoint x="540" y="80" />
        <di:waypoint x="620" y="80" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_err3_di" bpmnElement="f_err3">
        <di:waypoint x="720" y="80" />
        <di:waypoint x="800" y="80" />
      </bpmndi:BPMNEdge>
      <!-- Start → merge -->
      <bpmndi:BPMNEdge id="f01_di" bpmnElement="f01">
        <di:waypoint x="196" y="250" />
        <di:waypoint x="295" y="250" />
        <di:waypoint x="295" y="275" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f01_msg_di" bpmnElement="f01_msg">
        <di:waypoint x="196" y="350" />
        <di:waypoint x="295" y="350" />
        <di:waypoint x="295" y="325" />
      </bpmndi:BPMNEdge>
      <!-- Parent check diamond -->
      <bpmndi:BPMNEdge id="f_start_to_parent_check_di" bpmnElement="f_start_to_parent_check">
        <di:waypoint x="320" y="300" />
        <di:waypoint x="400" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_has_parent_di" bpmnElement="f_has_parent">
        <di:waypoint x="425" y="275" />
        <di:waypoint x="425" y="200" />
        <di:waypoint x="525" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_no_parent_di" bpmnElement="f_no_parent">
        <di:waypoint x="450" y="300" />
        <di:waypoint x="525" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_subtask_to_merge_di" bpmnElement="f_subtask_to_merge">
        <di:waypoint x="625" y="200" />
        <di:waypoint x="755" y="200" />
        <di:waypoint x="755" y="275" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_created_to_merge_di" bpmnElement="f_created_to_merge">
        <di:waypoint x="625" y="300" />
        <di:waypoint x="730" y="300" />
      </bpmndi:BPMNEdge>
      <!-- Checkpoint → git pull → changes -->
      <bpmndi:BPMNEdge id="f01_merged_di" bpmnElement="f01_merged">
        <di:waypoint x="780" y="300" />
        <di:waypoint x="855" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_checkpoint_to_pull_di" bpmnElement="f_checkpoint_to_pull">
        <di:waypoint x="955" y="300" />
        <di:waypoint x="1035" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f02_di" bpmnElement="f02">
        <di:waypoint x="1135" y="300" />
        <di:waypoint x="1240" y="300" />
      </bpmndi:BPMNEdge>
      <!-- Changes: no changes (upper) / detect modules (main) -->
      <bpmndi:BPMNEdge id="f03_di" bpmnElement="f03">
        <di:waypoint x="1265" y="275" />
        <di:waypoint x="1265" y="200" />
        <di:waypoint x="1345" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f03_to_end_di" bpmnElement="f03_to_end">
