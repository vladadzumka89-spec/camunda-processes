    <bpmn:serviceTask id="Activity_0yx0iju" name="Отримати список адміністраторів в Оду">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;https://o.tut.ua/api/server-action&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;,&#10;&#34;X-API-Key&#34;:&#34;632b5ed6-091f-48db-bd01-1e60aeb10bfc&#34;}" target="headers" />
          <zeebe:input source="={&#10;  &#34;action_identifier&#34;: &#34;studio_customization._4df8b2ca-76eb-4bef-bd5c-1597a406825b&#34;,&#10;  &#34;context&#34;: {},&#10;  &#34;payload&#34;: {&#10;    &#34;groups&#34;: [if x_studio_camunda_famo = true then 600 else if x_studio_camunda_technoprostir = true then 500 else if x_studio_camunda_pinky = true then 900 else 0]&#10;  }&#10;}" target="body" />
          <zeebe:input source="=&#34;result&#34;" target="result_variable_name" />
          <zeebe:output source="=result.data.data" target="employees" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0zu401u</bpmn:incoming>
      <bpmn:incoming>Flow_178ii0a</bpmn:incoming>
      <bpmn:outgoing>Flow_1sygqsb</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_1abeljt" name="Задача &#34;Задача для адміністратора&#34;">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="3" type="http-request-smart" />
        </zeebe:taskListeners>
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Задача для адміністратора&#34; + emp.employee_name, &#10; description: &#34;Опис задачі&#34;,&#10;_model: &#34;project.project&#34;,&#10; x_studio_camunda_user_id: emp.user_id,&#10;_id: 252}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1sygqsb</bpmn:incoming>
      <bpmn:outgoing>Flow_137ysju</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics>
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="=employees" inputElement="emp" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1sygqsb" sourceRef="Activity_0yx0iju" targetRef="Activity_1abeljt" />
