      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="Service_notify_2h" name="⏰ Надіслати нагадування працівнику">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;https://o.tut.ua/web/hook/1ba7c970-a3b5-4e99-b5ed-c9c1b7032dda&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={&#10;  _model: &#34;project.task&#34;,&#10;  _id: odoo_task_id,&#10;  message: &#34;⏰ Нагадуємо! Через 2 години у вас закінчується дедлайн. Будь ласка, завершіть задачу вчасно.&#34;&#10;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2h_to_notify</bpmn:incoming>
      <bpmn:outgoing>Flow_2h_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_reminder">
      <bpmn:incoming>Flow_2h_to_end</bpmn:incoming>
