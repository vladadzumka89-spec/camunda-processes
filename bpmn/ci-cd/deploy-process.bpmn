      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_publish_to_end_di" bpmnElement="f_publish_to_end">
        <di:waypoint x="3785" y="300" />
        <di:waypoint x="3865" y="300" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
