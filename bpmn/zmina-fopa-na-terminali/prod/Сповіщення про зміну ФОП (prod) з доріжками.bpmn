    <bpmn:serviceTask id="Activity_1cqrobx" name="Створити головне завдання">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Зміна ФОП на терміналі: &#34; + fop_name, description: &#34;&#60;b&#62;ФОП:&#60;/b&#62; &#34; + fop_name + &#34; (ЄДРПОУ: &#34; + fop_edrpou + &#34;)&#60;br/&#62;&#60;b&#62;Група ЄП:&#60;/b&#62; &#34; + string(ep_group) + &#34;&#60;br/&#62;&#60;b&#62;Дохід за рік:&#60;/b&#62; &#34; + string(total_income) + &#34; грн (&#34; + string(income_percent) + &#34;% від ліміту &#34; + string(limit_amount) + &#34; грн)&#60;br/&#62;&#60;b&#62;Днів до ліміту:&#60;/b&#62; &#34; + string(days_to_limit) + &#34;&#60;br/&#62;&#60;b&#62;Прогнозна дата:&#60;/b&#62; &#34; + projected_date + &#34;&#60;br/&#62;&#60;b&#62;К-сть працівників на ФОП:&#60;/b&#62; &#34; + string(employee_count) + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;Магазини:&#60;/b&#62;&#60;br/&#62;&#34; + stores, create_process: true, _model: &#34;project.project&#34;, _id: 524, bpmn_process_id: &#34;Process_rebvtea&#34;, x_studio_camunda_fop_name: fop_name, x_studio_camunda_total_income: total_income, x_studio_camunda_days_to_limit: days_to_limit, process_instance_key: process_instance_key, x_studio_camunda_edrpou: fop_edrpou, x_studio_camunda_role_code: &#34;accountant&#34;}" target="body" />
          <zeebe:input source="= &#34;odoo_response&#34;" target="result_variable_name" />
          <zeebe:output source="= string(odoo_response.id)" target="odoo_task_id" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0j0ehf2</bpmn:incoming>
      <bpmn:outgoing>Flow_08sqmwa</bpmn:outgoing>
