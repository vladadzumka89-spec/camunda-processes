<?xml version="1.0" encoding="UTF-8"?>
<definitions
  xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
  xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
  xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
  xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
  id="Definitions_invoice_drg"
  name="Деталізація та класифікація рахунків"
  namespace="http://camunda.org/schema/1.0/dmn"
  exporter="Camunda Web Modeler"
  exporterVersion="e787c33"
  modeler:executionPlatform="Camunda Cloud"
  modeler:executionPlatformVersion="8.8.0">

  <!--
    DRG — Decision Requirement Graph
    =================================

    П'ять рішень:

      ┌─────────────────────────────────────────────┐
      │  Класифікація комунальних послуг             │
      │  (utility-expense-classification)            │
      │  Вхід: назва послуги + тип рахунку           │
      │  Вихід: стаття витрат                        │
      └──────────────────┬──────────────────────────┘
                         │ informationRequirement
                         ▼
      ┌─────────────────────────────────────────────┐
      │  Деталізація рахунків                        │
      │  (invoice-detail-type)                       │
      │  Вхід: назва позиції + постачальник           │
      │  Вихід: тип рахунку (оренда / комунальні)    │
      └──────────────────┬──────────────────────────┘
                         │ informationRequirement
                         ▼
      ┌─────────────────────────────────────────────┐
      │  Визначення погоджувача рахунку              │
      │  (decision-1goz4yx)                          │
      │  Вхід: тип рахунку + сума                    │
      │  Вихід: роль погоджувача                     │
      └─────────────────────────────────────────────┘

    Автономне рішення:
      ┌─────────────────────────────────────────────┐
      │  Чи надає ТРЦ деталізацію комунальних?       │
      │  (supplier-detailization)                    │
      │  Вхід: назва постачальника                   │
      │  Вихід: boolean (надає / не надає)           │
      └─────────────────────────────────────────────┘

    Як працює в BPMN:
      1. Бухгалтер розбиває PDF-рахунок на позиції
      2. Для кожної позиції: BPMN викликає invoice-detail-type
         → визначає оренда / комунальні
      3. Якщо комунальні: BPMN отримує розшифровку послуг
         → викликає utility-expense-classification для кожної послуги
         → Camunda автоматично оцінює invoice-detail-type спочатку (DRG)
         → потім класифікує послугу за статтею витрат

    Вхідні змінні (процес має надати всі):
      - x_studio_camunda_invoice_line_name — назва позиції з рахунку
      - x_studio_camunda_partner_name      — назва постачальника
      - x_studio_camunda_service_name      — назва послуги з розшифровки

    Вихідні змінні:
      - x_studio_camunda_invoice_type      — "оренда" або "комунальні"
      - x_studio_camunda_invoice_notes     — підказка для бухгалтера
      - x_studio_camunda_expense_category  — стаття витрат в 1С
  -->

  <!-- ═══════════════════════════════════════════════════════════════════════
       РІШЕННЯ 1: Деталізація рахунків (оренда / комунальні)
       ═══════════════════════════════════════════════════════════════════════ -->

  <decision id="invoice-detail-type" name="Деталізація рахунків">
    <decisionTable id="decisionTable_invoice_detail" hitPolicy="FIRST">

      <!-- ── INPUTS ──────────────────────────────────────────────────────── -->

      <input id="input_line_name" label="Назва позиції рахунку">
        <inputExpression id="inputExpr_line_name" typeRef="string">
          <text>lower case(x_studio_camunda_invoice_line_name)</text>
        </inputExpression>
      </input>

      <input id="input_partner" label="Постачальник">
        <inputExpression id="inputExpr_partner" typeRef="string">
          <text>x_studio_camunda_partner_name</text>
        </inputExpression>
      </input>

      <!-- ── OUTPUTS ─────────────────────────────────────────────────────── -->

      <output id="output_invoice_type"
              label="Вид рахунку"
              name="x_studio_camunda_invoice_type"
              typeRef="string">
        <outputValues id="outputValues_type">
          <text>"оренда","комунальні"</text>
        </outputValues>
      </output>

      <output id="output_notes"
              label="Примітки"
              name="x_studio_camunda_invoice_notes"
              typeRef="string" />

      <!-- ═════════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: Герман Олена Василівна
           Контрагент 1: Стецюк Ірина Олександрівна
           Підрозділ:    906
           4 рахунки в одному PDF, один йде на погодження до Юлі,
           решта тільки до регіональних
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_german_suborenda">
        <description>Герман: Суборенда приміщення — оренда</description>
        <inputEntry id="ie_german_sub"><text>contains(?, "суборенда приміщення")</text></inputEntry>
        <inputEntry id="ie_german_sub_p"><text>"Герман Олена Василівна"</text></inputEntry>
        <outputEntry id="oe_german_sub_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_german_sub_notes"><text>"договір не вказаний, прописано pinky"</text></outputEntry>
      </rule>

      <rule id="rule_german_ekspl">
        <description>Герман: Експлуатаційна суборендна плата — комунальні</description>
        <inputEntry id="ie_german_ekspl"><text>contains(?, "експлуатаційна суборендна плата")</text></inputEntry>
        <inputEntry id="ie_german_ekspl_p"><text>"Герман Олена Василівна"</text></inputEntry>
        <outputEntry id="oe_german_ekspl_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_german_ekspl_notes"><text>"місяць оплати беру з рахунку на оренду"</text></outputEntry>
      </rule>

      <rule id="rule_german_market">
        <description>Герман: Маркетингова суборендна плата — комунальні</description>
        <inputEntry id="ie_german_market"><text>contains(?, "маркетингова суборендна плата")</text></inputEntry>
        <inputEntry id="ie_german_market_p"><text>"Герман Олена Василівна"</text></inputEntry>
        <outputEntry id="oe_german_market_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_german_market_notes"><text>"місяць оплати беру з рахунку на оренду"</text></outputEntry>
      </rule>

      <rule id="rule_german_reklam">
        <description>Герман: Розміщення рекламного матеріалу — комунальні</description>
        <inputEntry id="ie_german_reklam"><text>contains(?, "розміщення рекламного матеріалу")</text></inputEntry>
        <inputEntry id="ie_german_reklam_p"><text>"Герман Олена Василівна"</text></inputEntry>
        <outputEntry id="oe_german_reklam_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_german_reklam_notes"><text>""</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: ЛЬВІВБУДМАКС-ІНВЕСТ, ТЗОВ
           Контрагент 1: Технопростір Плюс
           Підрозділ:    605
           3 послуги в одному рахунку (оренда/експлуатація/маркетинг)
           Не вказано за який місяць — визначаю по даті виставлення
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_lviv_orenda">
        <description>ЛЬВІВБУДМАКС: Оренда нерухомого майна — оренда</description>
        <inputEntry id="ie_lviv_orenda"><text>contains(?, "оренда нерухомого майна")</text></inputEntry>
        <inputEntry id="ie_lviv_orenda_p"><text>"ЛЬВІВБУДМАКС-ІНВЕСТ, ТЗОВ"</text></inputEntry>
        <outputEntry id="oe_lviv_orenda_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_lviv_orenda_notes"><text>"місяць оренди визначаю по даті виставлення рахунку"</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: Сільпо фуд
           Контрагент 1: Технопростір Плюс
           Підрозділ:    909
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_silpo_komunal">
        <description>Сільпо фуд: Оплата комунальних — комунальні</description>
        <inputEntry id="ie_silpo_komunal"><text>contains(?, "оплата комунальних")</text></inputEntry>
        <inputEntry id="ie_silpo_komunal_p"><text>"Сільпо фуд"</text></inputEntry>
        <outputEntry id="oe_silpo_komunal_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_silpo_komunal_notes"><text>"деталізація комунальних в окремому документі"</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: Житомирський меблевий комбінат
           Контрагент 1: техно простір / Технопростір Плюс
           Підрозділи:   507 (оренда+рекл.), 508 (рекл.), 509 (комунальні)
                         908/602 — 4 рахунки та акти в одному PDF + акти
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_zhk_orenda">
        <description>ЖМК: Орендна плата — оренда</description>
        <inputEntry id="ie_zhk_orenda"><text>contains(?, "орендна плата")</text></inputEntry>
        <inputEntry id="ie_zhk_orenda_p"><text>"Житомирський меблевий комбінат"</text></inputEntry>
        <outputEntry id="oe_zhk_orenda_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_zhk_orenda_notes"><text>""</text></outputEntry>
      </rule>

      <rule id="rule_zhk_reklam">
        <description>ЖМК: Рекламні послуги — оренда (входить до орендного пакету)</description>
        <inputEntry id="ie_zhk_reklam"><text>contains(?, "рекламні послуги")</text></inputEntry>
        <inputEntry id="ie_zhk_reklam_p"><text>"Житомирський меблевий комбінат"</text></inputEntry>
        <outputEntry id="oe_zhk_reklam_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_zhk_reklam_notes"><text>""</text></outputEntry>
      </rule>

      <rule id="rule_zhk_komunal">
        <description>ЖМК: Компенсація комунальних послуг — комунальні</description>
        <inputEntry id="ie_zhk_komunal"><text>contains(?, "компенсація комунальних")</text></inputEntry>
        <inputEntry id="ie_zhk_komunal_p"><text>"Житомирський меблевий комбінат"</text></inputEntry>
        <outputEntry id="oe_zhk_komunal_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_zhk_komunal_notes"><text>""</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: Логістик Ультра-плюс
           Контрагент 1: Технопростір Плюс
           Підрозділ:    ?
           NB: не вказано за який місяць рахунок, тип та ключове слово
               відсутні — правило буде додано коли дані будуть доповнені
           ═════════════════════════════════════════════════════════════════ -->

      <!-- ═════════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: ФОП Боднарчук Максим Олександрович
           Контрагент 1: Козак Василь Миколайович
           Підрозділ:    505
           Контрагент вказаний в акті нижче рахунку, погоджує Сергій
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_bodnarchuk_orenda">
        <description>Боднарчук: Оренда приміщення — оренда</description>
        <inputEntry id="ie_bodnarchuk_orenda"><text>contains(?, "оренда приміщення")</text></inputEntry>
        <inputEntry id="ie_bodnarchuk_orenda_p"><text>"ФОП Боднарчук Максим Олександрович"</text></inputEntry>
        <outputEntry id="oe_bodnarchuk_orenda_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_bodnarchuk_orenda_notes"><text>"контрагент вказаний в акті нижче рахунку, погоджує Сергій"</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: ВД Текстиль
           Контрагент 1: Технопростір Плюс
           Підрозділ:    404
           Фото рахунку поганої якості, два договори оренди
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_vd_orenda">
        <description>ВД Текстиль: Договір оренди — оренда</description>
        <inputEntry id="ie_vd_orenda"><text>contains(?, "договір оренди")</text></inputEntry>
        <inputEntry id="ie_vd_orenda_p"><text>"ВД Текстиль"</text></inputEntry>
        <outputEntry id="oe_vd_orenda_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_vd_orenda_notes"><text>"фото рахунку поганої якості"</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: ЛЮБАВА СІТІ ТОВ
           Контрагент 1: Технопростір Плюс
           Підрозділи:   915 (40 м.кв.), 670 (76.9 м.кв.)
           Підрозділ визначається по площі
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_lubava_market">
        <description>ЛЮБАВА СІТІ: Послуги з маркетингу — оренда</description>
        <inputEntry id="ie_lubava_market"><text>contains(?, "послуги з маркетингу")</text></inputEntry>
        <inputEntry id="ie_lubava_market_p"><text>"ЛЮБАВА СІТІ ТОВ"</text></inputEntry>
        <outputEntry id="oe_lubava_market_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_lubava_market_notes"><text>"визначаю підрозділ по площі: 40 м.кв.=915, 76.9 м.кв.=670"</text></outputEntry>
      </rule>

      <rule id="rule_lubava_ekspl">
        <description>ЛЮБАВА СІТІ: Експлуатаційні витрати — оренда</description>
        <inputEntry id="ie_lubava_ekspl"><text>contains(?, "експлуатаційні витрати")</text></inputEntry>
        <inputEntry id="ie_lubava_ekspl_p"><text>"ЛЮБАВА СІТІ ТОВ"</text></inputEntry>
        <outputEntry id="oe_lubava_ekspl_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_lubava_ekspl_notes"><text>"визначаю підрозділ по площі: 40 м.кв.=915, 76.9 м.кв.=670"</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: Кропперс груп
           Контрагент 1: Дзісь Ольга Володимирівна
           Підрозділ:    646
           Виставляють рахунок на ДИКА О замість Дзісь О
           ═════════════════════════════════════════════════════════════════ -->

      <!-- Суборенда → оренда -->
      <rule id="rule_kroppers_suborenda">
        <description>Кропперс: Суборенда — оренда</description>
        <inputEntry id="ie_kroppers_sub"><text>contains(?, "суборенда")</text></inputEntry>
        <inputEntry id="ie_kroppers_sub_p"><text>"Кропперс груп"</text></inputEntry>
        <outputEntry id="oe_kroppers_sub_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_kroppers_sub_notes"><text>"виставляють рахунок на ДИКА О замість Дзісь О"</text></outputEntry>
      </rule>

      <!-- Сервісне обслуговування → оренда -->
      <rule id="rule_kroppers_servis">
        <description>Кропперс: Сервісне обслуговування — оренда</description>
        <inputEntry id="ie_kroppers_servis"><text>contains(?, "сервісне обслуговування")</text></inputEntry>
        <inputEntry id="ie_kroppers_servis_p"><text>"Кропперс груп"</text></inputEntry>
        <outputEntry id="oe_kroppers_servis_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_kroppers_servis_notes"><text>""</text></outputEntry>
      </rule>

      <!-- Маркетингові послуги → оренда (НЕ комунальні, на відміну від Герман!) -->
      <rule id="rule_kroppers_market">
        <description>Кропперс: Маркетингові послуги — оренда (входить до орендного пакету)</description>
        <inputEntry id="ie_kroppers_market"><text>contains(?, "маркетингові послуги")</text></inputEntry>
        <inputEntry id="ie_kroppers_market_p"><text>"Кропперс груп"</text></inputEntry>
        <outputEntry id="oe_kroppers_market_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_kroppers_market_notes"><text>""</text></outputEntry>
      </rule>

      <!-- Відшкодування ком.послуг (4 види: ел., реактивна ел., вода, опалення) → комунальні -->
      <rule id="rule_kroppers_komunal">
        <description>Кропперс: Відшкодування ком.послуг — комунальні</description>
        <inputEntry id="ie_kroppers_komunal"><text>contains(?, "відшкодування ком.послуг")</text></inputEntry>
        <inputEntry id="ie_kroppers_komunal_p"><text>"Кропперс груп"</text></inputEntry>
        <outputEntry id="oe_kroppers_komunal_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_kroppers_komunal_notes"><text>""</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           ЗАГАЛЬНІ ПРАВИЛА (catch-all)
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_fallback_orenda">
        <description>Загальне: будь-яка позиція зі словом "оренд" — оренда</description>
        <inputEntry id="ie_fb_orenda"><text>contains(?, "оренд")</text></inputEntry>
        <inputEntry id="ie_fb_orenda_p"><text></text></inputEntry>
        <outputEntry id="oe_fb_orenda_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_fb_orenda_notes"><text>"постачальник не знайдений в DMN — перевірте вручну"</text></outputEntry>
      </rule>

      <rule id="rule_fallback_komunal">
        <description>Загальне: будь-яка позиція зі словом "комунальн" — комунальні</description>
        <inputEntry id="ie_fb_komunal"><text>contains(?, "комунальн")</text></inputEntry>
        <inputEntry id="ie_fb_komunal_p"><text></text></inputEntry>
        <outputEntry id="oe_fb_komunal_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_fb_komunal_notes"><text>"постачальник не знайдений в DMN — перевірте вручну"</text></outputEntry>
      </rule>

      <rule id="rule_fallback_ekspl">
        <description>Загальне: будь-яка позиція зі словом "експлуатаці" — комунальні</description>
        <inputEntry id="ie_fb_ekspl"><text>contains(?, "експлуатаці")</text></inputEntry>
        <inputEntry id="ie_fb_ekspl_p"><text></text></inputEntry>
        <outputEntry id="oe_fb_ekspl_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_fb_ekspl_notes"><text>"постачальник не знайдений в DMN — перевірте вручну"</text></outputEntry>
      </rule>

      <rule id="rule_fallback_suborenda">
        <description>Загальне: будь-яка позиція зі словом "суборенд" — оренда</description>
        <inputEntry id="ie_fb_suborenda"><text>contains(?, "суборенд")</text></inputEntry>
        <inputEntry id="ie_fb_suborenda_p"><text></text></inputEntry>
        <outputEntry id="oe_fb_suborenda_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_fb_suborenda_notes"><text>"постачальник не знайдений в DMN — перевірте вручну"</text></outputEntry>
      </rule>

      <rule id="rule_fallback_vidshkod">
        <description>Загальне: будь-яке відшкодування ком.послуг — комунальні</description>
        <inputEntry id="ie_fb_vidshkod"><text>contains(?, "відшкодування ком")</text></inputEntry>
        <inputEntry id="ie_fb_vidshkod_p"><text></text></inputEntry>
        <outputEntry id="oe_fb_vidshkod_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_fb_vidshkod_notes"><text>"постачальник не знайдений в DMN — перевірте вручну"</text></outputEntry>
      </rule>

      <rule id="rule_fallback_kompens">
        <description>Загальне: будь-яка компенсація — комунальні</description>
        <inputEntry id="ie_fb_kompens"><text>contains(?, "компенсац")</text></inputEntry>
        <inputEntry id="ie_fb_kompens_p"><text></text></inputEntry>
        <outputEntry id="oe_fb_kompens_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_fb_kompens_notes"><text>"постачальник не знайдений в DMN — перевірте вручну"</text></outputEntry>
      </rule>

      <!-- DEFAULT -->

      <rule id="rule_detail_default">
        <description>Невідома позиція і постачальник — потребує ручної класифікації</description>
        <inputEntry id="ie_default_line"><text></text></inputEntry>
        <inputEntry id="ie_default_partner"><text></text></inputEntry>
        <outputEntry id="oe_default_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_default_notes"><text>"УВАГА: позиція не розпізнана — класифікуйте вручну"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <!-- ═══════════════════════════════════════════════════════════════════════
       РІШЕННЯ 2: Класифікація комунальних послуг за статтями витрат
       Залежить від Рішення 1 (information requirement)
       ═══════════════════════════════════════════════════════════════════════ -->

  <decision id="utility-expense-classification" name="Класифікація комунальних послуг за статтями витрат">

    <!-- DRG: спочатку оцінити invoice-detail-type -->
    <informationRequirement id="ir_invoice_type">
      <requiredDecision href="#invoice-detail-type" />
    </informationRequirement>

    <decisionTable id="dt_utility_expense" hitPolicy="FIRST">

      <!-- ── INPUTS ──────────────────────────────────────────────────────── -->

      <!-- Input 1: назва послуги з розшифровки комунальних -->
      <input id="input_service" label="Назва послуги в рахунку">
        <inputExpression id="ie_service" typeRef="string">
          <text>x_studio_camunda_service_name</text>
        </inputExpression>
      </input>

      <!-- Input 2: тип рахунку (з Рішення 1 через DRG) — guard -->
      <input id="input_invoice_type" label="Вид рахунку (з DRG)">
        <inputExpression id="ie_drg_type" typeRef="string">
          <text>x_studio_camunda_invoice_type</text>
        </inputExpression>
      </input>

      <!-- ── OUTPUT ──────────────────────────────────────────────────────── -->

      <output id="output_category"
              label="Стаття витрат"
              name="x_studio_camunda_expense_category"
              typeRef="string" />

      <!-- ═════════════════════════════════════════════════════════════════
           GUARD: якщо рахунок НЕ комунальний — класифікація не потрібна
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_guard_not_utilities">
        <description>Не комунальні — класифікація статей витрат не потрібна</description>
        <inputEntry id="ie_guard_service"><text></text></inputEntry>
        <inputEntry id="ie_guard_type"><text>not("комунальні")</text></inputEntry>
        <outputEntry id="oe_guard"><text>"N/A — тип рахунку: оренда, класифікація статей витрат не потрібна"</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           Комунальні - вивіз сміття, прибирання
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_garbage_1">
        <description>Вивіз ТПВ та захоронення</description>
        <inputEntry id="ie_garbage_1"><text>"компенс. витрат за вивіз ТПВ та їх захоронення"</text></inputEntry>
        <inputEntry id="ie_garbage_1_type"><text></text></inputEntry>
        <outputEntry id="oe_garbage_1"><text>"Комунальні - вивіз сміття, прибирання"</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           Комунальні - вода, стоки
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_water_1">
        <description>Відшкодування вартості водопостачання</description>
        <inputEntry id="ie_water_1"><text>"відшкодування вартості водопостачання"</text></inputEntry>
        <inputEntry id="ie_water_1_type"><text></text></inputEntry>
        <outputEntry id="oe_water_1"><text>"Комунальні - вода,стоки"</text></outputEntry>
      </rule>

      <rule id="rule_water_2">
        <description>Відшкодування комун. витрат (вода)</description>
        <inputEntry id="ie_water_2"><text>"відшкодування комун. витрат (вода)"</text></inputEntry>
        <inputEntry id="ie_water_2_type"><text></text></inputEntry>
        <outputEntry id="oe_water_2"><text>"Комунальні - вода,стоки"</text></outputEntry>
      </rule>

      <rule id="rule_water_3">
        <description>Водовідведення стічних труб</description>
        <inputEntry id="ie_water_3"><text>"водовідвед.стічних труб"</text></inputEntry>
        <inputEntry id="ie_water_3_type"><text></text></inputEntry>
        <outputEntry id="oe_water_3"><text>"Комунальні - вода,стоки"</text></outputEntry>
      </rule>

      <rule id="rule_water_4">
        <description>Холодне водопостачання</description>
        <inputEntry id="ie_water_4"><text>"холод.водопостач"</text></inputEntry>
        <inputEntry id="ie_water_4_type"><text></text></inputEntry>
        <outputEntry id="oe_water_4"><text>"Комунальні - вода,стоки"</text></outputEntry>
      </rule>

      <rule id="rule_water_5">
        <description>Водовідведення</description>
        <inputEntry id="ie_water_5"><text>"водовідведення"</text></inputEntry>
        <inputEntry id="ie_water_5_type"><text></text></inputEntry>
        <outputEntry id="oe_water_5"><text>"Комунальні - вода,стоки"</text></outputEntry>
      </rule>

      <rule id="rule_water_6">
        <description>Витрати за спожиту воду</description>
        <inputEntry id="ie_water_6"><text>"відшкодування витрат за спожиту воду"</text></inputEntry>
        <inputEntry id="ie_water_6_type"><text></text></inputEntry>
        <outputEntry id="oe_water_6"><text>"Комунальні - вода,стоки"</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           Комунальні - електроенергія
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_elec_1">
        <description>Відшкодування витрат комунальних послуг</description>
        <inputEntry id="ie_elec_1"><text>"відшкодування витрат комунальних послуг"</text></inputEntry>
        <inputEntry id="ie_elec_1_type"><text></text></inputEntry>
        <outputEntry id="oe_elec_1"><text>"Комунальні - електроенергія"</text></outputEntry>
      </rule>

      <rule id="rule_elec_2">
        <description>Компенс. витрат на електроустановку</description>
        <inputEntry id="ie_elec_2"><text>"відкодування комунальних витрат (компенс.вит. на електроустановку)"</text></inputEntry>
        <inputEntry id="ie_elec_2_type"><text></text></inputEntry>
        <outputEntry id="oe_elec_2"><text>"Комунальні - електроенергія"</text></outputEntry>
      </rule>

      <rule id="rule_elec_3">
        <description>Відшкодування вартості електричної енергії</description>
        <inputEntry id="ie_elec_3"><text>"відшкодування вартості електричної енергії"</text></inputEntry>
        <inputEntry id="ie_elec_3_type"><text></text></inputEntry>
        <outputEntry id="oe_elec_3"><text>"Комунальні - електроенергія"</text></outputEntry>
      </rule>

      <rule id="rule_elec_4">
        <description>Електроенергія активна (NB: в оригіналі "елекроенергія")</description>
        <inputEntry id="ie_elec_4"><text>"елекроенергія (активна)"</text></inputEntry>
        <inputEntry id="ie_elec_4_type"><text></text></inputEntry>
        <outputEntry id="oe_elec_4"><text>"Комунальні - електроенергія"</text></outputEntry>
      </rule>

      <rule id="rule_elec_5">
        <description>Електроенергія реактивна</description>
        <inputEntry id="ie_elec_5"><text>"електроенергія (реактивна)"</text></inputEntry>
        <inputEntry id="ie_elec_5_type"><text></text></inputEntry>
        <outputEntry id="oe_elec_5"><text>"Комунальні - електроенергія"</text></outputEntry>
      </rule>

      <rule id="rule_elec_6">
        <description>Використання генератора</description>
        <inputEntry id="ie_elec_6"><text>"викор. генератора"</text></inputEntry>
        <inputEntry id="ie_elec_6_type"><text></text></inputEntry>
        <outputEntry id="oe_elec_6"><text>"Комунальні - електроенергія"</text></outputEntry>
      </rule>

      <rule id="rule_elec_7">
        <description>Розподіл електроенергії</description>
        <inputEntry id="ie_elec_7"><text>"відшкодування витрат за розподіл електроенергії"</text></inputEntry>
        <inputEntry id="ie_elec_7_type"><text></text></inputEntry>
        <outputEntry id="oe_elec_7"><text>"Комунальні - електроенергія"</text></outputEntry>
      </rule>

      <rule id="rule_elec_8">
        <description>Обслуговування електрогенераторної установки</description>
        <inputEntry id="ie_elec_8"><text>"відшкодування експлуатаційних витрат за обслуговування електрогенераторної установки"</text></inputEntry>
        <inputEntry id="ie_elec_8_type"><text></text></inputEntry>
        <outputEntry id="oe_elec_8"><text>"Комунальні - електроенергія"</text></outputEntry>
      </rule>

      <rule id="rule_elec_9">
        <description>Експлуатаційний платіж за електрогенераторну установку</description>
        <inputEntry id="ie_elec_9"><text>"додатковий Експлуатаційний платіж за експлуатацію бензинової/дизельної електрогенераторної установки для цілей користування орендованими приміщеннями в період їх відключення від електропостачання"</text></inputEntry>
        <inputEntry id="ie_elec_9_type"><text></text></inputEntry>
        <outputEntry id="oe_elec_9"><text>"Комунальні - електроенергія"</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           Комунальні - опалення, кондиціонування
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_heat_1">
        <description>Блок кондиціонування</description>
        <inputEntry id="ie_heat_1"><text>"блок кондиціонування"</text></inputEntry>
        <inputEntry id="ie_heat_1_type"><text></text></inputEntry>
        <outputEntry id="oe_heat_1"><text>"Комунальні - опалення, кондиціонування"</text></outputEntry>
      </rule>

      <rule id="rule_heat_2">
        <description>Приточно-витяжна система</description>
        <inputEntry id="ie_heat_2"><text>"приточно-витяжна система"</text></inputEntry>
        <inputEntry id="ie_heat_2_type"><text></text></inputEntry>
        <outputEntry id="oe_heat_2"><text>"Комунальні - опалення, кондиціонування"</text></outputEntry>
      </rule>

      <rule id="rule_heat_3">
        <description>Договірна потужність природного газу</description>
        <inputEntry id="ie_heat_3"><text>"відшкодування вартості замовленої (договірної) потужності природного газу"</text></inputEntry>
        <inputEntry id="ie_heat_3_type"><text></text></inputEntry>
        <outputEntry id="oe_heat_3"><text>"Комунальні - опалення, кондиціонування"</text></outputEntry>
      </rule>

      <rule id="rule_heat_4">
        <description>Розподіл природного газу</description>
        <inputEntry id="ie_heat_4"><text>"відшкодування витрат за розподіл природного газ"</text></inputEntry>
        <inputEntry id="ie_heat_4_type"><text></text></inputEntry>
        <outputEntry id="oe_heat_4"><text>"Комунальні - опалення, кондиціонування"</text></outputEntry>
      </rule>

      <rule id="rule_heat_5">
        <description>Використання природного газу</description>
        <inputEntry id="ie_heat_5"><text>"відшкодування витрат по викор. природного газ"</text></inputEntry>
        <inputEntry id="ie_heat_5_type"><text></text></inputEntry>
        <outputEntry id="oe_heat_5"><text>"Комунальні - опалення, кондиціонування"</text></outputEntry>
      </rule>

      <rule id="rule_heat_6">
        <description>Компенсація теплопостачання</description>
        <inputEntry id="ie_heat_6"><text>"комунальні послуги (компенсація теплопостачання"</text></inputEntry>
        <inputEntry id="ie_heat_6_type"><text></text></inputEntry>
        <outputEntry id="oe_heat_6"><text>"Комунальні - опалення, кондиціонування"</text></outputEntry>
      </rule>

      <rule id="rule_heat_7">
        <description>Теплова енергія</description>
        <inputEntry id="ie_heat_7"><text>"відшкодування комунальних послуг за теплову енергію"</text></inputEntry>
        <inputEntry id="ie_heat_7_type"><text></text></inputEntry>
        <outputEntry id="oe_heat_7"><text>"Комунальні - опалення, кондиціонування"</text></outputEntry>
      </rule>

      <rule id="rule_heat_8">
        <description>Витрати на опалення</description>
        <inputEntry id="ie_heat_8"><text>"відшкодування витрат на опалення"</text></inputEntry>
        <inputEntry id="ie_heat_8_type"><text></text></inputEntry>
        <outputEntry id="oe_heat_8"><text>"Комунальні - опалення, кондиціонування"</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           Комунальні обслуговування заг площ
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_common_1">
        <description>Е/е на загальних площах ТЦ</description>
        <inputEntry id="ie_common_1"><text>"компенсація за е/е на загальних площах ТЦ"</text></inputEntry>
        <inputEntry id="ie_common_1_type"><text></text></inputEntry>
        <outputEntry id="oe_common_1"><text>"Комунальні обслуговування заг площ"</text></outputEntry>
      </rule>

      <rule id="rule_common_2">
        <description>Нерозподілені витрати на площі загального користування</description>
        <inputEntry id="ie_common_2"><text>"відшкодування нерозподілених витрат на площі загального користуванян"</text></inputEntry>
        <inputEntry id="ie_common_2_type"><text></text></inputEntry>
        <outputEntry id="oe_common_2"><text>"Комунальні обслуговування заг площ"</text></outputEntry>
      </rule>

      <rule id="rule_common_3">
        <description>Електроенергія та розподіл на площах ТЦ</description>
        <inputEntry id="ie_common_3"><text>"компенс. витрат за спожиту елекроенергію та її розподіл на площах корист. ТЦ"</text></inputEntry>
        <inputEntry id="ie_common_3_type"><text></text></inputEntry>
        <outputEntry id="oe_common_3"><text>"Комунальні обслуговування заг площ"</text></outputEntry>
      </rule>

      <rule id="rule_common_4">
        <description>Фонтан</description>
        <inputEntry id="ie_common_4"><text>"фонтан"</text></inputEntry>
        <inputEntry id="ie_common_4_type"><text></text></inputEntry>
        <outputEntry id="oe_common_4"><text>"Комунальні обслуговування заг площ"</text></outputEntry>
      </rule>

      <rule id="rule_common_5">
        <description>Енергозабезпечення місць загального користування</description>
        <inputEntry id="ie_common_5"><text>"компенсація витрат з енергозабеспечення місць загального користування"</text></inputEntry>
        <inputEntry id="ie_common_5_type"><text></text></inputEntry>
        <outputEntry id="oe_common_5"><text>"Комунальні обслуговування заг площ"</text></outputEntry>
      </rule>

      <rule id="rule_common_6">
        <description>Вода МЗК</description>
        <inputEntry id="ie_common_6"><text>"вода МЗК"</text></inputEntry>
        <inputEntry id="ie_common_6_type"><text></text></inputEntry>
        <outputEntry id="oe_common_6"><text>"Комунальні обслуговування заг площ"</text></outputEntry>
      </rule>

      <rule id="rule_common_7">
        <description>Тепло МЗК</description>
        <inputEntry id="ie_common_7"><text>"тепло МЗК"</text></inputEntry>
        <inputEntry id="ie_common_7_type"><text></text></inputEntry>
        <outputEntry id="oe_common_7"><text>"Комунальні обслуговування заг площ"</text></outputEntry>
      </rule>

      <rule id="rule_common_8">
        <description>Комунальні послуги площ загального користування та земельної ділянки</description>
        <inputEntry id="ie_common_8"><text>"компенсація витрат на забезпечення комунальними послугами площ загального користування та земельної ділянки"</text></inputEntry>
        <inputEntry id="ie_common_8_type"><text></text></inputEntry>
        <outputEntry id="oe_common_8"><text>"Комунальні обслуговування заг площ"</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           Оренда вивіски
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_sign_1">
        <description>Реклама</description>
        <inputEntry id="ie_sign_1"><text>"реклама"</text></inputEntry>
        <inputEntry id="ie_sign_1_type"><text></text></inputEntry>
        <outputEntry id="oe_sign_1"><text>"Оренда вивіски"</text></outputEntry>
      </rule>

      <rule id="rule_sign_2">
        <description>Оренда вивіски</description>
        <inputEntry id="ie_sign_2"><text>"оренда вивіски"</text></inputEntry>
        <inputEntry id="ie_sign_2_type"><text></text></inputEntry>
        <outputEntry id="oe_sign_2"><text>"Оренда вивіски"</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           DEFAULT — невідома послуга
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_expense_default">
        <description>Невідома назва послуги — потребує ручної класифікації</description>
        <inputEntry id="ie_default"><text></text></inputEntry>
        <inputEntry id="ie_default_type"><text></text></inputEntry>
        <outputEntry id="oe_default"><text>"Невідома послуга — потребує ручної класифікації"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <!-- ═══════════════════════════════════════════════════════════════════════
       РІШЕННЯ 3: Визначення погоджувача рахунку
       Залежить від Рішення 1 (invoice-detail-type → тип рахунку)
       Вхід:  x_studio_camunda_invoice_type (з invoice-detail-type через DRG)
              x_studio_camunda_invoice_amount (з процесу)
       Вихід: approver_role → "manager" | "director" | "accountant"

       ⚠️  ЗАПОВНІТЬ ТАБЛИЦЮ відповідно до реальних правил погодження!
           Зараз використовуються значення "оренда"/"комунальні" з invoice-detail-type.
       ═══════════════════════════════════════════════════════════════════════ -->

  <decision id="decision-1goz4yx" name="Визначення погоджувача рахунку">

    <informationRequirement id="ir_detail_to_approver">
      <requiredDecision href="#invoice-detail-type" />
    </informationRequirement>

    <decisionTable id="decisionTable_approver" hitPolicy="FIRST">

      <input id="input_invoice_type_approver" label="Тип рахунку">
        <inputExpression id="inputExpr_invoice_type_approver" typeRef="string">
          <text>x_studio_camunda_invoice_type</text>
        </inputExpression>
        <inputValues id="inputValues_invoice_type_approver">
          <text>"оренда","комунальні"</text>
        </inputValues>
      </input>

      <input id="input_invoice_amount" label="Сума рахунку (грн)">
        <inputExpression id="inputExpr_invoice_amount" typeRef="double">
          <text>x_studio_camunda_invoice_amount</text>
        </inputExpression>
      </input>

      <output id="output_approver_role"
              label="Роль погоджувача"
              name="approver_role"
              typeRef="string">
        <outputValues id="outputValues_approver_role">
          <text>"manager","director","accountant"</text>
        </outputValues>
      </output>

      <!-- ⚠️ ЗАПОВНІТЬ правилами для "оренда"/"комунальні" замість "rent"/"utilities" -->

      <!-- Оренда, велика сума (> 50 000 грн) — директор -->
      <rule id="rule_approver_rent_large">
        <description>Оренда понад 50 000 грн — погоджує директор</description>
        <inputEntry id="ie_approver_rent_large_type"><text>"оренда"</text></inputEntry>
        <inputEntry id="ie_approver_rent_large_amount"><text>&gt; 50000</text></inputEntry>
        <outputEntry id="oe_approver_rent_large"><text>"director"</text></outputEntry>
      </rule>

      <!-- Оренда, невелика сума (≤ 50 000 грн) — менеджер -->
      <rule id="rule_approver_rent_small">
        <description>Оренда до 50 000 грн — погоджує менеджер</description>
        <inputEntry id="ie_approver_rent_small_type"><text>"оренда"</text></inputEntry>
        <inputEntry id="ie_approver_rent_small_amount"><text>&lt;= 50000</text></inputEntry>
        <outputEntry id="oe_approver_rent_small"><text>"manager"</text></outputEntry>
      </rule>

      <!-- Комунальні платежі — бухгалтер -->
      <rule id="rule_approver_utilities">
        <description>Комунальні платежі — погоджує бухгалтер</description>
        <inputEntry id="ie_approver_utilities_type"><text>"комунальні"</text></inputEntry>
        <inputEntry id="ie_approver_utilities_amount"><text></text></inputEntry>
        <outputEntry id="oe_approver_utilities"><text>"accountant"</text></outputEntry>
      </rule>

      <!-- За замовчуванням — менеджер -->
      <rule id="rule_approver_default">
        <description>Інший тип — погоджує менеджер</description>
        <inputEntry id="ie_approver_default_type"><text></text></inputEntry>
        <inputEntry id="ie_approver_default_amount"><text></text></inputEntry>
        <outputEntry id="oe_approver_default"><text>"manager"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <!-- ═══════════════════════════════════════════════════════════════════════
       РІШЕННЯ 4: Чи надає ТРЦ деталізацію комунальних? (автономне)
       Вхід:  x_studio_camunda_partner_name — назва постачальника
       Вихід: x_studio_camunda_provides_detailization → true | false

       ⚠️  ЗАПОВНІТЬ ТАБЛИЦЮ реальними назвами ТРЦ!
           Зараз placeholder-и для ТРЦ що НЕ надають деталізацію.
       ═══════════════════════════════════════════════════════════════════════ -->

  <decision id="supplier-detailization" name="Чи надає ТРЦ деталізацію комунальних?">
    <decisionTable id="dt_supplier_detail" hitPolicy="FIRST">

      <!-- INPUT -->
      <input id="input_sd_partner_name" label="Назва постачальника">
        <inputExpression id="ie_sd_partner_name" typeRef="string">
          <text>x_studio_camunda_partner_name</text>
        </inputExpression>
      </input>

      <!-- OUTPUT -->
      <output id="output_sd_provides_detail"
              label="Надає деталізацію?"
              name="x_studio_camunda_provides_detailization"
              typeRef="boolean" />

      <!-- ═════════════════════════════════════════════════════════════════
           Постачальники, які НАДАЮТЬ деталізацію
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_sd_silpo">
        <description>Сільпо фуд — деталізація комунальних в окремому документі</description>
        <inputEntry id="ie_sd_silpo"><text>"Сільпо фуд"</text></inputEntry>
        <outputEntry id="oe_sd_silpo"><text>true</text></outputEntry>
      </rule>

      <rule id="rule_sd_german">
        <description>Герман Олена Василівна — надає деталізацію</description>
        <inputEntry id="ie_sd_german"><text>"Герман Олена Василівна"</text></inputEntry>
        <outputEntry id="oe_sd_german"><text>true</text></outputEntry>
      </rule>

      <rule id="rule_sd_lvivbudmax">
        <description>ЛЬВІВБУДМАКС-ІНВЕСТ, ТЗОВ — надає деталізацію</description>
        <inputEntry id="ie_sd_lvivbudmax"><text>"ЛЬВІВБУДМАКС-ІНВЕСТ, ТЗОВ"</text></inputEntry>
        <outputEntry id="oe_sd_lvivbudmax"><text>true</text></outputEntry>
      </rule>

      <rule id="rule_sd_zhk">
        <description>Житомирський меблевий комбінат — надає деталізацію</description>
        <inputEntry id="ie_sd_zhk"><text>"Житомирський меблевий комбінат"</text></inputEntry>
        <outputEntry id="oe_sd_zhk"><text>true</text></outputEntry>
      </rule>

      <rule id="rule_sd_kroppers">
        <description>Кропперс груп — надає деталізацію</description>
        <inputEntry id="ie_sd_kroppers"><text>"Кропперс груп"</text></inputEntry>
        <outputEntry id="oe_sd_kroppers"><text>true</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           Постачальники, які НЕ надають деталізацію
           (placeholder — замінити реальними назвами ТРЦ)
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_sd_no_detail_1">
        <description>Placeholder 1 — ТРЦ що не надає деталізацію (замінити реальною назвою)</description>
        <inputEntry id="ie_sd_no_detail_1"><text>"PLACEHOLDER_ТРЦ_1"</text></inputEntry>
        <outputEntry id="oe_sd_no_detail_1"><text>false</text></outputEntry>
      </rule>

      <rule id="rule_sd_no_detail_2">
        <description>Placeholder 2 — ТРЦ що не надає деталізацію (замінити реальною назвою)</description>
        <inputEntry id="ie_sd_no_detail_2"><text>"PLACEHOLDER_ТРЦ_2"</text></inputEntry>
        <outputEntry id="oe_sd_no_detail_2"><text>false</text></outputEntry>
      </rule>

      <!-- ═════════════════════════════════════════════════════════════════
           DEFAULT — невідомий постачальник, вважаємо що надає
           ═════════════════════════════════════════════════════════════════ -->

      <rule id="rule_sd_default">
        <description>Невідомий постачальник — за замовчуванням надає деталізацію</description>
        <inputEntry id="ie_sd_default"><text></text></inputEntry>
        <outputEntry id="oe_sd_default"><text>true</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <!-- ═══════════════════════════════════════════════════════════════════════
       DMNDI — Decision Requirement Graph (візуальне розташування)
       ═══════════════════════════════════════════════════════════════════════ -->
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_invoice_drg">

      <!-- Рішення 1 (нижній рівень): Деталізація рахунків -->
      <dmndi:DMNShape id="DMNShape_invoice_detail" dmnElementRef="invoice-detail-type">
        <dc:Bounds x="260" y="80" width="200" height="80" />
      </dmndi:DMNShape>

      <!-- Рішення 2 (середній рівень): Класифікація витрат -->
      <dmndi:DMNShape id="DMNShape_utility_expense" dmnElementRef="utility-expense-classification">
        <dc:Bounds x="260" y="260" width="200" height="80" />
      </dmndi:DMNShape>

      <!-- Рішення 3 (верхній рівень): Визначення погоджувача -->
      <dmndi:DMNShape id="DMNShape_approver" dmnElementRef="decision-1goz4yx">
        <dc:Bounds x="260" y="440" width="200" height="80" />
      </dmndi:DMNShape>

      <!-- Рішення 4 (автономне, праворуч): Деталізація постачальників -->
      <dmndi:DMNShape id="DMNShape_supplier_detail" dmnElementRef="supplier-detailization">
        <dc:Bounds x="560" y="80" width="200" height="80" />
      </dmndi:DMNShape>

      <!-- Стрілка залежності: Класифікація витрат ← Деталізація рахунків -->
      <dmndi:DMNEdge id="DMNEdge_ir_invoice_type" dmnElementRef="ir_invoice_type">
        <di:waypoint x="360" y="160" />
        <di:waypoint x="360" y="260" />
      </dmndi:DMNEdge>

      <!-- Стрілка залежності: Погоджувач ← Деталізація рахунків -->
      <dmndi:DMNEdge id="DMNEdge_ir_detail_to_approver" dmnElementRef="ir_detail_to_approver">
        <di:waypoint x="360" y="160" />
        <di:waypoint x="360" y="440" />
      </dmndi:DMNEdge>

    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
