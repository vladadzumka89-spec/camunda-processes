<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="e787c33" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Видача ОЗ" processRef="Process_1s0osfg" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1s0osfg" name="Видача ОЗ" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="2.0" />
    </bpmn:extensionElements>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_system" name="Система (автоматично)">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_odoo_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_create_main</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_odoo_merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_workspace</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Timer_wait_stazh</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_intern_arrived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Timer_official</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_move_oz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_ok</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_no_oz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_not_arrived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_rem_workspace</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_rem_available</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_rem_oz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_rem_intern</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_rem_workspace</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_rem_available</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_rem_oz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_rem_intern</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_responsible" name="Відповідальний за ОЗ">
        <bpmn:flowNodeRef>UT_workspace_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_check_available</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_issue_oz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_intern_check</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_manager" name="Керівник (ескалація)">
        <bpmn:flowNodeRef>UT_esc_workspace</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_esc_available</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_esc_oz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_esc_intern</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_esc_workspace</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_esc_available</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_esc_oz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_esc_intern</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- ============ MAIN FLOW ============ -->

    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_to_odoo_check</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="GW_odoo_check" name="Задача в Odoo існує?" default="Flow_odoo_default">
      <bpmn:incoming>Flow_to_odoo_check</bpmn:incoming>
      <bpmn:outgoing>Flow_odoo_skip</bpmn:outgoing>
      <bpmn:outgoing>Flow_odoo_default</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="ST_create_main" name="Створити задачу в Odoo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Видача ОЗ&#34;, create_process: true, _model: &#34;project.project&#34;, _id: 252}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_odoo_default</bpmn:incoming>
      <bpmn:outgoing>Flow_create_to_merge</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GW_odoo_merge">
      <bpmn:incoming>Flow_odoo_skip</bpmn:incoming>
      <bpmn:incoming>Flow_create_to_merge</bpmn:incoming>
      <bpmn:outgoing>Flow_to_workspace</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_workspace_check" name="Чи потрібне робоче місце?">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Чи потрібне робоче місце?&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_workspace</bpmn:incoming>
      <bpmn:outgoing>Flow_workspace_to_gw</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_workspace" name="Потрібне?" default="Flow_no_oz">
      <bpmn:incoming>Flow_workspace_to_gw</bpmn:incoming>
      <bpmn:outgoing>Flow_yes_workspace</bpmn:outgoing>
      <bpmn:outgoing>Flow_no_oz</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_check_available" name="Перевірити наявне обладнання">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Перевірити наявне обладнання&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
