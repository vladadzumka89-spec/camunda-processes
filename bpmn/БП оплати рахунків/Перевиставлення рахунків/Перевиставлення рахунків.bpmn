    <bpmn:intermediateCatchEvent id="Event_0yxhr8x" name="Останній день місяця">
      <bpmn:incoming>Flow_1t4rv71</bpmn:incoming>
      <bpmn:outgoing>Flow_0uct7ft</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_0a1iv8e">
        <bpmn:timeDate xsi:type="bpmn:tFormalExpression">= date and time(if month(today()) = 12 then date(year(today()) + 1, 1, 1) - duration("P1D") else date(year(today()), month(today()) + 1, 1) - duration("P1D"), time("18:00:00"))</bpmn:timeDate>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="Activity_0if1099" name="Провести бух реалізацію&#10;(на основі рахунку)">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://odoo.dev.dobrom.com/web/hook/90fdde6b-47f9-44ba-90b2-19559b206bce&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Бух реалізація рахунку №&#34; + x_studio_camunda_invoice_number + &#34; — &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#34;, description: &#34;Проведіть бухгалтерську реалізацію на основі рахунку&#34;, _model: &#34;project.project&#34;, _id: 288, process_instance_key: process_instance_key, x_studio_camunda_invoice_number: x_studio_camunda_invoice_number, x_studio_camunda_invoice_date: x_studio_camunda_invoice_date, x_studio_camunda_invoice_line_name: x_studio_camunda_invoice_line_name, x_studio_camunda_invoice_amount: x_studio_camunda_invoice_amount}" target="body" />
        </zeebe:ioMapping>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" type="http-request-smart" retries="3" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0uct7ft</bpmn:incoming>
      <bpmn:incoming>Flow_1gazj4c</bpmn:incoming>
      <bpmn:outgoing>Flow_1wjnu6v</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_0d65pqe" name="Рахунок оброблено">
      <bpmn:incoming>Flow_1wjnu6v</bpmn:incoming>
    </bpmn:endEvent>
