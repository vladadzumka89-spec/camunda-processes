    <bpmn:sequenceFlow id="Flow_start_to_gw_odoo" sourceRef="StartEvent_1" targetRef="GW_FAMO" />
    <bpmn:sequenceFlow id="Flow_famo_yes" name="Так" sourceRef="GW_FAMO" targetRef="GW_rent">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=is defined(x_studio_camunda_pidrozdil_complete_name) and x_studio_camunda_pidrozdil_complete_name != null and (contains(x_studio_camunda_pidrozdil_complete_name, "[Фамо]") or contains(x_studio_camunda_pidrozdil_complete_name, "[Пінкі]") or matches(x_studio_camunda_pidrozdil_complete_name, "/ 4[0-9][0-9]"))</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_famo_no" name="Ні" sourceRef="GW_FAMO" targetRef="UT_check_sum_tp" />
    <bpmn:sequenceFlow id="Flow_check_tp_to_appr" sourceRef="UT_check_sum_tp" targetRef="GW_approved_tp" />
    <bpmn:sequenceFlow id="Flow_appr_tp_yes" name="Так" sourceRef="GW_approved_tp" targetRef="UT_decide_pay_tp">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_approved = "yes"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_appr_tp_no" name="Ні" sourceRef="GW_approved_tp" targetRef="ST_not_approved_tp_end" />
    <bpmn:sequenceFlow id="Flow_not_appr_tp_end" sourceRef="ST_not_approved_tp_end" targetRef="End_not_approved_tp" />
