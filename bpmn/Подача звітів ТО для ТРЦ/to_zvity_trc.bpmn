    <bpmn:userTask id="UserTask_CreateTPLDelivery" name="Створити внутрішню доставку на магазин в ТРЦ">
      <bpmn:documentation>ТІЛЬКИ для магазинів зі змінної original_stores: 607 Форум, 918 Пінкі Форум, 621 Скай Парк, 902 Пінкі Океан. З коментарем "Документи в адміністрацію". Форма (Odoo): таблиця 4 рядки.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="finansist" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input target="body" source="={name: string(month) + &#34;.&#34; + string(year) + &#34; — Створити внутрішню доставку на магазин в ТРЦ&#34;, description: &#34;&lt;b&gt;Період:&lt;/b&gt; &#34; + string(month) + &#34;.&#34; + string(year) + &#34;&lt;br/&gt;&lt;b&gt;Коментар:&lt;/b&gt; Документи в адміністрацію&lt;br/&gt;Створи в TPL внутрішню доставку для кожного з 4 магазинів і познач &lt;b&gt;Доставку створено&lt;/b&gt;.&#34;, description_format: &#34;html&#34;, _model: &#34;project.project&#34;, _id: project_id, parent_id: odoo_task_id, process_instance_key: process_instance_key, x_studio_camunda_role_code: &#34;finansist&#34;, x_studio_camunda_task_code: &#34;create_tpl_delivery&#34;, x_studio_camunda_year: year, x_studio_camunda_month: month, original_stores: original_stores}" />
        </zeebe:ioMapping>
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_SubmitFork_to_CreateTPL</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateTPL_to_WeekTimer</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateCatchEvent id="IntermediateCatch_WeekTimer" name="До тижня">
      <bpmn:documentation>Після створення доставки чекаємо тиждень. Лише після цього у фінансиста з'являється задача "Отримати підтвердження передачі документа".</bpmn:documentation>
      <bpmn:incoming>Flow_CreateTPL_to_WeekTimer</bpmn:incoming>
      <bpmn:outgoing>Flow_WeekTimer_to_Receive</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Week">
        <bpmn:timeDate xsi:type="bpmn:tFormalExpression">=date and time(date(now()) + duration("P7D"), time("09:00:00@Europe/Kyiv"))</bpmn:timeDate>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="UserTask_ReceiveConfirmation" name="Отримати підтвердження передачі документа">
      <bpmn:documentation>Фінансист підтверджує отримання документів отримувачем по 4 магазинах. Поки задача активна, кожні 3 дні спрацьовує boundary timer-нагадування (не перериває задачу).</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="finansist" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input target="body" source="={name: string(month) + &#34;.&#34; + string(year) + &#34; — Отримати підтвердження передачі документа&#34;, description: &#34;&lt;b&gt;Період:&lt;/b&gt; &#34; + string(month) + &#34;.&#34; + string(year) + &#34;&lt;br/&gt;Підтверди отримання документів адміністрацією ТРЦ для 4 магазинів. Кожні 3 дні приходитиме нагадування (задача не переривається).&#34;, description_format: &#34;html&#34;, _model: &#34;project.project&#34;, _id: project_id, parent_id: odoo_task_id, process_instance_key: process_instance_key, x_studio_camunda_role_code: &#34;finansist&#34;, x_studio_camunda_task_code: &#34;receive_confirmation&#34;, x_studio_camunda_year: year, x_studio_camunda_month: month}" />
        </zeebe:ioMapping>
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_WeekTimer_to_Receive</bpmn:incoming>
      <bpmn:outgoing>Flow_Receive_to_WriteTT</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="BoundaryEvent_Reminder" name="Кожні 3 дні" cancelActivity="false" attachedToRef="UserTask_ReceiveConfirmation">
      <bpmn:outgoing>Flow_Reminder_to_Check</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Reminder">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">="R/" + string(date and time(date(now()), time("09:00:00@Europe/Kyiv")) + duration("P3D")) + "/P3D"</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="ServiceTask_CheckConfirmation" name="Перевірити підтвердження передачі документа">
      <bpmn:documentation>Нагадування фінансисту перевірити, чи отримано підтвердження передачі. Спрацьовує кожні 3 дні, поки задача "Отримати підтвердження" активна. Реальна автоматична логіка не обов'язкова — воркер на topic "check-delivery-confirmation" може просто завершувати job без дій (no-op нагадування).</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="check-delivery-confirmation" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Reminder_to_Check</bpmn:incoming>
      <bpmn:outgoing>Flow_Check_to_EndReminder</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Reminder" name="Нагадування опрацьовано">
      <bpmn:incoming>Flow_Check_to_EndReminder</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="UserTask_WriteToTT" name="Написати працівникам магазинів в ТТ">
      <bpmn:documentation>Повідомити працівників торгових точок (4 магазини original_stores) про передані документи.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
