<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_feature" targetNamespace="http://tut.ua/bpmn/feature-pipeline" exporter="Claude Code" exporterVersion="2.0">
  <bpmn:error id="Error_deploy_failed" name="Deploy Failed" errorCode="DEPLOY_FAILED" />
  <bpmn:message id="Message_pr_event" name="msg_pr_event">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=head_branch" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_pr_updated" name="msg_pr_updated">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_review_done" name="msg_review_done">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:process id="feature-to-production" name="Feature to Production" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="7.0" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="start_manual" name="Розробку розпочато (/start)">
      <bpmn:documentation>Розробник запускає /start в Claude Code CLI.</bpmn:documentation>
      <bpmn:outgoing>f_manual_to_odoo</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_odoo_check" name="Задача в Odoo існує?" default="f_odoo_default">
      <bpmn:incoming>f_manual_to_odoo</bpmn:incoming>
      <bpmn:outgoing>f_odoo_default</bpmn:outgoing>
      <bpmn:outgoing>f_odoo_skip</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_create_odoo" name="Створити задачу в Odoo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;https://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: if is defined(task_name) and task_name != null and task_name != &#34;&#34; then task_name else &#34;[feature] Нова задача&#34;, description: if is defined(task_description) and task_description != null then task_description else &#34;&#34;, _id: odoo_project_id, create_process: true}" target="body" />
          <zeebe:input source="=&#34;odoo_response&#34;" target="result_variable_name" />
          <zeebe:output source="=string(odoo_response.id)" target="odoo_task_id" />
          <zeebe:output source="=process_instance_key" target="process_instance_key" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_odoo_default</bpmn:incoming>
      <bpmn:outgoing>f_odoo_to_merge</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Merge_odoo">
      <bpmn:incoming>f_odoo_to_merge</bpmn:incoming>
      <bpmn:incoming>f_odoo_skip</bpmn:incoming>
      <bpmn:outgoing>f_merge_to_wait</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:intermediateCatchEvent id="catch_pr_created" name="Чекаємо Draft Pull Request в main">
      <bpmn:documentation>Чекає msg_pr_event з correlation key = head_branch.</bpmn:documentation>
      <bpmn:incoming>f_merge_to_wait</bpmn:incoming>
      <bpmn:outgoing>f_catch_to_review</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_catch_pr" messageRef="Message_pr_event" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="catch_review_done" name="Чекаємо результат ревʼю">
      <bpmn:documentation>Чекає msg_review_done від standalone pr-review процесу.</bpmn:documentation>
      <bpmn:incoming>f_catch_to_review</bpmn:incoming>
      <bpmn:incoming>f_rework_catch_to_review</bpmn:incoming>
      <bpmn:outgoing>f_review_to_gw_score</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_catch_review" messageRef="Message_review_done" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="gw_review_score" name="Оцінка ревʼю &#62;= 7?" default="f_review_ok">
      <bpmn:incoming>f_review_to_gw_score</bpmn:incoming>
      <bpmn:outgoing>f_review_ok</bpmn:outgoing>
      <bpmn:outgoing>f_review_low</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <!-- ── Timer: чекаємо 15 хв на деплой staging ────────── -->
    <bpmn:intermediateCatchEvent id="timer_wait_deploy" name="Чекаємо 15 хв на деплой">
      <bpmn:documentation>Після merge PR в staging (з pr-review), чекаємо 15 хвилин щоб deploy завершився через webhook.</bpmn:documentation>
      <bpmn:incoming>f_review_ok</bpmn:incoming>
      <bpmn:outgoing>f_timer_to_verify_staging</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_wait_deploy">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT15M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:callActivity id="call_verify_staging" name="Перевірити staging">
      <bpmn:documentation>Call Activity: verification-process. Створює Odoo задачу, чекає результату.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:calledElement processId="verification-process" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;Перевірити staging: &#34; + head_branch" target="task_name" />
          <zeebe:input source="=&#34;Перевірте зміни на staging.\nPR: &#34; + pr_url + &#34;\nМодулі: &#34; + string(staging_modules)" target="task_description" />
          <zeebe:input source="=string(process_instance_key)" target="correlation_key" />
          <zeebe:input source="=&#34;R/PT4H&#34;" target="reminder_cycle" />
          <zeebe:input source="=&#34;P3D&#34;" target="deadline_duration" />
          <zeebe:output source="=staging_approved" target="staging_approved" />
          <zeebe:output source="=comment" target="staging_comment" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_deploy_ok</bpmn:incoming>
      <bpmn:outgoing>f_verify_staging_to_gw</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:exclusiveGateway id="gw_staging_ok" name="Staging пройдено?" default="f_staging_ok">
      <bpmn:incoming>f_verify_staging_to_gw</bpmn:incoming>
      <bpmn:outgoing>f_staging_ok</bpmn:outgoing>
      <bpmn:outgoing>f_staging_rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_comment_staging_reject" name="Коментар: staging відхилено">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;⚠️ **Staging відхилено**: &#34; + (if is defined(staging_comment) and staging_comment != null then staging_comment else &#34;&#34;) + &#34;\nБудь ласка, виправте та пушніть зміни.&#34;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_staging_rejected</bpmn:incoming>
      <bpmn:outgoing>f_staging_reject_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_undraft_pr" name="Зняти Draft з PR">
      <bpmn:documentation>Позначає draft PR як ready for review.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-pr-ready" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=pr_number" target="pr_number" />
          <zeebe:input source="=repository" target="repository" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_staging_ok</bpmn:incoming>
      <bpmn:outgoing>f_undraft_to_verify_merge</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="call_verify_merge" name="Ревʼю та злиття PR">
      <bpmn:documentation>Call Activity: verification-process. Тімлід робить review та merge PR в main.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:calledElement processId="verification-process" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;Review та merge PR #&#34; + string(pr_number) + &#34; в main&#34;" target="task_name" />
          <zeebe:input source="=&#34;PR: &#34; + pr_url" target="task_description" />
          <zeebe:input source="=string(process_instance_key)" target="correlation_key" />
          <zeebe:input source="=&#34;R/PT4H&#34;" target="reminder_cycle" />
          <zeebe:input source="=&#34;P3D&#34;" target="deadline_duration" />
          <zeebe:output source="=merge_approved" target="merge_approved" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_undraft_to_verify_merge</bpmn:incoming>
      <bpmn:outgoing>f_verify_merge_to_gw</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:exclusiveGateway id="gw_merge_ok" name="Merge пройдено?" default="f_merge_ok">
      <bpmn:incoming>f_verify_merge_to_gw</bpmn:incoming>
      <bpmn:outgoing>f_merge_ok</bpmn:outgoing>
      <bpmn:outgoing>f_merge_rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_comment_merge_reject" name="Коментар: злиття відхилено">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;⚠️ **Merge відхилено**. Будь ласка, виправте та пушніть зміни.&#34;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_merge_rejected</bpmn:incoming>
      <bpmn:outgoing>f_merge_reject_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_github_merge" name="Змержити PR в main">
      <bpmn:documentation>Автоматичний merge PR в main через GitHub API.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-merge" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=pr_number" target="pr_number" />
          <zeebe:input source="=repository" target="repository" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_merge_ok</bpmn:incoming>
      <bpmn:outgoing>f_github_merge_to_verify_prod</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="call_verify_prod" name="Задеплоїте на продакшн">
      <bpmn:documentation>Call Activity: verification-process. Ручний деплой на production.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:calledElement processId="verification-process" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;Задеплоїте на production: PR #&#34; + string(pr_number)" target="task_name" />
          <zeebe:input source="=&#34;PR: &#34; + pr_url + &#34;\nЗмержено в main.&#34;" target="task_description" />
          <zeebe:input source="=string(process_instance_key)" target="correlation_key" />
          <zeebe:input source="=&#34;R/PT4H&#34;" target="reminder_cycle" />
          <zeebe:input source="=&#34;P1D&#34;" target="deadline_duration" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_github_merge_to_verify_prod</bpmn:incoming>
      <bpmn:outgoing>f_verify_prod_to_end</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="evt_end_success" name="Фіча на production ✅">
      <bpmn:incoming>f_verify_prod_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="task_comment_rework" name="Коментар: потрібне виправлення">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;🔄 Потрібне виправлення. Пушніть зміни в гілку `&#34; + head_branch + &#34;` для продовження CI/CD.&#34;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_staging_reject_to_rework</bpmn:incoming>
      <bpmn:incoming>f_merge_reject_to_rework</bpmn:incoming>
      <bpmn:incoming>f_review_low</bpmn:incoming>
      <bpmn:outgoing>f_rework_to_catch</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:receiveTask id="catch_pr_rework" name="Чекаємо оновлення PR" messageRef="Message_pr_updated">
      <bpmn:documentation>Чекає push нових комітів в PR (correlation by pr_number).</bpmn:documentation>
      <bpmn:incoming>f_rework_to_catch</bpmn:incoming>
      <bpmn:outgoing>f_rework_catch_to_review</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:boundaryEvent id="timer_rework_reminder" name="Нагадування (3 дні)" cancelActivity="false" attachedToRef="catch_pr_rework">
      <bpmn:outgoing>f_rework_reminder</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_rework_reminder">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P3D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="task_send_rework_reminder" name="Створити задачу: нагадування про виправлення">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;https://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;⏰ Нагадування: PR #&#34; + string(pr_number) + &#34; потребує виправлення&#34;, description: &#34;&#60;p&#62;⏰ Нагадування: PR #&#34; + string(pr_number) + &#34; потребує виправлення. Пушніть зміни в гілку &#34; + head_branch + &#34;.&#60;/p&#62;&#34;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_rework_reminder</bpmn:incoming>
      <bpmn:outgoing>f_to_End_rem_rework</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_rem_rework" name="Нагадування надіслано">
      <bpmn:incoming>f_to_End_rem_rework</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="subprocess_error_pipeline" name="Обробка помилок пайплайну" triggeredByEvent="true">
      <bpmn:startEvent id="evt_error_catch" name="Помилка пайплайну">
        <bpmn:outgoing>f_err_to_notify</bpmn:outgoing>
        <bpmn:errorEventDefinition id="ErrorDef_catch_pipeline" />
      </bpmn:startEvent>
      <bpmn:serviceTask id="ST_error_notify" name="Створити задачу: помилка пайплайну">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="http-request-smart" retries="2" />
          <zeebe:ioMapping>
            <zeebe:input source="=&#34;POST&#34;" target="method" />
            <zeebe:input source="=&#34;https://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&#34;" target="url" />
            <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
            <zeebe:input source="={name: &#34;[pipeline] ❌ Помилка CI/CD пайплайну&#34;, description: &#34;&#60;p&#62;Критична помилка в пайплайні для PR #&#34; + string(pr_number) + &#34;.&#60;/p&#62;&#34;}" target="body" />
            <zeebe:input source="=true" target="ignore_errors" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>f_err_to_notify</bpmn:incoming>
        <bpmn:outgoing>f_err_to_end</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="evt_error_end" name="Пайплайн завершено з помилкою">
        <bpmn:incoming>f_err_to_end</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="f_err_to_notify" sourceRef="evt_error_catch" targetRef="ST_error_notify" />
      <bpmn:sequenceFlow id="f_err_to_end" sourceRef="ST_error_notify" targetRef="evt_error_end" />
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="f_manual_to_odoo" sourceRef="start_manual" targetRef="GW_odoo_check" />
    <bpmn:sequenceFlow id="f_odoo_default" sourceRef="GW_odoo_check" targetRef="task_create_odoo" />
    <bpmn:sequenceFlow id="f_odoo_skip" name="Задача існує" sourceRef="GW_odoo_check" targetRef="Merge_odoo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=is defined(odoo_task_id) and odoo_task_id != null</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_odoo_to_merge" sourceRef="task_create_odoo" targetRef="Merge_odoo" />
    <bpmn:sequenceFlow id="f_merge_to_wait" sourceRef="Merge_odoo" targetRef="catch_pr_created" />
    <bpmn:sequenceFlow id="f_catch_to_review" sourceRef="catch_pr_created" targetRef="catch_review_done" />
    <bpmn:sequenceFlow id="f_review_to_gw_score" sourceRef="catch_review_done" targetRef="gw_review_score" />
    <bpmn:sequenceFlow id="f_review_ok" name="OK" sourceRef="gw_review_score" targetRef="timer_wait_deploy" />
    <bpmn:sequenceFlow id="f_review_low" name="Низька оцінка" sourceRef="gw_review_score" targetRef="task_comment_rework">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=review_score &lt; 7 or has_critical_issues = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_timer_to_verify_staging" sourceRef="timer_wait_deploy" targetRef="call_verify_staging" />
    <bpmn:sequenceFlow id="f_verify_staging_to_gw" sourceRef="call_verify_staging" targetRef="gw_staging_ok" />
    <bpmn:sequenceFlow id="f_staging_ok" name="OK" sourceRef="gw_staging_ok" targetRef="task_undraft_pr" />
    <bpmn:sequenceFlow id="f_staging_rejected" name="Проблеми" sourceRef="gw_staging_ok" targetRef="task_comment_staging_reject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=staging_approved = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_staging_reject_to_rework" sourceRef="task_comment_staging_reject" targetRef="task_comment_rework" />
    <bpmn:sequenceFlow id="f_undraft_to_verify_merge" sourceRef="task_undraft_pr" targetRef="call_verify_merge" />
    <bpmn:sequenceFlow id="f_verify_merge_to_gw" sourceRef="call_verify_merge" targetRef="gw_merge_ok" />
    <bpmn:sequenceFlow id="f_merge_ok" name="OK" sourceRef="gw_merge_ok" targetRef="task_github_merge" />
    <bpmn:sequenceFlow id="f_merge_rejected" name="Відхилено" sourceRef="gw_merge_ok" targetRef="task_comment_merge_reject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=merge_approved = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_merge_reject_to_rework" sourceRef="task_comment_merge_reject" targetRef="task_comment_rework" />
    <bpmn:sequenceFlow id="f_github_merge_to_verify_prod" sourceRef="task_github_merge" targetRef="call_verify_prod" />
    <bpmn:sequenceFlow id="f_verify_prod_to_end" sourceRef="call_verify_prod" targetRef="evt_end_success" />
    <bpmn:sequenceFlow id="f_rework_to_catch" sourceRef="task_comment_rework" targetRef="catch_pr_rework" />
    <bpmn:sequenceFlow id="f_rework_catch_to_review" sourceRef="catch_pr_rework" targetRef="catch_review_done" />
    <bpmn:sequenceFlow id="f_rework_reminder" sourceRef="timer_rework_reminder" targetRef="task_send_rework_reminder" />
    <bpmn:sequenceFlow id="f_to_End_rem_rework" sourceRef="task_send_rework_reminder" targetRef="End_rem_rework" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_feature">
    <bpmndi:BPMNPlane id="BPMNPlane_feature" bpmnElement="feature-to-production">
      <bpmndi:BPMNShape id="start_manual_di" bpmnElement="start_manual">
        <dc:Bounds x="152" y="282" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="127" y="318" width="87" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_odoo_check_di" bpmnElement="GW_odoo_check" isMarkerVisible="true">
        <dc:Bounds x="248" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
