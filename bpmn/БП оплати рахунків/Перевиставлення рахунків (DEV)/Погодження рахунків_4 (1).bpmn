          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Оплачуємо? (ТП, &#34; + (if x_studio_camunda_invoice_type != null then x_studio_camunda_invoice_type else &#34;—&#34;) + &#34;): &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34; №&#34; + x_studio_camunda_invoice_number + &#34; — &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#34;, description: &#34;&#60;b&#62;Постачальник:&#60;/b&#62; &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Сума:&#60;/b&#62; &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#60;br/&#62;1. Прийміть рішення щодо оплати рахунку.&#60;br/&#62;2. У полі «Оплачуємо» вкажіть «Так» якщо оплачуємо, «Ні» якщо відхиляємо.&#60;br/&#62;3. Змініть стадію задачі на &#60;b&#62;«Виконано»&#60;/b&#62;, щоб процес пішов далі.&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, parent_process_instance_key: parent_process_instance_key, x_studio_camunda_pidrozdil: if x_studio_camunda_pidrozdil != null then x_studio_camunda_pidrozdil else null}" target="body" />
          <zeebe:output source="= x_studio_camunda_pay" target="x_studio_camunda_pay" />
          <zeebe:output source="= x_studio_camunda_cash_on_site" target="x_studio_camunda_cash_on_site" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_appr_tp_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_07q19rg</bpmn:outgoing>
    </bpmn:userTask>
