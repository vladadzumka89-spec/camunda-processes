    <bpmn:userTask id="Activity_1glu1uv" name="Перевірити чи платна зміна ФОП та вказати Тип орендаря">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Перевірити умови зміни ФОП на &#34; + selected_store, description: &#34;&#60;b&#62;Магазин:&#60;/b&#62; &#34; + selected_store + &#34;&#60;br/&#62;&#60;b&#62;ФОП:&#60;/b&#62; &#34; + fop_name + &#34; (дохід &#34; + string(total_income) + &#34; грн, &#34; + string(income_percent) + &#34;% ліміту)&#34; + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#34; + &#34;&#60;br/&#62;1. Перевірте чи ТРЦ бере плату за зміну ФОП на терміналі.&#34; + &#34;&#60;br/&#62;2. Оберіть «Так» або «Ні» у полі «Чи платна зміна ФОП».&#34; + &#34;&#60;br/&#62;3. Якщо зміна платна — з&#39;явиться поле «Тип орендаря», вкажіть хто орендар по договору:&#34; + &#34;&#60;br/&#62;   • &#60;b&#62;ТП&#60;/b&#62; — договір на Технопростір&#34; + &#34;&#60;br/&#62;   • &#60;b&#62;ТП+&#60;/b&#62; — договір на Технопростір Плюс&#34; + &#34;&#60;br/&#62;   • &#60;b&#62;ФОП&#60;/b&#62; — договір на ФОП&#34; + &#34;&#60;br/&#62;4. Змініть стадію задачі на &#60;b&#62;«Виконано»&#60;/b&#62;, щоб процес пішов далі.&#34;, x_studio_camunda_fop_name: fop_name, x_studio_camunda_total_income: total_income, x_studio_camunda_days_to_limit: days_to_limit, x_studio_camunda_selected_store: selected_store, x_studio_camunda_role_code: &#34;rental_manager&#34;, parent_id: odoo_task_id, _model: &#34;project.project&#34;, _id: 524, process_instance_key: process_instance_key, x_studio_camunda_task_code: &#34;check_paid&#34;}" target="body" />
          <zeebe:output source="= x_studio_camunda_is_paid_change" target="is_paid_change" />
          <zeebe:output source="=x_studio_camunda_tenant_type" target="tenant_type" />
        </zeebe:ioMapping>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_15htyy8</bpmn:incoming>
      <bpmn:outgoing>Flow_14egqul</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_113c8jv" name="Сповістити ТРЦ про зміну ФОП з вказаною датою переключення">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Сповістити ТРЦ про зміну ФОП &#34; + fop_name + &#34; на &#34; + selected_store, description: &#34;&#60;b&#62;Магазин:&#60;/b&#62; &#34; + selected_store + &#34;&#60;br/&#62;&#60;b&#62;Старий ФОП:&#60;/b&#62; &#34; + fop_name + &#34;&#60;br/&#62;&#60;b&#62;Новий ФОП:&#60;/b&#62; &#34; + (if is defined(new_fop_name) then new_fop_name else &#34;(не вказано)&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Дата переключення:&#60;/b&#62; &#34; + (if is defined(switch_date) then switch_date else &#34;(не визначено)&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Чи платна зміна:&#60;/b&#62; &#34; + (if is_paid_change = &#34;Так&#34; then &#34;Так&#34; else &#34;Ні&#34;) + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#34; + &#34;&#60;br/&#62;1. Напишіть лист ТРЦ з проханням погодити переключення терміналу на нового ФОП із вказаною датою.&#34; + &#34;&#60;br/&#62;2. Змініть стадію задачі на &#60;b&#62;«Виконано»&#60;/b&#62;, щоб процес пішов далі.&#34;, x_studio_camunda_fop_name: fop_name, x_studio_camunda_total_income: total_income, x_studio_camunda_days_to_limit: days_to_limit, x_studio_camunda_selected_store: selected_store, x_studio_camunda_is_paid_change: (if is defined(is_paid_change) then is_paid_change else &#34;Ні&#34;), x_studio_camunda_new_fop_name: (if is defined(new_fop_name) then new_fop_name else &#34;&#34;), x_studio_camunda_switch_date: (if is defined(switch_date) then switch_date else &#34;&#34;), x_studio_camunda_role_code: &#34;rental_manager&#34;, parent_id: odoo_task_id, _model: &#34;project.project&#34;, _id: 524, process_instance_key: process_instance_key, x_studio_camunda_task_code: &#34;notify_trc&#34;}" target="body" />
        </zeebe:ioMapping>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
