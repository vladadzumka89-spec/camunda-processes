<?xml version="1.0" encoding="UTF-8"?>
<definitions
  xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
  xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
  xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
  id="Definitions_supplier_detail"
  name="Постачальники — деталізація"
  namespace="http://camunda.org/schema/1.0/dmn"
  exporter="Camunda Web Modeler"
  exporterVersion="e787c33"
  modeler:executionPlatform="Camunda Cloud"
  modeler:executionPlatformVersion="8.8.0">

  <decision id="supplier-detailization" name="Чи надає ТРЦ деталізацію комунальних?">
    <decisionTable id="dt_supplier_detail" hitPolicy="FIRST">

      <!-- INPUT -->
      <input id="input_partner_name" label="Назва постачальника">
        <inputExpression id="ie_partner_name" typeRef="string">
          <text>x_studio_camunda_partner_name</text>
        </inputExpression>
      </input>

      <!-- OUTPUT -->
      <output id="output_provides_detail"
              label="Надає деталізацію?"
              name="x_studio_camunda_provides_detailization"
              typeRef="boolean" />

      <!-- ═══════════════════════════════════════════════════════════════
           Постачальники, які НАДАЮТЬ деталізацію
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_silpo">
        <description>Сільпо фуд — деталізація комунальних в окремому документі</description>
        <inputEntry id="ie_silpo"><text>"Сільпо фуд"</text></inputEntry>
        <outputEntry id="oe_silpo"><text>true</text></outputEntry>
      </rule>

      <rule id="rule_german">
        <description>Герман Олена Василівна — надає деталізацію</description>
        <inputEntry id="ie_german"><text>"Герман Олена Василівна"</text></inputEntry>
        <outputEntry id="oe_german"><text>true</text></outputEntry>
      </rule>

      <rule id="rule_lvivbudmax">
        <description>ЛЬВІВБУДМАКС-ІНВЕСТ, ТЗОВ — надає деталізацію</description>
        <inputEntry id="ie_lvivbudmax"><text>"ЛЬВІВБУДМАКС-ІНВЕСТ, ТЗОВ"</text></inputEntry>
        <outputEntry id="oe_lvivbudmax"><text>true</text></outputEntry>
      </rule>

      <rule id="rule_zhk">
        <description>Житомирський меблевий комбінат — надає деталізацію</description>
        <inputEntry id="ie_zhk"><text>"Житомирський меблевий комбінат"</text></inputEntry>
        <outputEntry id="oe_zhk"><text>true</text></outputEntry>
      </rule>

      <rule id="rule_kroppers">
        <description>Кропперс груп — надає деталізацію</description>
        <inputEntry id="ie_kroppers"><text>"Кропперс груп"</text></inputEntry>
        <outputEntry id="oe_kroppers"><text>true</text></outputEntry>
      </rule>

      <!-- ═══════════════════════════════════════════════════════════════
           Постачальники, які НЕ надають деталізацію
           (placeholder — замінити реальними назвами ТРЦ)
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_no_detail_placeholder_1">
        <description>Placeholder 1 — ТРЦ що не надає деталізацію (замінити реальною назвою)</description>
        <inputEntry id="ie_no_detail_1"><text>"PLACEHOLDER_ТРЦ_1"</text></inputEntry>
        <outputEntry id="oe_no_detail_1"><text>false</text></outputEntry>
      </rule>

      <rule id="rule_no_detail_placeholder_2">
        <description>Placeholder 2 — ТРЦ що не надає деталізацію (замінити реальною назвою)</description>
        <inputEntry id="ie_no_detail_2"><text>"PLACEHOLDER_ТРЦ_2"</text></inputEntry>
        <outputEntry id="oe_no_detail_2"><text>false</text></outputEntry>
      </rule>

      <!-- ═══════════════════════════════════════════════════════════════
           DEFAULT — невідомий постачальник, вважаємо що надає
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_default">
        <description>Невідомий постачальник — за замовчуванням надає деталізацію</description>
        <inputEntry id="ie_default"><text></text></inputEntry>
        <outputEntry id="oe_default"><text>true</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_supplier_detail">
      <dmndi:DMNShape id="DMNShape_supplier_detail" dmnElementRef="supplier-detailization">
        <dc:Bounds x="200" y="200" width="200" height="80" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
