    <bpmn:serviceTask id="ST_not_approved_tp_end" name="Рахунок не погоджено">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;❌ Рахунок не погоджено (ТП, &#34; + (if x_studio_camunda_approved = &#34;no&#34; then &#34;перевірка суми не пройшла&#34; else if x_studio_camunda_pay = &#34;no&#34; then &#34;відмова в оплаті&#34; else &#34;відхилено&#34;) + &#34;): &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34; №&#34; + x_studio_camunda_invoice_number + &#34; — &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#34;,&#10;description: &#34;&#60;b&#62;Постачальник:&#60;/b&#62; &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Сума:&#60;/b&#62; &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#60;br/&#62;&#60;b&#62;Причина:&#60;/b&#62; &#34; + (if x_studio_camunda_approved = &#34;no&#34; then &#34;рахунок ТП відхилено на етапі перевірки суми (не погоджено).&#34; else if x_studio_camunda_pay = &#34;no&#34; then &#34;рахунок ТП погоджено, але вирішено НЕ оплачувати.&#34; else &#34;рахунок ТП відхилено.&#34;) + &#34;&#60;br/&#62;&#60;br/&#62;Це задача-сповіщення, дій не потребує.&#34;,&#10;_model: &#34;project.project&#34;, _id: 13946,&#10;process_instance_key: process_instance_key,&#10;parent_process_instance_key: parent_process_instance_key,&#10;x_studio_camunda_approved: &#34;no&#34;,&#10;x_studio_camunda_pidrozdil: if x_studio_camunda_pidrozdil != null then x_studio_camunda_pidrozdil else null}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_appr_tp_no</bpmn:incoming>
      <bpmn:incoming>Flow_pay_tp_no</bpmn:incoming>
      <bpmn:outgoing>Flow_not_appr_tp_end</bpmn:outgoing>
    </bpmn:serviceTask>
