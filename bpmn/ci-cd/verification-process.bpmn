<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_verification" targetNamespace="http://tut.ua/bpmn/verification" exporter="Claude Code" exporterVersion="1.0">

  

  <bpmn:message id="Message_odoo_task_done" name="msg_odoo_task_done">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(correlation_key)" />
    </bpmn:extensionElements>
  </bpmn:message>

  <bpmn:process id="verification-process" name="Verification Process" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="1.0" />
    </bpmn:extensionElements>

    
    <bpmn:startEvent id="evt_start" name="Початок верифікації">
      <bpmn:outgoing>f_start_to_create</bpmn:outgoing>
    </bpmn:startEvent>

    
    <bpmn:serviceTask id="ST_create_task" name="Створити задачу в Odoo">
      <bpmn:documentation>Створює задачу в Odoo через webhook. Використовує task_name та task_description з input.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-cicd" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=odoo_webhook_url" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: task_name, description: task_description, _model: &quot;project.project&quot;, _id: odoo_project_id, process_instance_key: correlation_key}" target="body" />
          <zeebe:input source="=true" target="ignore_errors" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_start_to_create</bpmn:incoming>
      <bpmn:outgoing>f_create_to_wait</bpmn:outgoing>
    </bpmn:serviceTask>

    
    <bpmn:receiveTask id="recv_wait_done" name="Чекаємо виконання задачі" messageRef="Message_odoo_task_done">
      <bpmn:documentation>Чекає поки виконавець завершить задачу в Odoo.
Odoo automation надсилає webhook з результатом.</bpmn:documentation>
      <bpmn:incoming>f_create_to_wait</bpmn:incoming>
      <bpmn:outgoing>f_wait_to_end</bpmn:outgoing>
    </bpmn:receiveTask>

    
    <bpmn:boundaryEvent id="BE_rem" name="Нагадування" cancelActivity="false" attachedToRef="recv_wait_done">
      <bpmn:outgoing>f_rem</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_rem">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">=if is defined(reminder_cycle) and reminder_cycle != null then reminder_cycle else "R/PT4H"</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="ST_rem" name="⚠️ Нагадування">
      <bpmn:documentation>Створює нагадування в Odoo.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-cicd" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=odoo_webhook_url" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: &quot;⚠️ НАГАДУВАННЯ: &quot; + task_name, description: &quot;&lt;p&gt;⚠️ НАГАДУВАННЯ: Задача очікує на виконання.&lt;/p&gt;&quot;, _model: &quot;project.project&quot;, _id: odoo_project_id, process_instance_key: correlation_key}" target="body" />
          <zeebe:input source="=true" target="ignore_errors" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_rem</bpmn:incoming>
      <bpmn:outgoing>f_to_End_rem</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_rem" name="Нагадування надіслано">
      <bpmn:incoming>f_to_End_rem</bpmn:incoming>
    </bpmn:endEvent>

    
    <bpmn:boundaryEvent id="BE_ded" name="Дедлайн" cancelActivity="false" attachedToRef="recv_wait_done">
      <bpmn:outgoing>f_ded</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_ded">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">=if is defined(deadline_duration) and deadline_duration != null then deadline_duration else "P3D"</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="ST_esc" name="🔴 Ескалація">
      <bpmn:documentation>Створює ескалаційну задачу в Odoo для керівника.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-cicd" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=odoo_webhook_url" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: &quot;🔴 ЕСКАЛАЦІЯ: &quot; + task_name, description: &quot;Задача не виконана вчасно. Потрібне втручання керівника.&quot;, _model: &quot;project.project&quot;, _id: odoo_project_id, process_instance_key: correlation_key}" target="body" />
          <zeebe:input source="=true" target="ignore_errors" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_ded</bpmn:incoming>
      <bpmn:outgoing>f_to_End_esc</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_esc" name="Ескалацію створено">
      <bpmn:incoming>f_to_End_esc</bpmn:incoming>
    </bpmn:endEvent>

    
    <bpmn:endEvent id="evt_end" name="Верифікацію завершено">
      <bpmn:incoming>f_wait_to_end</bpmn:incoming>
    </bpmn:endEvent>

    
    <bpmn:sequenceFlow id="f_start_to_create" sourceRef="evt_start" targetRef="ST_create_task" />
    <bpmn:sequenceFlow id="f_create_to_wait" sourceRef="ST_create_task" targetRef="recv_wait_done" />
    <bpmn:sequenceFlow id="f_wait_to_end" sourceRef="recv_wait_done" targetRef="evt_end" />
    <bpmn:sequenceFlow id="f_rem" sourceRef="BE_rem" targetRef="ST_rem" />
    <bpmn:sequenceFlow id="f_to_End_rem" sourceRef="ST_rem" targetRef="End_rem" />
    <bpmn:sequenceFlow id="f_ded" sourceRef="BE_ded" targetRef="ST_esc" />
    <bpmn:sequenceFlow id="f_to_End_esc" sourceRef="ST_esc" targetRef="End_esc" />

  </bpmn:process>

  
  <bpmndi:BPMNDiagram id="BPMNDiagram_1"><bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="verification-process"><bpmndi:BPMNShape id="evt_start_di" bpmnElement="evt_start"><dc:Bounds x="207" y="282" width="36" height="36" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="ST_create_task_di" bpmnElement="ST_create_task"><dc:Bounds x="291" y="260" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="recv_wait_done_di" bpmnElement="recv_wait_done"><dc:Bounds x="471" y="260" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="evt_end_di" bpmnElement="evt_end"><dc:Bounds x="683" y="182" width="36" height="36" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="ST_rem_di" bpmnElement="ST_rem"><dc:Bounds x="651" y="238" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="ST_esc_di" bpmnElement="ST_esc"><dc:Bounds x="651" y="338" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="End_rem_di" bpmnElement="End_rem"><dc:Bounds x="863" y="254" width="36" height="36" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="End_esc_di" bpmnElement="End_esc"><dc:Bounds x="863" y="310" width="36" height="36" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="BE_rem_di" bpmnElement="BE_rem"><dc:Bounds x="481" y="322" width="36" height="36" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="BE_ded_di" bpmnElement="BE_ded"><dc:Bounds x="525" y="322" width="36" height="36" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNEdge id="f_start_to_create_di" bpmnElement="f_start_to_create"><di:waypoint x="243" y="300" /><di:waypoint x="291" y="300" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="f_create_to_wait_di" bpmnElement="f_create_to_wait"><di:waypoint x="391" y="300" /><di:waypoint x="471" y="300" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="f_wait_to_end_di" bpmnElement="f_wait_to_end"><di:waypoint x="571" y="300" /><di:waypoint x="601" y="300" /><di:waypoint x="601" y="200" /><di:waypoint x="683" y="200" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="f_rem_di" bpmnElement="f_rem"><di:waypoint x="499" y="358" /><di:waypoint x="499" y="278" /><di:waypoint x="651" y="278" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="f_to_End_rem_di" bpmnElement="f_to_End_rem"><di:waypoint x="751" y="278" /><di:waypoint x="781" y="278" /><di:waypoint x="781" y="272" /><di:waypoint x="863" y="272" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="f_ded_di" bpmnElement="f_ded"><di:waypoint x="543" y="358" /><di:waypoint x="543" y="378" /><di:waypoint x="651" y="378" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="f_to_End_esc_di" bpmnElement="f_to_End_esc"><di:waypoint x="751" y="378" /><di:waypoint x="781" y="378" /><di:waypoint x="781" y="328" /><di:waypoint x="863" y="328" /></bpmndi:BPMNEdge></bpmndi:BPMNPlane></bpmndi:BPMNDiagram></bpmn:definitions>