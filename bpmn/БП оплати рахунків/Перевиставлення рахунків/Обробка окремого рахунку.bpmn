      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= is defined(x_studio_camunda_buyer_name) and x_studio_camunda_buyer_name != null and (contains(lower case(x_studio_camunda_buyer_name), "технопростір") or contains(lower case(x_studio_camunda_buyer_name), "технопростiр") or contains(lower case(x_studio_camunda_buyer_name), "техно простір") or contains(lower case(x_studio_camunda_buyer_name), "техно простiр"))</bpmn:conditionExpression>
