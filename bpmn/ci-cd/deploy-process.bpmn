      <bpmndi:BPMNShape id="ST_publish_no_changes_di" bpmnElement="ST_publish_no_changes">
        <dc:Bounds x="1345" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="evt_end_no_changes_di" bpmnElement="evt_end_no_changes">
        <dc:Bounds x="1527" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_detect_modules_di" bpmnElement="task_detect_modules">
        <dc:Bounds x="1345" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <!-- ── Docker build diamond ── -->
      <bpmndi:BPMNShape id="gw_docker_build_di" bpmnElement="gw_docker_build" isMarkerVisible="true">
        <dc:Bounds x="1550" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_docker_build_di" bpmnElement="task_docker_build">
