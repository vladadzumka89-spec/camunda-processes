<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="e787c33" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:collaboration id="Collab_1">
    <bpmn:participant id="Pool_1" name="Планування щомісячних оплат ФОП" processRef="Process_payment_planning" />
  </bpmn:collaboration>
  <bpmn:process id="Process_payment_planning" name="Планування щомісячних оплат ФОП" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="1.0" />
    </bpmn:extensionElements>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_system" name="Система (автоматично)">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_odoo_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_create_main</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Merge_odoo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_get_fops</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CA_period_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CA_period_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CA_period_3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_report</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_1" name="Старт">
      <bpmn:outgoing>Flow_start_to_gw</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_odoo_check" name="Задача в Odoo існує?" default="Flow_odoo_default">
      <bpmn:incoming>Flow_start_to_gw</bpmn:incoming>
      <bpmn:outgoing>Flow_odoo_has_task</bpmn:outgoing>
      <bpmn:outgoing>Flow_odoo_default</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ST_create_main" name="Створити головне завдання">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Планування щомісячних оплат ФОП&#34;, create_process: true, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_odoo_default</bpmn:incoming>
      <bpmn:outgoing>Flow_create_to_merge</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Merge_odoo">
      <bpmn:incoming>Flow_odoo_has_task</bpmn:incoming>
      <bpmn:incoming>Flow_create_to_merge</bpmn:incoming>
      <bpmn:outgoing>Flow_merge_to_fops</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ST_get_fops" name="Отримати список ФОП-ів">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/api/server-action&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;, &#34;X-API-Key&#34;:&#34;632b5ed6-091f-48db-bd01-1e60aeb10bfc&#34;}" target="headers" />
          <zeebe:input source="= {action_identifier: &#34;get_fop_list&#34;, context: {}, payload: {}}" target="body" />
          <zeebe:output source="= result.data" target="fops" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_merge_to_fops</bpmn:incoming>
      <bpmn:outgoing>Flow_fops_to_ca1</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="CA_period_1" name="Оплати періоду 1-10">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Process_payment_period" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="= fops" target="fops" />
          <zeebe:input source="= &#34;1-10&#34;" target="payment_period" />
          <zeebe:input source="= odoo_task_id" target="odoo_task_id" />
          <zeebe:input source="= process_instance_key" target="process_instance_key" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_fops_to_ca1</bpmn:incoming>
      <bpmn:outgoing>Flow_ca1_to_ca2</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="CA_period_2" name="Оплати періоду 11-20">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Process_payment_period" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="= fops" target="fops" />
          <zeebe:input source="= &#34;11-20&#34;" target="payment_period" />
          <zeebe:input source="= odoo_task_id" target="odoo_task_id" />
          <zeebe:input source="= process_instance_key" target="process_instance_key" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ca1_to_ca2</bpmn:incoming>
      <bpmn:outgoing>Flow_ca2_to_ca3</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="CA_period_3" name="Оплати періоду 21-30">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Process_payment_period" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="= fops" target="fops" />
          <zeebe:input source="= &#34;21-30&#34;" target="payment_period" />
          <zeebe:input source="= odoo_task_id" target="odoo_task_id" />
          <zeebe:input source="= process_instance_key" target="process_instance_key" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ca2_to_ca3</bpmn:incoming>
      <bpmn:outgoing>Flow_ca3_to_report</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:serviceTask id="ST_report" name="Сформувати звіт">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Звіт: Планування оплат ФОП завершено&#34;, description: &#34;Оплати за всі періоди (1-10, 11-20, 21-30) підтверджено та платіжні доручення створено.&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ca3_to_report</bpmn:incoming>
      <bpmn:outgoing>Flow_report_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_1" name="Завершено">
      <bpmn:incoming>Flow_report_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_start_to_gw" sourceRef="Start_1" targetRef="GW_odoo_check" />
    <bpmn:sequenceFlow id="Flow_odoo_has_task" name="Задача існує" sourceRef="GW_odoo_check" targetRef="Merge_odoo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= is defined(odoo_task_id) and odoo_task_id != null</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_odoo_default" sourceRef="GW_odoo_check" targetRef="ST_create_main" />
    <bpmn:sequenceFlow id="Flow_create_to_merge" sourceRef="ST_create_main" targetRef="Merge_odoo" />
    <bpmn:sequenceFlow id="Flow_merge_to_fops" sourceRef="Merge_odoo" targetRef="ST_get_fops" />
    <bpmn:sequenceFlow id="Flow_fops_to_ca1" sourceRef="ST_get_fops" targetRef="CA_period_1" />
    <bpmn:sequenceFlow id="Flow_ca1_to_ca2" sourceRef="CA_period_1" targetRef="CA_period_2" />
    <bpmn:sequenceFlow id="Flow_ca2_to_ca3" sourceRef="CA_period_2" targetRef="CA_period_3" />
    <bpmn:sequenceFlow id="Flow_ca3_to_report" sourceRef="CA_period_3" targetRef="ST_report" />
    <bpmn:sequenceFlow id="Flow_report_to_end" sourceRef="ST_report" targetRef="End_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collab_1">
      <bpmndi:BPMNShape id="Pool_1_di" bpmnElement="Pool_1" isHorizontal="true">
        <dc:Bounds x="105" y="80" width="1500" height="300" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_system_di" bpmnElement="Lane_system" isHorizontal="true">
        <dc:Bounds x="135" y="80" width="1470" height="300" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_1_di" bpmnElement="Start_1">
        <dc:Bounds x="187" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="191" y="185" width="31" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_odoo_check_di" bpmnElement="GW_odoo_check" isMarkerVisible="true">
        <dc:Bounds x="270" y="135" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="258" y="100" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST_create_main_di" bpmnElement="ST_create_main">
        <dc:Bounds x="310" y="260" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Merge_odoo_di" bpmnElement="Merge_odoo" isMarkerVisible="true">
        <dc:Bounds x="450" y="135" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST_get_fops_di" bpmnElement="ST_get_fops">
        <dc:Bounds x="550" y="120" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CA_period_1_di" bpmnElement="CA_period_1">
        <dc:Bounds x="710" y="120" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CA_period_2_di" bpmnElement="CA_period_2">
        <dc:Bounds x="890" y="120" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CA_period_3_di" bpmnElement="CA_period_3">
        <dc:Bounds x="1070" y="120" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST_report_di" bpmnElement="ST_report">
        <dc:Bounds x="1250" y="120" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_1_di" bpmnElement="End_1">
        <dc:Bounds x="1410" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1400" y="185" width="57" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_to_gw_di" bpmnElement="Flow_start_to_gw">
        <di:waypoint x="223" y="160" />
        <di:waypoint x="270" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_odoo_has_task_di" bpmnElement="Flow_odoo_has_task">
        <di:waypoint x="320" y="160" />
        <di:waypoint x="450" y="160" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="353" y="142" width="66" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_odoo_default_di" bpmnElement="Flow_odoo_default">
        <di:waypoint x="295" y="185" />
        <di:waypoint x="295" y="300" />
        <di:waypoint x="310" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_create_to_merge_di" bpmnElement="Flow_create_to_merge">
        <di:waypoint x="410" y="300" />
        <di:waypoint x="475" y="300" />
        <di:waypoint x="475" y="185" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_merge_to_fops_di" bpmnElement="Flow_merge_to_fops">
        <di:waypoint x="500" y="160" />
        <di:waypoint x="550" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_fops_to_ca1_di" bpmnElement="Flow_fops_to_ca1">
        <di:waypoint x="650" y="160" />
        <di:waypoint x="710" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ca1_to_ca2_di" bpmnElement="Flow_ca1_to_ca2">
        <di:waypoint x="830" y="160" />
        <di:waypoint x="890" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ca2_to_ca3_di" bpmnElement="Flow_ca2_to_ca3">
        <di:waypoint x="1010" y="160" />
        <di:waypoint x="1070" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ca3_to_report_di" bpmnElement="Flow_ca3_to_report">
        <di:waypoint x="1190" y="160" />
        <di:waypoint x="1250" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_report_to_end_di" bpmnElement="Flow_report_to_end">
        <di:waypoint x="1350" y="160" />
        <di:waypoint x="1410" y="160" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
