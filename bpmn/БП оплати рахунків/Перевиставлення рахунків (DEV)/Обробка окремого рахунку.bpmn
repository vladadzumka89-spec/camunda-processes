        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_timer_to_buh</bpmn:incoming>
      <bpmn:incoming>Flow_rent_no</bpmn:incoming>
      <bpmn:outgoing>Flow_buh_to_merge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:callActivity id="Activity_0pb3hxn" name="Погодження рахунку на стороні ДО3">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Process_0t31x9n" />
