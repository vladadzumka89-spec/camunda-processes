<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_deploy" targetNamespace="http://tut.ua/bpmn/deploy" exporter="Claude Code" exporterVersion="1.0">
  <bpmn:error id="Error_deploy_failed" name="Deploy Failed" errorCode="DEPLOY_FAILED" />
  <bpmn:process id="deploy-process" name="Deploy Process" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="14.0" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="evt_start" name="Початок деплою">
      <bpmn:outgoing>f_start_to_parent_check</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="gw_parent_check" name="Є батьківський процес?" default="f_no_parent">
      <bpmn:incoming>f_start_to_parent_check</bpmn:incoming>
      <bpmn:outgoing>f_has_parent</bpmn:outgoing>
      <bpmn:outgoing>f_no_parent</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ST_create_deploy_task" name="Створити задачу деплою в Odoo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-cicd" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=odoo_webhook_url" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: &quot;[deploy] &quot; + (if is defined(server_host) and server_host != null then server_host else &quot;unknown&quot;) + &quot; ← &quot; + (if is defined(branch) and branch != null then branch else &quot;staging&quot;) + (if is defined(pr_number) and pr_number != null then &quot; (PR #&quot; + string(pr_number) + &quot;)&quot; else &quot;&quot;) + (if is defined(pr_title) and pr_title != null and pr_title != &quot;&quot; then &quot; — &quot; + pr_title else &quot;&quot;) + (if is defined(pusher) and pusher != null and pusher != &quot;&quot; then &quot; by @&quot; + pusher else &quot;&quot;), description: &quot;&lt;p&gt;&lt;b&gt;Сервер:&lt;/b&gt; &quot; + (if is defined(server_host) and server_host != null then server_host else &quot;unknown&quot;) + &quot;&lt;br/&gt;&lt;b&gt;Гілка:&lt;/b&gt; &quot; + (if is defined(branch) and branch != null then branch else &quot;staging&quot;) + &quot;&lt;br/&gt;&lt;b&gt;SHA:&lt;/b&gt; &quot; + (if is defined(trigger_sha) and trigger_sha != null then trigger_sha else &quot;—&quot;) + (if is defined(pr_number) and pr_number != null then &quot;&lt;br/&gt;&lt;b&gt;PR:&lt;/b&gt; #&quot; + string(pr_number) else &quot;&quot;) + (if is defined(compare_url) and compare_url != null and compare_url != &quot;&quot; then &quot;&lt;br/&gt;&lt;b&gt;Diff:&lt;/b&gt; &lt;a href=\&quot;&quot; + compare_url + &quot;\&quot;&gt;GitHub&lt;/a&gt;&quot; else &quot;&quot;) + (if is defined(pusher) and pusher != null and pusher != &quot;&quot; then &quot;&lt;br/&gt;&lt;b&gt;Автор:&lt;/b&gt; &quot; + pusher else &quot;&quot;) + &quot;&lt;br/&gt;&lt;b&gt;Процес:&lt;/b&gt; &lt;a href=&apos;http://camunda25.a.local:8088/operate/#/processes/&quot; + string(process_instance_key) + &quot;&apos;&gt;Переглянути в Operate&lt;/a&gt;&lt;/p&gt;&quot;, create_process: true, _model: &quot;project.project&quot;, _id: if is defined(odoo_project_id) and odoo_project_id != null then odoo_project_id else 560, bpmn_process_id: &quot;deploy-process&quot;, process_instance_key: string(process_instance_key)}" target="body" />
          <zeebe:input source="=&quot;odoo_create_response&quot;" target="result_variable_name" />
          <zeebe:input source="=true" target="ignore_errors" />
          <zeebe:output source="=if is defined(odoo_create_response) and odoo_create_response != null and is defined(odoo_create_response.id) then string(odoo_create_response.id) else string(process_instance_key)" target="parent_process_instance_key" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_no_parent</bpmn:incoming>
      <bpmn:outgoing>f_created_to_merge</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ST_create_subtask" name="Створити підзадачу деплою в Odoo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-cicd" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;POST&quot;" target="method" />
          <zeebe:input source="=odoo_webhook_url" target="url" />
          <zeebe:input source="={&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="={name: &quot;[deploy] &quot; + (if is defined(server_host) and server_host != null then server_host else &quot;unknown&quot;) + &quot; ← &quot; + (if is defined(branch) and branch != null then branch else &quot;staging&quot;), description: &quot;&lt;p&gt;Автоматичний деплой на &quot; + (if is defined(server_host) and server_host != null then server_host else &quot;unknown&quot;) + &quot;&lt;br/&gt;&lt;b&gt;Процес:&lt;/b&gt; &lt;a href=&apos;http://camunda25.a.local:8088/operate/#/processes/&quot; + string(process_instance_key) + &quot;&apos;&gt;Переглянути в Operate&lt;/a&gt;&lt;/p&gt;&quot;, parent_process_instance_key: parent_process_instance_key, _model: &quot;project.project&quot;, _id: if is defined(odoo_project_id) and odoo_project_id != null then odoo_project_id else 560, bpmn_process_id: &quot;deploy-process&quot;, process_instance_key: string(process_instance_key)}" target="body" />
          <zeebe:input source="=&quot;odoo_subtask_response&quot;" target="result_variable_name" />
          <zeebe:input source="=true" target="ignore_errors" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_has_parent</bpmn:incoming>
      <bpmn:outgoing>f_subtask_to_merge</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_merge_parent">
      <bpmn:incoming>f_subtask_to_merge</bpmn:incoming>
      <bpmn:incoming>f_created_to_merge</bpmn:incoming>
      <bpmn:outgoing>f01_merged</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_git_pull" name="Завантажити код">
      <bpmn:documentation>SSH на сервер, git fetch origin, checkout branch.
Retry 3x з інтервалом 5s.
Output: old_commit, new_commit, has_changes</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="git-pull" retries="3" />
        <zeebe:executionListeners>
          <zeebe:executionListener eventType="end" type="progress" retries="3" />
        </zeebe:executionListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>f_checkpoint_to_pull</bpmn:incoming>
      <bpmn:outgoing>f_pull_to_detect</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_detect_modules" name="Визначити змінені модулі">
      <bpmn:documentation>Checksum порівняння: диск vs контейнер.
Output: changed_modules (CSV або порожній)</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="detect-modules" retries="1" />
        <zeebe:executionListeners>
          <zeebe:executionListener eventType="end" type="progress" retries="3" />
        </zeebe:executionListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>f_pull_to_detect</bpmn:incoming>
      <bpmn:outgoing>f_detect_to_gw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_changes" name="Є зміни?" default="f_has_changes">
      <bpmn:incoming>f_detect_to_gw</bpmn:incoming>
      <bpmn:outgoing>f_no_changes</bpmn:outgoing>
      <bpmn:outgoing>f_has_changes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ST_publish_no_changes" name="Повідомити: без змін">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="publish-message" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;msg_deploy_done&quot;" target="message_name" />
          <zeebe:input source="=if is defined(trigger_sha) and trigger_sha != null then trigger_sha else &quot;none&quot;" target="correlation_key" />
          <zeebe:input source="=true" target="no_changes" />
        </zeebe:ioMapping>
        <zeebe:executionListeners>
          <zeebe:executionListener eventType="end" type="progress" retries="3" />
        </zeebe:executionListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>f_no_changes</bpmn:incoming>
      <bpmn:outgoing>f_no_changes_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="evt_end_no_changes" name="Без змін">
      <bpmn:incoming>f_no_changes_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="ST_db_remove" name="Видалити старий чекпоінт">
      <bpmn:documentation>Видаляє попередній чекпоінт перед створенням нового.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="db-remove" retries="2" />
      </bpmn:extensionElements>
      <bpmn:incoming>f01_merged</bpmn:incoming>
      <bpmn:outgoing>f_remove_to_checkpoint</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ST_db_checkpoint" name="DB Checkpoint">
      <bpmn:documentation>Створює зліпок через HTTP API перед деплоєм.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="db-checkpoint" retries="2" />
        <zeebe:executionListeners>
          <zeebe:executionListener eventType="end" type="progress" retries="3" />
        </zeebe:executionListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>f_remove_to_checkpoint</bpmn:incoming>
      <bpmn:outgoing>f_checkpoint_to_pull</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_module_update" name="Міграція БД (module-update)">
      <bpmn:documentation>Запускає окремий контейнер для міграції БД:
docker compose run --rm web odoo-bin -d DB -u MODULES --stop-after-init --no-http
Якщо &gt;10 модулів — використовує -u all.
Output: modules_updated</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="module-update" retries="1" />
        <zeebe:executionListeners>
          <zeebe:executionListener eventType="end" type="progress" retries="3" />
        </zeebe:executionListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>f_has_changes</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_cache_clear" name="Очистити кеш assets">
      <bpmn:documentation>DELETE FROM ir_attachment WHERE url LIKE '/web/assets/%' OR name LIKE 'web.assets%';
Запускає Odoo: docker compose up -d</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="cache-clear" retries="1" />
        <zeebe:executionListeners>
          <zeebe:executionListener eventType="end" type="progress" retries="3" />
        </zeebe:executionListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>f_merge_clickbot_to_cache</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_smoke_test" name="Перевірка запуску Odoo">
      <bpmn:documentation>Окремий контейнер: odoo-bin --stop-after-init --no-http (120s timeout).
Аналіз логів на CRITICAL/ERROR/ImportError/SyntaxError.
Output: smoke_passed</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="smoke-test" retries="1" />
        <zeebe:executionListeners>
          <zeebe:executionListener eventType="end" type="progress" retries="3" />
        </zeebe:executionListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f_smoke_to_gw_clickbot</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_http_verify" name="Перевірка доступності сайту">
      <bpmn:documentation>curl -sf http://localhost:PORT/web/login (24 спроби x 10s)</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-verify" retries="3" />
        <zeebe:executionListeners>
          <zeebe:executionListener eventType="end" type="progress" retries="3" />
        </zeebe:executionListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f_http_to_save</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_clickbot" name="Clickbot?" default="f_run_clickbot">
      <bpmn:incoming>f_smoke_to_gw_clickbot</bpmn:incoming>
      <bpmn:outgoing>f_run_clickbot</bpmn:outgoing>
      <bpmn:outgoing>f_skip_clickbot</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_clickbot" name="Автотестування інтерфейсу">
      <bpmn:documentation>Запускає clickbot в ізольованому Docker середовищі.
Дампить БД, відновлює в tmpfs PostgreSQL, запускає browser-тести.
Клікає по всіх меню Odoo, перевіряє що все працює.
Light — тільки app menus (~10 хв). Full — всі views + фільтри (~30 хв).
Output: clickbot_passed, clickbot_report, clickbot_failed_apps</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="clickbot-test" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="=server_host" target="server_host" />
          <zeebe:input source="=db_name" target="db_name" />
          <zeebe:input source="=if is defined(test_mode) and test_mode != null then test_mode else &quot;light&quot;" target="test_mode" />
        </zeebe:ioMapping>
        <zeebe:executionListeners>
          <zeebe:executionListener eventType="end" type="progress" retries="3" />
        </zeebe:executionListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>f_run_clickbot</bpmn:incoming>
      <bpmn:outgoing>f_clickbot_to_merge</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_merge_clickbot">
      <bpmn:incoming>f_skip_clickbot</bpmn:incoming>
      <bpmn:incoming>f_clickbot_to_merge</bpmn:incoming>
      <bpmn:outgoing>f_merge_clickbot_to_cache</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_save_state" name="Зберегти стан деплою">
      <bpmn:documentation>Записує new_commit SHA у .deploy-state/deploy_state_BRANCH</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="save-deploy-state" retries="1" />
        <zeebe:executionListeners>
          <zeebe:executionListener eventType="end" type="progress" retries="3" />
        </zeebe:executionListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>f_http_to_save</bpmn:incoming>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ST_publish_deploy_done" name="Повідомити про завершення">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="publish-message" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;msg_deploy_done&quot;" target="message_name" />
          <zeebe:input source="=if is defined(trigger_sha) and trigger_sha != null then trigger_sha else &quot;none&quot;" target="correlation_key" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f_publish_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="evt_end_success" name="Деплой успішний">
      <bpmn:incoming>f_publish_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="subprocess_error" name="Обробка помилок деплою" triggeredByEvent="true">
      <bpmn:startEvent id="evt_error_catch" name="Помилка деплою">
        <bpmn:outgoing>f_err_to_rollback</bpmn:outgoing>
        <bpmn:errorEventDefinition id="ErrorDef_catch" />
      </bpmn:startEvent>
      <bpmn:serviceTask id="task_rollback" name="Відкат до попередньої версії">
        <bpmn:documentation>Відкат на зліпок через HTTP API.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="rollback" retries="5" />
          <zeebe:ioMapping>
            <zeebe:input source="=if is defined(merge_sha) and merge_sha != null then merge_sha else &quot;&quot;" target="merge_sha" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>f_err_to_rollback</bpmn:incoming>
        <bpmn:outgoing>f_err2</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="ST_publish_deploy_failed" name="Повідомити про помилку">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="publish-message" retries="1" />
          <zeebe:ioMapping>
            <zeebe:input source="=&quot;msg_deploy_done&quot;" target="message_name" />
            <zeebe:input source="=if is defined(trigger_sha) and trigger_sha != null then trigger_sha else &quot;none&quot;" target="correlation_key" />
            <zeebe:input source="=true" target="deploy_failed" />
            <zeebe:input source="=if is defined(caught_error_message) and caught_error_message != null then caught_error_message else &quot;Unknown error&quot;" target="error_message" />
            <zeebe:input source="=if is defined(error_traceback) and error_traceback != null then error_traceback else &quot;&quot;" target="error_traceback" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>f_err2</bpmn:incoming>
        <bpmn:outgoing>f_err3</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="evt_error_end" name="Деплой провалився">
        <bpmn:incoming>f_err3</bpmn:incoming>
        <bpmn:errorEventDefinition id="ErrorDef_throw" errorRef="Error_deploy_failed" />
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="f_err_to_rollback" sourceRef="evt_error_catch" targetRef="task_rollback" />
      <bpmn:sequenceFlow id="f_err2" sourceRef="task_rollback" targetRef="ST_publish_deploy_failed" />
      <bpmn:sequenceFlow id="f_err3" sourceRef="ST_publish_deploy_failed" targetRef="evt_error_end" />
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="f_start_to_parent_check" sourceRef="evt_start" targetRef="gw_parent_check" />
    <bpmn:sequenceFlow id="f_has_parent" name="Так" sourceRef="gw_parent_check" targetRef="ST_create_subtask">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=is defined(parent_process_instance_key) and parent_process_instance_key != null</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_no_parent" name="Standalone" sourceRef="gw_parent_check" targetRef="ST_create_deploy_task" />
    <bpmn:sequenceFlow id="f_created_to_merge" sourceRef="ST_create_deploy_task" targetRef="gw_merge_parent" />
    <bpmn:sequenceFlow id="f_subtask_to_merge" sourceRef="ST_create_subtask" targetRef="gw_merge_parent" />
    <bpmn:sequenceFlow id="f01_merged" sourceRef="gw_merge_parent" targetRef="ST_db_remove" />
    <bpmn:sequenceFlow id="f_remove_to_checkpoint" sourceRef="ST_db_remove" targetRef="ST_db_checkpoint" />
    <bpmn:sequenceFlow id="f_pull_to_detect" sourceRef="task_git_pull" targetRef="task_detect_modules" />
    <bpmn:sequenceFlow id="f_detect_to_gw" sourceRef="task_detect_modules" targetRef="gw_changes" />
    <bpmn:sequenceFlow id="f_no_changes" name="Ні" sourceRef="gw_changes" targetRef="ST_publish_no_changes">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=changed_modules = "" and (not(is defined(install_modules)) or install_modules = "")</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_no_changes_end" sourceRef="ST_publish_no_changes" targetRef="evt_end_no_changes" />
    <bpmn:sequenceFlow id="f_has_changes" name="Так" sourceRef="gw_changes" targetRef="task_module_update" />
    <bpmn:sequenceFlow id="f_checkpoint_to_pull" sourceRef="ST_db_checkpoint" targetRef="task_git_pull" />
    <bpmn:sequenceFlow id="f10" sourceRef="task_module_update" targetRef="task_smoke_test" />
    <bpmn:sequenceFlow id="f_smoke_to_gw_clickbot" sourceRef="task_smoke_test" targetRef="gw_clickbot" />
    <bpmn:sequenceFlow id="f_run_clickbot" sourceRef="gw_clickbot" targetRef="task_clickbot" />
    <bpmn:sequenceFlow id="f_skip_clickbot" name="Скіп" sourceRef="gw_clickbot" targetRef="gw_merge_clickbot">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=is defined(skip_clickbot) and skip_clickbot = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_clickbot_to_merge" sourceRef="task_clickbot" targetRef="gw_merge_clickbot" />
    <bpmn:sequenceFlow id="f_merge_clickbot_to_cache" sourceRef="gw_merge_clickbot" targetRef="task_cache_clear" />
    <bpmn:sequenceFlow id="f12" sourceRef="task_cache_clear" targetRef="task_http_verify" />
    <bpmn:sequenceFlow id="f_http_to_save" sourceRef="task_http_verify" targetRef="task_save_state" />
    <bpmn:sequenceFlow id="f18" sourceRef="task_save_state" targetRef="ST_publish_deploy_done" />
