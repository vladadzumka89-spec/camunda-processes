      <bpmndi:BPMNShape id="gw_merge_start_di" bpmnElement="gw_merge_start" isMarkerVisible="true">
        <dc:Bounds x="270" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_parent_check_di" bpmnElement="gw_parent_check" isMarkerVisible="true">
        <dc:Bounds x="400" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST_create_subtask_di" bpmnElement="ST_create_subtask">
        <dc:Bounds x="525" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST_create_deploy_task_di" bpmnElement="ST_create_deploy_task">
        <dc:Bounds x="525" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_merge_parent_di" bpmnElement="gw_merge_parent" isMarkerVisible="true">
        <dc:Bounds x="730" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <!-- ── Checkpoint → Git pull ── -->
      <bpmndi:BPMNShape id="ST_db_checkpoint_di" bpmnElement="ST_db_checkpoint">
        <dc:Bounds x="855" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_git_pull_di" bpmnElement="task_git_pull">
        <dc:Bounds x="1035" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <!-- ── Changes check ── -->
      <bpmndi:BPMNShape id="gw_changes_di" bpmnElement="gw_changes" isMarkerVisible="true">
