          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Сплатити готівкою (&#34; + (if x_studio_camunda_invoice_type != null then x_studio_camunda_invoice_type else &#34;—&#34;) + &#34;): &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34; №&#34; + x_studio_camunda_invoice_number + &#34; — &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#34;, description: &#34;&#60;b&#62;Постачальник:&#60;/b&#62; &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Сума до оплати:&#60;/b&#62; &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#60;br/&#62;1. Здійсніть оплату рахунку готівкою на магазині.&#60;br/&#62;2. Прикріпіть скан/фото квитанції до задачі.&#60;br/&#62;3. Змініть стадію задачі на &#60;b&#62;«Виконано»&#60;/b&#62;.&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, parent_process_instance_key: parent_process_instance_key, x_studio_camunda_pidrozdil: if x_studio_camunda_pidrozdil != null then x_studio_camunda_pidrozdil else null}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_cash_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_pay_cash_to_mark</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UT_pay_tp" name="ТП сплатити">
