          <zeebe:input source="={name: &#34;❌ Рахунок не погоджено (ФАМО, &#34; + (if x_studio_camunda_approved = &#34;no&#34; then &#34;перевірка суми не пройшла&#34; else if x_studio_camunda_pay = &#34;no&#34; then &#34;відмова в оплаті&#34; else &#34;відхилено&#34;) + &#34;): &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34; №&#34; + x_studio_camunda_invoice_number + &#34; — &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#34;,&#10;description: &#34;&#60;b&#62;Постачальник:&#60;/b&#62; &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Сума:&#60;/b&#62; &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#60;br/&#62;&#60;b&#62;Тип:&#60;/b&#62; &#34; + (if x_studio_camunda_invoice_type != null then x_studio_camunda_invoice_type else &#34;—&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Причина:&#60;/b&#62; &#34; + (if x_studio_camunda_approved = &#34;no&#34; then &#34;рахунок ФАМО відхилено на етапі перевірки суми (не погоджено).&#34; else if x_studio_camunda_pay = &#34;no&#34; then &#34;після розгляду було вирішено НЕ оплачувати цей рахунок.&#34; else &#34;рахунок ФАМО відхилено.&#34;) + &#34;&#60;br/&#62;&#60;br/&#62;Це задача-сповіщення, дій не потребує.&#34;,&#10;_model: &#34;project.project&#34;, _id: 13946,&#10;process_instance_key: process_instance_key,&#10;parent_process_instance_key: parent_process_instance_key,&#10;x_studio_camunda_approved: &#34;no&#34;,&#10;x_studio_camunda_pidrozdil: if x_studio_camunda_pidrozdil != null then x_studio_camunda_pidrozdil else null}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
