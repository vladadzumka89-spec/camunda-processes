      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_pay = "yes"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_pay_tp_no" name="Ні" sourceRef="GW_pay_tp" targetRef="ST_not_approved_tp_end" />
    <bpmn:sequenceFlow id="Flow_cash_yes" name="Так" sourceRef="GW_cash_on_site" targetRef="UT_pay_cash">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_cash_on_site = "yes"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_cash_no" name="Ні" sourceRef="GW_cash_on_site" targetRef="UT_pay_tp" />
    <bpmn:sequenceFlow id="Flow_pay_cash_to_mark" sourceRef="UT_pay_cash" targetRef="End_tp" />
    <bpmn:sequenceFlow id="Flow_pay_tp_to_mark" sourceRef="UT_pay_tp" targetRef="End_tp" />
    <bpmn:sequenceFlow id="Flow_rent_yes" name="Так" sourceRef="GW_rent" targetRef="ST_register_famo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_invoice_type = "оренда"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_rent_no" name="Ні" sourceRef="GW_rent" targetRef="UT_check_sum_famo" />
    <bpmn:sequenceFlow id="Flow_pay_rent_yes" name="Так" sourceRef="GW_pay_rent" targetRef="GW_join_to_pay_famo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_pay = "yes"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_pay_rent_no" name="Ні" sourceRef="GW_pay_rent" targetRef="ST_not_approved_famo_end" />
    <bpmn:sequenceFlow id="Flow_check_famo_to_appr" sourceRef="UT_check_sum_famo" targetRef="GW_approved_famo" />
    <bpmn:sequenceFlow id="Flow_appr_famo_yes" name="Так" sourceRef="GW_approved_famo" targetRef="GW_join_to_pay_famo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_approved = "yes"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_appr_famo_no" name="Ні" sourceRef="GW_approved_famo" targetRef="ST_not_approved_famo_end" />
    <bpmn:sequenceFlow id="Flow_not_appr_famo_end" sourceRef="ST_not_approved_famo_end" targetRef="End_not_approved_famo" />
    <bpmn:sequenceFlow id="Flow_join_to_pay_famo" sourceRef="GW_join_to_pay_famo" targetRef="UT_pay_invoice" />
    <bpmn:sequenceFlow id="Flow_pay_to_mark_main" sourceRef="UT_pay_invoice" targetRef="BRT_expense_category" />
    <bpmn:sequenceFlow id="Flow_brt_to_receipt" sourceRef="BRT_expense_category" targetRef="UT_add_receipt" />
    <bpmn:sequenceFlow id="Flow_receipt_to_end" sourceRef="UT_add_receipt" targetRef="End_main" />
    <bpmn:sequenceFlow id="Flow_07q19rg" sourceRef="UT_decide_pay_tp" targetRef="GW_pay_tp" />
    <bpmn:sequenceFlow id="Flow_04l3x2y" sourceRef="ST_register_famo" targetRef="GW_pay_rent" />
  </bpmn:process>
