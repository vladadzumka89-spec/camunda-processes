      </bpmn:extensionElements>
      <bpmn:incoming>Flow_verify_to_parallel</bpmn:incoming>
      <bpmn:outgoing>Flow_132hruz</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:serviceTask id="ST_write_type" name="Записати тип рахунку в Odoo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;http://karavaieva.dev-odoo.a.local/web/hook/ecbaf8c8-7138-4ae2-add5-a019dc1cd796&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {process_instance_key: process_instance_key, x_studio_camunda_invoice_type: invoice_detail_type.x_studio_camunda_invoice_type}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_132hruz</bpmn:incoming>
      <bpmn:outgoing>Flow_1bpv79h</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="Activity_0pb3hxn" name="Погодження рахунку">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Process_invoice_approval" />
        <zeebe:ioMapping>
          <zeebe:input source="=process_instance_key" target="parent_process_instance_key" />
          <zeebe:output source="=x_studio_camunda_approved" target="x_studio_camunda_approved" />
          <zeebe:output source="=x_studio_camunda_pay" target="x_studio_camunda_pay" />
