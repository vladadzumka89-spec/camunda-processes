    <bpmn:sequenceFlow id="Flow_reissue_to_dmn" sourceRef="UT_reissue" targetRef="BRT_detail_type" />
    <bpmn:sequenceFlow id="Flow_dmn_to_write" sourceRef="BRT_detail_type" targetRef="ST_write_type" />
    <bpmn:sequenceFlow id="Flow_write_to_gw_rent" sourceRef="ST_write_type" targetRef="GW_rent" />
    <bpmn:sequenceFlow id="Flow_rent_yes" name="оренда" sourceRef="GW_rent" targetRef="Timer_month_end">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= invoice_detail_type.x_studio_camunda_invoice_type = "оренда"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_rent_no" name="ні" sourceRef="GW_rent" targetRef="UT_buh_real" />
    <bpmn:sequenceFlow id="Flow_timer_to_buh" sourceRef="Timer_month_end" targetRef="UT_buh_real" />
    <bpmn:sequenceFlow id="Flow_buh_to_merge" sourceRef="UT_buh_real" targetRef="Gateway_0ytub5u" />
    <bpmn:sequenceFlow id="Flow_0k3j07w" sourceRef="Activity_0pb3hxn" targetRef="Gateway_0ytub5u" />
    <bpmn:sequenceFlow id="Flow_01kli45" sourceRef="Gateway_0ytub5u" targetRef="End_main" />
  </bpmn:process>
