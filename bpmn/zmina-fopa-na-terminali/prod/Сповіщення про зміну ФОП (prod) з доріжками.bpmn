    <bpmn:userTask id="Activity_1ym16t1" name="Перевірити чи погодженно ТРЦ переключення">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Перевірити погодження ТРЦ: &#34; + fop_name + &#34; → &#34; + (if is defined(new_fop_name) then new_fop_name else &#34;?&#34;) + &#34; на &#34; + selected_store, description: &#34;&#60;b&#62;Магазин:&#60;/b&#62; &#34; + selected_store + &#34;&#60;br/&#62;&#60;b&#62;Старий ФОП:&#60;/b&#62; &#34; + fop_name + &#34;&#60;br/&#62;&#60;b&#62;Новий ФОП:&#60;/b&#62; &#34; + (if is defined(new_fop_name) then new_fop_name else &#34;(не вказано)&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Дата переключення:&#60;/b&#62; &#34; + (if is defined(switch_date) then switch_date else &#34;(не визначено)&#34;) + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#34; + &#34;&#60;br/&#62;1. Якщо ТРЦ ще &#60;b&#62;не відповів&#60;/b&#62; — не чіпайте цю задачу. Через 2 дні прийде нагадування, щоб зв&#39;язатись з ТРЦ повторно.&#34; + &#34;&#60;br/&#62;2. Якщо ТРЦ &#60;b&#62;погодив&#60;/b&#62; — оберіть «Так» у полі «Погоджено орендодавцем».&#34; + &#34;&#60;br/&#62;3. Якщо ТРЦ &#60;b&#62;відмовив&#60;/b&#62; — оберіть «Ні» у полі «Погоджено орендодавцем».&#34; + &#34;&#60;br/&#62;4. Змініть стадію задачі на &#60;b&#62;«Виконано»&#60;/b&#62;, щоб процес пішов далі.&#34;, x_studio_camunda_fop_name: fop_name, x_studio_camunda_selected_store: selected_store, x_studio_camunda_new_fop_name: (if is defined(new_fop_name) then new_fop_name else &#34;&#34;), x_studio_camunda_switch_date: (if is defined(switch_date) then switch_date else &#34;&#34;), x_studio_camunda_is_paid_change: (if is defined(is_paid_change) then is_paid_change else &#34;Ні&#34;), x_studio_camunda_role_code: &#34;rental_manager&#34;, parent_id: odoo_task_id, _model: &#34;project.project&#34;, _id: 524, process_instance_key: process_instance_key, x_studio_camunda_task_code: &#34;landlord_check&#34;}" target="body" />
          <zeebe:output source="=x_studio_camunda_landlord_approved" target="landlord_approved" />
        </zeebe:ioMapping>
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
