      <bpmn:timerEventDefinition id="TimerEventDefinition_1cvcsly">
        <bpmn:timeDate xsi:type="bpmn:tFormalExpression">={
  first_day: (
    if x_studio_camunda_service_period != null and matches(x_studio_camunda_service_period, "^\d{2}\.\d{4}-\d{2}\.\d{4}$")
    then date(number(substring(x_studio_camunda_service_period, 12, 4)), number(substring(x_studio_camunda_service_period, 9, 2)), 1)
    else if x_studio_camunda_service_period != null and matches(x_studio_camunda_service_period, "^\d{2}\.\d{4}$")
    then date(number(substring(x_studio_camunda_service_period, 4, 4)), number(substring(x_studio_camunda_service_period, 1, 2)), 1)
    else null
  ),
  result: (
    if first_day = null then date and time(now())
    else date and time(
      if day of week(first_day) = "Saturday" then first_day + duration("P2D")
      else if day of week(first_day) = "Sunday" then first_day + duration("P1D")
      else first_day,
      time("09:00:00")
    )
  )
}.result</bpmn:timeDate>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Timer_month_end" name="Останній день вказаного місяця в рахунку">
      <bpmn:incoming>Flow_1escksh</bpmn:incoming>
      <bpmn:outgoing>Flow_timer_to_buh</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1">
        <bpmn:timeDate xsi:type="bpmn:tFormalExpression">={
  last_day: (
    if x_studio_camunda_service_period != null and matches(x_studio_camunda_service_period, "^\d{2}\.\d{4}$")
    then date(number(substring(x_studio_camunda_service_period, 4, 4)), number(substring(x_studio_camunda_service_period, 1, 2)), 1) + duration("P1M") - duration("P1D")
    else (if today().month = 12 then date(today().year + 1, 1, 1) else date(today().year, today().month + 1, 1)) - duration("P1D")
  ),
  result: date and time(last_day, time("09:00:00"))
}.result</bpmn:timeDate>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
