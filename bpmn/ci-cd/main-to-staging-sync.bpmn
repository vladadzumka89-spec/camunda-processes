<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_sync"
                  targetNamespace="http://tut.ua/bpmn/main-staging-sync"
                  exporter="Claude Code"
                  exporterVersion="1.0">

  <!-- ═══════════════════════════════════════════════════════════
       MAIN → STAGING SYNC — Щонічна синхронізація

       Запускається щоночі (cron R/P1D).
       Мерджить main в staging з -X theirs (upstream пріоритет).
       Після merge — deploy staging через call activity.

       Використовує існуючий handler merge-to-staging з sync_branch="main".
       ═══════════════════════════════════════════════════════════ -->

  <bpmn:error id="Error_deploy_failed" name="Deploy Failed" errorCode="DEPLOY_FAILED" />

  <bpmn:process id="main-to-staging-sync" name="Main to Staging Sync" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="1.0" />
    </bpmn:extensionElements>

    <!-- ── Timer Start: щоночі ──────────────────────────── -->
    <bpmn:startEvent id="start_timer" name="Щоночі (cron)">
      <bpmn:documentation>Запускається щоночі для синхронізації main → staging.
Мінімізує розходження між гілками.</bpmn:documentation>
      <bpmn:outgoing>f_start_to_merge</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_nightly">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P1D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>

    <!-- ── Merge main → staging ─────────────────────────── -->
    <bpmn:serviceTask id="task_merge_main_staging" name="Merge main → staging">
      <bpmn:documentation>Мерджить main в staging з -X theirs.
Використовує існуючий handler merge-to-staging.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="merge-to-staging" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;main&quot;" target="sync_branch" />
          <zeebe:input source="=&quot;staging&quot;" target="server_host" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_start_to_merge</bpmn:incoming>
      <bpmn:outgoing>f_merge_to_deploy</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Boundary error on merge -->
    <bpmn:boundaryEvent id="evt_merge_error" name="Merge failed" attachedToRef="task_merge_main_staging">
      <bpmn:outgoing>f_merge_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDef_merge" />
    </bpmn:boundaryEvent>

    <!-- ── Deploy staging (Call Activity) ───────────────── -->
    <bpmn:callActivity id="call_deploy_staging" name="Деплой на staging">
      <bpmn:documentation>Деплоїть staging після merge main → staging.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:calledElement processId="deploy-process" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;staging&quot;" target="server_host" />
          <zeebe:input source="=&quot;deploy&quot;" target="ssh_user" />
          <zeebe:input source="=&quot;staging&quot;" target="branch" />
          <zeebe:input source="=&quot;odoo19&quot;" target="db_name" />
          <zeebe:input source="=&quot;odoo19&quot;" target="container" />
          <zeebe:input source="=&quot;/opt/odoo-enterprise&quot;" target="repo_dir" />
          <zeebe:input source="=false" target="run_smoke_test" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_merge_to_deploy</bpmn:incoming>
      <bpmn:outgoing>f_deploy_to_end</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Boundary error on deploy -->
    <bpmn:boundaryEvent id="evt_deploy_error" name="Deploy failed" attachedToRef="call_deploy_staging">
      <bpmn:outgoing>f_deploy_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDef_deploy" errorRef="Error_deploy_failed" />
    </bpmn:boundaryEvent>

    <!-- ── Notify: sync/deploy failed ──────────────────── -->
    <bpmn:serviceTask id="task_notify_fail" name="Повідомити: sync failed">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;sync_warning&quot;" target="notification_type" />
          <zeebe:input source="=&quot;⚠️ Щонічний sync main → staging не вдався. Потрібна ручна синхронізація.&quot;" target="message_body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_merge_error</bpmn:incoming>
      <bpmn:incoming>f_deploy_error</bpmn:incoming>
      <bpmn:outgoing>f_notify_to_end_fail</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── End events ──────────────────────────────────── -->
    <bpmn:endEvent id="evt_end_success" name="Sync завершено">
      <bpmn:incoming>f_deploy_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="evt_end_fail" name="Sync не вдався">
      <bpmn:incoming>f_notify_to_end_fail</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ── Sequence flows ──────────────────────────────── -->
    <bpmn:sequenceFlow id="f_start_to_merge" sourceRef="start_timer" targetRef="task_merge_main_staging" />
    <bpmn:sequenceFlow id="f_merge_to_deploy" sourceRef="task_merge_main_staging" targetRef="call_deploy_staging" />
    <bpmn:sequenceFlow id="f_merge_error" sourceRef="evt_merge_error" targetRef="task_notify_fail" />
    <bpmn:sequenceFlow id="f_deploy_to_end" sourceRef="call_deploy_staging" targetRef="evt_end_success" />
    <bpmn:sequenceFlow id="f_deploy_error" sourceRef="evt_deploy_error" targetRef="task_notify_fail" />
    <bpmn:sequenceFlow id="f_notify_to_end_fail" sourceRef="task_notify_fail" targetRef="evt_end_fail" />

  </bpmn:process>

  <!-- ═══════════════════ DIAGRAM ═══════════════════ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_sync">
    <bpmndi:BPMNPlane id="BPMNPlane_sync" bpmnElement="main-to-staging-sync">

      <bpmndi:BPMNShape id="start_timer_di" bpmnElement="start_timer">
        <dc:Bounds x="30" y="162" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_merge_main_staging_di" bpmnElement="task_merge_main_staging">
        <dc:Bounds x="130" y="140" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="evt_merge_error_di" bpmnElement="evt_merge_error">
        <dc:Bounds x="192" y="202" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="call_deploy_staging_di" bpmnElement="call_deploy_staging">
        <dc:Bounds x="370" y="140" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="evt_deploy_error_di" bpmnElement="evt_deploy_error">
        <dc:Bounds x="432" y="202" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_notify_fail_di" bpmnElement="task_notify_fail">
        <dc:Bounds x="250" y="290" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="evt_end_success_di" bpmnElement="evt_end_success">
        <dc:Bounds x="612" y="162" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="evt_end_fail_di" bpmnElement="evt_end_fail">
        <dc:Bounds x="480" y="312" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Edges -->
      <bpmndi:BPMNEdge id="f_start_to_merge_di" bpmnElement="f_start_to_merge">
        <di:waypoint x="66" y="180" />
        <di:waypoint x="130" y="180" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="f_merge_to_deploy_di" bpmnElement="f_merge_to_deploy">
        <di:waypoint x="290" y="180" />
        <di:waypoint x="370" y="180" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="f_merge_error_di" bpmnElement="f_merge_error">
        <di:waypoint x="210" y="238" />
        <di:waypoint x="210" y="330" />
        <di:waypoint x="250" y="330" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="f_deploy_to_end_di" bpmnElement="f_deploy_to_end">
        <di:waypoint x="530" y="180" />
        <di:waypoint x="612" y="180" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="f_deploy_error_di" bpmnElement="f_deploy_error">
        <di:waypoint x="450" y="238" />
        <di:waypoint x="450" y="330" />
        <di:waypoint x="410" y="330" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="f_notify_to_end_fail_di" bpmnElement="f_notify_to_end_fail">
        <di:waypoint x="410" y="330" />
        <di:waypoint x="480" y="330" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
