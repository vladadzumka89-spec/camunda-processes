      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= is defined(x_studio_camunda_fop_name) and x_studio_camunda_fop_name != null and (contains(lower case(x_studio_camunda_fop_name), "технопростір") or contains(lower case(x_studio_camunda_fop_name), "технопростiр") or contains(lower case(x_studio_camunda_fop_name), "техно простір") or contains(lower case(x_studio_camunda_fop_name), "техно простiр"))</bpmn:conditionExpression>
