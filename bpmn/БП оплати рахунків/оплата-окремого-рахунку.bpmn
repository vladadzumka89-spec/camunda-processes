<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="e787c33" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:collaboration id="Collab_single">
    <bpmn:participant id="Pool_single" name="Оплата окремого рахунку" processRef="Process_single_invoice" />
    <bpmn:textAnnotation id="TextAnnotation_06jlc85">
      <bpmn:text>1с</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1jnlwqd" associationDirection="None" sourceRef="Task_calendar" targetRef="TextAnnotation_06jlc85" />
  </bpmn:collaboration>
  <bpmn:process id="Process_single_invoice" name="Оплата окремого рахунку" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="4.0" />
    </bpmn:extensionElements>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Buhgalter" name="Бухгалтер">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_odoo_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_odoo_merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CA_tp_reissue</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_pay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_main</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_request_detail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_task_pih</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Camunda" name="Система (Camunda)">
        <bpmn:flowNodeRef>ST_classify_type</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_is_communal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BRT_check_detail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_detail_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_detail_merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_main_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_tp_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Timer_payday</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_timer_decision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_dmn_nego_who</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_reject_type</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BRT_reject_detail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_reject_route</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Odoo" name="Система (Odoo авто)">
        <bpmn:flowNodeRef>ST_create_main</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_calendar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_service_receipt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1mf4l1i</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_rem_detail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_rem_detail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_rem_bui</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_rem_bui</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_rem_pih</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_rem_pih</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Pogodjuvach" name="Погоджувач">
        <bpmn:flowNodeRef>Task_approve</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_approver_contract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_dmn_record</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_contract_result</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_who_nego</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_dmn_decision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CA_break_contract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_wait_new</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_break_contract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_esc_detail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_esc_detail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_esc_bui</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_esc_bui</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_esc_pih</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_esc_pih</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_bui_done</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Yulia" name="Юля">
        <bpmn:flowNodeRef>End_nego_manual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_yulia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_yulia_decision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_no_pay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_nego_manual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Timer_yulia_deadline</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Dasha" name="Даша (Менеджер з оренди)">
        <bpmn:flowNodeRef>Task_dasha</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CA_nego_self</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_task_bui</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="Старт">
      <bpmn:outgoing>Flow_start_to_gw_odoo</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_odoo_check" name="Задача в Odoo існує?" default="Flow_odoo_no_task">
      <bpmn:incoming>Flow_start_to_gw_odoo</bpmn:incoming>
      <bpmn:outgoing>Flow_odoo_no_task</bpmn:outgoing>
      <bpmn:outgoing>Flow_odoo_has_task</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ST_create_main" name="Створити задачу рахунку в Odoo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Рахунок №&quot; + x_studio_camunda_invoice_number + &quot; — &quot; + x_studio_camunda_partner_name + &quot; — &quot; + string(x_studio_camunda_invoice_amount) + &quot; грн&quot;, create_process: true, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key, parent_process_instance_key: parent_process_instance_key, x_studio_camunda_invoice_number: x_studio_camunda_invoice_number, x_studio_camunda_invoice_date: x_studio_camunda_invoice_date, x_studio_camunda_invoice_line_name: x_studio_camunda_invoice_line_name, x_studio_camunda_supplier_code: x_studio_camunda_supplier_code, x_studio_camunda_contract: x_studio_camunda_contract, x_studio_camunda_buyer_name: x_studio_camunda_buyer_name, x_studio_camunda_quantity: x_studio_camunda_quantity, x_studio_camunda_unit: x_studio_camunda_unit}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_odoo_no_task</bpmn:incoming>
      <bpmn:outgoing>Flow_create_main_done</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_odoo_merge">
      <bpmn:incoming>Flow_odoo_has_task</bpmn:incoming>
      <bpmn:incoming>Flow_create_main_done</bpmn:incoming>
      <bpmn:outgoing>Flow_merge_to_classify</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:businessRuleTask id="ST_classify_type" name="Визначити тип рахунку [DMN]">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="invoice-detail-type" resultVariable="classificationResult" />
        <zeebe:ioMapping>
          <zeebe:output source="= classificationResult.x_studio_camunda_invoice_type" target="x_studio_camunda_invoice_type" />
          <zeebe:output source="= classificationResult.x_studio_camunda_invoice_notes" target="x_studio_camunda_invoice_notes" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_merge_to_classify</bpmn:incoming>
      <bpmn:outgoing>Flow_classify_to_split</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:parallelGateway id="GW_main_split">
      <bpmn:incoming>Flow_not_communal</bpmn:incoming>
      <bpmn:incoming>Flow_detail_merge_to_split</bpmn:incoming>
      <bpmn:outgoing>Flow_main_to_calendar</bpmn:outgoing>
      <bpmn:outgoing>Flow_main_to_approve</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:exclusiveGateway id="GW_tp_check" name="Тип ТП або ТП+?" default="Flow_tp_no">
      <bpmn:incoming>Flow_main_to_calendar</bpmn:incoming>
      <bpmn:outgoing>Flow_tp_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_tp_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="CA_tp_reissue" name="Перевиставлення оренди (ТП/ТП+)">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Process_12nvb3l" propagateAllChildVariables="false" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_tp_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_tp_done</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:serviceTask id="Task_calendar" name="Додати суму в платіжний календар">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {action: &quot;add_to_payment_calendar&quot;, x_studio_camunda_partner_name: x_studio_camunda_partner_name, x_studio_camunda_invoice_amount: x_studio_camunda_invoice_amount, x_studio_camunda_payment_date: x_studio_camunda_payment_date, x_studio_camunda_invoice_type: x_studio_camunda_invoice_type, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_tp_no</bpmn:incoming>
      <bpmn:incoming>Flow_tp_done</bpmn:incoming>
      <bpmn:outgoing>Flow_calendar_to_timer</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="Timer_payday" name="Очікуємо дедлайну рахунку">
      <bpmn:incoming>Flow_calendar_to_timer</bpmn:incoming>
      <bpmn:outgoing>Flow_timer_to_gw_decision</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_payday">
        <bpmn:timeDate xsi:type="bpmn:tFormalExpression">= x_studio_camunda_payment_date</bpmn:timeDate>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="Task_approve" name="Погодити рахунок">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Погодити рахунок від &quot; + x_studio_camunda_partner_name, description: &quot;Погодьте або відхиліть рахунок на суму &quot; + string(x_studio_camunda_invoice_amount) + &quot; грн від &quot; + x_studio_camunda_partner_name, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_approver_user_id, process_instance_key: process_instance_key}" target="body" />
          <zeebe:output source="= x_studio_camunda_approved" target="x_studio_camunda_approved" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_main_to_approve</bpmn:incoming>
      <bpmn:incoming>Flow_pih_to_approve</bpmn:incoming>
      <bpmn:outgoing>Flow_approve_to_gw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_approved" name="Погоджено?" default="Flow_approved_no">
      <bpmn:incoming>Flow_approve_to_gw</bpmn:incoming>
      <bpmn:outgoing>Flow_approved_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_approved_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_approver_contract" name="Погоджувач з договору">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Перевірка договору: &quot; + x_studio_camunda_partner_name, description: &quot;Перевірте відповідність рахунку умовам договору та погодьте або відхиліть&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_approver_user_id, process_instance_key: process_instance_key}" target="body" />
          <zeebe:output source="= x_studio_camunda_contract_approved" target="x_studio_camunda_contract_approved" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_approved_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_contract_to_gw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_nego_manual" name="Переговори завершено">
      <bpmn:incoming>Flow_nego_manual_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:businessRuleTask id="Task_dmn_record" name="Визначити результат перемовин">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="nego-result" resultVariable="nego_action" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_nego_self_to_gw</bpmn:incoming>
      <bpmn:outgoing>Flow_dmn_to_gw</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:userTask id="Task_yulia" name="Юля, ми не домовилися по рахунку — платимо?">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Рішення по рахунку: &quot; + x_studio_camunda_partner_name, description: &quot;Дедлайн наближається. Рахунок на суму &quot; + string(x_studio_camunda_invoice_amount) + &quot; грн. Підтвердьте оплату або відхиліть&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_yulia_user_id, process_instance_key: process_instance_key}" target="body" />
          <zeebe:output source="= x_studio_camunda_pay" target="x_studio_camunda_pay" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_timer_to_yulia</bpmn:incoming>
      <bpmn:outgoing>Flow_yulia_to_gw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_yulia_decision" name="Платимо?" default="Flow_yulia_no">
      <bpmn:incoming>Flow_yulia_to_gw</bpmn:incoming>
      <bpmn:outgoing>Flow_yulia_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_yulia_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_dasha" name="Даша, виріши з оплатою рахунку">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Ескалація: оплата рахунку &quot; + x_studio_camunda_partner_name, description: &quot;Юля не прийняла рішення вчасно. Рахунок &quot; + string(x_studio_camunda_invoice_amount) + &quot; грн. Прийміть рішення щодо оплати&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_dasha_user_id, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_yulia_timer_to_dasha</bpmn:incoming>
      <bpmn:outgoing>Flow_dasha_to_pay</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_pay" name="Оплатити рахунок">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Оплатити рахунок: &quot; + x_studio_camunda_partner_name, description: &quot;Виконайте оплату рахунку на суму &quot; + string(x_studio_camunda_invoice_amount) + &quot; грн. Підтвердьте після оплати&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_buhgalter_user_id, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_timer_to_pay</bpmn:incoming>
      <bpmn:incoming>Flow_contract_yes</bpmn:incoming>
      <bpmn:incoming>Flow_dmn_pay</bpmn:incoming>
      <bpmn:incoming>Flow_yulia_yes</bpmn:incoming>
      <bpmn:incoming>Flow_0ues5t2</bpmn:incoming>
      <bpmn:outgoing>Flow_pay_to_service</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_main" name="Рахунок оплачено">
      <bpmn:incoming>Flow_0073gjv</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_contract_result" name="Погоджено з договору?" default="Flow_contract_no">
      <bpmn:incoming>Flow_contract_to_gw</bpmn:incoming>
      <bpmn:outgoing>Flow_contract_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_contract_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_timer_decision" name="Є питання по рахунку?" default="Flow_timer_to_pay">
      <bpmn:incoming>Flow_timer_to_gw_decision</bpmn:incoming>
      <bpmn:outgoing>Flow_timer_to_pay</bpmn:outgoing>
      <bpmn:outgoing>Flow_timer_to_yulia</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="CA_nego_self" name="Перемовини з ТРЦ">
      <bpmn:extensionElements>
        <zeebe:calledElement propagateAllChildVariables="false" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_nego_self</bpmn:incoming>
      <bpmn:incoming>Flow_dasha_to_pay</bpmn:incoming>
      <bpmn:outgoing>Flow_nego_self_to_gw</bpmn:outgoing>
      <bpmn:outgoing>Flow_0ues5t2</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:businessRuleTask id="Task_dmn_nego_who" name="Визначити виконавця перемовин">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="nego-who" resultVariable="x_studio_camunda_nego_who" />
