<?xml version="1.0" encoding="utf-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="e787c33" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="Process_single_invoice_no_lanes" name="Оплата окремого рахунку (спрощена)" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="2.0" />
    </bpmn:extensionElements>

    <!-- ===== 1. СТАРТ ===== -->
    <bpmn:startEvent id="StartEvent_1" name="Старт">
      <bpmn:outgoing>Flow_start_to_upload</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ===== 2. ЗАВАНТАЖЕННЯ ФАЙЛУ ===== -->
    <bpmn:userTask id="UT_upload_file" name="Завантажити файл рахунку">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Завантажити файл рахунку&quot;, description: &quot;Завантажте файл рахунку (PDF, JPG, PNG, XLS, XLSX)&quot;, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key}" target="body" />
          <zeebe:output source="= x_studio_camunda_invoice_file" target="x_studio_camunda_invoice_file" />
          <zeebe:output source="= x_studio_camunda_file_extension" target="file_extension" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_start_to_upload</bpmn:incoming>
      <bpmn:outgoing>Flow_upload_to_extract</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ===== 3. РОЗПІЗНАВАННЯ РАХУНКУ (OCR/AI) ===== -->
    <bpmn:serviceTask id="ST_extract_invoice" name="Розпізнати дані рахунку">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="invoice-data-extractor" />
        <zeebe:ioMapping>
          <zeebe:input source="= x_studio_camunda_invoice_file" target="x_studio_camunda_invoice_file" />
          <zeebe:input source="= file_extension" target="file_extension" />
          <zeebe:output source="= invoice_items" target="invoice_items" />
          <zeebe:output source="= recognized" target="recognized" />
          <zeebe:output source="= if recognized then invoice_items[1].partner_name else null" target="x_studio_camunda_partner_name" />
          <zeebe:output source="= if recognized then invoice_items[1].invoice_number else null" target="x_studio_camunda_invoice_number" />
          <zeebe:output source="= if recognized then invoice_items[1].invoice_date else null" target="x_studio_camunda_invoice_date" />
          <zeebe:output source="= if recognized then invoice_items[1].invoice_line_name else null" target="x_studio_camunda_invoice_line_name" />
          <zeebe:output source="= if recognized then invoice_items[1].invoice_amount else null" target="x_studio_camunda_invoice_amount" />
          <zeebe:output source="= if recognized then invoice_items[1].supplier_code else null" target="x_studio_camunda_supplier_code" />
          <zeebe:output source="= if recognized then invoice_items[1].contract else null" target="x_studio_camunda_contract" />
          <zeebe:output source="= if recognized then invoice_items[1].buyer_name else null" target="x_studio_camunda_buyer_name" />
          <zeebe:output source="= if recognized then invoice_items[1].quantity else null" target="x_studio_camunda_quantity" />
          <zeebe:output source="= if recognized then invoice_items[1].unit else null" target="x_studio_camunda_unit" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_upload_to_extract</bpmn:incoming>
      <bpmn:outgoing>Flow_extract_to_gw_odoo</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ===== 4. ПЕРЕВІРКА ODOO ===== -->
    <bpmn:exclusiveGateway id="GW_odoo_check" name="Задача в Odoo існує?" default="Flow_odoo_no_task">
      <bpmn:incoming>Flow_extract_to_gw_odoo</bpmn:incoming>
      <bpmn:outgoing>Flow_odoo_no_task</bpmn:outgoing>
      <bpmn:outgoing>Flow_odoo_has_task</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="ST_create_main" name="Створити задачу рахунку в Odoo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Рахунок №&quot; + x_studio_camunda_invoice_number + &quot; — &quot; + x_studio_camunda_partner_name + &quot; — &quot; + string(x_studio_camunda_invoice_amount) + &quot; грн&quot;, create_process: true, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key, parent_process_instance_key: parent_process_instance_key, x_studio_camunda_invoice_number: x_studio_camunda_invoice_number, x_studio_camunda_invoice_date: x_studio_camunda_invoice_date, x_studio_camunda_invoice_line_name: x_studio_camunda_invoice_line_name, x_studio_camunda_supplier_code: x_studio_camunda_supplier_code, x_studio_camunda_contract: x_studio_camunda_contract, x_studio_camunda_buyer_name: x_studio_camunda_buyer_name, x_studio_camunda_quantity: x_studio_camunda_quantity, x_studio_camunda_unit: x_studio_camunda_unit}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_odoo_no_task</bpmn:incoming>
      <bpmn:outgoing>Flow_create_main_done</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GW_odoo_merge">
      <bpmn:incoming>Flow_odoo_has_task</bpmn:incoming>
      <bpmn:incoming>Flow_create_main_done</bpmn:incoming>
      <bpmn:outgoing>Flow_merge_to_classify</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ===== 5. КЛАСИФІКАЦІЯ ===== -->
    <bpmn:businessRuleTask id="ST_classify_type" name="Визначити тип рахунку [DMN]">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="invoice-detail-type" resultVariable="classificationResult" />
        <zeebe:ioMapping>
          <zeebe:output source="= classificationResult.x_studio_camunda_invoice_type" target="x_studio_camunda_invoice_type" />
          <zeebe:output source="= classificationResult.x_studio_camunda_invoice_notes" target="x_studio_camunda_invoice_notes" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_merge_to_classify</bpmn:incoming>
      <bpmn:outgoing>Flow_classify_to_communal_check</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <!-- ===== 6. ПЕРЕВІРКА КОМУНАЛЬНІ ===== -->
    <bpmn:exclusiveGateway id="GW_is_communal" name="Тип комунальні?" default="Flow_not_communal">
      <bpmn:incoming>Flow_classify_to_communal_check</bpmn:incoming>
      <bpmn:outgoing>Flow_communal_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_not_communal</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:businessRuleTask id="BRT_check_detail" name="Перевірити деталізацію постачальника [DMN]">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="supplier-detailization" resultVariable="detailResult" />
        <zeebe:ioMapping>
          <zeebe:output source="= detailResult.x_studio_camunda_provides_detailization" target="x_studio_camunda_provides_detailization" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_communal_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_detail_to_check</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="GW_detail_check" name="ТРЦ надає деталізацію?" default="Flow_no_detail">
      <bpmn:incoming>Flow_detail_to_check</bpmn:incoming>
      <bpmn:outgoing>Flow_detail_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_no_detail</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_request_detail" name="Запросити деталізацію у ТРЦ">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Запросити деталізацію комунальних у &quot; + x_studio_camunda_partner_name, description: &quot;Зверніться до ТРЦ та запросіть деталізацію комунальних послуг для рахунку на суму &quot; + string(x_studio_camunda_invoice_amount) + &quot; грн&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_buhgalter_user_id, process_instance_key: process_instance_key}" target="body" />
          <zeebe:output source="= x_studio_camunda_detailization_received" target="x_studio_camunda_detailization_received" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_detail_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_detail_received</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_detail_merge">
      <bpmn:incoming>Flow_detail_received</bpmn:incoming>
      <bpmn:incoming>Flow_no_detail</bpmn:incoming>
      <bpmn:incoming>Flow_not_communal</bpmn:incoming>
      <bpmn:outgoing>Flow_detail_to_calendar</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ===== 7. ПЛАТІЖНИЙ КАЛЕНДАР ===== -->
    <bpmn:serviceTask id="Task_calendar" name="Додати суму в платіжний календар">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {action: &quot;add_to_payment_calendar&quot;, x_studio_camunda_partner_name: x_studio_camunda_partner_name, x_studio_camunda_invoice_amount: x_studio_camunda_invoice_amount, x_studio_camunda_payment_date: x_studio_camunda_payment_date, x_studio_camunda_invoice_type: x_studio_camunda_invoice_type, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_detail_to_calendar</bpmn:incoming>
      <bpmn:outgoing>Flow_calendar_to_timer</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ===== 8. ОЧІКУВАННЯ ДЕДЛАЙНУ ===== -->
    <bpmn:intermediateCatchEvent id="Timer_payday" name="Очікуємо дедлайну рахунку">
      <bpmn:incoming>Flow_calendar_to_timer</bpmn:incoming>
      <bpmn:outgoing>Flow_timer_to_approve</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_payday">
        <bpmn:timeDate xsi:type="bpmn:tFormalExpression">= x_studio_camunda_payment_date</bpmn:timeDate>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>

    <!-- ===== 9. ПОГОДЖЕННЯ ===== -->
    <bpmn:userTask id="Task_approve" name="Погодити рахунок">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Погодити рахунок від &quot; + x_studio_camunda_partner_name, description: &quot;Погодьте або відхиліть рахунок на суму &quot; + string(x_studio_camunda_invoice_amount) + &quot; грн від &quot; + x_studio_camunda_partner_name, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_approver_user_id, process_instance_key: process_instance_key}" target="body" />
          <zeebe:output source="= x_studio_camunda_approved" target="x_studio_camunda_approved" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_timer_to_approve</bpmn:incoming>
      <bpmn:outgoing>Flow_approve_to_gw</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_approved" name="Погоджено?" default="Flow_approved_no">
      <bpmn:incoming>Flow_approve_to_gw</bpmn:incoming>
      <bpmn:outgoing>Flow_approved_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_approved_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ===== 10. ОПЛАТА ===== -->
    <bpmn:userTask id="Task_pay" name="Оплатити рахунок">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Оплатити рахунок: &quot; + x_studio_camunda_partner_name, description: &quot;Виконайте оплату рахунку на суму &quot; + string(x_studio_camunda_invoice_amount) + &quot; грн. Підтвердьте після оплати&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_buhgalter_user_id, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_approved_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_pay_to_service</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ===== 11. ЗАВЕРШЕННЯ ===== -->
    <bpmn:businessRuleTask id="Task_service_receipt" name="ДМН таблиця з статею витрат">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {action: &quot;create_service_receipt&quot;, x_studio_camunda_partner_name: x_studio_camunda_partner_name, x_studio_camunda_invoice_amount: x_studio_camunda_invoice_amount, x_studio_camunda_invoice_type: x_studio_camunda_invoice_type, x_studio_camunda_invoice_file: x_studio_camunda_invoice_file, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
        <zeebe:calledDecision decisionId="utility-expense-classification" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_pay_to_service</bpmn:incoming>
      <bpmn:outgoing>Flow_service_to_end</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:serviceTask id="Activity_1mf4l1i" name="Внести затрати в 1С">
      <bpmn:incoming>Flow_service_to_end</bpmn:incoming>
      <bpmn:outgoing>Flow_close_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_main" name="Рахунок оплачено">
      <bpmn:incoming>Flow_close_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="End_rejected" name="Рахунок відхилено">
      <bpmn:incoming>Flow_approved_no</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ===== SEQUENCE FLOWS ===== -->
    <bpmn:sequenceFlow id="Flow_start_to_upload" sourceRef="StartEvent_1" targetRef="UT_upload_file" />
    <bpmn:sequenceFlow id="Flow_upload_to_extract" sourceRef="UT_upload_file" targetRef="ST_extract_invoice" />
    <bpmn:sequenceFlow id="Flow_extract_to_gw_odoo" sourceRef="ST_extract_invoice" targetRef="GW_odoo_check" />
    <bpmn:sequenceFlow id="Flow_odoo_no_task" sourceRef="GW_odoo_check" targetRef="ST_create_main" />
    <bpmn:sequenceFlow id="Flow_odoo_has_task" name="Задача існує" sourceRef="GW_odoo_check" targetRef="GW_odoo_merge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= is defined(odoo_task_id) and odoo_task_id != null</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_create_main_done" sourceRef="ST_create_main" targetRef="GW_odoo_merge" />
    <bpmn:sequenceFlow id="Flow_merge_to_classify" sourceRef="GW_odoo_merge" targetRef="ST_classify_type" />
    <bpmn:sequenceFlow id="Flow_classify_to_communal_check" sourceRef="ST_classify_type" targetRef="GW_is_communal" />
    <bpmn:sequenceFlow id="Flow_communal_yes" name="комунальні" sourceRef="GW_is_communal" targetRef="BRT_check_detail">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_invoice_type = "комунальні"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_not_communal" name="оренда" sourceRef="GW_is_communal" targetRef="GW_detail_merge" />
    <bpmn:sequenceFlow id="Flow_detail_to_check" sourceRef="BRT_check_detail" targetRef="GW_detail_check" />
    <bpmn:sequenceFlow id="Flow_detail_yes" name="надає" sourceRef="GW_detail_check" targetRef="UT_request_detail">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_provides_detailization = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_no_detail" name="не надає" sourceRef="GW_detail_check" targetRef="GW_detail_merge" />
    <bpmn:sequenceFlow id="Flow_detail_received" sourceRef="UT_request_detail" targetRef="GW_detail_merge" />
    <bpmn:sequenceFlow id="Flow_detail_to_calendar" sourceRef="GW_detail_merge" targetRef="Task_calendar" />
    <bpmn:sequenceFlow id="Flow_calendar_to_timer" sourceRef="Task_calendar" targetRef="Timer_payday" />
    <bpmn:sequenceFlow id="Flow_timer_to_approve" sourceRef="Timer_payday" targetRef="Task_approve" />
    <bpmn:sequenceFlow id="Flow_approve_to_gw" sourceRef="Task_approve" targetRef="GW_approved" />
    <bpmn:sequenceFlow id="Flow_approved_yes" name="так" sourceRef="GW_approved" targetRef="Task_pay">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_approved = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_approved_no" name="ні" sourceRef="GW_approved" targetRef="End_rejected" />
    <bpmn:sequenceFlow id="Flow_pay_to_service" sourceRef="Task_pay" targetRef="Task_service_receipt" />
    <bpmn:sequenceFlow id="Flow_service_to_end" sourceRef="Task_service_receipt" targetRef="Activity_1mf4l1i" />
    <bpmn:sequenceFlow id="Flow_close_to_end" sourceRef="Activity_1mf4l1i" targetRef="End_main" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_single_invoice_no_lanes">
      <!-- SHAPES -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="160" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="164" y="225" width="28" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UT_upload_file_di" bpmnElement="UT_upload_file">
        <dc:Bounds x="250" y="160" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST_extract_invoice_di" bpmnElement="ST_extract_invoice">
        <dc:Bounds x="410" y="160" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_odoo_check_di" bpmnElement="GW_odoo_check" isMarkerVisible="true">
        <dc:Bounds x="570" y="175" width="50" height="50" />
        <bpmndi:BPMNLabel>
