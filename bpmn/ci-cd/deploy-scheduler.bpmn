<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_scheduler" targetNamespace="http://tut.ua/bpmn/deploy-scheduler" exporter="Claude Code" exporterVersion="1.0">

  <bpmn:error id="Error_deploy_failed" name="Deploy Failed" errorCode="DEPLOY_FAILED" />

  <bpmn:message id="Message_deploy_trigger" name="msg_deploy_trigger">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=branch" />
    </bpmn:extensionElements>
  </bpmn:message>

  <bpmn:process id="deploy-scheduler" name="Deploy Scheduler" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="5.0" />
    </bpmn:extensionElements>

    <!-- Start: triggered by webhook push -->
    <bpmn:startEvent id="evt_start" name="Пуш до staging">
      <bpmn:outgoing>f_start_to_deploy</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_start" messageRef="Message_deploy_trigger" />
    </bpmn:startEvent>

    <!-- Call Activity: actual deploy -->
    <bpmn:callActivity id="CA_deploy" name="Деплой на сервер">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="deploy-process" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=server_host" target="server_host" />
          <zeebe:input source="=ssh_user" target="ssh_user" />
          <zeebe:input source="=repo_dir" target="repo_dir" />
          <zeebe:input source="=db_name" target="db_name" />
          <zeebe:input source="=container" target="container" />
          <zeebe:input source="=branch" target="branch" />
          <zeebe:input source="=run_smoke_test" target="run_smoke_test" />
          <zeebe:input source="=if is defined(test_mode) and test_mode != null then test_mode else &quot;light&quot;" target="test_mode" />
          <zeebe:input source="=if is defined(skip_clickbot) and skip_clickbot != null then skip_clickbot else false" target="skip_clickbot" />
          <zeebe:input source="=if is defined(odoo_project_id) and odoo_project_id != null then odoo_project_id else 560" target="odoo_project_id" />
          <zeebe:input source="=if is defined(trigger_sha) and trigger_sha != null then trigger_sha else &quot;unknown&quot;" target="trigger_sha" />
          <zeebe:input source="=if is defined(install_modules) and install_modules != null then install_modules else &quot;&quot;" target="install_modules" />
          <zeebe:input source="=string(process_instance_key)" target="parent_process_instance_key" />
          <zeebe:input source="=if is defined(odoo_webhook_url) and odoo_webhook_url != null then odoo_webhook_url else &quot;&quot;" target="odoo_webhook_url" />
          <zeebe:input source="=if is defined(pr_number) and pr_number != null then pr_number else null" target="pr_number" />
          <zeebe:input source="=if is defined(pr_title) and pr_title != null then pr_title else &quot;&quot;" target="pr_title" />
          <zeebe:input source="=if is defined(pusher) and pusher != null then pusher else &quot;&quot;" target="pusher" />
          <zeebe:input source="=if is defined(compare_url) and compare_url != null then compare_url else &quot;&quot;" target="compare_url" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_start_to_deploy</bpmn:incoming>
      <bpmn:incoming>f_loop_to_deploy</bpmn:incoming>
      <bpmn:outgoing>f_deploy_to_gw</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Catch deploy errors — don't block scheduler -->
    <bpmn:boundaryEvent id="BE_deploy_error" name="Деплой впав" attachedToRef="CA_deploy">
      <bpmn:outgoing>f_error_to_gw</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDef_deploy_failed" errorRef="Error_deploy_failed" />
    </bpmn:boundaryEvent>

    <!-- After deploy: check if new push arrived -->
    <bpmn:eventBasedGateway id="gw_wait" name="Новий пуш?">
      <bpmn:incoming>f_deploy_to_gw</bpmn:incoming>
      <bpmn:incoming>f_error_to_gw</bpmn:incoming>
      <bpmn:outgoing>f_wait_msg</bpmn:outgoing>
      <bpmn:outgoing>f_wait_timer</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <!-- Option 1: new push arrived — deploy again -->
    <bpmn:intermediateCatchEvent id="evt_new_push" name="Новий пуш">
      <bpmn:incoming>f_wait_msg</bpmn:incoming>
      <bpmn:outgoing>f_loop_to_deploy</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_new_push" messageRef="Message_deploy_trigger" />
    </bpmn:intermediateCatchEvent>

    <!-- Option 2: no new push within 30s — done -->
    <bpmn:intermediateCatchEvent id="evt_timeout" name="30с без пушу">
      <bpmn:incoming>f_wait_timer</bpmn:incoming>
      <bpmn:outgoing>f_timeout_to_end</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_timeout">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT30S</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="evt_end" name="Черга порожня">
      <bpmn:incoming>f_timeout_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="f_error_to_gw" sourceRef="BE_deploy_error" targetRef="gw_wait" />
    <bpmn:sequenceFlow id="f_start_to_deploy" sourceRef="evt_start" targetRef="CA_deploy" />
    <bpmn:sequenceFlow id="f_deploy_to_gw" sourceRef="CA_deploy" targetRef="gw_wait" />
    <bpmn:sequenceFlow id="f_wait_msg" sourceRef="gw_wait" targetRef="evt_new_push" />
    <bpmn:sequenceFlow id="f_wait_timer" sourceRef="gw_wait" targetRef="evt_timeout" />
    <bpmn:sequenceFlow id="f_loop_to_deploy" sourceRef="evt_new_push" targetRef="CA_deploy" />
    <bpmn:sequenceFlow id="f_timeout_to_end" sourceRef="evt_timeout" targetRef="evt_end" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="deploy-scheduler">
      <bpmndi:BPMNShape id="evt_start_di" bpmnElement="evt_start">
        <dc:Bounds x="160" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CA_deploy_di" bpmnElement="CA_deploy">
        <dc:Bounds x="300" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BE_deploy_error_di" bpmnElement="BE_deploy_error">
        <dc:Bounds x="354" y="322" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_wait_di" bpmnElement="gw_wait">
        <dc:Bounds x="505" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="evt_new_push_di" bpmnElement="evt_new_push">
        <dc:Bounds x="632" y="222" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="evt_timeout_di" bpmnElement="evt_timeout">
        <dc:Bounds x="632" y="332" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="evt_end_di" bpmnElement="evt_end">
        <dc:Bounds x="762" y="332" width="36" height="36" />
      </bpmndi:BPMNShape>
      <!-- Edges -->
      <bpmndi:BPMNEdge id="f_error_to_gw_di" bpmnElement="f_error_to_gw">
        <di:waypoint x="372" y="358" />
        <di:waypoint x="372" y="400" />
        <di:waypoint x="530" y="400" />
        <di:waypoint x="530" y="325" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_start_to_deploy_di" bpmnElement="f_start_to_deploy">
        <di:waypoint x="196" y="300" />
        <di:waypoint x="300" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_deploy_to_gw_di" bpmnElement="f_deploy_to_gw">
        <di:waypoint x="400" y="300" />
        <di:waypoint x="505" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_wait_msg_di" bpmnElement="f_wait_msg">
        <di:waypoint x="530" y="275" />
        <di:waypoint x="530" y="240" />
        <di:waypoint x="632" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_wait_timer_di" bpmnElement="f_wait_timer">
        <di:waypoint x="530" y="325" />
        <di:waypoint x="530" y="350" />
        <di:waypoint x="632" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_loop_to_deploy_di" bpmnElement="f_loop_to_deploy">
        <di:waypoint x="650" y="222" />
        <di:waypoint x="650" y="160" />
        <di:waypoint x="350" y="160" />
        <di:waypoint x="350" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_timeout_to_end_di" bpmnElement="f_timeout_to_end">
        <di:waypoint x="668" y="350" />
        <di:waypoint x="762" y="350" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
