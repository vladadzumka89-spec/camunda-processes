<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_RakhunokTRC" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="e787c33" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="rakhunok-vid-trc" name="Рахунок від ТРЦ" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="1.0" />
    </bpmn:extensionElements>

    <bpmn:startEvent id="StartEvent_1" name="Рахунок отримано">
      <bpmn:outgoing>Flow_start_to_gw_odoo</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="GW_odoo_check" name="Задача в Odoo існує?" default="Flow_odoo_no_task">
      <bpmn:incoming>Flow_start_to_gw_odoo</bpmn:incoming>
      <bpmn:outgoing>Flow_odoo_no_task</bpmn:outgoing>
      <bpmn:outgoing>Flow_odoo_has_task</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="ST_create_main" name="Створити батьківську задачу в Odoo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Рахунок від ТРЦ&#34;, create_process: true, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_task_type: &#34;full&#34;, x_studio_camunda_is_famo: x_studio_camunda_is_famo, x_studio_camunda_is_rent: x_studio_camunda_is_rent, x_studio_camunda_invoice_amount: x_studio_camunda_invoice_amount, x_studio_camunda_partner_name: x_studio_camunda_partner_name}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_odoo_no_task</bpmn:incoming>
      <bpmn:outgoing>Flow_create_main_done</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GW_odoo_merge">
      <bpmn:incoming>Flow_odoo_has_task</bpmn:incoming>
      <bpmn:incoming>Flow_create_main_done</bpmn:incoming>
      <bpmn:outgoing>Flow_merge_to_famo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ===== РОЗГАЛУЖЕННЯ: ФАМО? ===== -->
    <bpmn:exclusiveGateway id="GW_FAMO" name="ФАМО?" default="Flow_famo_no">
      <bpmn:incoming>Flow_merge_to_famo</bpmn:incoming>
      <bpmn:outgoing>Flow_famo_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_famo_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ===== ГІЛКА ФАМО = ТАК ===== -->
    <bpmn:userTask id="UT_check_sum_famo" name="Перевірити суму та погодити (ФАМО)">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Перевірити суму та погодити (ФАМО): &#34; + x_studio_camunda_partner_name, description: &#34;Перевірте суму рахунку та погодьте або відхиліть&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_task_type: &#34;short&#34;}" target="body" />
          <zeebe:output source="= x_studio_camunda_approved" target="x_studio_camunda_approved" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_famo_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_check_famo_to_appr</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_approved_famo" name="Погоджено?" default="Flow_appr_famo_no">
      <bpmn:incoming>Flow_check_famo_to_appr</bpmn:incoming>
      <bpmn:outgoing>Flow_appr_famo_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_appr_famo_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_pay_famo" name="Оплачуємо?" default="Flow_pay_famo_no">
      <bpmn:incoming>Flow_appr_famo_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_pay_famo_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_pay_famo_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_register_tp" name="ТП зареєструвати">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;ТП зареєструвати: &#34; + x_studio_camunda_partner_name, description: &#34;Зареєструйте торговельну точку в 1С&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_task_type: &#34;short&#34;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_pay_famo_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_reg_tp_to_cash</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_cash_on_site" name="Сплачуємо готівкою на місці?" default="Flow_cash_no">
      <bpmn:incoming>Flow_reg_tp_to_cash</bpmn:incoming>
      <bpmn:outgoing>Flow_cash_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_cash_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_pay_cash" name="Сплатити готівкою">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Сплатити готівкою: &#34; + x_studio_camunda_partner_name, description: &#34;Здійсніть оплату готівкою на місці&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_task_type: &#34;short&#34;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_cash_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_pay_cash_to_mark</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_pay_tp" name="ТП сплатити">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;ТП сплатити: &#34; + x_studio_camunda_partner_name, description: &#34;Здійсніть оплату через торговельну точку&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_task_type: &#34;short&#34;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_cash_no</bpmn:incoming>
      <bpmn:outgoing>Flow_pay_tp_to_mark</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="ST_mark_paid_tp" name="Ознака сплачено (ТП/готівка)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {action: &#34;mark_paid&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_paid: true}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_pay_cash_to_mark</bpmn:incoming>
      <bpmn:incoming>Flow_pay_tp_to_mark</bpmn:incoming>
      <bpmn:outgoing>Flow_mark_tp_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_tp" name="Оплачено через ТП/готівку">
      <bpmn:incoming>Flow_mark_tp_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- "Рахунок не погоджено" — гілка ФАМО/Погоджено=Ні (кінець процесу) -->
    <bpmn:serviceTask id="ST_not_approved_famo_end" name="Рахунок не погоджено">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {action: &#34;mark_not_approved&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_approved: false}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_appr_famo_no</bpmn:incoming>
      <bpmn:outgoing>Flow_not_appr_famo_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_not_approved_famo" name="Не погоджено">
      <bpmn:incoming>Flow_not_appr_famo_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- "Рахунок не погоджено" — гілка ФАМО/Оплачуємо=Ні (іде в загальну реєстрацію) -->
    <bpmn:serviceTask id="ST_not_approved_famo_join" name="Рахунок не погоджено">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {action: &#34;mark_not_approved&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_approved: false}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_pay_famo_no</bpmn:incoming>
      <bpmn:outgoing>Flow_not_appr_famo_to_join</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ===== ГІЛКА ФАМО = НІ ===== -->
    <bpmn:exclusiveGateway id="GW_rent" name="Оренда?" default="Flow_rent_no">
      <bpmn:incoming>Flow_famo_no</bpmn:incoming>
      <bpmn:outgoing>Flow_rent_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_rent_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_pay_rent" name="Оплачуємо?" default="Flow_pay_rent_no">
      <bpmn:incoming>Flow_rent_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_pay_rent_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_pay_rent_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_check_sum_other" name="Перевірити суму та погодити">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Перевірити суму та погодити: &#34; + x_studio_camunda_partner_name, description: &#34;Перевірте суму рахунку та погодьте або відхиліть&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_task_type: &#34;short&#34;}" target="body" />
          <zeebe:output source="= x_studio_camunda_approved" target="x_studio_camunda_approved" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_rent_no</bpmn:incoming>
      <bpmn:outgoing>Flow_check_other_to_appr</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_approved_other" name="Погоджено?" default="Flow_appr_other_no">
      <bpmn:incoming>Flow_check_other_to_appr</bpmn:incoming>
      <bpmn:outgoing>Flow_appr_other_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_appr_other_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="ST_not_approved_rent_end" name="Рахунок не погоджено">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {action: &#34;mark_not_approved&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_approved: false}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_pay_rent_no</bpmn:incoming>
      <bpmn:incoming>Flow_appr_other_no</bpmn:incoming>
      <bpmn:outgoing>Flow_not_appr_other_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_not_approved_other" name="Не погоджено">
      <bpmn:incoming>Flow_not_appr_other_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ===== ЗАГАЛЬНА ГІЛКА: ФАМО Зареєструвати → Сплатити → Поступлення ===== -->
    <bpmn:exclusiveGateway id="GW_join_to_reg_famo">
      <bpmn:incoming>Flow_not_appr_famo_to_join</bpmn:incoming>
      <bpmn:incoming>Flow_pay_rent_yes</bpmn:incoming>
      <bpmn:incoming>Flow_appr_other_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_join_to_reg_famo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="ST_register_famo" name="ФАМО Зареєструвати">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {action: &#34;register_famo&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_partner_name: x_studio_camunda_partner_name, x_studio_camunda_invoice_amount: x_studio_camunda_invoice_amount}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_join_to_reg_famo</bpmn:incoming>
      <bpmn:outgoing>Flow_reg_famo_to_pay</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:userTask id="UT_pay_invoice" name="Сплатити рахунок">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Сплатити рахунок: &#34; + x_studio_camunda_partner_name, description: &#34;Здійсніть оплату рахунку відповідно до зареєстрованих даних ФАМО&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_task_type: &#34;short&#34;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_reg_famo_to_pay</bpmn:incoming>
      <bpmn:outgoing>Flow_pay_to_mark_main</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="ST_mark_paid_main" name="Ознака сплачено">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {action: &#34;mark_paid&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_paid: true}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_pay_to_mark_main</bpmn:incoming>
      <bpmn:outgoing>Flow_mark_main_to_receipt</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:userTask id="UT_add_receipt" name="Внести поступлення">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Внести поступлення: &#34; + x_studio_camunda_partner_name, description: &#34;Внесіть поступлення товарів/послуг до 1С&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, x_studio_camunda_task_type: &#34;short&#34;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_mark_main_to_receipt</bpmn:incoming>
      <bpmn:outgoing>Flow_receipt_to_end</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="End_main" name="Поступлення внесено">
      <bpmn:incoming>Flow_receipt_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ===== ERROR SUBPROCESS ===== -->
    <bpmn:subProcess id="subprocess_error_rakhunok" triggeredByEvent="true">
      <bpmn:startEvent id="evt_error_catch_rakhunok" isInterrupting="false">
        <bpmn:outgoing>Flow_error_to_notify</bpmn:outgoing>
        <bpmn:errorEventDefinition id="ErrorEventDefinition_rakhunok" errorCodeVariable="caught_error_code" errorMessageVariable="caught_error_message" />
      </bpmn:startEvent>

      <bpmn:serviceTask id="ST_error_notify_rakhunok" name="Створити підзадачу про помилку">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="http-request-smart" />
          <zeebe:ioMapping>
            <zeebe:input source="= &#34;POST&#34;" target="method" />
            <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
            <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
            <zeebe:input source="= {name: &#34;Помилка процесу &#39;Рахунок від ТРЦ&#39;&#34;, description: &#34;Код: &#34; + caught_error_code + &#34;. Повідомлення: &#34; + caught_error_message, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, notification_type: &#34;rakhunok_error&#34;, x_studio_camunda_error_code: caught_error_code, x_studio_camunda_error_message: caught_error_message}" target="body" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_error_to_notify</bpmn:incoming>
        <bpmn:outgoing>Flow_error_to_end</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:endEvent id="End_error_rakhunok" name="Помилку зафіксовано">
        <bpmn:incoming>Flow_error_to_end</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="Flow_error_to_notify" sourceRef="evt_error_catch_rakhunok" targetRef="ST_error_notify_rakhunok" />
      <bpmn:sequenceFlow id="Flow_error_to_end" sourceRef="ST_error_notify_rakhunok" targetRef="End_error_rakhunok" />
    </bpmn:subProcess>

    <!-- ===== ПОТОКИ ===== -->
    <bpmn:sequenceFlow id="Flow_start_to_gw_odoo" sourceRef="StartEvent_1" targetRef="GW_odoo_check" />
    <bpmn:sequenceFlow id="Flow_odoo_no_task" sourceRef="GW_odoo_check" targetRef="ST_create_main" />
    <bpmn:sequenceFlow id="Flow_odoo_has_task" name="Задача існує" sourceRef="GW_odoo_check" targetRef="GW_odoo_merge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= is defined(odoo_task_id) and odoo_task_id != null</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_create_main_done" sourceRef="ST_create_main" targetRef="GW_odoo_merge" />
    <bpmn:sequenceFlow id="Flow_merge_to_famo" sourceRef="GW_odoo_merge" targetRef="GW_FAMO" />

    <bpmn:sequenceFlow id="Flow_famo_yes" name="Так" sourceRef="GW_FAMO" targetRef="UT_check_sum_famo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_is_famo = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_famo_no" name="Ні" sourceRef="GW_FAMO" targetRef="GW_rent" />

    <bpmn:sequenceFlow id="Flow_check_famo_to_appr" sourceRef="UT_check_sum_famo" targetRef="GW_approved_famo" />
    <bpmn:sequenceFlow id="Flow_appr_famo_yes" name="Так" sourceRef="GW_approved_famo" targetRef="GW_pay_famo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_approved = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_appr_famo_no" name="Ні" sourceRef="GW_approved_famo" targetRef="ST_not_approved_famo_end" />
    <bpmn:sequenceFlow id="Flow_not_appr_famo_end" sourceRef="ST_not_approved_famo_end" targetRef="End_not_approved_famo" />

    <bpmn:sequenceFlow id="Flow_pay_famo_yes" name="Так" sourceRef="GW_pay_famo" targetRef="UT_register_tp">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_pay = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_pay_famo_no" name="Ні" sourceRef="GW_pay_famo" targetRef="ST_not_approved_famo_join" />
    <bpmn:sequenceFlow id="Flow_not_appr_famo_to_join" sourceRef="ST_not_approved_famo_join" targetRef="GW_join_to_reg_famo" />

    <bpmn:sequenceFlow id="Flow_reg_tp_to_cash" sourceRef="UT_register_tp" targetRef="GW_cash_on_site" />
    <bpmn:sequenceFlow id="Flow_cash_yes" name="Так" sourceRef="GW_cash_on_site" targetRef="UT_pay_cash">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_cash_on_site = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_cash_no" name="Ні" sourceRef="GW_cash_on_site" targetRef="UT_pay_tp" />
    <bpmn:sequenceFlow id="Flow_pay_cash_to_mark" sourceRef="UT_pay_cash" targetRef="ST_mark_paid_tp" />
    <bpmn:sequenceFlow id="Flow_pay_tp_to_mark" sourceRef="UT_pay_tp" targetRef="ST_mark_paid_tp" />
    <bpmn:sequenceFlow id="Flow_mark_tp_to_end" sourceRef="ST_mark_paid_tp" targetRef="End_tp" />

    <bpmn:sequenceFlow id="Flow_rent_yes" name="Так" sourceRef="GW_rent" targetRef="GW_pay_rent">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_is_rent = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_rent_no" name="Ні" sourceRef="GW_rent" targetRef="UT_check_sum_other" />
    <bpmn:sequenceFlow id="Flow_pay_rent_yes" name="Так" sourceRef="GW_pay_rent" targetRef="GW_join_to_reg_famo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_pay = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_pay_rent_no" name="Ні" sourceRef="GW_pay_rent" targetRef="ST_not_approved_rent_end" />

    <bpmn:sequenceFlow id="Flow_check_other_to_appr" sourceRef="UT_check_sum_other" targetRef="GW_approved_other" />
    <bpmn:sequenceFlow id="Flow_appr_other_yes" name="Так" sourceRef="GW_approved_other" targetRef="GW_join_to_reg_famo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_approved = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_appr_other_no" name="Ні" sourceRef="GW_approved_other" targetRef="ST_not_approved_rent_end" />
    <bpmn:sequenceFlow id="Flow_not_appr_other_end" sourceRef="ST_not_approved_rent_end" targetRef="End_not_approved_other" />

    <bpmn:sequenceFlow id="Flow_join_to_reg_famo" sourceRef="GW_join_to_reg_famo" targetRef="ST_register_famo" />
    <bpmn:sequenceFlow id="Flow_reg_famo_to_pay" sourceRef="ST_register_famo" targetRef="UT_pay_invoice" />
    <bpmn:sequenceFlow id="Flow_pay_to_mark_main" sourceRef="UT_pay_invoice" targetRef="ST_mark_paid_main" />
    <bpmn:sequenceFlow id="Flow_mark_main_to_receipt" sourceRef="ST_mark_paid_main" targetRef="UT_add_receipt" />
    <bpmn:sequenceFlow id="Flow_receipt_to_end" sourceRef="UT_add_receipt" targetRef="End_main" />

  </bpmn:process>

