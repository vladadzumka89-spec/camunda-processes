<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="e787c33" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="Process_fop_limit_monitor" name="Моніторинг лімітів ФОП" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="1.0" />
    </bpmn:extensionElements>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_system" name="Система (автоматично)">
        <bpmn:flowNodeRef>StartEvent_timer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_manual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Merge_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_fop_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_send_report</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_has_critical</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CA_fop_notification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_done</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_timer" name="Щоденна перевірка">
      <bpmn:outgoing>Flow_timer_to_merge</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_1">
        <bpmn:timeCycle>R/2026-03-31T05:00:00Z/P1D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:startEvent id="StartEvent_manual" name="Ручний запуск">
      <bpmn:outgoing>Flow_manual_to_merge</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Merge_start">
      <bpmn:incoming>Flow_timer_to_merge</bpmn:incoming>
      <bpmn:incoming>Flow_manual_to_merge</bpmn:incoming>
      <bpmn:outgoing>Flow_to_check</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ST_fop_check" name="Перевірка лімітів ФОП">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="fop-limit-check" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="= if is defined(days_ahead) and days_ahead != null then days_ahead else 14" target="days_ahead" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_check</bpmn:incoming>
      <bpmn:outgoing>Flow_check_to_report</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ST_send_report" name="Звіт в Odoo дашборд">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/bb450e05-4673-4cc9-9ba3-8674da99dc61&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {action: &#34;fop_limit_report&#34;, report: report_json}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_check_to_report</bpmn:incoming>
      <bpmn:outgoing>Flow_report_to_gw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_has_critical" name="Є критичні ФОП?" default="Flow_no_critical">
      <bpmn:incoming>Flow_report_to_gw</bpmn:incoming>
      <bpmn:outgoing>Flow_yes_critical</bpmn:outgoing>
      <bpmn:outgoing>Flow_no_critical</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:callActivity id="CA_fop_notification" name="Сповіщення про зміну ФОП">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Process_0iy2u1a" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="= fop.fop_name" target="fop_name" />
          <zeebe:input source="= fop.fop_edrpou" target="fop_edrpou" />
          <zeebe:input source="= fop.ep_group" target="ep_group" />
          <zeebe:input source="= fop.total_income" target="total_income" />
          <zeebe:input source="= fop.limit_amount" target="limit_amount" />
          <zeebe:input source="= fop.income_percent" target="income_percent" />
          <zeebe:input source="= fop.days_to_limit" target="days_to_limit" />
          <zeebe:input source="= fop.projected_date" target="projected_date" />
          <zeebe:input source="= fop.stores" target="stores" />
          <zeebe:input source="= fop.stores_count" target="stores_count" />
          <zeebe:input source="= fop.trend_ratio" target="trend_ratio" />
          <zeebe:input source="= string(processInstanceKey)" target="process_instance_key" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_yes_critical</bpmn:incoming>
      <bpmn:outgoing>Flow_ca_to_end</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics>
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="= critical_fops" inputElement="fop" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:callActivity>
    <bpmn:endEvent id="End_done" name="Перевірку завершено">
      <bpmn:incoming>Flow_no_critical</bpmn:incoming>
      <bpmn:incoming>Flow_ca_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_timer_to_merge" sourceRef="StartEvent_timer" targetRef="Merge_start" />
    <bpmn:sequenceFlow id="Flow_manual_to_merge" sourceRef="StartEvent_manual" targetRef="Merge_start" />
    <bpmn:sequenceFlow id="Flow_to_check" sourceRef="Merge_start" targetRef="ST_fop_check" />
    <bpmn:sequenceFlow id="Flow_check_to_report" sourceRef="ST_fop_check" targetRef="ST_send_report" />
    <bpmn:sequenceFlow id="Flow_report_to_gw" sourceRef="ST_send_report" targetRef="GW_has_critical" />
    <bpmn:sequenceFlow id="Flow_yes_critical" name="Так" sourceRef="GW_has_critical" targetRef="CA_fop_notification">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= critical_count &gt; 0</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_no_critical" name="Ні" sourceRef="GW_has_critical" targetRef="End_done" />
    <bpmn:sequenceFlow id="Flow_ca_to_end" sourceRef="CA_fop_notification" targetRef="End_done" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_fop_limit_monitor">
      <bpmndi:BPMNShape id="Participant_pool_di" bpmnElement="Lane_system" isHorizontal="true">
        <dc:Bounds x="105" y="90" width="1230" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_timer_di" bpmnElement="StartEvent_timer">
        <dc:Bounds x="182" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="155" y="128" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_manual_di" bpmnElement="StartEvent_manual">
        <dc:Bounds x="182" y="252" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="160" y="295" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Merge_start_di" bpmnElement="Merge_start" isMarkerVisible="true">
        <dc:Bounds x="315" y="195" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST_fop_check_di" bpmnElement="ST_fop_check">
        <dc:Bounds x="445" y="180" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST_send_report_di" bpmnElement="ST_send_report">
        <dc:Bounds x="625" y="180" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_has_critical_di" bpmnElement="GW_has_critical" isMarkerVisible="true">
        <dc:Bounds x="815" y="195" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="800" y="165" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CA_fop_notification_di" bpmnElement="CA_fop_notification">
        <dc:Bounds x="955" y="180" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_done_di" bpmnElement="End_done">
        <dc:Bounds x="1157" y="202" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1130" y="245" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_timer_to_merge_di" bpmnElement="Flow_timer_to_merge">
        <di:waypoint x="218" y="170" />
        <di:waypoint x="267" y="170" />
        <di:waypoint x="267" y="220" />
        <di:waypoint x="315" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_manual_to_merge_di" bpmnElement="Flow_manual_to_merge">
        <di:waypoint x="218" y="270" />
        <di:waypoint x="267" y="270" />
        <di:waypoint x="267" y="220" />
        <di:waypoint x="315" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_check_di" bpmnElement="Flow_to_check">
        <di:waypoint x="365" y="220" />
        <di:waypoint x="445" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_check_to_report_di" bpmnElement="Flow_check_to_report">
        <di:waypoint x="545" y="220" />
        <di:waypoint x="625" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_report_to_gw_di" bpmnElement="Flow_report_to_gw">
        <di:waypoint x="725" y="220" />
        <di:waypoint x="815" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_yes_critical_di" bpmnElement="Flow_yes_critical">
        <di:waypoint x="865" y="220" />
        <di:waypoint x="955" y="220" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="903" y="202" width="16" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_no_critical_di" bpmnElement="Flow_no_critical">
        <di:waypoint x="840" y="245" />
        <di:waypoint x="840" y="300" />
        <di:waypoint x="1175" y="300" />
        <di:waypoint x="1175" y="238" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1000" y="282" width="14" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ca_to_end_di" bpmnElement="Flow_ca_to_end">
        <di:waypoint x="1055" y="220" />
        <di:waypoint x="1157" y="220" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
