          <zeebe:input target="body" source="={name: string(month) + &#34;.&#34; + string(year) + &#34; — Загрузити довідки на сайт орендодавця&#34;, description: &#34;&lt;b&gt;Період:&lt;/b&gt; &#34; + string(month) + &#34;.&#34; + string(year) + &#34;&lt;br/&gt;Завантаж довідки на сайти орендодавців і познач кожен рядок &lt;b&gt;Загружено&lt;/b&gt;.&#34;, description_format: &#34;html&#34;, _model: &#34;project.project&#34;, _id: project_id, parent_id: odoo_task_id, process_instance_key: process_instance_key, x_studio_camunda_role_code: &#34;finansist&#34;, x_studio_camunda_task_code: &#34;upload_to_site&#34;, x_studio_camunda_year: year, x_studio_camunda_month: month, upload_site_stores: upload_site_stores}" />
