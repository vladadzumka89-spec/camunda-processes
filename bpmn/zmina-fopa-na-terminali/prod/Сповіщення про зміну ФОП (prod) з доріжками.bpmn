    <bpmn:serviceTask id="Activity_1sbkk55" name="Нагадати ТРЦ про погодження">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;🔔 Нагадайте ТРЦ про погодження переключення: &#34; + fop_name + &#34; → &#34; + (if is defined(new_fop_name) then new_fop_name else &#34;?&#34;) + &#34; на &#34; + selected_store, description: &#34;&#60;b&#62;Магазин:&#60;/b&#62; &#34; + selected_store + &#34;&#60;br/&#62;&#60;b&#62;Старий ФОП:&#60;/b&#62; &#34; + fop_name + &#34;&#60;br/&#62;&#60;b&#62;Новий ФОП:&#60;/b&#62; &#34; + (if is defined(new_fop_name) then new_fop_name else &#34;(не вказано)&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Дата переключення:&#60;/b&#62; &#34; + (if is defined(switch_date) then switch_date else &#34;(не визначено)&#34;) + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#34; + &#34;&#60;br/&#62;1. Відповідь від ТРЦ ще не отримана — зв&#39;яжіться з ТРЦ та нагадайте про погодження переключення.&#34; + &#34;&#60;br/&#62;2. Коли отримаєте відповідь від ТРЦ — поверніться до задачі «Перевірити погодження ТРЦ» та виконайте її.&#34;, x_studio_camunda_role_code: &#34;rental_manager&#34;, parent_id: odoo_task_id, _model: &#34;project.project&#34;, _id: 524, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
        <zeebe:taskDefinition type="http-request-smart" retries="1" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0zrpjt4</bpmn:incoming>
      <bpmn:outgoing>Flow_0x7bnbc</bpmn:outgoing>
