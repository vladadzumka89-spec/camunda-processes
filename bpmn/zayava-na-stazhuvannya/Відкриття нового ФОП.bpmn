<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="e787c33" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Відкриття нового ФОП" processRef="Process_vidkryttya_fop" />
  </bpmn:collaboration>

  <bpmn:process id="Process_vidkryttya_fop" name="Відкриття нового ФОП" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="1.0" />
    </bpmn:extensionElements>

    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_system" name="Система (автоматично)">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_odoo_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_create_main</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_odoo_merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Merge_docs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_docs_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Merge_debt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_debt_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_final</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_candidate" name="Кандидат">
        <bpmn:flowNodeRef>UT_want_fop</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_read_telegram</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_add_docs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_read_wiki</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_gen_file_key</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_save_password</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_pay_debt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_register_diia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_open_account</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_trusted_privat</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_accountant" name="Бухгалтер">
        <bpmn:flowNodeRef>UT_check_dps</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_get_extract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_upload_cert</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_check_tax_date</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_get_tax_extract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_make_cards</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_get_key_card</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_create_org_erp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_create_counterparty</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_wait1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_wait2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_add_key_do3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_add_trusted_final</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_1c_admin" name="Адміністратор 1С">
        <bpmn:flowNodeRef>UT_fill_org</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_create_license</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_setup_sick</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_salary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_fill_signatories</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_create_folder</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- ============ START + ODOO CHECK ============ -->

    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_start_to_gw</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="GW_odoo_check" name="Задача в Odoo існує?" default="Flow_odoo_default">
      <bpmn:incoming>Flow_start_to_gw</bpmn:incoming>
      <bpmn:outgoing>Flow_odoo_skip</bpmn:outgoing>
      <bpmn:outgoing>Flow_odoo_default</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="ST_create_main" name="Створити задачу в Odoo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Відкриття нового ФОП&#34;, create_process: true, _model: &#34;project.project&#34;, _id: 252}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_odoo_default</bpmn:incoming>
      <bpmn:outgoing>Flow_create_to_merge</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GW_odoo_merge">
      <bpmn:incoming>Flow_odoo_skip</bpmn:incoming>
      <bpmn:incoming>Flow_create_to_merge</bpmn:incoming>
      <bpmn:outgoing>Flow_merge_to_want</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ============ CANDIDATE: ПОЧАТОК ПРОЦЕСУ ============ -->

    <bpmn:userTask id="UT_want_fop" name="Працівник бажає стати ФОП">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Працівник бажає стати ФОП&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_merge_to_want</bpmn:incoming>
      <bpmn:outgoing>Flow_want_to_telegram</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_read_telegram" name="Ознайомся з офіційним телеграмом Бухгалтерії">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Ознайомся з офіційним телеграмом Бухгалтерії&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_want_to_telegram</bpmn:incoming>
      <bpmn:outgoing>Flow_telegram_to_docs_merge</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ============ DOCUMENT CHECK LOOP ============ -->

    <bpmn:exclusiveGateway id="Merge_docs">
      <bpmn:incoming>Flow_telegram_to_docs_merge</bpmn:incoming>
      <bpmn:incoming>Flow_add_docs_to_merge</bpmn:incoming>
      <bpmn:outgoing>Flow_docs_merge_to_check</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_docs_check" name="Всі документи отримані?" default="Flow_docs_yes">
      <bpmn:incoming>Flow_docs_merge_to_check</bpmn:incoming>
      <bpmn:outgoing>Flow_docs_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_docs_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_add_docs" name="Додайте документи">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Додайте документи&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_docs_no</bpmn:incoming>
      <bpmn:outgoing>Flow_add_docs_to_merge</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ============ CANDIDATE: ПІДГОТОВКА КЛЮЧІВ ============ -->

    <bpmn:userTask id="UT_read_wiki" name="Ознайомитися із статтями на вікі">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Ознайомитися із статтями на вікі&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_docs_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_wiki_to_key</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_gen_file_key" name="Сформувати файловий ключ та передати бухгалтеру">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Сформувати файловий ключ та передати бухгалтеру&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_wiki_to_key</bpmn:incoming>
      <bpmn:outgoing>Flow_key_to_password</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_save_password" name="Зберегти пароль в Passbolt та ключ на Хмарі">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Зберегти пароль в Passbolt та ключ на Хмарі&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_key_to_password</bpmn:incoming>
      <bpmn:outgoing>Flow_password_to_dps</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ============ БУХГАЛТЕР: ПЕРЕВІРКА ДПС ============ -->

    <bpmn:userTask id="UT_check_dps" name="Перевірити в ДПС заборгованість кандидата">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Перевірити в ДПС заборгованість кандидата&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_password_to_dps</bpmn:incoming>
      <bpmn:outgoing>Flow_dps_to_debt_merge</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ============ DEBT CHECK LOOP ============ -->

    <bpmn:exclusiveGateway id="Merge_debt">
      <bpmn:incoming>Flow_dps_to_debt_merge</bpmn:incoming>
      <bpmn:incoming>Flow_pay_to_merge</bpmn:incoming>
      <bpmn:outgoing>Flow_debt_merge_to_check</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_debt_check" name="Заборгованість?" default="Flow_debt_no">
      <bpmn:incoming>Flow_debt_merge_to_check</bpmn:incoming>
      <bpmn:outgoing>Flow_debt_no</bpmn:outgoing>
      <bpmn:outgoing>Flow_debt_yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_pay_debt" name="Кандидат оплачує заборгованість в ДПС">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Кандидат оплачує заборгованість в ДПС&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_debt_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_pay_to_merge</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ============ CANDIDATE: РЕЄСТРАЦІЯ ФОП ============ -->

    <bpmn:userTask id="UT_register_diia" name="Зареєструвати ФОП в Дії">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Зареєструвати ФОП в Дії&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_debt_no</bpmn:incoming>
      <bpmn:outgoing>Flow_diia_to_extract</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_get_extract" name="Отримати виписку по ФОП в Дії, завантажити в ДО">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Отримати виписку по ФОП в Дії, завантажити в ДО&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_diia_to_extract</bpmn:incoming>
      <bpmn:outgoing>Flow_extract_to_account</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_open_account" name="Ознайомся зі статтею та відкрий рахунок в Приват24">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Ознайомся зі статтею та відкрий рахунок в Приват24&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_extract_to_account</bpmn:incoming>
      <bpmn:outgoing>Flow_account_to_trusted</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_trusted_privat" name="Зробити довірену особу в Приват24">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Зробити довірену особу в Приват24&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_account_to_trusted</bpmn:incoming>
      <bpmn:outgoing>Flow_trusted_to_cert</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ============ БУХГАЛТЕР: РЕЄСТРАЦІЯ ТА ДОКУМЕНТИ ============ -->

    <bpmn:userTask id="UT_upload_cert" name="Завантажити довідку про відкриття рахунку">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Завантажити довідку про відкриття рахунку&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_trusted_to_cert</bpmn:incoming>
      <bpmn:outgoing>Flow_cert_to_taxdate</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_check_tax_date" name="Перевірити з якої дати ФОП на єдиному податку">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Перевірити з якої дати ФОП на єдиному податку&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_cert_to_taxdate</bpmn:incoming>
      <bpmn:outgoing>Flow_taxdate_to_extract</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_get_tax_extract" name="Отримати витяг з реєстру платників податків">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Отримати витяг з реєстру платників податків&#34;, _model: &#34;project.project&#34;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
