    <bpmn:sequenceFlow id="Flow_main_to_calendar" sourceRef="GW_main_split" targetRef="GW_tp_check" />
    <bpmn:sequenceFlow id="Flow_main_to_approve" sourceRef="GW_main_split" targetRef="Task_approve" />
    <bpmn:sequenceFlow id="Flow_tp_yes" name="ТП або ТП+" sourceRef="GW_tp_check" targetRef="CA_tp_reissue">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_invoice_type = "ТП" or x_studio_camunda_invoice_type = "ТП+"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_tp_no" sourceRef="GW_tp_check" targetRef="Task_calendar" />
    <bpmn:sequenceFlow id="Flow_tp_done" sourceRef="CA_tp_reissue" targetRef="Task_calendar" />
    <bpmn:sequenceFlow id="Flow_calendar_to_timer" sourceRef="Task_calendar" targetRef="Timer_payday" />
    <bpmn:sequenceFlow id="Flow_timer_to_gw_decision" sourceRef="Timer_payday" targetRef="GW_timer_decision" />
    <bpmn:sequenceFlow id="Flow_approve_to_gw" sourceRef="Task_approve" targetRef="GW_approved" />
    <bpmn:sequenceFlow id="Flow_approved_yes" name="так" sourceRef="GW_approved" targetRef="Task_approver_contract">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_approved = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_approved_no" name="ні" sourceRef="GW_approved" targetRef="GW_reject_type" />
    <bpmn:sequenceFlow id="Flow_reject_communal" name="комунальні" sourceRef="GW_reject_type" targetRef="BRT_reject_detail">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_invoice_type = "комунальні"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_reject_not_communal" name="оренда" sourceRef="GW_reject_type" targetRef="Task_nego_manual" />
    <bpmn:sequenceFlow id="Flow_reject_detail_to_route" sourceRef="BRT_reject_detail" targetRef="GW_reject_route" />
    <bpmn:sequenceFlow id="Flow_reject_to_bui" name="не надає деталізацію" sourceRef="GW_reject_route" targetRef="UT_task_bui">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_provides_detailization = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_reject_to_pih" name="надає деталізацію" sourceRef="GW_reject_route" targetRef="UT_task_pih" />
