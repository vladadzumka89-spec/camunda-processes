<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="65aa273" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collab_1" name="Оплата рахунків оренда та комунальні">
    <bpmn:participant id="Pool_1" name="Оплата рахунків оренда та комунальні (OCR)" processRef="Process_kb8b44r" />
  </bpmn:collaboration>
  <bpmn:process id="Process_kb8b44r" name="Оплата рахунків оренда та комунальні (OCR)" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="4.0" />
    </bpmn:extensionElements>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Buhgalter" name="Бухгалтер">
        <bpmn:flowNodeRef>End_main</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_has_file</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Camunda" name="Система (Camunda)">
        <bpmn:flowNodeRef>GW_recognized</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_ocr_extract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CA_per_invoice</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Odoo" name="Система (Odoo авто)">
        <bpmn:flowNodeRef>ST_update_summary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_1nnp8p8</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_notify_empty</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_06g7f5e</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_notify_no_file</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:sequenceFlow id="Flow_0yovwk0" sourceRef="GW_has_file" targetRef="ST_ocr_extract">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=attachedFile != null and count(attachedFile) &gt; 0</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1l8vzto" sourceRef="StartEvent_1" targetRef="GW_has_file" />
    <bpmn:sequenceFlow id="Flow_1h9lqy4" sourceRef="GW_has_file" targetRef="ST_notify_no_file" />
    <bpmn:sequenceFlow id="Flow_011f2ch" sourceRef="ST_notify_no_file" targetRef="Event_06g7f5e" />
    <bpmn:sequenceFlow id="Flow_ocr_to_recognized" sourceRef="ST_ocr_extract" targetRef="GW_recognized" />
    <bpmn:sequenceFlow id="Flow_not_recognized" sourceRef="GW_recognized" targetRef="ST_notify_empty" />
    <bpmn:sequenceFlow id="Flow_0a33c8f" sourceRef="ST_notify_empty" targetRef="Event_1nnp8p8" />
    <bpmn:sequenceFlow id="Flow_ca_to_end" sourceRef="CA_per_invoice" targetRef="End_main" />
    <bpmn:sequenceFlow id="Flow_summary_to_ca" sourceRef="ST_update_summary" targetRef="CA_per_invoice" />
    <bpmn:sequenceFlow id="Flow_recognized_yes" name="Так" sourceRef="GW_recognized" targetRef="ST_update_summary">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= recognized = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="ST_ocr_extract" name="Розпізнати рахунки (OCR)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="invoice-data-extractor" />
        <zeebe:ioMapping>
          <zeebe:input source="= x_studio_camunda_invoice_file" target="x_studio_camunda_invoice_file" />
          <zeebe:input source="= file_extension" target="file_extension" />
          <zeebe:output source="= invoice_items" target="invoice_items" />
          <zeebe:output source="= total_invoices" target="total_invoices" />
          <zeebe:output source="= total_amount" target="total_amount" />
          <zeebe:output source="= recognized" target="recognized" />
          <zeebe:output source="= ocr_summary" target="ocr_summary" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0yovwk0</bpmn:incoming>
      <bpmn:outgoing>Flow_ocr_to_recognized</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:startEvent id="StartEvent_1" name="Старт">
      <bpmn:outgoing>Flow_1l8vzto</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_has_file" name="Файл завантажено?" default="Flow_1h9lqy4">
      <bpmn:incoming>Flow_1l8vzto</bpmn:incoming>
      <bpmn:outgoing>Flow_0yovwk0</bpmn:outgoing>
      <bpmn:outgoing>Flow_1h9lqy4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ST_notify_no_file" name="Повідомити: немає файлу">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;http://karavaieva.dev-odoo.a.local/web/hook/ecbaf8c8-7138-4ae2-add5-a019dc1cd796&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={ _id: odoo_task_id, process_instance_key: process_instance_key, description: &#34;⚠️ Рахунок не завантажено. Поверніть задачу у стадію &#39;Новий&#39;, завантажте файл і перенесіть знову.&#34;&#10;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1h9lqy4</bpmn:incoming>
      <bpmn:outgoing>Flow_011f2ch</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_06g7f5e" name="Файл відсутній">
      <bpmn:incoming>Flow_011f2ch</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_recognized" name="Рахунки розпізнано?" default="Flow_not_recognized">
      <bpmn:incoming>Flow_ocr_to_recognized</bpmn:incoming>
      <bpmn:outgoing>Flow_recognized_yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_not_recognized</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ST_notify_empty" name="Повідомити: OCR не розпізнав">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;http://karavaieva.dev-odoo.a.local/web/hook/ecbaf8c8-7138-4ae2-add5-a019dc1cd796&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {_id: odoo_task_id, process_instance_key: process_instance_key, description: &#34;OCR не розпізнав жодного рахунку. Будь ласка, завантажте інший файл.&#34;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_not_recognized</bpmn:incoming>
      <bpmn:outgoing>Flow_0a33c8f</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_1nnp8p8" name="Файл не розпізнано">
      <bpmn:incoming>Flow_0a33c8f</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_main" name="Усі рахунки оброблено">
      <bpmn:incoming>Flow_ca_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="ST_update_summary" name="Записати summary в головне завдання">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;http://karavaieva.dev-odoo.a.local/web/hook/ecbaf8c8-7138-4ae2-add5-a019dc1cd796&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {_id: odoo_task_id, process_instance_key: process_instance_key, x_studio_camunda_process_instance_key: process_instance_key, description: &#34;Розпізнано &#34; + string(total_invoices) + &#34; рахунків на загальну суму &#34; + string(total_amount) + &#34; грн\n&#34; + ocr_summary}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_recognized_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_summary_to_ca</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="CA_per_invoice" name="Обробка окремого рахунку">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= item.partner_name" target="x_studio_camunda_partner_name" />
          <zeebe:input source="= item.invoice_number" target="x_studio_camunda_invoice_number" />
          <zeebe:input source="= item.invoice_date" target="x_studio_camunda_invoice_date" />
          <zeebe:input source="= item.invoice_line_name" target="x_studio_camunda_invoice_line_name" />
          <zeebe:input source="= item.invoice_amount" target="x_studio_camunda_invoice_amount" />
          <zeebe:input source="= item.invoice_amount_no_vat" target="x_studio_camunda_invoice_amount_no_vat" />
          <zeebe:input source="= item.vat_amount" target="x_studio_camunda_vat_amount" />
          <zeebe:input source="= item.partner_code" target="x_studio_camunda_partner_code" />
          <zeebe:input source="= item.contract" target="x_studio_camunda_contract" />
          <zeebe:input source="= item.fop_name" target="x_studio_camunda_fop_name" />
          <zeebe:input source="= item.quantity" target="x_studio_camunda_quantity" />
          <zeebe:input source="= item.unit" target="x_studio_camunda_unit" />
          <zeebe:input source="= item.invoice_type" target="x_studio_camunda_invoice_type" />
          <zeebe:input source="= x_studio_camunda_invoice_file" target="x_studio_camunda_invoice_file" />
          <zeebe:input source="= process_instance_key" target="parent_process_instance_key" />
          <zeebe:input source="= odoo_task_id" target="parent_odoo_task_id" />
          <zeebe:input source="=item.partner_iban" target="x_studio_camunda_partner_iban" />
          <zeebe:input source="=item.partner_bank_name" target="x_studio_camunda_partner_bank_name" />
          <zeebe:input source="=item.service_period" target="x_studio_camunda_service_period" />
          <zeebe:input source="=item.unit_price" target="x_studio_camunda_unit_price" />
          <zeebe:input source="=item.vat_rate" target="x_studio_camunda_vat_rate" />
          <zeebe:input source="=item.invoice_lines_summary" target="x_studio_camunda_invoice_lines_summary" />
          <zeebe:input source="=item.invoice_lines" target="x_studio_camunda_invoice_lines_data" />
        </zeebe:ioMapping>
        <zeebe:calledElement processId="Process_jfmercl" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_summary_to_ca</bpmn:incoming>
      <bpmn:outgoing>Flow_ca_to_end</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics>
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="= invoice_items" inputElement="item" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:callActivity>
  </bpmn:process>
