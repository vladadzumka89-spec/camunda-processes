        <di:waypoint x="1527" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f04_di" bpmnElement="f04">
        <di:waypoint x="1290" y="300" />
        <di:waypoint x="1345" y="300" />
      </bpmndi:BPMNEdge>
      <!-- Docker build diamond -->
      <bpmndi:BPMNEdge id="f05_di" bpmnElement="f05">
