        <bpmndi:BPMNLabel>
          <dc:Bounds x="1118" y="98" width="104" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Merge_debt_di" bpmnElement="Merge_debt" isMarkerVisible="true">
        <dc:Bounds x="1975" y="135" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_debt_check_di" bpmnElement="GW_debt_check" isMarkerVisible="true">
        <dc:Bounds x="2085" y="135" width="50" height="50" />
