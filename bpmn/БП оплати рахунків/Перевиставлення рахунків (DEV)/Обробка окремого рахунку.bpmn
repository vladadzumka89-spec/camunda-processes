    <bpmn:sequenceFlow id="Flow_start_to_create" sourceRef="StartEvent_1" targetRef="ST_create_subtask" />
    <bpmn:sequenceFlow id="Flow_create_to_verify" sourceRef="ST_create_subtask" targetRef="UT_verify_invoice" />
    <bpmn:sequenceFlow id="Flow_verify_to_parallel" sourceRef="UT_verify_invoice" targetRef="Gateway_1h51f9c" />
    <bpmn:sequenceFlow id="Flow_0399ull" sourceRef="Gateway_1h51f9c" targetRef="Activity_0pb3hxn" />
    <bpmn:sequenceFlow id="Flow_182dhza" sourceRef="Gateway_1h51f9c" targetRef="Gateway_0szlp8w" />
    <bpmn:sequenceFlow id="Flow_1wwa9rs" name="так" sourceRef="Gateway_0szlp8w" targetRef="UT_reissue">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= is defined(x_studio_camunda_buyer_name) and x_studio_camunda_buyer_name != null and (contains(lower case(x_studio_camunda_buyer_name), "технопростір") or contains(lower case(x_studio_camunda_buyer_name), "технопростiр") or contains(lower case(x_studio_camunda_buyer_name), "техно простір") or contains(lower case(x_studio_camunda_buyer_name), "техно простiр"))</bpmn:conditionExpression>
