      <bpmn:outgoing>Flow_pay_famo_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_register_tp" name="Оплачуємо?">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="3" type="http-request-smart" />
