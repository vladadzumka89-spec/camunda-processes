<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_scheduler" targetNamespace="http://tut.ua/bpmn/deploy-scheduler" exporter="Claude Code" exporterVersion="1.0">

  <bpmn:message id="Message_deploy_trigger" name="msg_deploy_trigger">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=branch" />
    </bpmn:extensionElements>
  </bpmn:message>

  <bpmn:process id="deploy-scheduler" name="Deploy Scheduler" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="1.0" />
    </bpmn:extensionElements>

    <bpmn:startEvent id="evt_start" name="Пуш до staging">
      <bpmn:outgoing>f_start_to_timer</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_start" messageRef="Message_deploy_trigger" />
    </bpmn:startEvent>

    <bpmn:intermediateCatchEvent id="timer_debounce" name="Збір змін (5 хв)">
      <bpmn:incoming>f_start_to_timer</bpmn:incoming>
      <bpmn:outgoing>f_timer_to_deploy</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_debounce">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT5M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>

    <bpmn:callActivity id="CA_deploy" name="Деплой на сервер">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="deploy-process" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=server_host" target="server_host" />
          <zeebe:input source="=ssh_user" target="ssh_user" />
          <zeebe:input source="=repo_dir" target="repo_dir" />
          <zeebe:input source="=db_name" target="db_name" />
          <zeebe:input source="=container" target="container" />
          <zeebe:input source="=branch" target="branch" />
          <zeebe:input source="=run_smoke_test" target="run_smoke_test" />
          <zeebe:input source="=test_mode" target="test_mode" />
          <zeebe:input source="=if is defined(odoo_project_id) and odoo_project_id != null then odoo_project_id else 237" target="odoo_project_id" />
          <zeebe:input source="=if is defined(trigger_sha) and trigger_sha != null then trigger_sha else &quot;unknown&quot;" target="trigger_sha" />
          <zeebe:input source="=string(process_instance_key)" target="parent_process_instance_key" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_timer_to_deploy</bpmn:incoming>
      <bpmn:outgoing>f_deploy_to_end</bpmn:outgoing>
    </bpmn:callActivity>

    <bpmn:endEvent id="evt_end" name="Деплой завершено">
      <bpmn:incoming>f_deploy_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="f_start_to_timer" sourceRef="evt_start" targetRef="timer_debounce" />
    <bpmn:sequenceFlow id="f_timer_to_deploy" sourceRef="timer_debounce" targetRef="CA_deploy" />
    <bpmn:sequenceFlow id="f_deploy_to_end" sourceRef="CA_deploy" targetRef="evt_end" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="deploy-scheduler">
      <bpmndi:BPMNShape id="evt_start_di" bpmnElement="evt_start">
        <dc:Bounds x="160" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="timer_debounce_di" bpmnElement="timer_debounce">
        <dc:Bounds x="320" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CA_deploy_di" bpmnElement="CA_deploy">
        <dc:Bounds x="480" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="evt_end_di" bpmnElement="evt_end">
        <dc:Bounds x="700" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f_start_to_timer_di" bpmnElement="f_start_to_timer">
        <di:waypoint x="196" y="300" />
        <di:waypoint x="320" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_timer_to_deploy_di" bpmnElement="f_timer_to_deploy">
        <di:waypoint x="356" y="300" />
        <di:waypoint x="480" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_deploy_to_end_di" bpmnElement="f_deploy_to_end">
        <di:waypoint x="580" y="300" />
        <di:waypoint x="700" y="300" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
