    </bpmn:parallelGateway>
    <bpmn:userTask id="UT_review_and_set" name="Перевірити тип рахунку та вказати підрозділ">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Перевірити тип рахунку та вказати Підрозділ: &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34; №&#34; + x_studio_camunda_invoice_number + &#34; — &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#34;, description: &#34;1. Перевірте тип рахунку (попередньо визначено системою як: &#34; + (if invoice_detail_type.x_studio_camunda_invoice_type != null then invoice_detail_type.x_studio_camunda_invoice_type else &#34;—&#34;) + &#34;). За потреби — змініть.&#60;br/&#62;2. Виберіть Підрозділ.&#60;br/&#62;3. &#60;b&#62;Якщо Підрозділ — магазин ТП (500-ті):&#60;/b&#62; заповніть поле &#60;b&#62;«Готівка на місці»&#60;/b&#62; (Так — адмін магазину сплатить готівкою; Ні — оплата через ТП).&#60;br/&#62;&#60;br/&#62;Постачальник: &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34;&#60;br/&#62;Позиції:&#60;br/&#62;&#34; + (if x_studio_camunda_invoice_lines_summary != null then x_studio_camunda_invoice_lines_summary else &#34;—&#34;), _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, parent_process_instance_key: parent_process_instance_key}" target="body" />
          <zeebe:output source="=x_studio_camunda_invoice_type" target="x_studio_camunda_invoice_type" />
          <zeebe:output source="=x_studio_camunda_pidrozdil" target="x_studio_camunda_pidrozdil" />
          <zeebe:output source="=x_studio_camunda_pidrozdil_complete_name" target="x_studio_camunda_pidrozdil_complete_name" />
          <zeebe:output source="=x_studio_camunda_responsible_user_id" target="x_studio_camunda_responsible_user_id" />
        </zeebe:ioMapping>
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="3" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1bpv79h</bpmn:incoming>
      <bpmn:outgoing>Flow_0ykalbh</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UT_verify_invoice" name="Перевірити заповнені дані рахунку">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Перевірте дані: &#34; + &#34;Рахунок від &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34; на №&#34; + x_studio_camunda_invoice_number + &#34; — &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#34;, description: &#34;Система розпізнала рахунок. Перевірте дані перед тим, як процес піде далі.&#60;br/&#62;&#60;br/&#62;&#60;b&#62;КРОКИ:&#60;/b&#62;&#60;br/&#62;&#60;br/&#62;1. Відкрийте батьківську задачу «Рахунок від ...» — через хлібну крихту (три крапки) зліва вгорі або кнопка «Батьківська» зверху задачі.&#60;br/&#62;&#60;br/&#62;2. Звірте з оригіналом (PDF/скан у вкладеннях головної задачі):&#60;br/&#62;• &#60;b&#62;Сторони договору&#60;/b&#62; (Організація, Контрагент)&#60;br/&#62;• &#60;b&#62;Реквізити для оплати&#60;/b&#62; (ЄДРПОУ, IBAN, Банк)&#60;br/&#62;• &#60;b&#62;Дані рахунку&#60;/b&#62; (номер, дата, договір, період)&#60;br/&#62;• &#60;b&#62;Деталізація&#60;/b&#62; — таблиця з послугами, кількістю, цінами і ПДВ&#60;br/&#62;• &#60;b&#62;Сума до сплати&#60;/b&#62; — підсумки мають збігатись з оригіналом&#60;br/&#62;&#60;br/&#62;3. Якщо щось розпізнано з помилкою — виправте прямо на батьківській задачі.&#60;br/&#62;&#60;br/&#62;4. Поверніться сюди і натисніть «Виконано». Після цього система визначить тип рахунку (оренда / комунальні / інше) і передасть процес далі.&#34;&#10;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, parent_process_instance_key: parent_process_instance_key&#10;}" target="body" />
          <zeebe:output source="= odoo_task_id" target="odoo_task_id" />
          <zeebe:output source="=x_studio_camunda_partner_name" target="x_studio_camunda_partner_name" />
          <zeebe:output source="=x_studio_camunda_fop_name" target="x_studio_camunda_fop_name" />
          <zeebe:output source="=x_studio_camunda_invoice_number" target="x_studio_camunda_invoice_number" />
          <zeebe:output source="=x_studio_camunda_invoice_date" target="x_studio_camunda_invoice_date" />
          <zeebe:output source="=x_studio_camunda_invoice_amount" target="x_studio_camunda_invoice_amount" />
          <zeebe:output source="=x_studio_camunda_invoice_amount_no_vat" target="x_studio_camunda_invoice_amount_no_vat" />
          <zeebe:output source="=x_studio_camunda_vat_amount" target="x_studio_camunda_vat_amount" />
          <zeebe:output source="=x_studio_camunda_vat_rate" target="x_studio_camunda_vat_rate" />
          <zeebe:output source="=x_studio_camunda_partner_code" target="x_studio_camunda_partner_code" />
          <zeebe:output source="=x_studio_camunda_partner_iban" target="x_studio_camunda_partner_iban" />
          <zeebe:output source="=x_studio_camunda_partner_bank_name" target="x_studio_camunda_partner_bank_name" />
          <zeebe:output source="=x_studio_camunda_contract" target="x_studio_camunda_contract" />
          <zeebe:output source="=x_studio_camunda_invoice_line_name" target="x_studio_camunda_invoice_line_name" />
          <zeebe:output source="=x_studio_camunda_quantity" target="x_studio_camunda_quantity" />
          <zeebe:output source="=x_studio_camunda_unit" target="x_studio_camunda_unit" />
          <zeebe:output source="=x_studio_camunda_unit_price" target="x_studio_camunda_unit_price" />
          <zeebe:output source="=x_studio_camunda_service_period" target="x_studio_camunda_service_period" />
        </zeebe:ioMapping>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="3" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_create_to_verify</bpmn:incoming>
      <bpmn:outgoing>Flow_verify_to_parallel</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_1isenfd" name="Завести рахунок в БДУ">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="3" type="http-request-smart" />
        </zeebe:taskListeners>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
