<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_TO_TRC" targetNamespace="http://camunda.org/schema/1.0/bpmn" exporter="Camunda Web Modeler" exporterVersion="65aa273" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="to-zvity-trc" name="Подача звітів ТО для ТРЦ" isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Finansist" name="Фінансист">
        <bpmn:flowNodeRef>UserTask_UploadToSite</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_CreateTPLDelivery</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SubmitFork</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IntermediateCatch_WeekTimer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ReceiveConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_PrepareRefs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParFork</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_FillRROinTable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_FillTable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_LoadSchedule</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_CheckConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Reminder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_WriteToTT</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SubmitJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_Reminder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_Manual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IntermediateCatch_FirstWorkday</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Done</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_CorrectRefs</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Analyst" name="Аналітик">
        <bpmn:flowNodeRef>ServiceTask_FetchRRO</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_GenerateWebchekReports</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Yulia" name="Юля Томусяк (затверджувач)">
        <bpmn:flowNodeRef>UserTask_YuliaApprove</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_CorrA_Join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_NeedCorrections</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Manual" name="Ручний запуск (тест)">
      <bpmn:documentation>None start event для ручного запуску через REST/Modeler/Operate (минаючи cron-таймер). Йде напряму на ServiceTask_LoadSchedule.</bpmn:documentation>
      <bpmn:outgoing>Flow_Manual_to_LoadSchedule</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:startEvent id="StartEvent_Start" name="1 числа місяця, 09:00">
      <bpmn:documentation>Timer start event — інстанція створюється 1 числа кожного місяця о 09:00 (cron). Якщо 1-ше припадає на вихідний, наступний крок-таймер зсуває процес до першого буднього дня.</bpmn:documentation>
      <bpmn:outgoing>Flow_Start_to_FirstWorkday</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Start">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">0 0 9 1 * *</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:intermediateCatchEvent id="IntermediateCatch_FirstWorkday" name="Зсув до першого буднього дня">
      <bpmn:documentation>Якщо 1-ше число — вихідний (Сб/Нд), таймер чекає до найближчого буднього дня о 09:00. Якщо 1-ше вже будній — спрацьовує одразу (нульова затримка). FEEL: weekday 6=Сб → +2 дні, 7=Нд → +1 день, інакше +0.</bpmn:documentation>
      <bpmn:incoming>Flow_Start_to_FirstWorkday</bpmn:incoming>
      <bpmn:outgoing>Flow_FirstWorkday_to_LoadSchedule</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_FirstWorkday">
        <bpmn:timeDate xsi:type="bpmn:tFormalExpression">=date and time(date(now()) + (if date(now()).weekday = 6 then duration("P2D") else if date(now()).weekday = 7 then duration("P1D") else duration("P0D")), time("09:00:00@Europe/Kyiv"))</bpmn:timeDate>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="ServiceTask_LoadSchedule" name="Прочитати графік магазинів і згрупувати за дедлайнами">
      <bpmn:documentation>scripts/build_submission_schedule.py:build_deadline_groups(year, month). Кладе у змінні процесу: stores, deadline_groups, upload_site_stores (607,918), original_stores (607,918,621,902), start_date, total_stores.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="load-store-schedule" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_FirstWorkday_to_LoadSchedule</bpmn:incoming>
      <bpmn:incoming>Flow_Manual_to_LoadSchedule</bpmn:incoming>
      <bpmn:outgoing>Flow_LoadSchedule_to_CreateMain</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_CreateMainOdooTask" name="Створити головну задачу в Odoo">
      <bpmn:documentation>Створює project.task "Подача звітів ТО — {місяць}.{рік}" з create_process=true. Webhook повертає id новоствореної задачі в odoo_response, який зберігається у Camunda variable odoo_task_id. Усі наступні userTask використовують його як parent_id.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: string(month) + &#34;.&#34; + string(year) + &#34; — Подача звітів ТО для ТРЦ&#34;, description_format: &#34;html&#34;, description: &#34;&lt;b&gt;Період:&lt;/b&gt; &#34; + string(month) + &#34;.&#34; + string(year) + &#34;&lt;br/&gt;&lt;b&gt;Магазинів:&lt;/b&gt; &#34; + string(total_stores), create_process: true, _model: &#34;project.project&#34;, _id: project_id, bpmn_process_id: &#34;to-zvity-trc&#34;, process_instance_key: process_instance_key, x_studio_camunda_year: year, x_studio_camunda_month: month}" target="body" />
          <zeebe:input source="=&#34;odoo_response&#34;" target="result_variable_name" />
          <zeebe:output source="= string(odoo_response.id)" target="odoo_task_id" />
          <zeebe:output source="= string(odoo_response.id)" target="odooTaskId" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_LoadSchedule_to_CreateMain</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateMain_to_FillTable</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="UserTask_FillTable" name="Заповнити таблицю: факт оберт та оренда за період">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="finansist" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input target="body" source="={name: string(month) + &#34;.&#34; + string(year) + &#34; — Заповнити таблицю: факт оберт та оренда за період&#34;, description: &#34;&lt;b&gt;Період:&lt;/b&gt; &#34; + string(month) + &#34;.&#34; + string(year) + &#34;&lt;br/&gt;&lt;b&gt;Всього магазинів:&lt;/b&gt; &#34; + string(total_stores), description_format: &#34;html&#34;, _model: &#34;project.project&#34;, _id: project_id, parent_id: odoo_task_id, process_instance_key: process_instance_key, x_studio_camunda_role_code: &#34;finansist&#34;, x_studio_camunda_task_code: &#34;fill_table&#34;, x_studio_camunda_year: year, x_studio_camunda_month: month}" />
        </zeebe:ioMapping>
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CreateMain_to_FillTable</bpmn:incoming>
      <bpmn:outgoing>Flow_FillTable_to_FetchRRO</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="ServiceTask_FetchRRO" name="Витяг ФН ПРРО ФОП з 1С (famo)">
      <bpmn:documentation>scripts/rro_fop_for_stores.py:fetch_active_fop_rro(stores, year, month).</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="fetch-rro-fop" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_FillTable_to_FetchRRO</bpmn:incoming>
      <bpmn:outgoing>Flow_FetchRRO_to_Webchek</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_GenerateWebchekReports" name="Згенерувати PDF періодичних Z-звітів для кожного ФН">
      <bpmn:documentation>Автоматизує колишню задачу аналітика. Тягне .db бази ПРРО з SMB-шари \\ralf\WebCheck\DB і генерує PDF періодичного Z-звіту для кожного ФН з rroData. Виходи: webchekReports (список з шляхами до PDF), webchekReportsCount, webchekReportsFailed, webchekReportsDir.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generate-webchek-reports" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_FetchRRO_to_Webchek</bpmn:incoming>
      <bpmn:outgoing>Flow_Webchek_to_Send</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="UserTask_FillRROinTable" name="Внести дані з РРО звітів у таблицю та надіслати Юлі на затвердження">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="finansist" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input target="body" source="={name: string(month) + &#34;.&#34; + string(year) + &#34; — Внести дані з РРО звітів у таблицю&#34;, description: &#34;&lt;b&gt;Період:&lt;/b&gt; &#34; + string(month) + &#34;.&#34; + string(year) + &#34;&lt;br/&gt;&lt;b&gt;Звітів РРО:&lt;/b&gt; &#34; + string(webchekReportsCount) + &#34;&lt;br/&gt;Переглянь PDF періодичних Z-звітів у вкладці і перепиши цифри у робочу таблицю, потім надішли Юлі на затвердження.&#34;, description_format: &#34;html&#34;, _model: &#34;project.project&#34;, _id: project_id, parent_id: odoo_task_id, process_instance_key: process_instance_key, x_studio_camunda_role_code: &#34;finansist&#34;, x_studio_camunda_task_code: &#34;fill_rro_in_table&#34;, x_studio_camunda_year: year, x_studio_camunda_month: month, webchekReports: webchekReports}" />
        </zeebe:ioMapping>
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Webchek_to_Send</bpmn:incoming>
      <bpmn:outgoing>Flow_FillRRO_to_SendYulia</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Gateway_ParFork">
      <bpmn:incoming>Flow_FillRRO_to_SendYulia</bpmn:incoming>
      <bpmn:outgoing>Flow_Fork_to_Yulia</bpmn:outgoing>
      <bpmn:outgoing>Flow_Fork_to_PrepRefs</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="UserTask_YuliaApprove" name="Затвердити таблицю та повернути">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="yulia" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input target="body" source="={name: string(month) + &#34;.&#34; + string(year) + &#34; — Затвердити таблицю та повернути&#34;, description: &#34;&lt;b&gt;Період:&lt;/b&gt; &#34; + string(month) + &#34;.&#34; + string(year) + &#34;&lt;br/&gt;Перевір таблицю фінансиста. Якщо вніс правки — обери &lt;b&gt;Так&lt;/b&gt;, інакше &lt;b&gt;Ні&lt;/b&gt;. Перехід у Виконано передає yuliaCorrected у Camunda.&#34;, description_format: &#34;html&#34;, _model: &#34;project.project&#34;, _id: project_id, parent_id: odoo_task_id, process_instance_key: process_instance_key, x_studio_camunda_role_code: &#34;yulia&#34;, x_studio_camunda_task_code: &#34;yulia_approve&#34;, x_studio_camunda_year: year, x_studio_camunda_month: month}" />
        </zeebe:ioMapping>
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Fork_to_Yulia</bpmn:incoming>
      <bpmn:outgoing>Flow_Yulia_to_NeedCorr</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_NeedCorrections" name="Юля коригувала таблицю?">
      <bpmn:incoming>Flow_Yulia_to_NeedCorr</bpmn:incoming>
      <bpmn:outgoing>Flow_NeedCorr_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_NeedCorr_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UserTask_CorrectRefs" name="Скоригувати дані в довідках">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="finansist" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input target="body" source="={name: string(month) + &#34;.&#34; + string(year) + &#34; — Скоригувати дані в довідках&#34;, description: &#34;&lt;b&gt;ℹ️ Юля внесла правки в таблицю.&lt;/b&gt;&lt;br/&gt;Подивись зміни у Sheet і за потреби перероби довідки у задачі &lt;b&gt;Звіти ТО по магазинах&lt;/b&gt;.&#34;, description_format: &#34;html&#34;, _model: &#34;project.project&#34;, _id: project_id, parent_id: odoo_task_id, process_instance_key: process_instance_key, x_studio_camunda_role_code: &#34;finansist&#34;, x_studio_camunda_task_code: &#34;correct_refs&#34;, x_studio_camunda_year: year, x_studio_camunda_month: month}" />
        </zeebe:ioMapping>
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NeedCorr_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_CorrectRefs_to_CorrAJoin</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_CorrA_Join">
      <bpmn:incoming>Flow_CorrectRefs_to_CorrAJoin</bpmn:incoming>
      <bpmn:incoming>Flow_NeedCorr_No</bpmn:incoming>
      <bpmn:outgoing>Flow_CorrAJoin_to_ParJoin</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UserTask_PrepareRefs" name="Звіти ТО по магазинах">
      <bpmn:documentation>Один task на весь місяць, паралельно з гілкою затвердження Юлі. По кожному з 51 магазину фінансист:
1) готує довідку (електронна форма → друк → підпис → скан);
2) надсилає скани довідки орендодавцю на e-mail;
3) вносить дані по ТО в 1С.

Форма (Odoo) — таблиця 51 рядок, відсортована за дедлайном, колонки:
  №  Магазин  Дедлайн  Довідка готова  Скани надіслані  Дані по ТО в 1С
Опціонально — підстатуси готовності (Електр./Друк/Підпис/Скан) та upload скан-файлу.
Task завершується, коли всі 51 рядок повністю позначені.

NB: назва "Підготувати довідки" вужча за реальний зміст (підготовка + надсилання + дані по ТО) — за потреби перейменувати.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="finansist" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input target="body" source="={name: string(month) + &#34;.&#34; + string(year) + &#34; — Звіти ТО по магазинах&#34;, description: &#34;&lt;b&gt;Період:&lt;/b&gt; &#34; + string(month) + &#34;.&#34; + string(year) + &#34;&lt;br/&gt;&lt;b&gt;Магазинів:&lt;/b&gt; &#34; + string(total_stores) + &#34;&lt;br/&gt;Готуй довідки, надсилай скани орендодавцям, вноси дані по ТО в 1С. Рядки згруповані за дедлайном.&#34;, description_format: &#34;html&#34;, _model: &#34;project.project&#34;, _id: project_id, parent_id: odoo_task_id, process_instance_key: process_instance_key, x_studio_camunda_role_code: &#34;finansist&#34;, x_studio_camunda_task_code: &#34;prepare_refs&#34;, x_studio_camunda_year: year, x_studio_camunda_month: month, stores: stores, deadline_groups: deadline_groups}" />
        </zeebe:ioMapping>
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Fork_to_PrepRefs</bpmn:incoming>
      <bpmn:outgoing>Flow_PrepRefs_to_ParJoin</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Gateway_ParJoin">
      <bpmn:incoming>Flow_CorrAJoin_to_ParJoin</bpmn:incoming>
      <bpmn:incoming>Flow_PrepRefs_to_ParJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_ParJoin_to_SubmitFork</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:parallelGateway id="Gateway_SubmitFork">
      <bpmn:incoming>Flow_ParJoin_to_SubmitFork</bpmn:incoming>
      <bpmn:outgoing>Flow_SubmitFork_to_Upload</bpmn:outgoing>
      <bpmn:outgoing>Flow_SubmitFork_to_CreateTPL</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="UserTask_UploadToSite" name="Загрузити довідки на сайт орендодавця">
      <bpmn:documentation>ТІЛЬКИ для магазинів зі змінної upload_site_stores: 607 Форум, 918 Пінкі Форум. Форма (Odoo): таблиця 2 рядки, галочка "Загружено на сайт".</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="finansist" />
