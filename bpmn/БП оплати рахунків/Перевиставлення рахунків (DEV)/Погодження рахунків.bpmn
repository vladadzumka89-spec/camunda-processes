          <zeebe:input source="={name: &#34;Внести поступлення (&#34; + (if x_studio_camunda_invoice_type != null then x_studio_camunda_invoice_type else &#34;—&#34;) + &#34;): &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34; №&#34; + x_studio_camunda_invoice_number + &#34; — &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#34;, description: &#34;&#60;b&#62;Постачальник:&#60;/b&#62; &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Сума:&#60;/b&#62; &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#60;br/&#62;&#60;b&#62;Тип рахунку:&#60;/b&#62; &#34; + (if x_studio_camunda_invoice_type != null then x_studio_camunda_invoice_type else &#34;—&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Договір:&#60;/b&#62; &#34; + (if x_studio_camunda_contract != null then x_studio_camunda_contract else &#34;—&#34;) + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#60;br/&#62;1. Внесіть поступлення товарів/послуг до 1С відповідно до даних рахунку.&#60;br/&#62;2. Звірте дані з договором.&#60;br/&#62;3. Змініть стадію задачі на &#60;b&#62;«Виконано»&#60;/b&#62;, щоб завершити процес.&#34;, _model: &#34;project.project&#34;, _id: 13946, process_instance_key: process_instance_key, parent_process_instance_key: parent_process_instance_key, x_studio_camunda_pidrozdil: if x_studio_camunda_pidrozdil != null then x_studio_camunda_pidrozdil else null}" target="body" />
