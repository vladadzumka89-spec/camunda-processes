          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input target="body" source="={name: string(month) + &#34;.&#34; + string(year) + &#34; — Написати працівникам магазинів в ТТ&#34;, description: &#34;&lt;b&gt;Період:&lt;/b&gt; &#34; + string(month) + &#34;.&#34; + string(year) + &#34;&lt;br/&gt;Напиши працівникам торгових точок (4 магазини) про передані документи в адміністрацію.&#34;, description_format: &#34;html&#34;, _model: &#34;project.project&#34;, _id: project_id, parent_id: odoo_task_id, process_instance_key: process_instance_key, x_studio_camunda_role_code: &#34;finansist&#34;, x_studio_camunda_task_code: &#34;write_to_tt&#34;, x_studio_camunda_year: year, x_studio_camunda_month: month}" />
        </zeebe:ioMapping>
