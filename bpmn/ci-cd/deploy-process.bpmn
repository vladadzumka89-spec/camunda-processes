<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_deploy" targetNamespace="http://tut.ua/bpmn/deploy" exporter="Claude Code" exporterVersion="1.0">
  <bpmn:error id="Error_deploy_failed" name="Deploy Failed" errorCode="DEPLOY_FAILED" />
  <bpmn:message id="Message_deploy_trigger" name="msg_deploy_trigger">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=trigger_sha" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:process id="deploy-process" name="Deploy Process" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="3.0" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="evt_start" name="Початок деплою">
      <bpmn:outgoing>f01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:startEvent id="evt_start_msg" name="Деплой (webhook)">
      <bpmn:outgoing>f01_msg</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_deploy_trigger" messageRef="Message_deploy_trigger" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="gw_merge_start">
      <bpmn:incoming>f01</bpmn:incoming>
      <bpmn:incoming>f01_msg</bpmn:incoming>
      <bpmn:outgoing>f01_merged</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_git_pull" name="Завантажити код">
      <bpmn:documentation>SSH на сервер, git fetch origin, checkout branch.
Retry 3x з інтервалом 5s.
Output: old_commit, new_commit, has_changes</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="git-pull" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>f01_merged</bpmn:incoming>
      <bpmn:outgoing>f02</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_changes" name="Зміни є?" default="f04">
      <bpmn:incoming>f02</bpmn:incoming>
      <bpmn:outgoing>f03</bpmn:outgoing>
      <bpmn:outgoing>f04</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ST_publish_no_changes" name="Повідомити: без змін">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="publish-message" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;msg_deploy_done&#34;" target="message_name" />
          <zeebe:input source="=if is defined(trigger_sha) and trigger_sha != null then trigger_sha else &#34;none&#34;" target="correlation_key" />
          <zeebe:input source="=true" target="no_changes" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f03</bpmn:incoming>
      <bpmn:outgoing>f03_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="evt_end_no_changes" name="Без змін">
      <bpmn:incoming>f03_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="task_detect_modules" name="Визначити змінені модулі">
      <bpmn:documentation>git diff old..new, сканує src/custom, src/enterprise, src/third-party.
Якщо &gt;250 файлів — виводить "all".
Output: changed_modules, docker_build_needed</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="detect-modules" retries="1" />
      </bpmn:extensionElements>
      <bpmn:incoming>f04</bpmn:incoming>
      <bpmn:outgoing>f05</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_docker_build" name="Потрібен новий образ?" default="f07">
      <bpmn:incoming>f05</bpmn:incoming>
      <bpmn:outgoing>f06</bpmn:outgoing>
      <bpmn:outgoing>f07</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_docker_build" name="Зібрати Docker образ">
      <bpmn:documentation>docker compose build --pull web (retry 3x).
Потрібен тільки при зміні docker/, Dockerfile, requirements.txt.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="docker-build" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>f06</bpmn:incoming>
      <bpmn:outgoing>f08</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_merge_docker">
      <bpmn:incoming>f07</bpmn:incoming>
      <bpmn:incoming>f08</bpmn:incoming>
      <bpmn:outgoing>f09</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_docker_up" name="Запустити новий образ">
      <bpmn:documentation>docker compose up -d, чекає container running (60s),
потім HTTP /web/login (24x10s = 240s).</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="docker-up" retries="1" />
      </bpmn:extensionElements>
      <bpmn:incoming>f_clickbot_report_to_docker_up</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_module_update" name="Міграція БД (module-update)">
      <bpmn:documentation>Зупиняє Odoo, запускає окремий контейнер:
docker compose run --rm web odoo-bin -d DB -u MODULES --stop-after-init --no-http
Якщо &gt;10 модулів — використовує -u all.
Output: modules_updated</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="module-update" retries="1" />
      </bpmn:extensionElements>
      <bpmn:incoming>f09</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_cache_clear" name="Очистити кеш assets">
      <bpmn:documentation>DELETE FROM ir_attachment WHERE url LIKE '/web/assets/%' OR name LIKE 'web.assets%';
Запускає Odoo: docker compose up -d</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="cache-clear" retries="1" />
      </bpmn:extensionElements>
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_smoke_test" name="Перевірка запуску Odoo">
      <bpmn:documentation>Окремий контейнер: odoo-bin --stop-after-init --no-http (120s timeout).
Аналіз логів на CRITICAL/ERROR/ImportError/SyntaxError.
Output: smoke_passed</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="smoke-test" retries="1" />
      </bpmn:extensionElements>
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f_smoke_to_gw_clickbot</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_http_verify" name="Перевірка доступності сайту">
      <bpmn:documentation>curl -sf http://localhost:PORT/web/login (24 спроби x 10s)</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-verify" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f_http_to_save</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_clickbot" name="Clickbot?" default="f_run_clickbot">
      <bpmn:incoming>f_smoke_to_gw_clickbot</bpmn:incoming>
      <bpmn:outgoing>f_run_clickbot</bpmn:outgoing>
      <bpmn:outgoing>f_skip_clickbot</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_clickbot" name="Автотестування інтерфейсу">
      <bpmn:documentation>Запускає clickbot в ізольованому Docker середовищі.
Дампить БД, відновлює в tmpfs PostgreSQL, запускає browser-тести.
Клікає по всіх меню Odoo, перевіряє що все працює.
Light — тільки app menus (~10 хв). Full — всі views + фільтри (~30 хв).
Output: clickbot_passed, clickbot_report, clickbot_failed_apps</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="clickbot-test" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="=server_host" target="server_host" />
          <zeebe:input source="=db_name" target="db_name" />
          <zeebe:input source="=if is defined(test_mode) and test_mode != null then test_mode else &#34;full&#34;" target="test_mode" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_run_clickbot</bpmn:incoming>
      <bpmn:outgoing>f_clickbot_to_merge</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_merge_clickbot">
      <bpmn:incoming>f_skip_clickbot</bpmn:incoming>
      <bpmn:incoming>f_clickbot_to_merge</bpmn:incoming>
      <bpmn:outgoing>f_merge_to_clickbot_report</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ST_clickbot_report" name="📋 Звіт тестування → Odoo">
      <bpmn:documentation>Створює підзадачу в Odoo з повними результатами clickbot тестів.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;https://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;[deploy] 🤖 Результати Clickbot тестів&#34;, description: &#34;&#60;p&#62;Сервер: &#34; + (if is defined(server_host) and server_host != null then server_host else &#34;unknown&#34;) + &#34;&#60;br/&#62;Гілка: &#34; + (if is defined(branch) and branch != null then branch else &#34;unknown&#34;) + &#34;&#60;br/&#62;Результат: &#34; + (if is defined(clickbot_passed) and clickbot_passed = true then &#34;✅ PASSED&#34; else &#34;❌ FAILED&#34;) + &#34;&#60;/p&#62;&#60;pre&#62;&#34; + (if is defined(clickbot_report) and clickbot_report != null then clickbot_report else &#34;Clickbot не запускався&#34;) + &#34;&#60;/pre&#62;&#34;, parent_process_instance_key: if is defined(parent_process_instance_key) and parent_process_instance_key != null then parent_process_instance_key else process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_merge_to_clickbot_report</bpmn:incoming>
      <bpmn:outgoing>f_clickbot_report_to_docker_up</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_save_state" name="Зберегти стан деплою">
      <bpmn:documentation>Записує new_commit SHA у .deploy-state/deploy_state_BRANCH</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="save-deploy-state" retries="1" />
      </bpmn:extensionElements>
      <bpmn:incoming>f_http_to_save</bpmn:incoming>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ST_publish_deploy_done" name="Повідомити про завершення">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="publish-message" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;msg_deploy_done&#34;" target="message_name" />
          <zeebe:input source="=if is defined(trigger_sha) and trigger_sha != null then trigger_sha else &#34;none&#34;" target="correlation_key" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f_publish_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="evt_end_success" name="Деплой успішний">
      <bpmn:incoming>f_publish_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="subprocess_error" name="Обробка помилок деплою" triggeredByEvent="true">
      <bpmn:sequenceFlow id="f_err_to_odoo" sourceRef="evt_error_catch" targetRef="ST_error_odoo_task" />
      <bpmn:sequenceFlow id="f_err_odoo_to_rollback" sourceRef="ST_error_odoo_task" targetRef="task_rollback" />
      <bpmn:sequenceFlow id="f_err2" sourceRef="task_rollback" targetRef="ST_publish_deploy_failed" />
      <bpmn:sequenceFlow id="f_err3" sourceRef="ST_publish_deploy_failed" targetRef="evt_error_end" />
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="f01" sourceRef="evt_start" targetRef="gw_merge_start" />
    <bpmn:sequenceFlow id="f01_msg" sourceRef="evt_start_msg" targetRef="gw_merge_start" />
    <bpmn:sequenceFlow id="f01_merged" sourceRef="gw_merge_start" targetRef="task_git_pull" />
    <bpmn:sequenceFlow id="f02" sourceRef="task_git_pull" targetRef="gw_changes" />
    <bpmn:sequenceFlow id="f03" name="Ні" sourceRef="gw_changes" targetRef="ST_publish_no_changes">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=has_changes = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f03_to_end" sourceRef="ST_publish_no_changes" targetRef="evt_end_no_changes" />
    <bpmn:sequenceFlow id="f04" name="Так" sourceRef="gw_changes" targetRef="task_detect_modules" />
    <bpmn:sequenceFlow id="f05" sourceRef="task_detect_modules" targetRef="gw_docker_build" />
    <bpmn:sequenceFlow id="f06" name="Потрібен" sourceRef="gw_docker_build" targetRef="task_docker_build">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=docker_build_needed = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f07" sourceRef="gw_docker_build" targetRef="gw_merge_docker" />
    <bpmn:sequenceFlow id="f08" sourceRef="task_docker_build" targetRef="gw_merge_docker" />
    <bpmn:sequenceFlow id="f09" sourceRef="gw_merge_docker" targetRef="task_module_update" />
    <bpmn:sequenceFlow id="f10" sourceRef="task_module_update" targetRef="task_smoke_test" />
    <bpmn:sequenceFlow id="f_smoke_to_gw_clickbot" sourceRef="task_smoke_test" targetRef="gw_clickbot" />
    <bpmn:sequenceFlow id="f_run_clickbot" sourceRef="gw_clickbot" targetRef="task_clickbot" />
    <bpmn:sequenceFlow id="f_skip_clickbot" name="Скіп" sourceRef="gw_clickbot" targetRef="gw_merge_clickbot">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=is defined(skip_clickbot) and skip_clickbot = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_clickbot_to_merge" sourceRef="task_clickbot" targetRef="gw_merge_clickbot" />
    <bpmn:sequenceFlow id="f_merge_to_clickbot_report" sourceRef="gw_merge_clickbot" targetRef="ST_clickbot_report" />
    <bpmn:sequenceFlow id="f_clickbot_report_to_docker_up" sourceRef="ST_clickbot_report" targetRef="task_docker_up" />
    <bpmn:sequenceFlow id="f11" sourceRef="task_docker_up" targetRef="task_cache_clear" />
    <bpmn:sequenceFlow id="f12" sourceRef="task_cache_clear" targetRef="task_http_verify" />
    <bpmn:sequenceFlow id="f_http_to_save" sourceRef="task_http_verify" targetRef="task_save_state" />
    <bpmn:sequenceFlow id="f18" sourceRef="task_save_state" targetRef="ST_publish_deploy_done" />
    <bpmn:sequenceFlow id="f_publish_to_end" sourceRef="ST_publish_deploy_done" targetRef="evt_end_success" />
    <bpmn:serviceTask id="ST_error_odoo_task" name="❌ Створити задачу про помилку в Odoo">
      <bpmn:documentation>Створює підзадачу в Odoo про помилку деплою з деталями помилки.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;https://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;[deploy] ❌ Помилка деплою&#34;, description: &#34;&#60;p&#62;Сервер: &#34; + (if is defined(server_host) and server_host != null then server_host else &#34;unknown&#34;) + &#34;&#60;br/&#62;Гілка: &#34; + (if is defined(branch) and branch != null then branch else &#34;unknown&#34;) + &#34;&#60;br/&#62;Код помилки: &#34; + (if is defined(caught_error_code) and caught_error_code != null then caught_error_code else &#34;—&#34;) + &#34;&#60;br/&#62;Деталі: &#34; + (if is defined(caught_error_message) and caught_error_message != null then caught_error_message else &#34;Невідома помилка&#34;) + &#34;&#60;br/&#62;&#60;br/&#62;Автоматичний rollback виконано.&#60;/p&#62;&#34;, parent_process_instance_key: if is defined(parent_process_instance_key) and parent_process_instance_key != null then parent_process_instance_key else process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_err_to_odoo</bpmn:incoming>
      <bpmn:outgoing>f_err_odoo_to_rollback</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:startEvent id="evt_error_catch" name="Помилка деплою">
      <bpmn:outgoing>f_err_to_odoo</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="task_rollback" name="Відкат до попередньої версії">
      <bpmn:documentation>git checkout old_commit, docker compose up -d --force-recreate.
Перевіряє чи є old_commit (якщо немає — no-op).</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="rollback" retries="1" />
      </bpmn:extensionElements>
      <bpmn:incoming>f_err_odoo_to_rollback</bpmn:incoming>
      <bpmn:outgoing>f_err2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ST_publish_deploy_failed" name="Повідомити про помилку">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="publish-message" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;msg_deploy_done&#34;" target="message_name" />
          <zeebe:input source="=if is defined(trigger_sha) and trigger_sha != null then trigger_sha else &#34;none&#34;" target="correlation_key" />
          <zeebe:input source="=true" target="deploy_failed" />
          <zeebe:input source="=if is defined(caught_error_message) and caught_error_message != null then caught_error_message else &#34;Unknown error&#34;" target="error_message" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_err2</bpmn:incoming>
      <bpmn:outgoing>f_err3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="evt_error_end" name="Деплой провалився">
      <bpmn:incoming>f_err3</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorDef_throw" errorRef="Error_deploy_failed" />
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="deploy-process">
      <bpmndi:BPMNShape id="task_detect_modules_di" bpmnElement="task_detect_modules">
        <dc:Bounds x="831" y="338" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_merge_docker_di" bpmnElement="gw_merge_docker" isMarkerVisible="true">
        <dc:Bounds x="1346" y="275" width="50" height="50" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_module_update_di" bpmnElement="task_module_update">
        <dc:Bounds x="1451" y="260" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_smoke_test_di" bpmnElement="task_smoke_test">
        <dc:Bounds x="1631" y="260" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_merge_start_di" bpmnElement="gw_merge_start" isMarkerVisible="true">
        <dc:Bounds x="335" y="303" width="50" height="50" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="evt_start_msg_di" bpmnElement="evt_start_msg">
        <dc:Bounds x="207" y="372" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="199" y="408" width="52" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="evt_start_di" bpmnElement="evt_start">
        <dc:Bounds x="207" y="247" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="183" y="283" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_git_pull_di" bpmnElement="task_git_pull">
        <dc:Bounds x="450" y="288" width="100" height="80" />
