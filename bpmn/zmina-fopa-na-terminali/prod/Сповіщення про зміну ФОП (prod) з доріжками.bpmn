    <bpmn:scriptTask id="ST_normalize_vars" name="Підготовка змінних">
      <bpmn:extensionElements>
        <zeebe:script expression="= 1" resultVariable="_normalized" />
        <zeebe:ioMapping>
          <zeebe:output source="= if is defined(fop_name) then fop_name else if is defined(x_studio_camunda_fop_name) then x_studio_camunda_fop_name else &#34;&#34;" target="fop_name" />
          <zeebe:output source="= if is defined(fop_edrpou) then fop_edrpou else if is defined(x_studio_camunda_edrpou) then x_studio_camunda_edrpou else if is defined(x_studio_camunda_fop_edrpou) then x_studio_camunda_fop_edrpou else if is defined(x_studio_camunda_supplier_code) then x_studio_camunda_supplier_code else if is defined(x_studio_camunda_contract) then x_studio_camunda_contract else &#34;&#34;" target="fop_edrpou" />
          <zeebe:output source="= if is defined(ep_group) then ep_group else if is defined(x_studio_camunda_ep_group) then x_studio_camunda_ep_group else 2" target="ep_group" />
          <zeebe:output source="= if is defined(total_income) then total_income else 0" target="total_income" />
          <zeebe:output source="= if is defined(income_percent) then income_percent else 0" target="income_percent" />
          <zeebe:output source="= if is defined(limit_amount) then limit_amount else 0" target="limit_amount" />
          <zeebe:output source="= if is defined(days_to_limit) then days_to_limit else 0" target="days_to_limit" />
          <zeebe:output source="= if is defined(projected_date) then projected_date else &#34;ручний запуск&#34;" target="projected_date" />
          <zeebe:output source="= if is defined(stores) then stores else &#34;н/д (ручний запуск)&#34;" target="stores" />
          <zeebe:output source="= if is defined(stores_count) then stores_count else 0" target="stores_count" />
          <zeebe:output source="= if is defined(trend_ratio) then trend_ratio else 0" target="trend_ratio" />
          <zeebe:output source="= if is defined(process_instance_key) and process_instance_key != null and process_instance_key != &#34;&#34; then process_instance_key else if is defined(parent_process_instance_key) and parent_process_instance_key != null then parent_process_instance_key else string(odoo_task_id)" target="process_instance_key" />
          <zeebe:output source="=if is defined(employee_count) then employee_count else 0" target="employee_count" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_08c6ueu</bpmn:incoming>
      <bpmn:outgoing>Flow_normalize_to_gw</bpmn:outgoing>
    </bpmn:scriptTask>
