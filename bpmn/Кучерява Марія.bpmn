<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="e787c33" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:collaboration id="Collab_kucheryava">
    <bpmn:participant id="Pool_1" name="Підготовка контенту (Кучерява Марія)" processRef="kucheryava-mariya-content" />
  </bpmn:collaboration>
  <bpmn:process id="kucheryava-mariya-content" name="Підготовка контенту (Кучерява Марія)" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="1.0" />
    </bpmn:extensionElements>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_system" name="Система (автоматично)">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_odoo_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_create_main</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Merge_odoo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_parallel_merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_final</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_rem_write_ads</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_rem_write_ads</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST_rem_write_social</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_rem_write_social</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_writer" name="Контент-менеджер">
        <bpmn:flowNodeRef>UT_write_ads</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_write_social</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_reviewer" name="Відповідальний за перевірку">
        <bpmn:flowNodeRef>UT_send_ads</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_check_ads</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_check_ads</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_return_ads</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_send_social</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_check_social</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_check_social</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_return_social</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_manager" name="Керівник (ескалація)">
        <bpmn:flowNodeRef>UT_esc_write_ads</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_esc_write_ads</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_esc_write_social</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_esc_write_social</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    
    <bpmn:startEvent id="StartEvent_1" name="Старт">
      <bpmn:outgoing>Flow_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_odoo_check" name="Задача в Odoo існує?" default="Flow_odoo_no_task">
      <bpmn:incoming>Flow_start</bpmn:incoming>
      <bpmn:outgoing>Flow_odoo_exists</bpmn:outgoing>
      <bpmn:outgoing>Flow_odoo_no_task</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ST_create_main" name="Створити головне завдання">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Підготовка контенту (Кучерява Марія)&quot;, create_process: true, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_odoo_no_task</bpmn:incoming>
      <bpmn:outgoing>Flow_create_main_done</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Merge_odoo">
      <bpmn:incoming>Flow_odoo_exists</bpmn:incoming>
      <bpmn:incoming>Flow_create_main_done</bpmn:incoming>
      <bpmn:outgoing>Flow_to_split</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    
    <bpmn:parallelGateway id="GW_parallel_split">
      <bpmn:incoming>Flow_to_split</bpmn:incoming>
      <bpmn:outgoing>Flow_to_write_ads</bpmn:outgoing>
      <bpmn:outgoing>Flow_to_write_social</bpmn:outgoing>
    </bpmn:parallelGateway>

    
    <bpmn:userTask id="UT_write_ads" name="Написати 5 товарів під рекламу">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Написати 5 товарів під рекламу&quot;, description: &quot;Підготуйте 5 товарів для рекламних кампаній&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_writer_user_id, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_write_ads</bpmn:incoming>
      <bpmn:incoming>Flow_return_to_write_ads</bpmn:incoming>
      <bpmn:outgoing>Flow_write_to_send_ads</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UT_send_ads" name="Надіслати товари відповідальному за рекламу">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Перевірити товари під рекламу&quot;, description: &quot;Отримано товари під рекламу від контент-менеджера. Перевірте та підтвердіть.&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_ads_user_id, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_write_to_send_ads</bpmn:incoming>
      <bpmn:outgoing>Flow_send_to_check_ads</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UT_check_ads" name="Достатньо товарів під рекламу?">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Достатньо товарів під рекламу?&quot;, description: &quot;Перевірте чи достатньо товарів для рекламної кампанії&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_ads_user_id, process_instance_key: process_instance_key}" target="body" />
          <zeebe:output source="= x_studio_camunda_ads_approved" target="x_studio_camunda_ads_approved" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_send_to_check_ads</bpmn:incoming>
      <bpmn:outgoing>Flow_check_to_gw_ads</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_check_ads" name="Результат перевірки реклами" default="Flow_ads_not_enough">
      <bpmn:incoming>Flow_check_to_gw_ads</bpmn:incoming>
      <bpmn:outgoing>Flow_ads_enough</bpmn:outgoing>
      <bpmn:outgoing>Flow_ads_not_enough</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_return_ads" name="Повернути задачу виконавцю з коментарем">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Доопрацювати товари під рекламу&quot;, description: &quot;Відповідальний за рекламу повернув задачу. Потрібно доопрацювати товари.&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_writer_user_id, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ads_not_enough</bpmn:incoming>
      <bpmn:outgoing>Flow_return_to_write_ads</bpmn:outgoing>
    </bpmn:userTask>

    
    <bpmn:userTask id="UT_write_social" name="Написати 20 товарів для соцмереж">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Написати 20 товарів для соцмереж&quot;, description: &quot;Підготуйте 20 товарів для публікації в соціальних мережах&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_writer_user_id, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_write_social</bpmn:incoming>
      <bpmn:incoming>Flow_return_to_write_social</bpmn:incoming>
      <bpmn:outgoing>Flow_write_to_send_social</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UT_send_social" name="Надіслати товари відповідальному за соцмережі">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Перевірити товари для соцмереж&quot;, description: &quot;Отримано товари для соцмереж від контент-менеджера. Перевірте та підтвердіть.&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_social_user_id, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_write_to_send_social</bpmn:incoming>
      <bpmn:outgoing>Flow_send_to_check_social</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UT_check_social" name="Достатньо товарів для соцмереж?">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Достатньо товарів для соцмереж?&quot;, description: &quot;Перевірте чи достатньо товарів для публікації в соцмережах&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_social_user_id, process_instance_key: process_instance_key}" target="body" />
          <zeebe:output source="= x_studio_camunda_social_approved" target="x_studio_camunda_social_approved" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_send_to_check_social</bpmn:incoming>
      <bpmn:outgoing>Flow_check_to_gw_social</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_check_social" name="Результат перевірки соцмереж" default="Flow_social_not_enough">
      <bpmn:incoming>Flow_check_to_gw_social</bpmn:incoming>
      <bpmn:outgoing>Flow_social_enough</bpmn:outgoing>
      <bpmn:outgoing>Flow_social_not_enough</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_return_social" name="Повернути задачу виконавцю з коментарем">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;Доопрацювати товари для соцмереж&quot;, description: &quot;Відповідальний за соцмережі повернув задачу. Потрібно доопрацювати товари.&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_writer_user_id, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_social_not_enough</bpmn:incoming>
      <bpmn:outgoing>Flow_return_to_write_social</bpmn:outgoing>
    </bpmn:userTask>

    
    <bpmn:parallelGateway id="GW_parallel_merge">
      <bpmn:incoming>Flow_ads_enough</bpmn:incoming>
      <bpmn:incoming>Flow_social_enough</bpmn:incoming>
      <bpmn:outgoing>Flow_to_end</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:endEvent id="End_final" name="Контент підготовлено">
      <bpmn:incoming>Flow_to_end</bpmn:incoming>
    </bpmn:endEvent>

    
    <bpmn:boundaryEvent id="BE_rem_write_ads" name="Нагадування" cancelActivity="false" attachedToRef="UT_write_ads">
      <bpmn:outgoing>Flow_rem_write_ads</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_rem_write_ads">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT24H</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="ST_rem_write_ads" name="Нагадування: написати товари під рекламу">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;⚠️ НАГАДУВАННЯ: Написати 5 товарів під рекламу&quot;, description: &quot;Контент-менеджер ще не завершив підготовку товарів під рекламу.&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_writer_user_id, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_rem_write_ads</bpmn:incoming>
      <bpmn:outgoing>Flow_rem_write_ads_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_rem_write_ads">
      <bpmn:incoming>Flow_rem_write_ads_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:boundaryEvent id="BE_ded_write_ads" name="Дедлайн" cancelActivity="false" attachedToRef="UT_write_ads">
      <bpmn:outgoing>Flow_ded_write_ads</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_ded_write_ads">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:userTask id="UT_esc_write_ads" name="🔴 ЕСКАЛАЦІЯ: Товари під рекламу не підготовлено">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;🔴 ЕСКАЛАЦІЯ: Товари під рекламу не підготовлено&quot;, description: &quot;Контент-менеджер не підготував товари під рекламу протягом 3 днів. Потрібне втручання керівника.&quot;, _model: &quot;project.project&quot;, _id: 252, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ded_write_ads</bpmn:incoming>
      <bpmn:outgoing>Flow_esc_write_ads_end</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_esc_write_ads">
      <bpmn:incoming>Flow_esc_write_ads_end</bpmn:incoming>
    </bpmn:endEvent>

    
    <bpmn:boundaryEvent id="BE_rem_write_social" name="Нагадування" cancelActivity="false" attachedToRef="UT_write_social">
      <bpmn:outgoing>Flow_rem_write_social</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_rem_write_social">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT24H</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="ST_rem_write_social" name="Нагадування: написати товари для соцмереж">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &quot;POST&quot;" target="method" />
          <zeebe:input source="= &quot;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&quot;" target="url" />
          <zeebe:input source="= {&quot;Content-Type&quot;:&quot;application/json&quot;}" target="headers" />
          <zeebe:input source="= {name: &quot;⚠️ НАГАДУВАННЯ: Написати 20 товарів для соцмереж&quot;, description: &quot;Контент-менеджер ще не завершив підготовку товарів для соцмереж.&quot;, _model: &quot;project.project&quot;, _id: 252, x_studio_camunda_user_ids: x_studio_camunda_writer_user_id, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_rem_write_social</bpmn:incoming>
      <bpmn:outgoing>Flow_rem_write_social_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_rem_write_social">
      <bpmn:incoming>Flow_rem_write_social_end</bpmn:incoming>
    </bpmn:endEvent>
