    <bpmn:serviceTask id="ST_create_subtask" name="Створити підзадачу в Odoo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;http://karavaieva.dev-odoo.a.local/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Рахунок від &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34; на №&#34; + x_studio_camunda_invoice_number + &#34; — &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#34;, description: (if x_studio_camunda_invoice_lines_summary != null then x_studio_camunda_invoice_lines_summary else &#34;&#34;) + (if x_studio_camunda_invoice_date != null then &#34;&#60;br/&#62;(&#34; + x_studio_camunda_invoice_date + &#34;)&#34; else &#34;&#34;), _model: &#34;project.project&#34;, _id: 13946, is_subprocess: true, process_instance_key: process_instance_key, parent_process_instance_key: parent_process_instance_key, x_studio_camunda_invoice_number: x_studio_camunda_invoice_number, x_studio_camunda_invoice_line_name: if x_studio_camunda_invoice_line_name != null then x_studio_camunda_invoice_line_name else &#34;&#34;, x_studio_camunda_invoice_amount: x_studio_camunda_invoice_amount, x_studio_camunda_invoice_amount_no_vat: if x_studio_camunda_invoice_amount_no_vat != null then x_studio_camunda_invoice_amount_no_vat else 0, x_studio_camunda_vat_amount: if x_studio_camunda_vat_amount != null then x_studio_camunda_vat_amount else 0, x_studio_camunda_partner_code: if x_studio_camunda_partner_code != null then x_studio_camunda_partner_code else &#34;&#34;, x_studio_camunda_contract: if x_studio_camunda_contract != null then x_studio_camunda_contract else &#34;&#34;, x_studio_camunda_fop_name: if x_studio_camunda_fop_name != null then x_studio_camunda_fop_name else &#34;&#34;, x_studio_camunda_partner_name: if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;&#34;, x_studio_camunda_quantity: if x_studio_camunda_quantity != null then x_studio_camunda_quantity else &#34;&#34;, x_studio_camunda_unit: if x_studio_camunda_unit != null then x_studio_camunda_unit else &#34;&#34;, x_studio_camunda_invoice_type: if x_studio_camunda_invoice_type != null then x_studio_camunda_invoice_type else &#34;&#34;, x_studio_camunda_partner_iban: if x_studio_camunda_partner_iban != null then x_studio_camunda_partner_iban else &#34;&#34;,&#10;x_studio_camunda_partner_bank_name: if x_studio_camunda_partner_bank_name != null then x_studio_camunda_partner_bank_name else &#34;&#34;,&#10;x_studio_camunda_service_period: if x_studio_camunda_service_period != null then x_studio_camunda_service_period else &#34;&#34;,&#10;x_studio_camunda_unit_price: if x_studio_camunda_unit_price != null then x_studio_camunda_unit_price else 0, x_studio_camunda_invoice_date: if x_studio_camunda_invoice_date != null then x_studio_camunda_invoice_date else &#34;&#34;, x_studio_camunda_vat_rate: if x_studio_camunda_vat_rate != null then x_studio_camunda_vat_rate else &#34;&#34;, x_studio_camunda_invoice_lines: if x_studio_camunda_invoice_lines_data != null then x_studio_camunda_invoice_lines_data else []&#10;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_start_to_create</bpmn:incoming>
      <bpmn:outgoing>Flow_create_to_verify</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:businessRuleTask id="BRT_detail_type" name="Визначити тип рахунку [DMN]">
      <bpmn:extensionElements>
