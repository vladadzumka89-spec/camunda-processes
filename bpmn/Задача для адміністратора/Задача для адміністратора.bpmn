    <bpmn:userTask id="Activity_1abeljt" name="Задача &#34;Задача для адміністратора&#34;">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="3" type="http-request-smart" />
        </zeebe:taskListeners>
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={&#10;  name: &#34;Обери сертифікат до дня народження &#34; + emp.employee_name,&#10;  description: &#34;&#60;p&#62;Це обовʼязкове завдання. Воно потрібне, щоб ми підготували для тебе подарунок — сертифікат на &#60;b&#62;2500 грн&#60;/b&#62;.&#60;/p&#62;&#60;br&#62;&#60;p&#62;&#60;b&#62;Що потрібно зробити:&#60;/b&#62;&#60;/p&#62;&#60;ol&#62;&#60;li&#62;У верхній частині задачі знайди поле «Обери сертифікат до дня народження».&#60;/li&#62;&#60;li&#62;Натисни на нього та обери один варіант: &#60;b&#62;Famo/Pinky&#60;/b&#62; чи &#60;b&#62;Технопростір&#60;/b&#62;.&#60;/li&#62;&#60;li&#62;Після вибору обовʼязково натисни кнопку &#60;b&#62;«Завершено»&#60;/b&#62; у верхній частині задачі. Якщо не натиснути «Завершено», вибір не збережеться і сертифікат не буде підготовлений.&#60;/li&#62;&#60;/ol&#62;&#60;br&#62;&#60;p&#62;&#60;b&#62;Як скористатися сертифікатом:&#60;/b&#62;&#60;/p&#62;&#60;ol&#62;&#60;li&#62;Сертифікат діє у вибраній мережі магазинів. Номінал &#60;b&#62;2500 грн&#60;/b&#62;.&#60;/li&#62;&#60;li&#62;Завітай до магазину та скажи на касі, що ти працівник компанії (для співробітників, які працюють понад 3 місяці, діє гуртова знижка).&#60;/li&#62;&#60;li&#62;Якщо потрібного товару немає в магазині — оформи онлайн-замовлення, але оплата сертифікатом завжди здійснюється лише у фізичному магазині.&#60;/li&#62;&#60;/ol&#62;&#34;,&#10;  _model: &#34;project.project&#34;,&#10;  _id: 252,&#10;  x_studio_camunda_user_ids: emp.user_id,&#10;   process_instance_key: process_instance_key&#10;}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1sygqsb</bpmn:incoming>
      <bpmn:outgoing>Flow_137ysju</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics>
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="=employees" inputElement="emp" outputCollection="" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:userTask>
