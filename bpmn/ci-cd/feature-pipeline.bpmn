<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_ftp" targetNamespace="http://tut.ua/bpmn/feature-pipeline" exporter="Claude Code" exporterVersion="3.0">
  <bpmn:message id="Message_pr_event" name="msg_pr_event">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=head_branch" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_review_done" name="msg_review_done">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_pr_updated" name="msg_pr_updated">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_pr_merged" name="msg_pr_merged">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_deploy_done" name="msg_deploy_done">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_pr_ready" name="msg_pr_ready">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_prod_deployed" name="msg_prod_deployed">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:process id="feature-to-production" name="Feature Pipeline" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="19.0" />
    </bpmn:extensionElements>

    <!-- ═══ START EVENTS ═══ -->
    <bpmn:startEvent id="start_manual" name="Розробку розпочато (/start)">
      <bpmn:documentation>Розробник запускає /start — передає task_description, head_branch.</bpmn:documentation>
      <bpmn:outgoing>f_start_to_catch_pr</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:startEvent id="start_pr_event" name="PR створено в main">
      <bpmn:documentation>Автоматичний старт від webhook — PR created в main. Змінні: pr_number, pr_url, head_branch, repository, pr_title.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=pr_number" target="pr_number" />
          <zeebe:output source="=pr_url" target="pr_url" />
          <zeebe:output source="=pr_title" target="pr_title" />
          <zeebe:output source="=head_branch" target="head_branch" />
          <zeebe:output source="=if is defined(repository) then repository else &#34;&#34;" target="repository" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>f_auto_to_merge_entry</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_start_pr" messageRef="Message_pr_event" />
    </bpmn:startEvent>

    <!-- ═══ WAIT FOR PR (manual flow) ═══ -->
    <bpmn:intermediateCatchEvent id="catch_pr_created" name="Чекаємо PR в main">
      <bpmn:documentation>Чекає msg_pr_event з correlation key = head_branch. Тільки для /start flow.</bpmn:documentation>
      <bpmn:incoming>f_start_to_catch_pr</bpmn:incoming>
      <bpmn:outgoing>f_pr_to_merge_entry</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_pr_event" messageRef="Message_pr_event" />
    </bpmn:intermediateCatchEvent>

    <!-- ═══ MERGE: both flows converge ═══ -->
    <bpmn:exclusiveGateway id="Merge_entry">
      <bpmn:incoming>f_pr_to_merge_entry</bpmn:incoming>
      <bpmn:incoming>f_auto_to_merge_entry</bpmn:incoming>
      <bpmn:outgoing>f_entry_to_review</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ═══ REVIEW LOOP ═══ -->
    <bpmn:intermediateCatchEvent id="catch_review_done" name="Чекаємо результат ревʼю">
      <bpmn:documentation>Чекає msg_review_done від standalone pr-review процесу (correlation: pr_number).</bpmn:documentation>
      <bpmn:incoming>f_entry_to_review</bpmn:incoming>
      <bpmn:incoming>f_rework_to_review</bpmn:incoming>
      <bpmn:incoming>f_staging_rework_to_review</bpmn:incoming>
      <bpmn:incoming>f_deploy_failed_to_rework</bpmn:incoming>
      <bpmn:incoming>f_merge_failed_to_rework</bpmn:incoming>
      <bpmn:incoming>f_validate_failed_to_rework</bpmn:incoming>
      <bpmn:outgoing>f_review_to_score</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_review_done" messageRef="Message_review_done" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="GW_score" name="Оцінка &#62;= 7?" default="f_score_ok">
      <bpmn:incoming>f_review_to_score</bpmn:incoming>
      <bpmn:outgoing>f_score_ok</bpmn:outgoing>
      <bpmn:outgoing>f_score_low</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ═══ REWORK: low score ═══ -->
    <bpmn:serviceTask id="ST_comment_rework" name="Коментар: потрібне виправлення">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;🔄 Оцінка ревʼю: &#34; + string(review_score) + &#34;/10. Потрібне виправлення. Пушніть зміни в гілку `&#34; + head_branch + &#34;` для повторного ревʼю.&#10;&#10;[Процес в Operate](http://camunda-demo.a.local:8088/operate/processes/&#34; + string(process_instance_key) + &#34;)&#34;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_score_low</bpmn:incoming>
      <bpmn:outgoing>f_comment_to_wait</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:receiveTask id="catch_pr_updated" name="Чекаємо оновлення PR" messageRef="Message_pr_updated">
      <bpmn:documentation>Чекає push нових комітів в PR (msg_pr_updated, correlation: pr_number).</bpmn:documentation>
      <bpmn:incoming>f_comment_to_wait</bpmn:incoming>
      <bpmn:outgoing>f_rework_to_review</bpmn:outgoing>
    </bpmn:receiveTask>

    <!-- ═══ VALIDATE BRANCH (before merge) ═══ -->
    <bpmn:serviceTask id="ST_validate_branch" name="Перевірити гілку">
      <bpmn:documentation>Перевіряє код гілки ПЕРЕД merge в staging (без змін на staging): manifest, XML syntax, Python syntax, CSV. Повертає validate_ok + validate_errors.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="validate-branch" retries="1" />
        <zeebe:ioMapping>
          <zeebe:input source="=head_branch" target="feature_branch" />
          <zeebe:input source="=&#34;staging&#34;" target="server_host" />
          <zeebe:output source="=validate_ok" target="validate_ok" />
          <zeebe:output source="=validate_errors" target="validate_errors" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_score_ok</bpmn:incoming>
      <bpmn:outgoing>f_validate_to_gw</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GW_validate_ok" name="Код валідний?" default="f_validate_err">
      <bpmn:incoming>f_validate_to_gw</bpmn:incoming>
      <bpmn:outgoing>f_validate_ok</bpmn:outgoing>
      <bpmn:outgoing>f_validate_err</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="ST_comment_validate_failed" name="Коментар: код зламаний">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;❌ Гілку `&#34; + head_branch + &#34;` відхилено — код зламаний.&#10;&#10;**Помилка:** &#34; + (if is defined(validate_errors) and validate_errors != null then validate_errors else &#34;деталі невідомі&#34;) + &#34;&#10;&#10;Виправте помилку і пушніть знову. Merge в staging не відбувся — staging чистий.&#10;&#10;[Процес в Operate](http://camunda-demo.a.local:8088/operate/processes/&#34; + string(process_instance_key) + &#34;)&#34;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_validate_err</bpmn:incoming>
      <bpmn:outgoing>f_validate_failed_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ═══ MERGE TO STAGING ═══ -->
    <bpmn:serviceTask id="ST_merge_to_staging" name="Замерджити в staging">
      <bpmn:documentation>Merge feature branch в staging (git merge -X theirs). Повертає merge_sha.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="merge-feature-to-staging" retries="5" />
        <zeebe:ioMapping>
          <zeebe:input source="=head_branch" target="feature_branch" />
          <zeebe:input source="=&#34;staging&#34;" target="server_host" />
          <zeebe:output source="=merge_sha" target="merge_sha" />
          <zeebe:output source="=false" target="deploy_failed" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_validate_ok</bpmn:incoming>
      <bpmn:incoming>f_wait_to_merge</bpmn:incoming>
      <bpmn:outgoing>f_merge_to_deploy</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Boundary error: merge failed → rework -->
    <bpmn:boundaryEvent id="BE_merge_failed" name="Merge failed" attachedToRef="ST_merge_to_staging">
      <bpmn:outgoing>f_merge_err_to_comment</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDef_merge_failed" zeebe:errorMessageVariable="caught_error_message" />
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="ST_comment_merge_failed" name="Коментар: merge failed">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;❌ Merge в staging не вдався.&#10;&#10;**Помилка:** &#34; + (if is defined(caught_error_message) and caught_error_message != null and caught_error_message != &#34;&#34; then caught_error_message else &#34;деталі невідомі&#34;) + &#34;&#10;&#10;[Процес в Operate](http://camunda-demo.a.local:8088/operate/processes/&#34; + string(process_instance_key) + &#34;)&#10;&#10;Пушніть виправлення в `&#34; + head_branch + &#34;`.&#34;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_merge_err_to_comment</bpmn:incoming>
      <bpmn:outgoing>f_merge_failed_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ═══ DEPLOY TRIGGER + WAIT ═══ -->
    <bpmn:serviceTask id="ST_publish_deploy_trigger" name="Тригер деплою staging">
      <bpmn:documentation>Публікує msg_deploy_trigger для deploy-scheduler. Черга гарантує що деплої йдуть послідовно.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="publish-message" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;msg_deploy_trigger&#34;" target="message_name" />
          <zeebe:input source="=&#34;staging&#34;" target="correlation_key" />
          <zeebe:input source="=merge_sha" target="trigger_sha" />
          <zeebe:input source="=merge_sha" target="merge_sha" />
          <zeebe:input source="=pr_number" target="pr_number" />
          <zeebe:input source="=pr_title" target="pr_title" />
          <zeebe:input source="=&#34;staging&#34;" target="server_host" />
          <zeebe:input source="=&#34;staging&#34;" target="branch" />
          <zeebe:input source="=true" target="run_smoke_test" />
          <zeebe:input source="=&#34;light&#34;" target="test_mode" />
          <zeebe:input source="=3600000" target="ttl_ms" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_merge_to_deploy</bpmn:incoming>
      <bpmn:outgoing>f_trigger_to_catch</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="catch_staging_deployed" name="Чекаємо деплой staging">
      <bpmn:documentation>Чекає msg_deploy_done від deploy-scheduler (correlation: pr_number).</bpmn:documentation>
      <bpmn:incoming>f_trigger_to_catch</bpmn:incoming>
      <bpmn:outgoing>f_deploy_to_check</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_deploy_done" messageRef="Message_deploy_done" />
    </bpmn:intermediateCatchEvent>

    <!-- ═══ DEPLOY CHECK ═══ -->
    <bpmn:exclusiveGateway id="GW_deploy_ok" name="Deploy OK?" default="f_deploy_ok">
      <bpmn:incoming>f_deploy_to_check</bpmn:incoming>
      <bpmn:outgoing>f_deploy_ok</bpmn:outgoing>
      <bpmn:outgoing>f_deploy_failed</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ═══ RETRY LOGIC ═══ -->
    <bpmn:exclusiveGateway id="GW_retry_type" name="Infra retry?" default="f_deploy_failed_code">
      <bpmn:incoming>f_deploy_failed</bpmn:incoming>
      <bpmn:outgoing>f_retry_infra</bpmn:outgoing>
      <bpmn:outgoing>f_deploy_failed_code</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:scriptTask id="ST_increment_retry" name="Лічильник retry++">
      <bpmn:extensionElements>
        <zeebe:script expression="=if is defined(deploy_retry_count) then deploy_retry_count + 1 else 1" resultVariable="deploy_retry_count" />
      </bpmn:extensionElements>
      <bpmn:incoming>f_retry_infra</bpmn:incoming>
      <bpmn:outgoing>f_increment_to_wait</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:intermediateCatchEvent id="TE_retry_wait" name="Очікування 3 хв">
      <bpmn:incoming>f_increment_to_wait</bpmn:incoming>
      <bpmn:outgoing>f_wait_to_merge</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_retry_wait">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT3M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="ST_comment_deploy_failed" name="Коментар: deploy failed">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;❌ **Staging deploy failed**&#34; + (if is defined(error_message) and error_message != null and error_message != &#34;&#34; then &#34;: &#34; + error_message else &#34;&#34;) + &#34;&#10;&#10;&lt;details&gt;&lt;summary&gt;Traceback&lt;/summary&gt;&#10;&#10;```&#10;&#34; + (if is defined(error_traceback) and error_traceback != null and error_traceback != &#34;&#34; then error_traceback else if is defined(error_message) and error_message != null and error_message != &#34;&#34; then error_message else &#34;No traceback available&#34;) + &#34;&#10;```&#10;&#10;&lt;/details&gt;&#10;&#10;[Процес в Operate](http://camunda-demo.a.local:8088/operate/processes/&#34; + string(process_instance_key) + &#34;)&#10;&#10;Пушніть виправлення в `&#34; + head_branch + &#34;`.&#34;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_deploy_failed_code</bpmn:incoming>
      <bpmn:outgoing>f_deploy_failed_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="ST_comment_staging_ok" name="Коментар: staging deployed">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;✅ **Staging deploy successful**&#10;&#10;Гілка `&#34; + head_branch + &#34;` задеплоєна на staging.&#10;Перевірте зміни і зніміть draft з PR коли все ок.&#10;&#10;[Процес в Operate](http://camunda-demo.a.local:8088/operate/processes/&#34; + string(process_instance_key) + &#34;)&#34;" target="comment_text" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_deploy_ok</bpmn:incoming>
      <bpmn:outgoing>f_staging_comment_to_event</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ═══ STAGING VERIFICATION ═══ -->
    <bpmn:eventBasedGateway id="GW_event_staging" name="Undraft чи push?">
      <bpmn:documentation>Чекає на одну з двох подій: PR знято з draft (staging ок) або push нових комітів (rework).</bpmn:documentation>
      <bpmn:incoming>f_staging_comment_to_event</bpmn:incoming>
      <bpmn:outgoing>f_event_to_ready</bpmn:outgoing>
      <bpmn:outgoing>f_event_to_staging_rework</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="catch_pr_ready" name="PR знято з draft">
      <bpmn:documentation>Розробник перевірив staging і зняв draft з PR — staging ок.</bpmn:documentation>
      <bpmn:incoming>f_event_to_ready</bpmn:incoming>
      <bpmn:outgoing>f_ready_to_catch_merged</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_pr_ready" messageRef="Message_pr_ready" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="catch_staging_rework" name="Push: rework staging">
      <bpmn:documentation>Розробник пушить фікс — staging не ок, потрібен rework.</bpmn:documentation>
      <bpmn:incoming>f_event_to_staging_rework</bpmn:incoming>
      <bpmn:outgoing>f_staging_rework_to_review</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_staging_rework" messageRef="Message_pr_updated" />
    </bpmn:intermediateCatchEvent>

    <!-- ═══ MERGE PR + PRODUCTION ═══ -->
    <bpmn:intermediateCatchEvent id="catch_pr_merged" name="Чекаємо merge PR в main">
      <bpmn:documentation>Чекає msg_pr_merged від GitHub webhook (correlation: pr_number).</bpmn:documentation>
      <bpmn:incoming>f_ready_to_catch_merged</bpmn:incoming>
      <bpmn:outgoing>f_merged_to_prod</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_pr_merged" messageRef="Message_pr_merged" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="catch_prod_deployed" name="Чекаємо деплой production">
      <bpmn:documentation>Чекає msg_prod_deployed від production-nightly-deploy (correlation: pr_number). Деплой відбувається щодня о 23:30.</bpmn:documentation>
      <bpmn:incoming>f_merged_to_prod</bpmn:incoming>
      <bpmn:outgoing>f_prod_to_end</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_prod_deployed" messageRef="Message_prod_deployed" />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="evt_end_success" name="Фіча на production">
      <bpmn:incoming>f_prod_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ═══ SEQUENCE FLOWS ═══ -->
    <bpmn:sequenceFlow id="f_start_to_catch_pr" sourceRef="start_manual" targetRef="catch_pr_created" />
    <bpmn:sequenceFlow id="f_pr_to_merge_entry" sourceRef="catch_pr_created" targetRef="Merge_entry" />
    <bpmn:sequenceFlow id="f_auto_to_merge_entry" sourceRef="start_pr_event" targetRef="Merge_entry" />
    <bpmn:sequenceFlow id="f_entry_to_review" sourceRef="Merge_entry" targetRef="catch_review_done" />
    <bpmn:sequenceFlow id="f_review_to_score" sourceRef="catch_review_done" targetRef="GW_score" />
    <bpmn:sequenceFlow id="f_score_ok" sourceRef="GW_score" targetRef="ST_validate_branch" />
    <bpmn:sequenceFlow id="f_validate_to_gw" sourceRef="ST_validate_branch" targetRef="GW_validate_ok" />
    <bpmn:sequenceFlow id="f_validate_ok" sourceRef="GW_validate_ok" targetRef="ST_merge_to_staging">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=validate_ok = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_validate_err" sourceRef="GW_validate_ok" targetRef="ST_comment_validate_failed" />
    <bpmn:sequenceFlow id="f_validate_failed_to_rework" sourceRef="ST_comment_validate_failed" targetRef="catch_review_done" />
    <bpmn:sequenceFlow id="f_score_low" sourceRef="GW_score" targetRef="ST_comment_rework">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=review_score &lt; 7 or (is defined(has_critical_issues) and has_critical_issues = true)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_comment_to_wait" sourceRef="ST_comment_rework" targetRef="catch_pr_updated" />
    <bpmn:sequenceFlow id="f_rework_to_review" sourceRef="catch_pr_updated" targetRef="catch_review_done" />
    <bpmn:sequenceFlow id="f_merge_to_deploy" sourceRef="ST_merge_to_staging" targetRef="ST_publish_deploy_trigger" />
    <bpmn:sequenceFlow id="f_merge_err_to_comment" sourceRef="BE_merge_failed" targetRef="ST_comment_merge_failed" />
    <bpmn:sequenceFlow id="f_merge_failed_to_rework" sourceRef="ST_comment_merge_failed" targetRef="catch_review_done" />
    <bpmn:sequenceFlow id="f_trigger_to_catch" sourceRef="ST_publish_deploy_trigger" targetRef="catch_staging_deployed" />
    <bpmn:sequenceFlow id="f_deploy_to_check" sourceRef="catch_staging_deployed" targetRef="GW_deploy_ok" />
    <bpmn:sequenceFlow id="f_deploy_ok" sourceRef="GW_deploy_ok" targetRef="ST_comment_staging_ok" />
    <bpmn:sequenceFlow id="f_staging_comment_to_event" sourceRef="ST_comment_staging_ok" targetRef="GW_event_staging" />
    <bpmn:sequenceFlow id="f_deploy_failed" sourceRef="GW_deploy_ok" targetRef="GW_retry_type">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=is defined(deploy_failed) and deploy_failed = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_retry_infra" sourceRef="GW_retry_type" targetRef="ST_increment_retry">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=is defined(error_type) and error_type = "infra" and (not(is defined(deploy_retry_count)) or deploy_retry_count &lt; 2)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_deploy_failed_code" sourceRef="GW_retry_type" targetRef="ST_comment_deploy_failed" />
    <bpmn:sequenceFlow id="f_increment_to_wait" sourceRef="ST_increment_retry" targetRef="TE_retry_wait" />
    <bpmn:sequenceFlow id="f_wait_to_merge" sourceRef="TE_retry_wait" targetRef="ST_merge_to_staging" />
    <bpmn:sequenceFlow id="f_deploy_failed_to_rework" sourceRef="ST_comment_deploy_failed" targetRef="catch_review_done" />
    <bpmn:sequenceFlow id="f_event_to_ready" sourceRef="GW_event_staging" targetRef="catch_pr_ready" />
    <bpmn:sequenceFlow id="f_event_to_staging_rework" sourceRef="GW_event_staging" targetRef="catch_staging_rework" />
    <bpmn:sequenceFlow id="f_ready_to_catch_merged" sourceRef="catch_pr_ready" targetRef="catch_pr_merged" />
    <bpmn:sequenceFlow id="f_staging_rework_to_review" sourceRef="catch_staging_rework" targetRef="catch_review_done" />
    <bpmn:sequenceFlow id="f_merged_to_prod" sourceRef="catch_pr_merged" targetRef="catch_prod_deployed" />
    <bpmn:sequenceFlow id="f_prod_to_end" sourceRef="catch_prod_deployed" targetRef="evt_end_success" />

    <!-- ═══ EVENT SUBPROCESS: TTL 14 днів ═══ -->
    <bpmn:subProcess id="SP_ttl" name="TTL: 14 днів" triggeredByEvent="true">
      <bpmn:startEvent id="SE_ttl_timer" name="14 днів" isInterrupting="true">
        <bpmn:outgoing>f_ttl_to_end</bpmn:outgoing>
        <bpmn:timerEventDefinition id="TimerDef_ttl">
          <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P14D</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:startEvent>
      <bpmn:endEvent id="EE_ttl" name="Процес скасовано (TTL)">
        <bpmn:incoming>f_ttl_to_end</bpmn:incoming>
        <bpmn:terminateEventDefinition id="TermDef_ttl" />
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="f_ttl_to_end" sourceRef="SE_ttl_timer" targetRef="EE_ttl" />
    </bpmn:subProcess>

    <!-- ═══ ANNOTATIONS ═══ -->
    <bpmn:textAnnotation id="note_pr_review">
      <bpmn:text>pr-review (standalone)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="assoc_pr_review" sourceRef="catch_review_done" targetRef="note_pr_review" />
    <bpmn:textAnnotation id="note_nightly_deploy">
      <bpmn:text>production-nightly-deploy</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="assoc_nightly_deploy" sourceRef="catch_prod_deployed" targetRef="note_nightly_deploy" />
    <bpmn:textAnnotation id="note_deploy_scheduler">
      <bpmn:text>deploy-scheduler → deploy-process</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="assoc_deploy_scheduler" sourceRef="ST_publish_deploy_trigger" targetRef="note_deploy_scheduler" />
  </bpmn:process>

  <!-- ═══════════════════════════════════════════════════════════
       DI LAYOUT
       Main flow Y=200 (center line)
       Rework branch Y=370 (low score) → Y=500 (wait push)
       Merge failed Y=370
       Staging rework Y=80
       Validate branch Y=80 (top corridor)
       ═══════════════════════════════════════════════════════════ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_ftp">
    <bpmndi:BPMNPlane id="BPMNPlane_ftp" bpmnElement="feature-to-production">

      <!-- ── Start events ── -->
      <bpmndi:BPMNShape id="di_start_manual" bpmnElement="start_manual">
        <dc:Bounds x="160" y="120" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="130" y="160" width="96" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_start_pr_event" bpmnElement="start_pr_event">
        <dc:Bounds x="160" y="260" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="130" y="300" width="96" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ── Wait PR + merge gateways ── -->
      <bpmndi:BPMNShape id="di_catch_pr_created" bpmnElement="catch_pr_created">
        <dc:Bounds x="282" y="120" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="262" y="160" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Merge_entry" bpmnElement="Merge_entry" isMarkerVisible="true">
        <dc:Bounds x="385" y="175" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- ── Review catch ── -->
      <bpmndi:BPMNShape id="di_catch_review_done" bpmnElement="catch_review_done">
        <dc:Bounds x="512" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="488" y="222" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_note_pr_review" bpmnElement="note_pr_review">
        <dc:Bounds x="480" y="130" width="120" height="30" />
      </bpmndi:BPMNShape>

      <!-- ── Score gateway ── -->
      <bpmndi:BPMNShape id="di_GW_score" bpmnElement="GW_score" isMarkerVisible="true">
        <dc:Bounds x="615" y="175" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="605" y="153" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ── Rework: low score branch (Y=370, Y=500) ── -->
      <bpmndi:BPMNShape id="di_ST_comment_rework" bpmnElement="ST_comment_rework">
        <dc:Bounds x="590" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_catch_pr_updated" bpmnElement="catch_pr_updated">
        <dc:Bounds x="590" y="490" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- ── Validate branch (above merge) ── -->
      <bpmndi:BPMNShape id="di_ST_validate_branch" bpmnElement="ST_validate_branch">
        <dc:Bounds x="740" y="50" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_GW_validate_ok" bpmnElement="GW_validate_ok" isMarkerVisible="true">
        <dc:Bounds x="865" y="65" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="848" y="38" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_ST_comment_validate_failed" bpmnElement="ST_comment_validate_failed">
        <dc:Bounds x="945" y="50" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- ── Merge to staging ── -->
      <bpmndi:BPMNShape id="di_ST_merge_to_staging" bpmnElement="ST_merge_to_staging">
        <dc:Bounds x="740" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_BE_merge_failed" bpmnElement="BE_merge_failed">
        <dc:Bounds x="750" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="706" y="256" width="64" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_ST_comment_merge_failed" bpmnElement="ST_comment_merge_failed">
        <dc:Bounds x="740" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- ── Deploy trigger + wait ── -->
      <bpmndi:BPMNShape id="di_ST_publish_deploy_trigger" bpmnElement="ST_publish_deploy_trigger">
        <dc:Bounds x="910" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_note_deploy_scheduler" bpmnElement="note_deploy_scheduler">
        <dc:Bounds x="890" y="110" width="140" height="30" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_catch_staging_deployed" bpmnElement="catch_staging_deployed">
        <dc:Bounds x="1072" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1045" y="222" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ── Deploy check ── -->
      <bpmndi:BPMNShape id="di_GW_deploy_ok" bpmnElement="GW_deploy_ok" isMarkerVisible="true">
        <dc:Bounds x="1175" y="175" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1170" y="153" width="60" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ── Retry logic ── -->
      <bpmndi:BPMNShape id="di_GW_retry_type" bpmnElement="GW_retry_type" isMarkerVisible="true">
        <dc:Bounds x="1175" y="265" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1165" y="243" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_ST_increment_retry" bpmnElement="ST_increment_retry">
        <dc:Bounds x="1000" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_TE_retry_wait" bpmnElement="TE_retry_wait">
        <dc:Bounds x="860" y="282" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="835" y="322" width="86" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_ST_comment_deploy_failed" bpmnElement="ST_comment_deploy_failed">
        <dc:Bounds x="1150" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- ── Staging deploy OK comment ── -->
      <bpmndi:BPMNShape id="di_ST_comment_staging_ok" bpmnElement="ST_comment_staging_ok">
        <dc:Bounds x="1270" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- ── Staging verification: event-based gateway ── -->
      <bpmndi:BPMNShape id="di_GW_event_staging" bpmnElement="GW_event_staging">
        <dc:Bounds x="1445" y="175" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1429" y="229" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_catch_pr_ready" bpmnElement="catch_pr_ready">
        <dc:Bounds x="1562" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1538" y="222" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_catch_staging_rework" bpmnElement="catch_staging_rework">
        <dc:Bounds x="1452" y="72" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1422" y="52" width="96" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ── PR merged + prod deploy + end ── -->
      <bpmndi:BPMNShape id="di_catch_pr_merged" bpmnElement="catch_pr_merged">
        <dc:Bounds x="1662" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1630" y="222" width="100" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_catch_prod_deployed" bpmnElement="catch_prod_deployed">
        <dc:Bounds x="1762" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1730" y="222" width="100" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_note_nightly_deploy" bpmnElement="note_nightly_deploy">
        <dc:Bounds x="1720" y="130" width="130" height="30" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_evt_end_success" bpmnElement="evt_end_success">
        <dc:Bounds x="1862" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1838" y="222" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ── TTL Event Subprocess (Y=600) ── -->
      <bpmndi:BPMNShape id="di_SP_ttl" bpmnElement="SP_ttl" isExpanded="true">
        <dc:Bounds x="160" y="600" width="350" height="120" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="290" y="582" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_SE_ttl_timer" bpmnElement="SE_ttl_timer">
        <dc:Bounds x="212" y="652" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="207" y="692" width="46" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_EE_ttl" bpmnElement="EE_ttl">
        <dc:Bounds x="442" y="652" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="416" y="692" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="di_f_ttl_to_end" bpmnElement="f_ttl_to_end">
        <di:waypoint x="248" y="670" />
        <di:waypoint x="442" y="670" />
      </bpmndi:BPMNEdge>

      <!-- ═══ EDGES ═══ -->

      <!-- Start → catch PR (horizontal) -->
      <bpmndi:BPMNEdge id="di_f_start_to_catch_pr" bpmnElement="f_start_to_catch_pr">
        <di:waypoint x="196" y="138" />
        <di:waypoint x="282" y="138" />
      </bpmndi:BPMNEdge>

      <!-- catch PR → Merge_entry (L-shape down) -->
      <bpmndi:BPMNEdge id="di_f_pr_to_merge_entry" bpmnElement="f_pr_to_merge_entry">
        <di:waypoint x="318" y="138" />
        <di:waypoint x="410" y="138" />
        <di:waypoint x="410" y="175" />
      </bpmndi:BPMNEdge>

      <!-- start_pr_event → Merge_entry (L-shape up) -->
      <bpmndi:BPMNEdge id="di_f_auto_to_merge_entry" bpmnElement="f_auto_to_merge_entry">
        <di:waypoint x="196" y="278" />
        <di:waypoint x="410" y="278" />
        <di:waypoint x="410" y="225" />
      </bpmndi:BPMNEdge>

      <!-- Merge_entry → catch_review_done (horizontal) -->
      <bpmndi:BPMNEdge id="di_f_entry_to_review" bpmnElement="f_entry_to_review">
        <di:waypoint x="435" y="200" />
        <di:waypoint x="512" y="200" />
      </bpmndi:BPMNEdge>

      <!-- review → score (horizontal) -->
      <bpmndi:BPMNEdge id="di_f_review_to_score" bpmnElement="f_review_to_score">
        <di:waypoint x="548" y="200" />
        <di:waypoint x="615" y="200" />
      </bpmndi:BPMNEdge>

      <!-- score → validate branch (right then up) -->
      <bpmndi:BPMNEdge id="di_f_score_ok" bpmnElement="f_score_ok">
        <di:waypoint x="665" y="200" />
        <di:waypoint x="790" y="200" />
        <di:waypoint x="790" y="130" />
      </bpmndi:BPMNEdge>

      <!-- validate branch → GW_validate_ok (right) -->
      <bpmndi:BPMNEdge id="di_f_validate_to_gw" bpmnElement="f_validate_to_gw">
        <di:waypoint x="840" y="90" />
        <di:waypoint x="865" y="90" />
      </bpmndi:BPMNEdge>

      <!-- GW_validate_ok → merge (ok path, down-left) -->
      <bpmndi:BPMNEdge id="di_f_validate_ok" bpmnElement="f_validate_ok">
        <di:waypoint x="890" y="115" />
        <di:waypoint x="890" y="200" />
        <di:waypoint x="840" y="200" />
      </bpmndi:BPMNEdge>

      <!-- GW_validate_ok → comment validate failed (right) -->
      <bpmndi:BPMNEdge id="di_f_validate_err" bpmnElement="f_validate_err">
        <di:waypoint x="915" y="90" />
        <di:waypoint x="945" y="90" />
      </bpmndi:BPMNEdge>

      <!-- comment validate failed → catch_review_done (left then down) -->
      <bpmndi:BPMNEdge id="di_f_validate_failed_to_rework" bpmnElement="f_validate_failed_to_rework">
        <di:waypoint x="945" y="90" />
        <di:waypoint x="530" y="90" />
        <di:waypoint x="530" y="182" />
      </bpmndi:BPMNEdge>

      <!-- score → comment rework (down) -->
      <bpmndi:BPMNEdge id="di_f_score_low" bpmnElement="f_score_low">
        <di:waypoint x="640" y="225" />
        <di:waypoint x="640" y="340" />
      </bpmndi:BPMNEdge>

      <!-- comment rework → wait push (down) -->
      <bpmndi:BPMNEdge id="di_f_comment_to_wait" bpmnElement="f_comment_to_wait">
        <di:waypoint x="640" y="420" />
        <di:waypoint x="640" y="490" />
      </bpmndi:BPMNEdge>

      <!-- wait push → review (loop back left) -->
      <bpmndi:BPMNEdge id="di_f_rework_to_review" bpmnElement="f_rework_to_review">
        <di:waypoint x="590" y="530" />
        <di:waypoint x="530" y="530" />
        <di:waypoint x="530" y="218" />
      </bpmndi:BPMNEdge>

      <!-- merge staging → deploy trigger (horizontal) -->
      <bpmndi:BPMNEdge id="di_f_merge_to_deploy" bpmnElement="f_merge_to_deploy">
        <di:waypoint x="840" y="200" />
        <di:waypoint x="910" y="200" />
      </bpmndi:BPMNEdge>

      <!-- BE merge failed → comment merge failed (down from boundary) -->
      <bpmndi:BPMNEdge id="di_f_merge_err_to_comment" bpmnElement="f_merge_err_to_comment">
        <di:waypoint x="768" y="258" />
        <di:waypoint x="768" y="340" />
      </bpmndi:BPMNEdge>

      <!-- comment merge failed → review (loop back left) -->
      <bpmndi:BPMNEdge id="di_f_merge_failed_to_rework" bpmnElement="f_merge_failed_to_rework">
        <di:waypoint x="790" y="420" />
        <di:waypoint x="790" y="450" />
        <di:waypoint x="530" y="450" />
        <di:waypoint x="530" y="218" />
      </bpmndi:BPMNEdge>

      <!-- deploy trigger → catch deployed (horizontal) -->
      <bpmndi:BPMNEdge id="di_f_trigger_to_catch" bpmnElement="f_trigger_to_catch">
        <di:waypoint x="1010" y="200" />
        <di:waypoint x="1072" y="200" />
      </bpmndi:BPMNEdge>

      <!-- catch deployed → GW deploy ok (horizontal) -->
      <bpmndi:BPMNEdge id="di_f_deploy_to_check" bpmnElement="f_deploy_to_check">
        <di:waypoint x="1108" y="200" />
        <di:waypoint x="1175" y="200" />
      </bpmndi:BPMNEdge>

      <!-- deploy ok → staging comment (horizontal) -->
      <bpmndi:BPMNEdge id="di_f_deploy_ok" bpmnElement="f_deploy_ok">
        <di:waypoint x="1225" y="200" />
        <di:waypoint x="1270" y="200" />
      </bpmndi:BPMNEdge>

      <!-- staging comment → event staging (horizontal) -->
      <bpmndi:BPMNEdge id="di_f_staging_comment_to_event" bpmnElement="f_staging_comment_to_event">
        <di:waypoint x="1370" y="200" />
        <di:waypoint x="1445" y="200" />
      </bpmndi:BPMNEdge>

      <!-- deploy failed → retry gateway (down) -->
      <bpmndi:BPMNEdge id="di_f_deploy_failed" bpmnElement="f_deploy_failed">
        <di:waypoint x="1200" y="225" />
        <di:waypoint x="1200" y="265" />
      </bpmndi:BPMNEdge>

      <!-- retry gateway → infra retry (left to ST_increment_retry) -->
      <bpmndi:BPMNEdge id="di_f_retry_infra" bpmnElement="f_retry_infra">
        <di:waypoint x="1175" y="290" />
        <di:waypoint x="1100" y="300" />
      </bpmndi:BPMNEdge>

      <!-- retry gateway → code fail (down to comment task) -->
      <bpmndi:BPMNEdge id="di_f_deploy_failed_code" bpmnElement="f_deploy_failed_code">
        <di:waypoint x="1200" y="315" />
        <di:waypoint x="1200" y="340" />
      </bpmndi:BPMNEdge>

      <!-- ST_increment_retry → TE_retry_wait (left) -->
      <bpmndi:BPMNEdge id="di_f_increment_to_wait" bpmnElement="f_increment_to_wait">
        <di:waypoint x="1000" y="300" />
        <di:waypoint x="896" y="300" />
      </bpmndi:BPMNEdge>

      <!-- TE_retry_wait → ST_merge_to_staging (up then left) -->
      <bpmndi:BPMNEdge id="di_f_wait_to_merge" bpmnElement="f_wait_to_merge">
        <di:waypoint x="878" y="282" />
        <di:waypoint x="878" y="240" />
        <di:waypoint x="790" y="240" />
      </bpmndi:BPMNEdge>

      <!-- comment deploy failed → review (loop back left) -->
      <bpmndi:BPMNEdge id="di_f_deploy_failed_to_rework" bpmnElement="f_deploy_failed_to_rework">
        <di:waypoint x="1150" y="380" />
        <di:waypoint x="530" y="380" />
        <di:waypoint x="530" y="218" />
      </bpmndi:BPMNEdge>

      <!-- event staging → PR ready (horizontal) -->
      <bpmndi:BPMNEdge id="di_f_event_to_ready" bpmnElement="f_event_to_ready">
        <di:waypoint x="1495" y="200" />
        <di:waypoint x="1562" y="200" />
      </bpmndi:BPMNEdge>

      <!-- event staging → staging rework (up) -->
      <bpmndi:BPMNEdge id="di_f_event_to_staging_rework" bpmnElement="f_event_to_staging_rework">
        <di:waypoint x="1470" y="175" />
        <di:waypoint x="1470" y="108" />
      </bpmndi:BPMNEdge>

      <!-- staging rework → review (loop back left via Y=90 corridor) -->
      <bpmndi:BPMNEdge id="di_f_staging_rework_to_review" bpmnElement="f_staging_rework_to_review">
        <di:waypoint x="1452" y="90" />
        <di:waypoint x="530" y="90" />
        <di:waypoint x="530" y="182" />
      </bpmndi:BPMNEdge>

      <!-- PR ready → catch merged (horizontal) -->
      <bpmndi:BPMNEdge id="di_f_ready_to_catch_merged" bpmnElement="f_ready_to_catch_merged">
        <di:waypoint x="1598" y="200" />
        <di:waypoint x="1662" y="200" />
      </bpmndi:BPMNEdge>

      <!-- catch merged → catch prod deployed (horizontal) -->
      <bpmndi:BPMNEdge id="di_f_merged_to_prod" bpmnElement="f_merged_to_prod">
        <di:waypoint x="1698" y="200" />
        <di:waypoint x="1762" y="200" />
      </bpmndi:BPMNEdge>

      <!-- catch prod deployed → end (horizontal) -->
      <bpmndi:BPMNEdge id="di_f_prod_to_end" bpmnElement="f_prod_to_end">
        <di:waypoint x="1798" y="200" />
        <di:waypoint x="1862" y="200" />
      </bpmndi:BPMNEdge>

      <!-- ── Annotations ── -->
      <bpmndi:BPMNEdge id="di_assoc_pr_review" bpmnElement="assoc_pr_review">
        <di:waypoint x="530" y="182" />
        <di:waypoint x="530" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_assoc_nightly_deploy" bpmnElement="assoc_nightly_deploy">
        <di:waypoint x="1780" y="182" />
        <di:waypoint x="1780" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_assoc_deploy_scheduler" bpmnElement="assoc_deploy_scheduler">
        <di:waypoint x="960" y="160" />
        <di:waypoint x="960" y="140" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
