        <di:waypoint x="1985" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f10_di" bpmnElement="f10">
        <di:waypoint x="2085" y="300" />
        <di:waypoint x="2165" y="300" />
      </bpmndi:BPMNEdge>
      <!-- Clickbot diamond -->
