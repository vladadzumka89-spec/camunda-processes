          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Бух реалізація рахунку №&#34; + x_studio_camunda_invoice_number + &#34; — &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#34;, description: &#34;Проведіть бухгалтерську реалізацію на основі рахунку&#34;, _model: &#34;project.project&#34;, _id: 288, process_instance_key: process_instance_key, parent_process_instance_key: parent_process_instance_key, x_studio_camunda_invoice_number: x_studio_camunda_invoice_number, x_studio_camunda_invoice_line_name: if x_studio_camunda_invoice_line_name != null then x_studio_camunda_invoice_line_name else &#34;&#34;, x_studio_camunda_invoice_amount: x_studio_camunda_invoice_amount}" target="body" />
