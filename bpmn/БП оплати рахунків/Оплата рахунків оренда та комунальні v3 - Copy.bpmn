<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="e787c33" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:collaboration id="Collab_1">
    <bpmn:participant id="Pool_1" name="Оплата рахунків оренда та комунальні (OCR)" processRef="Process_mkg20od" />
  </bpmn:collaboration>
  <bpmn:process id="Process_mkg20od" name="Оплата рахунків оренда та комунальні (OCR)" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="1.0" />
    </bpmn:extensionElements>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Manager" name="Керівник (ескалація)" />
      <bpmn:lane id="Lane_Odoo" name="Система (Odoo авто)">
        <bpmn:flowNodeRef>ST_create_main</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Camunda" name="Система (Camunda)">
        <bpmn:flowNodeRef>ST_ocr_extract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CA_per_invoice</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Buhgalter" name="Бухгалтер">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_odoo_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_add_file</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UT_review_items</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_main</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="Старт">
      <bpmn:outgoing>Flow_start_to_gw_odoo</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_odoo_check" name="Задача в Odoo існує?" default="Flow_odoo_no_task">
      <bpmn:incoming>Flow_start_to_gw_odoo</bpmn:incoming>
      <bpmn:outgoing>Flow_odoo_no_task</bpmn:outgoing>
      <bpmn:outgoing>Flow_1vsxaf1</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_add_file" name="Завантажити файл рахунку">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Завантажити файл рахунку&#34;, description: &#34;Завантажте PDF/JPG/PNG/XLS файл з рахунками для автоматичного розпізнавання&#34;, _model: &#34;project.project&#34;, _id: 236, process_instance_key: process_instance_key}" target="body" />
          <zeebe:output source="=x_studio_camunda_invoice_file" target="x_studio_camunda_invoice_file" />
          <zeebe:output source="=x_studio_camunda_file_extension" target="file_extension" />
        </zeebe:ioMapping>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" type="http-request-smart" retries="3" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0oceo78</bpmn:incoming>
      <bpmn:incoming>Flow_1vsxaf1</bpmn:incoming>
      <bpmn:outgoing>Flow_add_file_to_ocr</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UT_review_items" name="Перевірити розпізнані рахунки">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Перевірити розпізнані рахунки (&#34; + string(total_invoices) + &#34; шт, &#34; + string(total_amount) + &#34; грн)&#34;, description: &#34;OCR розпізнав &#34; + string(total_invoices) + &#34; рахунків на загальну суму &#34; + string(total_amount) + &#34; грн. Перевірте та скоригуйте дані за потреби.&#34;, _model: &#34;project.project&#34;, _id: 236, process_instance_key: process_instance_key}" target="body" />
          <zeebe:output source="=x_studio_camunda_invoice_items" target="invoice_items" />
        </zeebe:ioMapping>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" type="http-request-smart" retries="3" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ocr_to_review</bpmn:incoming>
      <bpmn:outgoing>Flow_review_to_ca</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_main" name="Усі рахунки оброблено">
      <bpmn:incoming>Flow_ca_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_start_to_gw_odoo" sourceRef="StartEvent_1" targetRef="GW_odoo_check" />
    <bpmn:sequenceFlow id="Flow_odoo_no_task" sourceRef="GW_odoo_check" targetRef="ST_create_main" />
    <bpmn:sequenceFlow id="Flow_add_file_to_ocr" sourceRef="UT_add_file" targetRef="ST_ocr_extract" />
    <bpmn:sequenceFlow id="Flow_ocr_to_review" sourceRef="ST_ocr_extract" targetRef="UT_review_items" />
    <bpmn:sequenceFlow id="Flow_review_to_ca" sourceRef="UT_review_items" targetRef="CA_per_invoice" />
    <bpmn:sequenceFlow id="Flow_ca_to_end" sourceRef="CA_per_invoice" targetRef="End_main" />
    <bpmn:serviceTask id="ST_ocr_extract" name="Розпізнати рахунки (OCR)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="invoice-data-extractor" />
        <zeebe:ioMapping>
          <zeebe:input source="=x_studio_camunda_invoice_file" target="x_studio_camunda_invoice_file" />
          <zeebe:input source="=file_extension" target="file_extension" />
          <zeebe:output source="=invoice_items" target="invoice_items" />
          <zeebe:output source="=total_invoices" target="total_invoices" />
          <zeebe:output source="=total_amount" target="total_amount" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_add_file_to_ocr</bpmn:incoming>
      <bpmn:outgoing>Flow_ocr_to_review</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="CA_per_invoice" name="Обробка окремого рахунку">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Process_single_invoice" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="= item.partner_name" target="x_studio_camunda_partner_name" />
          <zeebe:input source="= item.invoice_number" target="x_studio_camunda_invoice_number" />
          <zeebe:input source="= item.invoice_date" target="x_studio_camunda_invoice_date" />
          <zeebe:input source="= item.invoice_line_name" target="x_studio_camunda_invoice_line_name" />
          <zeebe:input source="= item.invoice_amount" target="x_studio_camunda_invoice_amount" />
          <zeebe:input source="= item.invoice_amount_no_vat" target="x_studio_camunda_invoice_amount_no_vat" />
          <zeebe:input source="= item.vat_amount" target="x_studio_camunda_vat_amount" />
          <zeebe:input source="= item.supplier_code" target="x_studio_camunda_supplier_code" />
          <zeebe:input source="= item.contract" target="x_studio_camunda_contract" />
          <zeebe:input source="= item.buyer_name" target="x_studio_camunda_buyer_name" />
          <zeebe:input source="= item.quantity" target="x_studio_camunda_quantity" />
          <zeebe:input source="= item.unit" target="x_studio_camunda_unit" />
          <zeebe:input source="= item.invoice_type" target="x_studio_camunda_invoice_type" />
          <zeebe:input source="= x_studio_camunda_invoice_file" target="x_studio_camunda_invoice_file" />
          <zeebe:input source="= process_instance_key" target="parent_process_instance_key" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_review_to_ca</bpmn:incoming>
      <bpmn:outgoing>Flow_ca_to_end</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics>
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="= invoice_items" inputElement="item" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:callActivity>
    <bpmn:sequenceFlow id="Flow_0oceo78" sourceRef="ST_create_main" targetRef="UT_add_file" />
    <bpmn:sequenceFlow id="Flow_1vsxaf1" sourceRef="GW_odoo_check" targetRef="UT_add_file">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=is defined(odoo_task_id) and odoo_task_id != nul</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="ST_create_main" name="Створити головне завдання">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="=&#34;http://odoo.dev.dobrom.com/web/hook/21c8dbff-86e8-4005-9bfc-9f77ee9b5c57&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Оплата рахунків оренда та комунальні (OCR)&#34;, create_process: true, _model: &#34;project.project&#34;, _id: 236, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_odoo_no_task</bpmn:incoming>
      <bpmn:outgoing>Flow_0oceo78</bpmn:outgoing>
    </bpmn:serviceTask>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collab_1">
      <bpmndi:BPMNShape id="Pool_1_di" bpmnElement="Pool_1" isHorizontal="true">
        <dc:Bounds x="105" y="90" width="1400" height="605" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Buhgalter_di" bpmnElement="Lane_Buhgalter" isHorizontal="true">
        <dc:Bounds x="135" y="90" width="1370" height="170" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Camunda_di" bpmnElement="Lane_Camunda" isHorizontal="true">
        <dc:Bounds x="135" y="260" width="1370" height="150" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Odoo_di" bpmnElement="Lane_Odoo" isHorizontal="true">
        <dc:Bounds x="135" y="410" width="1370" height="155" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Manager_di" bpmnElement="Lane_Manager" isHorizontal="true">
        <dc:Bounds x="135" y="565" width="1370" height="130" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="187" y="147" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="191" y="190" width="31" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_odoo_check_di" bpmnElement="GW_odoo_check" isMarkerVisible="true">
        <dc:Bounds x="260" y="140" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="248" y="105" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UT_add_file_di" bpmnElement="UT_add_file">
        <dc:Bounds x="535" y="125" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UT_review_items_di" bpmnElement="UT_review_items">
        <dc:Bounds x="855" y="125" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_main_di" bpmnElement="End_main">
        <dc:Bounds x="1337" y="147" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1326" y="109.5" width="57" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST_ocr_extract_di" bpmnElement="ST_ocr_extract">
        <dc:Bounds x="695" y="300" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CA_per_invoice_di" bpmnElement="CA_per_invoice">
        <dc:Bounds x="1095" y="300" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST_create_main_di" bpmnElement="ST_create_main">
        <dc:Bounds x="340" y="440" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_to_gw_odoo_di" bpmnElement="Flow_start_to_gw_odoo">
        <di:waypoint x="223" y="165" />
        <di:waypoint x="260" y="165" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_odoo_no_task_di" bpmnElement="Flow_odoo_no_task">
        <di:waypoint x="285" y="190" />
        <di:waypoint x="285" y="480" />
        <di:waypoint x="340" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_add_file_to_ocr_di" bpmnElement="Flow_add_file_to_ocr">
        <di:waypoint x="635" y="165" />
        <di:waypoint x="665" y="165" />
        <di:waypoint x="665" y="340" />
        <di:waypoint x="695" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ocr_to_review_di" bpmnElement="Flow_ocr_to_review">
        <di:waypoint x="795" y="340" />
        <di:waypoint x="825" y="340" />
        <di:waypoint x="825" y="165" />
        <di:waypoint x="855" y="165" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_review_to_ca_di" bpmnElement="Flow_review_to_ca">
        <di:waypoint x="955" y="165" />
        <di:waypoint x="1025" y="165" />
        <di:waypoint x="1025" y="340" />
        <di:waypoint x="1095" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ca_to_end_di" bpmnElement="Flow_ca_to_end">
        <di:waypoint x="1215" y="340" />
        <di:waypoint x="1355" y="340" />
        <di:waypoint x="1355" y="183" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0oceo78_di" bpmnElement="Flow_0oceo78">
        <di:waypoint x="440" y="480" />
        <di:waypoint x="465" y="480" />
        <di:waypoint x="465" y="165" />
        <di:waypoint x="535" y="165" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1vsxaf1_di" bpmnElement="Flow_1vsxaf1">
        <di:waypoint x="310" y="165" />
        <di:waypoint x="535" y="165" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
