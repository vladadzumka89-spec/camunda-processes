<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_ftp" targetNamespace="http://tut.ua/bpmn/feature-pipeline" exporter="Claude Code" exporterVersion="3.0">
  <bpmn:message id="Message_pr_event" name="msg_pr_event">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=head_branch" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_review_done" name="msg_review_done">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_pr_updated" name="msg_pr_updated">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_deploy_done" name="msg_deploy_done">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=merge_sha" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_pr_merged" name="msg_pr_merged">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_pr_ready" name="msg_pr_ready">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_prod_deployed" name="msg_prod_deployed">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=string(pr_number)" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:process id="feature-to-production" name="Feature to Production" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="11.0" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="start_manual" name="Розробку розпочато (/start)">
      <bpmn:documentation>Розробник запускає /start — передає task_description, head_branch.</bpmn:documentation>
      <bpmn:outgoing>f_start_to_catch_pr</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:startEvent id="start_pr_event" name="PR створено в main">
      <bpmn:documentation>Автоматичний старт від webhook — PR created в main. Змінні: pr_number, pr_url, head_branch, repository, pr_title.</bpmn:documentation>
      <bpmn:outgoing>f_auto_to_merge_entry</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_start_pr" messageRef="Message_pr_event" />
    </bpmn:startEvent>
    <bpmn:intermediateCatchEvent id="catch_pr_created" name="Чекаємо PR в main">
      <bpmn:documentation>Чекає msg_pr_event з correlation key = head_branch. Тільки для /start flow.</bpmn:documentation>
      <bpmn:incoming>f_start_to_catch_pr</bpmn:incoming>
      <bpmn:outgoing>f_pr_to_merge_entry</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_pr_event" messageRef="Message_pr_event" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="Merge_entry">
      <bpmn:incoming>f_pr_to_merge_entry</bpmn:incoming>
      <bpmn:incoming>f_auto_to_merge_entry</bpmn:incoming>
      <bpmn:outgoing>f_merge_entry_to_odoo_check</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_odoo_check" name="Задача в Odoo існує?" default="f_odoo_create">
      <bpmn:incoming>f_merge_entry_to_odoo_check</bpmn:incoming>
      <bpmn:outgoing>f_odoo_create</bpmn:outgoing>
      <bpmn:outgoing>f_odoo_skip</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ST_create_odoo" name="Створити задачу в Odoo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-cicd" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=odoo_webhook_url" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={_model: &#34;project.project&#34;, name: if is defined(task_name) and task_name != null and task_name != &#34;&#34; then task_name else if is defined(pr_title) and pr_title != null and pr_title != &#34;&#34; then pr_title else &#34;[feature] Нова задача&#34;, description: if is defined(task_description) and task_description != null then task_description else &#34;&#34;, _id: odoo_project_id, create_process: true}" target="body" />
          <zeebe:input source="=&#34;odoo_response&#34;" target="result_variable_name" />
          <zeebe:input source="=true" target="ignore_errors" />
          <zeebe:output source="=if is defined(odoo_response) and odoo_response != null and is defined(odoo_response.id) then string(odoo_response.id) else string(process_instance_key)" target="odoo_task_id" />
          <zeebe:output source="=process_instance_key" target="process_instance_key" />
          <zeebe:output source="=if is defined(pr_number) and pr_number != null then pr_number else null" target="pr_number" />
          <zeebe:output source="=if is defined(pr_url) and pr_url != null then pr_url else &#34;&#34;" target="pr_url" />
          <zeebe:output source="=if is defined(pr_title) and pr_title != null then pr_title else &#34;&#34;" target="pr_title" />
          <zeebe:output source="=if is defined(head_branch) and head_branch != null then head_branch else &#34;&#34;" target="head_branch" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_odoo_create</bpmn:incoming>
      <bpmn:outgoing>f_odoo_to_merge</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Merge_odoo">
      <bpmn:incoming>f_odoo_to_merge</bpmn:incoming>
      <bpmn:incoming>f_odoo_skip</bpmn:incoming>
      <bpmn:outgoing>f_odoo_to_review</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:intermediateCatchEvent id="catch_review_done" name="Чекаємо результат ревʼю">
      <bpmn:documentation>Чекає msg_review_done від standalone pr-review процесу (correlation: pr_number).</bpmn:documentation>
      <bpmn:incoming>f_odoo_to_review</bpmn:incoming>
      <bpmn:incoming>f_rework_to_review</bpmn:incoming>
      <bpmn:incoming>f_staging_rework_to_review</bpmn:incoming>
      <bpmn:incoming>f_deploy_failed_to_rework</bpmn:incoming>
      <bpmn:outgoing>f_review_to_score</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_review_done" messageRef="Message_review_done" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="GW_score" name="Оцінка &#62;= 7?" default="f_score_ok">
      <bpmn:incoming>f_review_to_score</bpmn:incoming>
      <bpmn:outgoing>f_score_ok</bpmn:outgoing>
      <bpmn:outgoing>f_score_low</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ST_comment_rework" name="Коментар: потрібне виправлення">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;🔄 Оцінка ревʼю: &#34; + string(review_score) + &#34;/10. Потрібне виправлення. Пушніть зміни в гілку `&#34; + head_branch + &#34;` для повторного ревʼю.&#34;" target="comment_text" />
          <zeebe:input source="=true" target="ignore_errors" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_score_low</bpmn:incoming>
      <bpmn:outgoing>f_comment_to_wait</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:receiveTask id="catch_pr_updated" name="Чекаємо оновлення PR" messageRef="Message_pr_updated">
      <bpmn:documentation>Чекає push нових комітів в PR (msg_pr_updated, correlation: pr_number).</bpmn:documentation>
      <bpmn:incoming>f_comment_to_wait</bpmn:incoming>
      <bpmn:outgoing>f_rework_to_review</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:boundaryEvent id="BE_rem_rework" name="Нагадування (3 дні)" cancelActivity="false" attachedToRef="catch_pr_updated">
      <bpmn:outgoing>f_rem_to_notify</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_rem_rework">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P3D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="ST_rem_rework" name="Нагадування: PR потребує виправлення">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-cicd" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=odoo_webhook_url" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={_model: &#34;project.project&#34;, name: &#34;⚠️ НАГАДУВАННЯ: PR #&#34; + string(pr_number) + &#34; потребує виправлення&#34;, description: &#34;PR: &#34; + pr_url + &#34;\nГілка: &#34; + head_branch, _id: odoo_project_id, process_instance_key: process_instance_key}" target="body" />
          <zeebe:input source="=true" target="ignore_errors" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_rem_to_notify</bpmn:incoming>
      <bpmn:outgoing>f_rem_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_rem_rework" name="Нагадування надіслано">
      <bpmn:incoming>f_rem_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="ST_merge_to_staging" name="Замерджити в staging">
      <bpmn:documentation>Merge feature branch в staging (git merge -X theirs). Повертає merge_sha.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="merge-feature-to-staging" retries="5" />
        <zeebe:ioMapping>
          <zeebe:input source="=head_branch" target="feature_branch" />
          <zeebe:input source="=&#34;staging&#34;" target="server_host" />
          <zeebe:output source="=merge_sha" target="merge_sha" />
          <zeebe:output source="=false" target="deploy_failed" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_score_ok</bpmn:incoming>
      <bpmn:outgoing>f_merge_to_deploy</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="catch_staging_deployed" name="Чекаємо деплой staging">
      <bpmn:documentation>Чекає msg_deploy_done від deploy-process (correlation: merge_sha = trigger_sha).</bpmn:documentation>
      <bpmn:incoming>f_merge_to_deploy</bpmn:incoming>
      <bpmn:outgoing>f_deploy_to_check</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_deploy_done" messageRef="Message_deploy_done" />
    </bpmn:intermediateCatchEvent>

    <!-- ── Deploy OK check ───────────────────────────── -->
    <bpmn:exclusiveGateway id="GW_deploy_ok" name="Deploy OK?" default="f_deploy_ok">
      <bpmn:incoming>f_deploy_to_check</bpmn:incoming>
      <bpmn:outgoing>f_deploy_ok</bpmn:outgoing>
      <bpmn:outgoing>f_deploy_failed</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="ST_comment_deploy_failed" name="Коментар: deploy failed">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="github-comment" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;❌ Staging deploy failed. Потрібне виправлення. Пушніть зміни в `&#34; + head_branch + &#34;`.&#34;" target="comment_text" />
          <zeebe:input source="=true" target="ignore_errors" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_deploy_failed</bpmn:incoming>
      <bpmn:outgoing>f_deploy_failed_to_rework</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:eventBasedGateway id="GW_event_staging" name="Undraft чи push?">
      <bpmn:documentation>Чекає на одну з двох подій: PR знято з draft (staging ок) або push нових комітів (rework).</bpmn:documentation>
      <bpmn:incoming>f_deploy_ok</bpmn:incoming>
      <bpmn:outgoing>f_event_to_ready</bpmn:outgoing>
      <bpmn:outgoing>f_event_to_staging_rework</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="catch_pr_ready" name="PR знято з draft">
      <bpmn:documentation>Розробник перевірив staging і зняв draft з PR — staging ок.</bpmn:documentation>
      <bpmn:incoming>f_event_to_ready</bpmn:incoming>
      <bpmn:outgoing>f_ready_to_merge_task</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_pr_ready" messageRef="Message_pr_ready" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="catch_staging_rework" name="Push: rework staging">
      <bpmn:documentation>Розробник пушить фікс — staging не ок, потрібен rework.</bpmn:documentation>
      <bpmn:incoming>f_event_to_staging_rework</bpmn:incoming>
      <bpmn:outgoing>f_staging_rework_to_review</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_staging_rework" messageRef="Message_pr_updated" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="ST_create_merge_task" name="Задача: review та merge PR">
      <bpmn:documentation>Створює задачу в Odoo для тімліда — зробити review та merge PR в main.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-cicd" retries="2" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;POST&#34;" target="method" />
          <zeebe:input source="=odoo_webhook_url" target="url" />
          <zeebe:input source="={&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={_model: &#34;project.project&#34;, name: &#34;Review та merge PR #&#34; + string(pr_number) + &#34; в main&#34;, description: &#34;PR: &#34; + pr_url + &#34;\nГілка: &#34; + head_branch + &#34;\nStaging перевірено ✅&#34;, _id: odoo_project_id, process_instance_key: process_instance_key}" target="body" />
          <zeebe:input source="=true" target="ignore_errors" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>f_ready_to_merge_task</bpmn:incoming>
      <bpmn:outgoing>f_merge_task_to_catch</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="catch_pr_merged" name="Чекаємо merge PR в main">
      <bpmn:documentation>Чекає msg_pr_merged від GitHub webhook (correlation: pr_number).</bpmn:documentation>
      <bpmn:incoming>f_merge_task_to_catch</bpmn:incoming>
      <bpmn:outgoing>f_merged_to_prod</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_pr_merged" messageRef="Message_pr_merged" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="catch_prod_deployed" name="Чекаємо деплой production">
      <bpmn:documentation>Чекає msg_prod_deployed від production-nightly-deploy (correlation: pr_number). Деплой відбувається щодня о 22:00.</bpmn:documentation>
      <bpmn:incoming>f_merged_to_prod</bpmn:incoming>
      <bpmn:outgoing>f_prod_to_end</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_prod_deployed" messageRef="Message_prod_deployed" />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="evt_end_success" name="Фіча на production">
      <bpmn:incoming>f_prod_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f_start_to_catch_pr" sourceRef="start_manual" targetRef="catch_pr_created" />
    <bpmn:sequenceFlow id="f_pr_to_merge_entry" sourceRef="catch_pr_created" targetRef="Merge_entry" />
    <bpmn:sequenceFlow id="f_auto_to_merge_entry" sourceRef="start_pr_event" targetRef="Merge_entry" />
    <bpmn:sequenceFlow id="f_merge_entry_to_odoo_check" sourceRef="Merge_entry" targetRef="GW_odoo_check" />
    <bpmn:sequenceFlow id="f_odoo_create" sourceRef="GW_odoo_check" targetRef="ST_create_odoo" />
    <bpmn:sequenceFlow id="f_odoo_skip" sourceRef="GW_odoo_check" targetRef="Merge_odoo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=is defined(odoo_task_id) and odoo_task_id != null</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_odoo_to_merge" sourceRef="ST_create_odoo" targetRef="Merge_odoo" />
    <bpmn:sequenceFlow id="f_odoo_to_review" sourceRef="Merge_odoo" targetRef="catch_review_done" />
    <bpmn:sequenceFlow id="f_review_to_score" sourceRef="catch_review_done" targetRef="GW_score" />
    <bpmn:sequenceFlow id="f_score_ok" sourceRef="GW_score" targetRef="ST_merge_to_staging" />
    <bpmn:sequenceFlow id="f_score_low" sourceRef="GW_score" targetRef="ST_comment_rework">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=review_score &lt; 7 or (is defined(has_critical_issues) and has_critical_issues = true)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_comment_to_wait" sourceRef="ST_comment_rework" targetRef="catch_pr_updated" />
    <bpmn:sequenceFlow id="f_rework_to_review" sourceRef="catch_pr_updated" targetRef="catch_review_done" />
    <bpmn:sequenceFlow id="f_rem_to_notify" sourceRef="BE_rem_rework" targetRef="ST_rem_rework" />
    <bpmn:sequenceFlow id="f_rem_to_end" sourceRef="ST_rem_rework" targetRef="End_rem_rework" />
    <bpmn:sequenceFlow id="f_merge_to_deploy" sourceRef="ST_merge_to_staging" targetRef="catch_staging_deployed" />
    <bpmn:sequenceFlow id="f_deploy_to_check" sourceRef="catch_staging_deployed" targetRef="GW_deploy_ok" />
    <bpmn:sequenceFlow id="f_deploy_ok" sourceRef="GW_deploy_ok" targetRef="GW_event_staging" />
    <bpmn:sequenceFlow id="f_deploy_failed" sourceRef="GW_deploy_ok" targetRef="ST_comment_deploy_failed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=is defined(deploy_failed) and deploy_failed = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_deploy_failed_to_rework" sourceRef="ST_comment_deploy_failed" targetRef="catch_review_done" />
    <bpmn:sequenceFlow id="f_event_to_ready" sourceRef="GW_event_staging" targetRef="catch_pr_ready" />
    <bpmn:sequenceFlow id="f_event_to_staging_rework" sourceRef="GW_event_staging" targetRef="catch_staging_rework" />
    <bpmn:sequenceFlow id="f_ready_to_merge_task" sourceRef="catch_pr_ready" targetRef="ST_create_merge_task" />
    <bpmn:sequenceFlow id="f_staging_rework_to_review" sourceRef="catch_staging_rework" targetRef="catch_review_done" />
    <bpmn:sequenceFlow id="f_merge_task_to_catch" sourceRef="ST_create_merge_task" targetRef="catch_pr_merged" />
    <bpmn:sequenceFlow id="f_merged_to_prod" sourceRef="catch_pr_merged" targetRef="catch_prod_deployed" />
    <bpmn:sequenceFlow id="f_prod_to_end" sourceRef="catch_prod_deployed" targetRef="evt_end_success" />
    <bpmn:textAnnotation id="note_pr_review">
      <bpmn:text>← pr-review</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="assoc_pr_review" sourceRef="catch_review_done" targetRef="note_pr_review" />
    <bpmn:textAnnotation id="note_deploy_process">
      <bpmn:text>← deploy-process (staging)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="assoc_deploy_process" sourceRef="catch_staging_deployed" targetRef="note_deploy_process" />
    <bpmn:textAnnotation id="note_nightly_deploy">
      <bpmn:text>← production-nightly-deploy, deploy-process</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="assoc_nightly_deploy" sourceRef="catch_prod_deployed" targetRef="note_nightly_deploy" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_ftp">
    <bpmndi:BPMNPlane id="BPMNPlane_ftp" bpmnElement="feature-to-production">
      <bpmndi:BPMNShape id="di_start_pr_event" bpmnElement="start_pr_event">
        <dc:Bounds x="160" y="252" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Merge_entry" bpmnElement="Merge_entry" isMarkerVisible="true">
        <dc:Bounds x="365" y="175" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_GW_odoo_check" bpmnElement="GW_odoo_check" isMarkerVisible="true">
        <dc:Bounds x="475" y="175" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_ST_create_odoo" bpmnElement="ST_create_odoo">
        <dc:Bounds x="575" y="60" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Merge_odoo" bpmnElement="Merge_odoo" isMarkerVisible="true">
        <dc:Bounds x="735" y="175" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_catch_review_done" bpmnElement="catch_review_done">
