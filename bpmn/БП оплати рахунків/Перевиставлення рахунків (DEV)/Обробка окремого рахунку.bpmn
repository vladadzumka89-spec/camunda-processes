    <bpmn:userTask id="UT_reissue" name="Завести рахунок в БДУ, Визначити ФОП та перевиставити рахунок на нього">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://odoo.dev.dobrom.com/web/hook/90fdde6b-47f9-44ba-90b2-19559b206bce&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {name: &#34;Перевиставити: &#34; + &#34;Рахунок від &#34; + (if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;—&#34;) + &#34; на №&#34; + x_studio_camunda_invoice_number + &#34; — &#34; + string(x_studio_camunda_invoice_amount) + &#34; грн&#34;, description: &#34;1. Заведіть рахунок в БДУ&lt;br/&gt;2. Визначте ФОП за організацією&lt;br/&gt;3. Перевиставте рахунок на цього ФОП&lt;br/&gt;4. Прикріпіть скрін перевиставленого рахунку до задачі&#34;, _model: &#34;project.project&#34;, _id: 288, process_instance_key: process_instance_key, parent_process_instance_key: parent_process_instance_key, x_studio_camunda_invoice_number: x_studio_camunda_invoice_number, x_studio_camunda_invoice_line_name: if x_studio_camunda_invoice_line_name != null then x_studio_camunda_invoice_line_name else &#34;&#34;, x_studio_camunda_invoice_amount: x_studio_camunda_invoice_amount, x_studio_camunda_invoice_amount_no_vat: if x_studio_camunda_invoice_amount_no_vat != null then x_studio_camunda_invoice_amount_no_vat else 0, x_studio_camunda_vat_amount: if x_studio_camunda_vat_amount != null then x_studio_camunda_vat_amount else 0, x_studio_camunda_supplier_code: if x_studio_camunda_supplier_code != null then x_studio_camunda_supplier_code else &#34;&#34;, x_studio_camunda_contract: if x_studio_camunda_contract != null then x_studio_camunda_contract else &#34;&#34;, x_studio_camunda_buyer_name: if x_studio_camunda_buyer_name != null then x_studio_camunda_buyer_name else &#34;&#34;, x_studio_camunda_partner_name: if x_studio_camunda_partner_name != null then x_studio_camunda_partner_name else &#34;&#34;, x_studio_camunda_quantity: if x_studio_camunda_quantity != null then x_studio_camunda_quantity else &#34;&#34;, x_studio_camunda_unit: if x_studio_camunda_unit != null then x_studio_camunda_unit else &#34;&#34;, x_studio_camunda_invoice_type: if x_studio_camunda_invoice_type != null then x_studio_camunda_invoice_type else &#34;&#34;}" target="body" />
          <zeebe:output source="= odoo_task_id" target="odoo_task_id" />
        </zeebe:ioMapping>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" type="http-request-smart" retries="3" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1wwa9rs</bpmn:incoming>
      <bpmn:outgoing>Flow_reissue_to_dmn</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:businessRuleTask id="BRT_detail_type" name="Визначити тип рахунку [DMN]">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="invoice-detail-type" resultVariable="invoice_detail_type" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_reissue_to_dmn</bpmn:incoming>
      <bpmn:outgoing>Flow_dmn_to_write</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:serviceTask id="ST_write_type" name="Записати тип рахунку в Odoo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="http-request-smart" />
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://odoo.dev.dobrom.com/web/hook/b1c3b316-0624-438d-a82e-461500b26d12&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="= {process_instance_key: process_instance_key, x_studio_camunda_invoice_type: invoice_detail_type.x_studio_camunda_invoice_type}" target="body" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_dmn_to_write</bpmn:incoming>
      <bpmn:outgoing>Flow_write_to_gw_rent</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_rent" name="Рахунок по оренді?" default="Flow_rent_no">
      <bpmn:incoming>Flow_write_to_gw_rent</bpmn:incoming>
      <bpmn:outgoing>Flow_rent_yes</bpmn:outgoing>
