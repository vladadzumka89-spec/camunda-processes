    <bpmn:intermediateCatchEvent id="Timer_month_end" name="Останній день вказаного місяця в рахунку">
      <bpmn:incoming>Flow_rent_yes</bpmn:incoming>
      <bpmn:outgoing>Flow_timer_to_buh</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1">
        <bpmn:timeDate xsi:type="bpmn:tFormalExpression">=if x_studio_camunda_service_period != null and matches(x_studio_camunda_service_period, "^\d{2}\.\d{4}$") then date and time(date(number(substring(x_studio_camunda_service_period, 4, 4)), number(substring(x_studio_camunda_service_period, 1, 2)), 1) + duration("P1M") - duration("P1D"), time("18:00:00")) else date and time(if today().month = 12 then date(today().year + 1, 1, 1) - duration("P1D") else date(today().year, today().month + 1, 1) - duration("P1D"), time("18:00:00"))</bpmn:timeDate>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="ST_write_type" name="Записати тип рахунку в Odoo">
