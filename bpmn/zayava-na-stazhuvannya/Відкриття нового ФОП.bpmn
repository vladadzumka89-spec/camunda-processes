    <!-- ============ SEQUENCE FLOWS ============ -->

    <bpmn:sequenceFlow id="Flow_start_to_gw" sourceRef="StartEvent_1" targetRef="GW_odoo_check" />
    <bpmn:sequenceFlow id="Flow_odoo_default" sourceRef="GW_odoo_check" targetRef="ST_create_main" />
    <bpmn:sequenceFlow id="Flow_odoo_skip" sourceRef="GW_odoo_check" targetRef="GW_odoo_merge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= is defined(odoo_task_id) and odoo_task_id != null</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_create_to_merge" sourceRef="ST_create_main" targetRef="GW_odoo_merge" />
    <bpmn:sequenceFlow id="Flow_merge_to_want" sourceRef="GW_odoo_merge" targetRef="UT_want_fop" />
    <bpmn:sequenceFlow id="Flow_want_to_telegram" sourceRef="UT_want_fop" targetRef="UT_read_telegram" />
    <bpmn:sequenceFlow id="Flow_telegram_to_docs_merge" sourceRef="UT_read_telegram" targetRef="Merge_docs" />
    <bpmn:sequenceFlow id="Flow_docs_merge_to_check" sourceRef="Merge_docs" targetRef="GW_docs_check" />
    <bpmn:sequenceFlow id="Flow_docs_yes" name="Так" sourceRef="GW_docs_check" targetRef="UT_read_wiki" />
    <bpmn:sequenceFlow id="Flow_docs_no" name="Ні" sourceRef="GW_docs_check" targetRef="UT_add_docs">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_docs_complete = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_add_docs_to_merge" sourceRef="UT_add_docs" targetRef="Merge_docs" />
    <bpmn:sequenceFlow id="Flow_wiki_to_key" sourceRef="UT_read_wiki" targetRef="UT_gen_file_key" />
    <bpmn:sequenceFlow id="Flow_key_to_password" sourceRef="UT_gen_file_key" targetRef="UT_save_password" />
    <bpmn:sequenceFlow id="Flow_password_to_dps" sourceRef="UT_save_password" targetRef="UT_check_dps" />
    <bpmn:sequenceFlow id="Flow_dps_to_debt_merge" sourceRef="UT_check_dps" targetRef="Merge_debt" />
    <bpmn:sequenceFlow id="Flow_debt_merge_to_check" sourceRef="Merge_debt" targetRef="GW_debt_check" />
    <bpmn:sequenceFlow id="Flow_debt_no" name="Ні" sourceRef="GW_debt_check" targetRef="UT_register_diia" />
    <bpmn:sequenceFlow id="Flow_debt_yes" name="Так" sourceRef="GW_debt_check" targetRef="UT_pay_debt">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= x_studio_camunda_has_debt = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_pay_to_merge" sourceRef="UT_pay_debt" targetRef="Merge_debt" />
    <bpmn:sequenceFlow id="Flow_diia_to_extract" sourceRef="UT_register_diia" targetRef="UT_get_extract" />
    <bpmn:sequenceFlow id="Flow_extract_to_account" sourceRef="UT_get_extract" targetRef="UT_open_account" />
    <bpmn:sequenceFlow id="Flow_account_to_trusted" sourceRef="UT_open_account" targetRef="UT_trusted_privat" />
    <bpmn:sequenceFlow id="Flow_trusted_to_cert" sourceRef="UT_trusted_privat" targetRef="UT_upload_cert" />
    <bpmn:sequenceFlow id="Flow_cert_to_taxdate" sourceRef="UT_upload_cert" targetRef="UT_check_tax_date" />
    <bpmn:sequenceFlow id="Flow_taxdate_to_extract" sourceRef="UT_check_tax_date" targetRef="UT_get_tax_extract" />
    <bpmn:sequenceFlow id="Flow_extract_to_cards" sourceRef="UT_get_tax_extract" targetRef="UT_make_cards" />
    <bpmn:sequenceFlow id="Flow_cards_to_keycard" sourceRef="UT_make_cards" targetRef="UT_get_key_card" />
    <bpmn:sequenceFlow id="Flow_keycard_to_org" sourceRef="UT_get_key_card" targetRef="UT_create_org_erp" />
    <bpmn:sequenceFlow id="Flow_org_to_fill" sourceRef="UT_create_org_erp" targetRef="UT_fill_org" />
    <bpmn:sequenceFlow id="Flow_fill_to_license" sourceRef="UT_fill_org" targetRef="UT_create_license" />
    <bpmn:sequenceFlow id="Flow_license_to_sick" sourceRef="UT_create_license" targetRef="UT_setup_sick" />
    <bpmn:sequenceFlow id="Flow_sick_to_salary" sourceRef="UT_setup_sick" targetRef="UT_salary" />
    <bpmn:sequenceFlow id="Flow_salary_to_counterparty" sourceRef="UT_salary" targetRef="UT_create_counterparty" />
    <bpmn:sequenceFlow id="Flow_counterparty_to_signatories" sourceRef="UT_create_counterparty" targetRef="UT_fill_signatories" />
    <bpmn:sequenceFlow id="Flow_signatories_to_wait1" sourceRef="UT_fill_signatories" targetRef="UT_wait1" />
    <bpmn:sequenceFlow id="Flow_wait1_to_folder" sourceRef="UT_wait1" targetRef="UT_create_folder" />
    <bpmn:sequenceFlow id="Flow_folder_to_wait2" sourceRef="UT_create_folder" targetRef="UT_wait2" />
    <bpmn:sequenceFlow id="Flow_wait2_to_key" sourceRef="UT_wait2" targetRef="UT_add_key_do3" />
    <bpmn:sequenceFlow id="Flow_key_to_trusted_final" sourceRef="UT_add_key_do3" targetRef="UT_add_trusted_final" />
    <bpmn:sequenceFlow id="Flow_trusted_to_end" sourceRef="UT_add_trusted_final" targetRef="End_final" />

  </bpmn:process>

  <!-- ============ DIAGRAM ============ -->

