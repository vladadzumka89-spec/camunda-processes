<?xml version="1.0" encoding="UTF-8"?>
<definitions
  xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
  xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
  xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
  xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
  id="Definitions_invoice_drg"
  name="Деталізація та класифікація рахунків"
  namespace="http://camunda.org/schema/1.0/dmn"
  exporter="Camunda Web Modeler"
  exporterVersion="e787c33"
  modeler:executionPlatform="Camunda Cloud"
  modeler:executionPlatformVersion="8.8.0">

  <!--
    DRG — Decision Requirement Graph
    =================================

    Два рішення пов'язані залежністю:

      ┌─────────────────────────────────────────────┐
      │  Класифікація комунальних послуг             │
      │  (utility-expense-classification)            │
      │  Вхід: назва послуги + тип рахунку           │
      │  Вихід: стаття витрат                        │
      └──────────────────┬──────────────────────────┘
                         │ informationRequirement
                         ▼
      ┌─────────────────────────────────────────────┐
      │  Деталізація рахунків                        │
      │  (invoice-detail-type)                       │
      │  Вхід: назва позиції + постачальник           │
      │  Вихід: тип рахунку (оренда / комунальні)    │
      └─────────────────────────────────────────────┘

    Як працює в BPMN:
      1. Бухгалтер розбиває PDF-рахунок на позиції
      2. Для кожної позиції: BPMN викликає invoice-detail-type
         → визначає оренда / комунальні
      3. Якщо комунальні: BPMN отримує розшифровку послуг
         → викликає utility-expense-classification для кожної послуги
         → Camunda автоматично оцінює invoice-detail-type спочатку (DRG)
         → потім класифікує послугу за статтею витрат

    Вхідні змінні (процес має надати всі):
      - x_studio_camunda_invoice_line_name — назва позиції з рахунку
      - x_studio_camunda_partner_name      — назва постачальника
      - x_studio_camunda_service_name      — назва послуги з розшифровки

    Вихідні змінні:
      - x_studio_camunda_invoice_type      — "оренда" або "комунальні"
      - x_studio_camunda_invoice_notes     — підказка для бухгалтера
      - x_studio_camunda_expense_category  — стаття витрат в 1С

    Стратегія класифікації (FIRST hit policy — перший збіг виграє):
      TIER 1: Правила для конкретних постачальників-виключень
              (НЕТ-ІНВЕСТ = все оренда, Дайнеко = все комунальні, і т.д.)
      TIER 2: Правила для оренди з "комунальними" словами
              (відшкодування/компенсація експлуатаційних = оренда)
      TIER 3: Ключові слова комунальних послуг
              (електроенергія, водопостачання, опалення, генератор тощо)
      TIER 4: Ключові слова оренди
              (оренд, суборенд, маркетинг, експлуатаційний тощо)
      TIER 5: Default = оренда (невідома позиція)

    Джерело даних: Excel "Деталізація рахунків (5).xlsx"
      451 запис, 172 оренда, 279 комунальні, 8 назв у обох категоріях
  -->

  <!-- ═══════════════════════════════════════════════════════════════════════
       РІШЕННЯ 1: Деталізація рахунків (оренда / комунальні)
       451 запис з Excel → 127 правил DMN
       ═══════════════════════════════════════════════════════════════════════ -->

  <decision id="invoice-detail-type" name="Деталізація рахунків">
    <decisionTable id="decisionTable_invoice_detail" hitPolicy="FIRST">

      <!-- ── INPUTS ──────────────────────────────────────────────────────── -->

      <input id="input_line_name" label="Назва позиції рахунку">
        <inputExpression id="inputExpr_line_name" typeRef="string">
          <text>lower case(x_studio_camunda_invoice_line_name)</text>
        </inputExpression>
      </input>

      <input id="input_partner" label="Постачальник">
        <inputExpression id="inputExpr_partner" typeRef="string">
          <text>x_studio_camunda_partner_name</text>
        </inputExpression>
      </input>

      <input id="input_buyer" label="Контрагент (покупець)">
        <inputExpression id="inputExpr_buyer" typeRef="string">
          <text>x_studio_camunda_buyer_name</text>
        </inputExpression>
      </input>

      <!-- ── OUTPUTS ─────────────────────────────────────────────────────── -->

      <output id="output_invoice_type"
              label="Вид рахунку"
              name="x_studio_camunda_invoice_type"
              typeRef="string">
        <outputValues id="outputValues_type">
          <text>"оренда","комунальні"</text>
        </outputValues>
      </output>

      <output id="output_notes"
              label="Примітки"
              name="x_studio_camunda_invoice_notes"
              typeRef="string" />


      <!-- ═══════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: НЕТ-ІНВЕСТ, ТОВ (підрозділ 400)
           ВСІ позиції = оренда, навіть з комунальними назвами
           (водопостачання, електроенергія, вивіз сміття)
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_netinvest_all">
        <description>НЕТ-ІНВЕСТ: всі позиції = оренда (включно з комунальними назвами)</description>
        <inputEntry id="ie_001_line"><text></text></inputEntry>
        <inputEntry id="ie_001_partner"><text>contains(?, "НЕТ-ІНВЕСТ")</text></inputEntry>
        <inputEntry id="ie_001_buyer"><text></text></inputEntry>
        <outputEntry id="oe_001_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_001_notes"><text>"НЕТ-ІНВЕСТ: оренда за поточний місяць, комунальні за попередній"</text></outputEntry>
      </rule>

      <!-- ═══════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: Деркач Людмила Іванівна ФОП
           Тип визначається за пунктом договору:
             п.5.1.1 = оренда, п.5.1.2/п.5.1.3 = комунальні
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_derkach_p513">
        <description>Деркач: п.5.1.3 договору — комунальні</description>
        <inputEntry id="ie_002_line"><text>contains(?, "п.5.1.3")</text></inputEntry>
        <inputEntry id="ie_002_partner"><text>contains(?, "Деркач")</text></inputEntry>
        <inputEntry id="ie_002_buyer"><text></text></inputEntry>
        <outputEntry id="oe_002_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_002_notes"><text>""</text></outputEntry>
      </rule>
      <rule id="rule_derkach_p512">
        <description>Деркач: п.5.1.2 договору — комунальні</description>
        <inputEntry id="ie_003_line"><text>contains(?, "п.5.1.2")</text></inputEntry>
        <inputEntry id="ie_003_partner"><text>contains(?, "Деркач")</text></inputEntry>
        <inputEntry id="ie_003_buyer"><text></text></inputEntry>
        <outputEntry id="oe_003_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_003_notes"><text>""</text></outputEntry>
      </rule>

      <!-- ═══════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: ФОП Дайнеко Людмила Анатоліївна
           ВСІ позиції = комунальні (деталізація в додатку)
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_daineko_all">
        <description>Дайнеко: всі позиції = комунальні (деталізація в додатку)</description>
        <inputEntry id="ie_004_line"><text></text></inputEntry>
        <inputEntry id="ie_004_partner"><text>contains(?, "Дайнеко")</text></inputEntry>
        <inputEntry id="ie_004_buyer"><text></text></inputEntry>
        <outputEntry id="oe_004_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_004_notes"><text>"деталізація комунальних в додатку до рахунку"</text></outputEntry>
      </rule>

      <!-- ═══════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: ФОП ШПЕКО ОЛЕКСАНДРА СЕРГІЇВНА
           Орендна плата = комунальні (деталізація в додатку)
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_shpeko_orplata">
        <description>ШПЕКО: Орендна плата — комунальні (деталізація в додатку)</description>
        <inputEntry id="ie_005_line"><text>contains(?, "орендна плата")</text></inputEntry>
        <inputEntry id="ie_005_partner"><text>contains(?, "ШПЕКО")</text></inputEntry>
        <inputEntry id="ie_005_buyer"><text></text></inputEntry>
        <outputEntry id="oe_005_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_005_notes"><text>"деталізація комунальних в додатку до рахунку"</text></outputEntry>
      </rule>

      <!-- ═══════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: ФОП Юхимчук Наталія Миколаївна
           Експлуатаційний платіж = комунальні (на відміну від більшості)
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_yukhymchuk_ekspl">
        <description>Юхимчук: Експлуатаційний платіж — комунальні</description>
        <inputEntry id="ie_006_line"><text>contains(?, "експлуатаційний платіж")</text></inputEntry>
        <inputEntry id="ie_006_partner"><text>contains(?, "Юхимчук")</text></inputEntry>
        <inputEntry id="ie_006_buyer"><text></text></inputEntry>
        <outputEntry id="oe_006_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_006_notes"><text>""</text></outputEntry>
      </rule>

      <!-- ═══════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: Бручковська Наталія Михайлівна ФОП
           Маркетинговий платіж = комунальні (на відміну від більшості)
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_bruchkovska_market">
        <description>Бручковська: Маркетинговий платіж — комунальні</description>
        <inputEntry id="ie_007_line"><text>contains(?, "маркетинговий платіж")</text></inputEntry>
        <inputEntry id="ie_007_partner"><text>contains(?, "Бручковська")</text></inputEntry>
        <inputEntry id="ie_007_buyer"><text></text></inputEntry>
        <outputEntry id="oe_007_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_007_notes"><text>""</text></outputEntry>
      </rule>

      <!-- ═══════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: Буковина Ритейл
           Експлуатаційні та маркетингові послуги = комунальні
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_bukovyna_ekspl">
        <description>Буковина Ритейл: Експлуатаційні послуги — комунальні</description>
        <inputEntry id="ie_008_line"><text>contains(?, "експлуатаційні послуги")</text></inputEntry>
        <inputEntry id="ie_008_partner"><text>contains(?, "Буковина")</text></inputEntry>
        <inputEntry id="ie_008_buyer"><text></text></inputEntry>
        <outputEntry id="oe_008_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_008_notes"><text>""</text></outputEntry>
      </rule>
      <rule id="rule_bukovyna_market">
        <description>Буковина Ритейл: Маркетингові послуги — комунальні</description>
        <inputEntry id="ie_009_line"><text>contains(?, "маркетингові послуги")</text></inputEntry>
        <inputEntry id="ie_009_partner"><text>contains(?, "Буковина")</text></inputEntry>
        <inputEntry id="ie_009_buyer"><text></text></inputEntry>
        <outputEntry id="oe_009_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_009_notes"><text>""</text></outputEntry>
      </rule>
      <rule id="rule_bukovyna_tovarooborot">
        <description>Буковина Ритейл: Доплата за товарообіг — комунальні (оренда ТО)</description>
        <inputEntry id="ie_010_line"><text>contains(?, "доплата за товарообіг")</text></inputEntry>
        <inputEntry id="ie_010_partner"><text>contains(?, "Буковина")</text></inputEntry>
        <inputEntry id="ie_010_buyer"><text></text></inputEntry>
        <outputEntry id="oe_010_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_010_notes"><text>"оренда ТО"</text></outputEntry>
      </rule>

      <!-- ═══════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: АЛЬЯНС-ЕКОПРОЕКТ ТОВ
           Оренда нежилого приміщення = комунальні (оренда ТО)
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_alyans_orenda">
        <description>АЛЬЯНС-ЕКОПРОЕКТ: Оренда нежилого приміщення — комунальні</description>
        <inputEntry id="ie_011_line"><text>contains(?, "оренда нежилого приміщення")</text></inputEntry>
        <inputEntry id="ie_011_partner"><text>contains(?, "АЛЬЯНС-ЕКОПРОЕКТ")</text></inputEntry>
        <inputEntry id="ie_011_buyer"><text></text></inputEntry>
        <outputEntry id="oe_011_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_011_notes"><text>"оренда ТО"</text></outputEntry>
      </rule>

      <!-- ═══════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: Герман Олена Василівна (підрозділ 906)
           Суборенда = оренда, решта = комунальні
           4 рахунки в одному PDF
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_german_suborenda">
        <description>Герман: Суборенда приміщення — оренда</description>
        <inputEntry id="ie_012_line"><text>contains(?, "суборенда приміщення")</text></inputEntry>
        <inputEntry id="ie_012_partner"><text>"Герман Олена Василівна"</text></inputEntry>
        <inputEntry id="ie_012_buyer"><text></text></inputEntry>
        <outputEntry id="oe_012_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_012_notes"><text>"договір не вказаний, прописано pinky"</text></outputEntry>
      </rule>
      <rule id="rule_german_ekspl">
        <description>Герман: Експлуатаційна суборендна плата — комунальні</description>
        <inputEntry id="ie_013_line"><text>contains(?, "експлуатаційна суборендна плата")</text></inputEntry>
        <inputEntry id="ie_013_partner"><text>"Герман Олена Василівна"</text></inputEntry>
        <inputEntry id="ie_013_buyer"><text></text></inputEntry>
        <outputEntry id="oe_013_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_013_notes"><text>"місяць оплати беру з рахунку на оренду"</text></outputEntry>
      </rule>
      <rule id="rule_german_market">
        <description>Герман: Маркетингова суборендна плата — комунальні</description>
        <inputEntry id="ie_014_line"><text>contains(?, "маркетингова суборендна плата")</text></inputEntry>
        <inputEntry id="ie_014_partner"><text>"Герман Олена Василівна"</text></inputEntry>
        <inputEntry id="ie_014_buyer"><text></text></inputEntry>
        <outputEntry id="oe_014_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_014_notes"><text>"місяць оплати беру з рахунку на оренду"</text></outputEntry>
      </rule>
      <rule id="rule_german_reklam">
        <description>Герман: Розміщення рекламного матеріалу — комунальні</description>
        <inputEntry id="ie_015_line"><text>contains(?, "розміщення рекламного матеріалу")</text></inputEntry>
        <inputEntry id="ie_015_partner"><text>"Герман Олена Василівна"</text></inputEntry>
        <inputEntry id="ie_015_buyer"><text></text></inputEntry>
        <outputEntry id="oe_015_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_015_notes"><text>""</text></outputEntry>
      </rule>

      <!-- ═══════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: Данчук Анатолій Петрович ФОП (підрозділ 650)
           Орендна плата що тотожна... = комунальні
           Плата за обслуговування = комунальні
           Плата з обороту = комунальні
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_danchuk_totozhna">
        <description>Данчук: Орендна плата що тотожна... — комунальні</description>
        <inputEntry id="ie_016_line"><text>contains(?, "тотожна")</text></inputEntry>
        <inputEntry id="ie_016_partner"><text>contains(?, "Данчук")</text></inputEntry>
        <inputEntry id="ie_016_buyer"><text></text></inputEntry>
        <outputEntry id="oe_016_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_016_notes"><text>""</text></outputEntry>
      </rule>
      <rule id="rule_danchuk_obsluv">
        <description>Данчук: Плата за обслуговування (генератор) — комунальні</description>
        <inputEntry id="ie_017_line"><text>contains(?, "плата за обслуговування")</text></inputEntry>
        <inputEntry id="ie_017_partner"><text>contains(?, "Данчук")</text></inputEntry>
        <inputEntry id="ie_017_buyer"><text></text></inputEntry>
        <outputEntry id="oe_017_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_017_notes"><text>"генератор"</text></outputEntry>
      </rule>
      <rule id="rule_danchuk_oborot">
        <description>ФОП Данчук: Плата з обороту — комунальні (оренда ТО)</description>
        <inputEntry id="ie_018_line"><text>contains(?, "плата з обороту")</text></inputEntry>
        <inputEntry id="ie_018_partner"><text>contains(?, "Данчук")</text></inputEntry>
        <inputEntry id="ie_018_buyer"><text></text></inputEntry>
        <outputEntry id="oe_018_type"><text>"комунальні"</text></outputEntry>
        <outputEntry id="oe_018_notes"><text>"оренда ТО"</text></outputEntry>
      </rule>

      <!-- ═══════════════════════════════════════════════════════════════
           ПОСТАЧАЛЬНИК: Кропперс груп (підрозділ 646)
           Суборенда/сервісне/маркетинг = оренда
           Відшкодування ком.послуг = комунальні
           Виставляють рахунок на ДИКА О замість Дзісь О
           ═══════════════════════════════════════════════════════════════ -->

      <rule id="rule_kroppers_suborenda">
        <description>Кропперс: Суборенда — оренда</description>
        <inputEntry id="ie_019_line"><text>contains(?, "суборенда")</text></inputEntry>
        <inputEntry id="ie_019_partner"><text>"Кропперс груп"</text></inputEntry>
        <inputEntry id="ie_019_buyer"><text></text></inputEntry>
        <outputEntry id="oe_019_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_019_notes"><text>"виставляють рахунок на ДИКА О замість Дзісь О"</text></outputEntry>
      </rule>
      <rule id="rule_kroppers_servis">
        <description>Кропперс: Сервісне обслуговування — оренда</description>
        <inputEntry id="ie_020_line"><text>contains(?, "сервісне обслуговування")</text></inputEntry>
        <inputEntry id="ie_020_partner"><text>"Кропперс груп"</text></inputEntry>
        <inputEntry id="ie_020_buyer"><text></text></inputEntry>
        <outputEntry id="oe_020_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_020_notes"><text>""</text></outputEntry>
      </rule>
      <rule id="rule_kroppers_market">
        <description>Кропперс: Маркетингові послуги — оренда (входить до орендного пакету)</description>
        <inputEntry id="ie_021_line"><text>contains(?, "маркетингові послуги")</text></inputEntry>
        <inputEntry id="ie_021_partner"><text>"Кропперс груп"</text></inputEntry>
        <inputEntry id="ie_021_buyer"><text></text></inputEntry>
        <outputEntry id="oe_021_type"><text>"оренда"</text></outputEntry>
        <outputEntry id="oe_021_notes"><text>""</text></outputEntry>
      </rule>
      <rule id="rule_kroppers_komunal">
        <description>Кропперс: Відшкодування ком.послуг — комунальні</description>
        <inputEntry id="ie_022_line"><text>contains(?, "відшкодування ком.послуг")</text></inputEntry>
        <inputEntry id="ie_022_partner"><text>"Кропперс груп"</text></inputEntry>
        <inputEntry id="ie_022_buyer"><text></text></inputEntry>
        <outputEntry id="oe_022_type"><text>"комунальні"</text></outputEntry>
