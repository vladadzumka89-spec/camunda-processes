    <bpmn:sequenceFlow id="Flow_2h_to_notify" sourceRef="BoundaryTimer_2h" targetRef="Service_notify_2h" />
    <bpmn:sequenceFlow id="Flow_2h_to_end" sourceRef="Service_notify_2h" targetRef="End_reminder" />
