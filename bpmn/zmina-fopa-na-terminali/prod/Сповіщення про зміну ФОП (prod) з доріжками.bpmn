    <bpmn:userTask id="Activity_1riu9zl" name="Оплатити зміну ФОП">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Оплатити зміну ФОП на &#34; + selected_store, description: &#34;&#60;b&#62;Магазин:&#60;/b&#62; &#34; + selected_store + &#34;&#60;br/&#62;&#60;b&#62;Старий ФОП:&#60;/b&#62; &#34; + fop_name + &#34;&#60;br/&#62;&#60;b&#62;Новий ФОП:&#60;/b&#62; &#34; + (if is defined(new_fop_name) then new_fop_name else &#34;(не вказано)&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Дата переключення:&#60;/b&#62; &#34; + (if is defined(switch_date) then switch_date else &#34;(не визначено)&#34;) + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#34; + &#34;&#60;br/&#62;1. ТРЦ погодив переключення — необхідно оплатити зміну ФОП на терміналі.&#34; + &#34;&#60;br/&#62;2. Змініть стадію задачі на &#60;b&#62;«Виконано»&#60;/b&#62;.&#34;, x_studio_camunda_fop_name: fop_name, x_studio_camunda_total_income: total_income, x_studio_camunda_selected_store: selected_store, x_studio_camunda_is_paid_change: &#34;Так&#34;, x_studio_camunda_new_fop_name: (if is defined(new_fop_name) then new_fop_name else &#34;&#34;), x_studio_camunda_switch_date: (if is defined(switch_date) then switch_date else &#34;&#34;), x_studio_camunda_role_code: payment_role_code, parent_id: odoo_task_id, _model: &#34;project.project&#34;, _id: 524, process_instance_key: process_instance_key, x_studio_camunda_task_code: &#34;pay_change&#34;}" target="body" />
        </zeebe:ioMapping>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1l637ur</bpmn:incoming>
      <bpmn:outgoing>Flow_1ylxgno</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_1gouaw1" name="Переключаємо на нового ФОП">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;Переключити термінал на нового ФОП: &#34; + (if is defined(new_fop_name) then new_fop_name else &#34;(не вказано)&#34;), description: &#34;&#60;b&#62;Магазин:&#60;/b&#62; &#34; + selected_store + &#34;&#60;br/&#62;&#60;b&#62;Старий ФОП:&#60;/b&#62; &#34; + fop_name + &#34;&#60;br/&#62;&#60;b&#62;Новий ФОП:&#60;/b&#62; &#34; + (if is defined(new_fop_name) then new_fop_name else &#34;(не вказано)&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Дата переключення:&#60;/b&#62; &#34; + (if is defined(switch_date) then switch_date else &#34;(не визначено)&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Дохід старого ФОП:&#60;/b&#62; &#34; + string(total_income) + &#34; грн (&#34; + string(income_percent) + &#34;% ліміту)&#34; + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;Що потрібно зробити:&#60;/b&#62;&#34; + &#34;&#60;br/&#62;1. Виконайте переключення терміналу на нового ФОП у вказану дату.&#34; + &#34;&#60;br/&#62;2. Змініть стадію задачі на &#60;b&#62;«Виконано»&#60;/b&#62;.&#34;, x_studio_camunda_fop_name: fop_name, x_studio_camunda_total_income: total_income, x_studio_camunda_days_to_limit: days_to_limit, x_studio_camunda_selected_store: selected_store, x_studio_camunda_is_paid_change: (if is defined(is_paid_change) then is_paid_change else &#34;Ні&#34;), x_studio_camunda_new_fop_name: (if is defined(new_fop_name) then new_fop_name else &#34;&#34;), x_studio_camunda_switch_date: (if is defined(switch_date) then switch_date else &#34;&#34;), x_studio_camunda_role_code: &#34;accountant&#34;, parent_id: odoo_task_id, _model: &#34;project.project&#34;, _id: 524, process_instance_key: process_instance_key, x_studio_camunda_task_code: &#34;switch_fop&#34;}" target="body" />
        </zeebe:ioMapping>
        <zeebe:userTask />
        <zeebe:taskListeners>
          <zeebe:taskListener eventType="creating" retries="1" type="http-request-smart" />
        </zeebe:taskListeners>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1hxkjgf</bpmn:incoming>
      <bpmn:incoming>Flow_1mejo49</bpmn:incoming>
      <bpmn:outgoing>Flow_1k7dg8u</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_11ydaqo" name="Сповістити бухгалтера про непогодження">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="= &#34;POST&#34;" target="method" />
          <zeebe:input source="= &#34;https://o.tut.ua/web/hook/8531324a-2785-48d1-8f4d-ddd66a267d50&#34;" target="url" />
          <zeebe:input source="= {&#34;Content-Type&#34;:&#34;application/json&#34;}" target="headers" />
          <zeebe:input source="={name: &#34;🔴 ТРЦ не погодив зміну ФОП на &#34; + selected_store, description: &#34;&#60;b&#62;Магазин:&#60;/b&#62; &#34; + selected_store + &#34;&#60;br/&#62;&#60;b&#62;Старий ФОП:&#60;/b&#62; &#34; + fop_name + &#34;&#60;br/&#62;&#60;b&#62;Новий ФОП:&#60;/b&#62; &#34; + (if is defined(new_fop_name) then new_fop_name else &#34;(не вказано)&#34;) + &#34;&#60;br/&#62;&#60;b&#62;Дата переключення:&#60;/b&#62; &#34; + (if is defined(switch_date) then switch_date else &#34;(не визначено)&#34;) + &#34;&#60;br/&#62;&#60;br/&#62;&#60;b&#62;📋 Що потрібно зробити:&#60;/b&#62;&#34; + &#34;&#60;br/&#62;1. Орендодавець не погодив переключення терміналу — необхідно прийняти рішення щодо подальших дій.&#34; + &#34;&#60;br/&#62;2. Узгодьте з командою наступні кроки (пошук іншого ФОП, переговори з ТРЦ, інший магазин тощо).&#34;, x_studio_camunda_fop_name: fop_name, x_studio_camunda_selected_store: selected_store, x_studio_camunda_new_fop_name: (if is defined(new_fop_name) then new_fop_name else &#34;&#34;), x_studio_camunda_role_code: &#34;accountant&#34;, parent_id: odoo_task_id, _model: &#34;project.project&#34;, _id: 524, process_instance_key: process_instance_key}" target="body" />
        </zeebe:ioMapping>
        <zeebe:taskDefinition type="http-request-smart" retries="1" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1cyy7d3</bpmn:incoming>
      <bpmn:outgoing>Flow_1j9v7nn</bpmn:outgoing>
    </bpmn:serviceTask>
